---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TileCalculator from '../../components/calculators/TileCalculator.tsx';
import { buildCalculatorSchema, buildBreadcrumbSchema, buildFAQSchema, buildHowToSchema, buildSpeakableSchema } from '../../lib/seo';

const meta = {
  slug: 'tile-calculator', name: 'Tile Calculator',
  description: 'Free tile calculator: enter your floor length, width and tile size to get the exact number of tiles and boxes needed, with a waste allowance built in.',
  category: 'construction' as const,
  keywords: ['tile calculator', 'how many tiles do i need', 'tiles per box calculator', 'floor tile calculator', 'tile area calculator', 'boxes of tile needed'],
  lastUpdated: '2026-07-19',
};
const path = '/construction/tile-calculator';
const breadcrumbs = [
  { name: 'Home', url: '/' }, { name: 'Construction', url: '/construction/' }, { name: 'Tile Calculator', url: path },
];

// Build-time reference: tiles & boxes for a common 12 × 12 in tile (= 1 sq ft) at 10% waste, 10 tiles/box.
const rows = [50, 100, 150, 200, 300, 500].map((area) => {
  const tiles = Math.ceil(area * 1.1); // 12×12 in tile = 1 sq ft, so tiles = ceil(area × 1.1)
  return { area, tiles, boxes: Math.ceil(tiles / 10) };
});

const faqs = [
  { q: 'How many tiles do I need for a room?', a: 'Divide the floor area by the area of one tile, then add a waste allowance. A 10 × 10 ft room is 100 square feet, and a 12 × 12 inch tile covers exactly 1 square foot (144 ÷ 144). So 100 ÷ 1 = 100 tiles, and with 10% waste you need ceil(100 × 1.10) = 110 tiles. At 10 tiles per box that is 11 boxes. Always round up. You cannot buy a fraction of a tile or a box.' },
  { q: 'How do I convert my tile size into tile area?', a: 'In imperial, multiply the tile width and height in inches and divide by 144 (the number of square inches in a square foot). A 12 × 12 in tile is 144 ÷ 144 = 1 sq ft, while a 24 × 24 in tile is 576 ÷ 144 = 4 sq ft. In metric, multiply the two sides in centimetres and divide by 10,000: a 30 × 30 cm tile is 900 ÷ 10,000 = 0.09 m². The calculator does this for you once you pick a unit.' },
  { q: 'How much extra should I add for waste?', a: 'A 10% allowance is standard for a straight (grid) layout, covering edge cuts and the odd broken tile. Step up to 15% for diagonal, herringbone or patterned layouts, which create far more offcuts. For a 200 sq ft floor of 1 sq ft tiles, 10% waste gives ceil(200 × 1.10) = 220 tiles, whereas 15% gives ceil(200 × 1.15) = 230 tiles, ten extra tiles for the safety margin.' },
  { q: 'How many tiles come in a box?', a: 'It varies by tile size and brand, so check the box label. Common counts are 6, 8, 10 or 12 tiles per box, and this calculator defaults to 10. The box count is boxes = ceil(tiles needed ÷ tiles per box). If you need 165 tiles and there are 10 per box, that is ceil(165 ÷ 10) = 17 boxes. Buying whole boxes from the same batch keeps the shade and thickness consistent.' },
  { q: 'Do larger tiles mean I buy fewer of them?', a: 'Yes. Bigger tiles cover more area each, so you need fewer pieces (though each one is heavier and pricier). A 200 sq ft room tiled with 12 × 12 in tiles (1 sq ft each) needs ceil(200 ÷ 1 × 1.10) = 220 tiles, but with 24 × 24 in tiles (4 sq ft each) it drops to ceil(200 ÷ 4 × 1.10) = 55 tiles. The floor area is the same; only the piece count changes.' },
];
const schemas = [
  buildCalculatorSchema(meta, path),
  buildBreadcrumbSchema(breadcrumbs),
  buildFAQSchema(faqs),
  buildSpeakableSchema(path),
  buildHowToSchema({
    name: 'How to calculate how many tiles you need',
    description: 'Work out the number of tiles and boxes for a floor or wall from the area and tile size.',
    totalTime: 'PT2M',
    estimatedCost: { value: '0', currency: 'USD' },
    steps: [
      { name: 'Measure the area', text: 'Enter the length and width of the room to get the floor area.' },
      { name: 'Enter the tile size', text: 'Type the tile width and height so the calculator can work out the area each tile covers.' },
      { name: 'Add waste and box size', text: 'Set a waste allowance (~10%) and how many tiles come in a box.' },
      { name: 'Read the tiles and boxes', text: 'The calculator shows the total tiles needed and how many boxes to order.' },
    ],
  }),
];
const relatedCalcs = [
  { name: 'Concrete Calculator', href: '/construction/concrete-calculator/', desc: 'Cubic yards & bags.', icon: '🧱', color: 'bg-orange-300' },
  { name: 'Brick Calculator', href: '/construction/brick-calculator/', desc: 'Bricks for a wall.', icon: '🧱', color: 'bg-lime-accent' },
  { name: 'Paint Calculator', href: '/construction/paint-calculator/', desc: 'Paint by room area.', icon: '🎨', color: 'bg-yellow-accent' },
  { name: 'Roofing Calculator', href: '/construction/roofing-calculator/', desc: 'Squares & bundles.', icon: '🏠', color: 'bg-violet-300' },
];
---

<BaseLayout title="Tile Calculator: Tiles & Boxes Needed by Floor Area" description={meta.description} schemas={schemas} publishedTime={meta.lastUpdated} modifiedTime={meta.lastUpdated}>
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-cyan-accent/40 rounded-full blur-[120px] float-slow"></div>
      <div class="absolute top-[5%] right-[-10%] w-[400px] h-[400px] bg-violet-300/25 rounded-full blur-[120px] float-slow-2"></div>
    </div>
    <div class="container-wide relative pt-8 pb-10 md:pt-12 md:pb-14">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-1.5 text-xs sm:text-sm">
          {breadcrumbs.map((item, idx) => (
            <li class="flex items-center gap-1.5">
              {idx === breadcrumbs.length - 1 ? (
                <span class="px-3 py-1 rounded-full bg-ink-900 text-white font-bold border-2 border-ink-900">{item.name}</span>
              ) : (
                <>
                  <a href={item.url} class="px-3 py-1 rounded-full bg-white border-2 border-ink-200 text-ink-700 font-semibold hover:border-ink-900 hover:text-ink-900 no-underline transition-colors">{item.name}</a>
                  <svg class="w-3 h-3 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </>
              )}
            </li>
          ))}
        </ol>
      </nav>
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="chip bg-orange-300 text-ink-900">🧱 Construction</span>
          <span class="chip-white"><span class="text-ink-500">Updated</span><span>{meta.lastUpdated}</span></span>
        </div>
        <h1 class="!text-4xl sm:!text-5xl md:!text-6xl !font-extrabold !tracking-tight !leading-[1.05] text-ink-900" style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.035em;">
          Tile <span class="text-gradient-brand">Calculator.</span>
        </h1>
        <div class="mt-7 bg-yellow-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker">
          <div class="flex items-start gap-3">
            <div class="text-2xl">⚡</div>
            <div>
              <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-1">Quick answer</div>
              <p class="speakable-answer text-ink-900 text-base sm:text-lg leading-relaxed font-medium !m-0">
                Tiles needed = <strong>floor area ÷ tile area × (1 + waste)</strong>. A 10 × 10 ft room (100 sq ft) with 12" × 12" tiles needs <strong>110 tiles</strong>. That's <strong>11 boxes of 10</strong> at 10% waste. Enter your room and tile size below.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wide pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto">
      <TileCalculator client:load />
    </div>
  </section>

  <!-- TILE TABLE -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-3xl mx-auto">
        <span class="chip bg-orange-300 text-ink-900 mb-4">📊 Quick reference</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Tiles & boxes for a 12 × 12 in tile.</h2>
        <p class="mt-3 text-ink-700 font-medium">Each 12 × 12 inch tile covers 1 sq ft. Counts include a 10% waste allowance, at 10 tiles per box.</p>
        <div class="mt-8 overflow-x-auto">
          <table class="w-full bg-white border-[2.5px] border-ink-900 rounded-2xl shadow-sticker-sm overflow-hidden border-separate border-spacing-0 text-sm">
            <thead><tr class="bg-ink-900 text-white">
              <th class="text-left p-3 font-extrabold">Floor area</th>
              <th class="text-center p-3 font-extrabold">Tiles needed</th>
              <th class="text-right p-3 font-extrabold">Boxes (10/box)</th>
            </tr></thead>
            <tbody>
              {rows.map((r, i) => (
                <tr class={`border-b-2 border-ink-100 ${i % 2 ? 'bg-ink-50' : ''}`}>
                  <td class="p-3 font-extrabold text-ink-900">{r.area} sq ft</td>
                  <td class="p-3 text-center font-mono font-bold text-ink-900">{r.tiles}</td>
                  <td class="p-3 text-right font-mono font-bold text-ink-900">{r.boxes}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-3xl mx-auto">
      <span class="chip-yellow mb-4">❓ FAQ</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Common questions.</h2>
      <div class="space-y-3 mt-8">
        {faqs.map((faq, idx) => (
          <details class="group bg-white border-2 border-ink-900 rounded-2xl shadow-sticker-sm hover:shadow-sticker transition-all" open={idx === 0}>
            <summary class="cursor-pointer p-5 md:p-6 font-extrabold text-ink-900 flex items-center justify-between gap-4 list-none">
              <span class="text-base md:text-lg" style="font-family: 'Inter Tight', sans-serif;">{faq.q}</span>
              <span class="flex-shrink-0 w-9 h-9 rounded-full bg-ink-900 group-open:bg-lime-accent flex items-center justify-center transition-colors">
                <svg class="w-4 h-4 text-white group-open:text-ink-900 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </span>
            </summary>
            <div class="px-5 md:px-6 pb-5 md:pb-6 text-ink-700 leading-relaxed font-medium">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <span class="chip bg-orange-300 text-ink-900 mb-4">🔗 Related</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">More construction tools.</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-8">
          {relatedCalcs.map((c) => (
            <a href={c.href} class={`group ${c.color} border-[2.5px] border-ink-900 rounded-3xl p-5 no-underline shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200`}>
              <div class="text-3xl mb-3 group-hover:rotate-12 transition-transform inline-block">{c.icon}</div>
              <div class="font-extrabold text-ink-900 text-base leading-tight" style="font-family: 'Inter Tight', sans-serif;">{c.name}</div>
              <p class="text-xs text-ink-800 mt-1.5 leading-snug font-medium">{c.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
