---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RoofingCalculator from '../../components/calculators/RoofingCalculator.tsx';
import { buildCalculatorSchema, buildBreadcrumbSchema, buildFAQSchema, buildHowToSchema, buildSpeakableSchema } from '../../lib/seo';

const meta = {
  slug: 'roofing-calculator', name: 'Roofing Calculator',
  description: 'Free roofing calculator: enter footprint and roof pitch to get roof area in square feet, roofing squares and shingle bundles needed, with waste allowance.',
  category: 'construction' as const,
  keywords: ['roofing calculator', 'roofing squares', 'shingle calculator', 'how many bundles of shingles', 'roof area calculator', 'shingle bundles'],
  lastUpdated: '2026-07-19',
};
const path = '/construction/roofing-calculator';
const breadcrumbs = [
  { name: 'Home', url: '/' }, { name: 'Construction', url: '/construction/' }, { name: 'Roofing Calculator', url: path },
];

// Build-time reference: pitch multiplier and roof area for a 40 × 30 ft (1200 sq ft) footprint.
const FOOTPRINT = 40 * 30; // 1200 sq ft
const pitchRows = [4, 6, 8, 10, 12].map((rise) => {
  const mult = Math.sqrt(1 + (rise / 12) ** 2);
  return { pitch: `${rise}/12`, mult, area: FOOTPRINT * mult };
});

const faqs = [
  { q: 'How many bundles of shingles do I need?', a: 'Architectural asphalt shingles are sold three bundles to a roofing square (100 square feet of roof). Work out the roof area, divide by 100 to get squares, multiply by 3, then add a waste allowance. A 40 × 30 ft home (1,200 sq ft footprint) with a 6/12 pitch has about 1,342 sq ft of roof, or 13.4 squares. That is 40 bundles bare, and rounding up with 10% waste gives 45 bundles.' },
  { q: 'What is a roofing square?', a: 'A roofing square is the trade unit for roof area and always equals 100 square feet, a 10 × 10 ft patch of roof surface. Shingles, underlayment and labour are all quoted per square, so the first job of any estimate is to convert the roof area into squares by dividing the total square footage by 100. The 1,342 sq ft roof above works out to 13.4 squares.' },
  { q: 'How does roof pitch change how much material I need?', a: 'A steeper roof covers more surface for the same footprint. Multiply the footprint by the pitch factor √(1 + (rise/12)²) to get the true sloped area. On the same 1,200 sq ft footprint the roof area grows from about 1,265 sq ft at a 4/12 pitch (factor 1.054) to 1,697 sq ft at a 12/12 pitch (factor 1.414), roughly 34% more shingles for the steeper roof.' },
  { q: 'How do I measure my roof footprint?', a: 'The footprint is the ground area the building covers, not the sloped roof itself. Measure the outside length and width of the structure in feet and multiply them: a 40 ft by 30 ft house has a 1,200 sq ft footprint. The calculator then applies the pitch factor to convert that flat footprint into actual roof surface area, so you never have to climb onto the roof to measure the slope.' },
  { q: 'How much waste should I add for a shingle order?', a: 'A 10% allowance is standard for a simple gable roof and covers starter courses, ridge caps, cut-off at rakes and a few damaged shingles. Complex roofs with many hips, valleys and dormers waste more, so bump it to 15%. On the 13.4-square example, 10% waste turns 41 bundles into 45; that extra material is far cheaper than a second delivery mid-job.' },
];
const schemas = [
  buildCalculatorSchema(meta, path),
  buildBreadcrumbSchema(breadcrumbs),
  buildFAQSchema(faqs),
  buildSpeakableSchema(path),
  buildHowToSchema({
    name: 'How to calculate roofing squares and shingle bundles',
    description: 'Work out the roof area, roofing squares and number of shingle bundles from the building footprint and roof pitch.',
    totalTime: 'PT2M',
    estimatedCost: { value: '0', currency: 'USD' },
    steps: [
      { name: 'Measure the footprint', text: 'Enter the building length and width in feet to get the ground footprint.' },
      { name: 'Set pitch and waste', text: 'Choose the roof pitch (rise per 12) and a waste allowance (~10%).' },
      { name: 'Read squares and bundles', text: 'The calculator shows roof area, roofing squares and the number of shingle bundles.' },
    ],
  }),
];
const relatedCalcs = [
  { name: 'Concrete Calculator', href: '/construction/concrete-calculator/', desc: 'Cubic yards & bags.', icon: '🧱', color: 'bg-orange-300' },
  { name: 'Paint Calculator', href: '/construction/paint-calculator/', desc: 'Paint by room area.', icon: '🎨', color: 'bg-cyan-accent' },
  { name: 'Tile Calculator', href: '/construction/tile-calculator/', desc: 'Tiles & boxes by area.', icon: '🟦', color: 'bg-lime-accent' },
  { name: 'Brick Calculator', href: '/construction/brick-calculator/', desc: 'Bricks for a wall.', icon: '🧱', color: 'bg-yellow-accent' },
];
---

<BaseLayout title="Roofing Calculator: Squares, Shingle Bundles & Roof Area" description={meta.description} schemas={schemas} publishedTime={meta.lastUpdated} modifiedTime={meta.lastUpdated}>
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-violet-300/40 rounded-full blur-[120px] float-slow"></div>
      <div class="absolute top-[5%] right-[-10%] w-[400px] h-[400px] bg-cyan-accent/25 rounded-full blur-[120px] float-slow-2"></div>
    </div>
    <div class="container-wide relative pt-8 pb-10 md:pt-12 md:pb-14">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-1.5 text-xs sm:text-sm">
          {breadcrumbs.map((item, idx) => (
            <li class="flex items-center gap-1.5">
              {idx === breadcrumbs.length - 1 ? (
                <span class="px-3 py-1 rounded-full bg-ink-900 text-white font-bold border-2 border-ink-900">{item.name}</span>
              ) : (
                <>
                  <a href={item.url} class="px-3 py-1 rounded-full bg-white border-2 border-ink-200 text-ink-700 font-semibold hover:border-ink-900 hover:text-ink-900 no-underline transition-colors">{item.name}</a>
                  <svg class="w-3 h-3 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </>
              )}
            </li>
          ))}
        </ol>
      </nav>
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="chip bg-violet-300 text-ink-900">🏠 Construction</span>
          <span class="chip-white"><span class="text-ink-500">Updated</span><span>{meta.lastUpdated}</span></span>
        </div>
        <h1 class="!text-4xl sm:!text-5xl md:!text-6xl !font-extrabold !tracking-tight !leading-[1.05] text-ink-900" style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.035em;">
          Roofing <span class="text-gradient-brand">Calculator.</span>
        </h1>
        <div class="mt-7 bg-yellow-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker">
          <div class="flex items-start gap-3">
            <div class="text-2xl">⚡</div>
            <div>
              <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-1">Quick answer</div>
              <p class="speakable-answer text-ink-900 text-base sm:text-lg leading-relaxed font-medium !m-0">
                Roof area = <strong>footprint × pitch factor</strong>, where the factor is √(1 + (rise/12)²). A 40 × 30 ft home (1,200 ft²) at a 6/12 pitch has <strong>~1,342 ft² of roof</strong> = <strong>13.4 squares</strong> = <strong>45 bundles</strong> of shingles (3 per square, 10% waste).
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wide pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto">
      <RoofingCalculator client:load />
    </div>
  </section>

  <!-- PITCH TABLE -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-3xl mx-auto">
        <span class="chip bg-violet-300 text-ink-900 mb-4">📊 Quick reference</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Pitch factor & roof area by slope.</h2>
        <p class="mt-3 text-ink-700 font-medium">For a 40 × 30 ft footprint (1,200 ft²), before waste allowance.</p>
        <div class="mt-8 overflow-x-auto">
          <table class="w-full bg-white border-[2.5px] border-ink-900 rounded-2xl shadow-sticker-sm overflow-hidden border-separate border-spacing-0 text-sm">
            <thead><tr class="bg-ink-900 text-white">
              <th class="text-left p-3 font-extrabold">Roof pitch</th>
              <th class="text-center p-3 font-extrabold">Pitch factor</th>
              <th class="text-right p-3 font-extrabold">Roof area (ft²)</th>
            </tr></thead>
            <tbody>
              {pitchRows.map((r, i) => (
                <tr class={`border-b-2 border-ink-100 ${i % 2 ? 'bg-ink-50' : ''}`}>
                  <td class="p-3 font-extrabold text-ink-900">{r.pitch}</td>
                  <td class="p-3 text-center font-mono font-bold text-ink-900">{r.mult.toFixed(3)}</td>
                  <td class="p-3 text-right font-mono font-bold text-ink-900">{r.area.toFixed(0)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-3xl mx-auto">
      <span class="chip-yellow mb-4">❓ FAQ</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Common questions.</h2>
      <div class="space-y-3 mt-8">
        {faqs.map((faq, idx) => (
          <details class="group bg-white border-2 border-ink-900 rounded-2xl shadow-sticker-sm hover:shadow-sticker transition-all" open={idx === 0}>
            <summary class="cursor-pointer p-5 md:p-6 font-extrabold text-ink-900 flex items-center justify-between gap-4 list-none">
              <span class="text-base md:text-lg" style="font-family: 'Inter Tight', sans-serif;">{faq.q}</span>
              <span class="flex-shrink-0 w-9 h-9 rounded-full bg-ink-900 group-open:bg-lime-accent flex items-center justify-center transition-colors">
                <svg class="w-4 h-4 text-white group-open:text-ink-900 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </span>
            </summary>
            <div class="px-5 md:px-6 pb-5 md:pb-6 text-ink-700 leading-relaxed font-medium">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <span class="chip bg-violet-300 text-ink-900 mb-4">🔗 Related</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">More construction tools.</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-8">
          {relatedCalcs.map((c) => (
            <a href={c.href} class={`group ${c.color} border-[2.5px] border-ink-900 rounded-3xl p-5 no-underline shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200`}>
              <div class="text-3xl mb-3 group-hover:rotate-12 transition-transform inline-block">{c.icon}</div>
              <div class="font-extrabold text-ink-900 text-base leading-tight" style="font-family: 'Inter Tight', sans-serif;">{c.name}</div>
              <p class="text-xs text-ink-800 mt-1.5 leading-snug font-medium">{c.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
