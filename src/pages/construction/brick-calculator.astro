---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AuthorBadge from '../../components/ui/AuthorBadge.astro';
import BrickCalculator from '../../components/calculators/BrickCalculator.tsx';
import { buildCalculatorSchema, buildBreadcrumbSchema, buildFAQSchema, buildHowToSchema, buildSpeakableSchema } from '../../lib/seo';
import { getAuthor } from '../../data/authors';

const meta = {
  slug: 'brick-calculator', name: 'Brick Calculator',
  description: 'Free brick calculator: enter wall length, height and waste to get the exact number of bricks and bags of mortar you need, in imperial or metric units.',
  category: 'construction' as const,
  keywords: ['brick calculator', 'how many bricks do i need', 'bricks per square foot', 'brick wall calculator', 'bricks for a wall', 'mortar calculator'],
  lastUpdated: '2026-07-19',
};
const path = '/construction/brick-calculator';
const reviewer = getAuthor('calctube-editorial')!;
const breadcrumbs = [
  { name: 'Home', url: '/' }, { name: 'Construction', url: '/construction/' }, { name: 'Brick Calculator', url: path },
];

// Build-time reference: bricks + mortar for common wall areas.
// Imperial standard modular brick = 7 per sq ft, single-wythe, +10% waste.
const walls = [50, 100, 150, 200, 300].map((area) => {
  const bricks = Math.ceil(area * 7 * 1.1);
  return { area, bricks, mortar: Math.ceil(bricks / 30) };
});

const faqs = [
  { q: 'How many bricks do I need for a wall?', a: 'Multiply wall length × height to get the area, then multiply by the bricks-per-unit figure and add waste. With standard US modular bricks you use about 7 bricks per square foot for a single-wythe wall. A 20 × 8 ft wall is 160 sq ft, so 160 × 7 = 1,120 bricks, plus 10% waste = 1,232 bricks. In metric, a standard 215 × 102.5 × 65 mm brick works out to about 60 per square meter, so a 6 × 2.4 m wall (14.4 m²) needs 864 bricks, or 951 with 10% waste.' },
  { q: 'How many bricks are there per square foot or square meter?', a: 'A standard US modular brick laid with a 3/8-inch mortar joint covers roughly 7 bricks per square foot on a single-wythe (half-brick) wall. A standard metric brick (215 × 102.5 × 65 mm) works out to about 60 bricks per square meter for the same single-layer wall. So a 100 sq ft wall needs around 700 bricks before waste, and a 10 m² wall around 600. This calculator adds your waste allowance on top.' },
  { q: 'How much mortar do I need for bricklaying?', a: 'A good rule of thumb is one 80 lb bag of mortar mix per about 30 bricks laid on a single-wythe wall with a standard joint. So a 1,232-brick wall needs roughly 42 bags. For 500 bricks you would need about 17 bags, and 1,000 bricks about 34 bags. Thicker joints, wider bricks or a richer sand-to-cement ratio use more, so buy a little extra rather than running short mid-course.' },
  { q: 'Why should I add a waste percentage for bricks?', a: 'Bricks get cut at corners, window and door openings, and at the end of courses; some arrive chipped or cracked; and it is smart to keep spares that match for future repairs. A 5–10% allowance covers all of this. On the 160 sq ft wall above, a 10% allowance turns 1,120 bricks into 1,232, an extra 112 bricks that stops you halting the job to wait on a second delivery.' },
  { q: 'Does a double-wythe (full-brick) wall need twice as many bricks?', a: 'Roughly, yes. This calculator assumes a single-wythe (half-brick) wall, which is standard for brick veneers and garden walls. A double-wythe wall is two leaves thick, so it needs about double the bricks. The 160 sq ft wall above would jump from ~1,232 to ~2,464. King- and queen-size bricks are larger than modular, so they need fewer per square foot (about 5.5 and 6 respectively). Adjust if you are not using standard modular brick.' },
];
const schemas = [
  buildCalculatorSchema(meta, path),
  buildBreadcrumbSchema(breadcrumbs),
  buildFAQSchema(faqs),
  buildSpeakableSchema(path),
  buildHowToSchema({
    name: 'How to calculate bricks for a wall',
    description: 'Work out the number of bricks and bags of mortar needed for a wall.',
    totalTime: 'PT2M',
    estimatedCost: { value: '0', currency: 'USD' },
    steps: [
      { name: 'Measure the wall', text: 'Enter the wall length and height in feet or meters.' },
      { name: 'Add a waste allowance', text: 'Set a waste percentage (~10%) to cover cuts and breakages.' },
      { name: 'Read bricks and mortar', text: 'The calculator shows the total bricks needed, the wall area and the number of 80 lb mortar bags.' },
    ],
  }),
];
const relatedCalcs = [
  { name: 'Concrete Calculator', href: '/construction/concrete-calculator/', desc: 'Slabs, footings & bags.', icon: '🧱', color: 'bg-orange-300' },
  { name: 'Tile Calculator', href: '/construction/tile-calculator/', desc: 'Tiles & boxes by area.', icon: '🟦', color: 'bg-cyan-accent' },
  { name: 'Paint Calculator', href: '/construction/paint-calculator/', desc: 'Paint by room area.', icon: '🎨', color: 'bg-yellow-accent' },
  { name: 'Roofing Calculator', href: '/construction/roofing-calculator/', desc: 'Squares & bundles.', icon: '🏠', color: 'bg-violet-300' },
];
---

<BaseLayout title="Brick Calculator: How Many Bricks Do I Need for a Wall" description={meta.description} schemas={schemas} publishedTime={meta.lastUpdated} modifiedTime={meta.lastUpdated}>
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-orange-300/40 rounded-full blur-[120px] float-slow"></div>
      <div class="absolute top-[5%] right-[-10%] w-[400px] h-[400px] bg-yellow-accent/25 rounded-full blur-[120px] float-slow-2"></div>
    </div>
    <div class="container-wide relative pt-8 pb-10 md:pt-12 md:pb-14">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-1.5 text-xs sm:text-sm">
          {breadcrumbs.map((item, idx) => (
            <li class="flex items-center gap-1.5">
              {idx === breadcrumbs.length - 1 ? (
                <span class="px-3 py-1 rounded-full bg-ink-900 text-white font-bold border-2 border-ink-900">{item.name}</span>
              ) : (
                <>
                  <a href={item.url} class="px-3 py-1 rounded-full bg-white border-2 border-ink-200 text-ink-700 font-semibold hover:border-ink-900 hover:text-ink-900 no-underline transition-colors">{item.name}</a>
                  <svg class="w-3 h-3 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </>
              )}
            </li>
          ))}
        </ol>
      </nav>
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="chip bg-orange-300 text-ink-900">🧱 Construction</span>
          <span class="chip-white"><span class="text-ink-500">Updated</span><span>{meta.lastUpdated}</span></span>
        </div>
        <h1 class="!text-4xl sm:!text-5xl md:!text-6xl !font-extrabold !tracking-tight !leading-[1.05] text-ink-900" style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.035em;">
          Brick <span class="text-gradient-brand">Calculator.</span>
        </h1>
        <div class="mt-7 bg-yellow-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker">
          <div class="flex items-start gap-3">
            <div class="text-2xl">⚡</div>
            <div>
              <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-1">Quick answer</div>
              <p class="speakable-answer text-ink-900 text-base sm:text-lg leading-relaxed font-medium !m-0">
                Bricks = <strong>wall area × 7 per ft² × waste</strong>. A 20 × 8 ft wall is <strong>160 ft²</strong>, so at 7 bricks/ft² plus 10% waste you need <strong>1,232 bricks</strong> and about <strong>42 bags</strong> of mortar. Enter your wall size below.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wide pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto">
      <BrickCalculator client:load />
      {reviewer && <div class="mt-4"><AuthorBadge author={reviewer} verb="Reviewed" /></div>}
    </div>
  </section>

  <!-- WALL TABLE -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-3xl mx-auto">
        <span class="chip bg-orange-300 text-ink-900 mb-4">📊 Quick reference</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Bricks for common wall areas.</h2>
        <p class="mt-3 text-ink-700 font-medium">Standard US modular bricks at 7 per square foot, single-wythe, with 10% waste added.</p>
        <div class="mt-8 overflow-x-auto">
          <table class="w-full bg-white border-[2.5px] border-ink-900 rounded-2xl shadow-sticker-sm overflow-hidden border-separate border-spacing-0 text-sm">
            <thead><tr class="bg-ink-900 text-white">
              <th class="text-left p-3 font-extrabold">Wall area (ft²)</th>
              <th class="text-center p-3 font-extrabold">Bricks needed</th>
              <th class="text-right p-3 font-extrabold">Mortar (80 lb bags)</th>
            </tr></thead>
            <tbody>
              {walls.map((w, i) => (
                <tr class={`border-b-2 border-ink-100 ${i % 2 ? 'bg-ink-50' : ''}`}>
                  <td class="p-3 font-extrabold text-ink-900">{w.area} ft²</td>
                  <td class="p-3 text-center font-mono font-bold text-ink-900">{w.bricks.toLocaleString()}</td>
                  <td class="p-3 text-right font-mono font-bold text-ink-900">{w.mortar}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-3xl mx-auto">
      <span class="chip-yellow mb-4">❓ FAQ</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Common questions.</h2>
      <div class="space-y-3 mt-8">
        {faqs.map((faq, idx) => (
          <details class="group bg-white border-2 border-ink-900 rounded-2xl shadow-sticker-sm hover:shadow-sticker transition-all" open={idx === 0}>
            <summary class="cursor-pointer p-5 md:p-6 font-extrabold text-ink-900 flex items-center justify-between gap-4 list-none">
              <span class="text-base md:text-lg" style="font-family: 'Inter Tight', sans-serif;">{faq.q}</span>
              <span class="flex-shrink-0 w-9 h-9 rounded-full bg-ink-900 group-open:bg-lime-accent flex items-center justify-center transition-colors">
                <svg class="w-4 h-4 text-white group-open:text-ink-900 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </span>
            </summary>
            <div class="px-5 md:px-6 pb-5 md:pb-6 text-ink-700 leading-relaxed font-medium">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <span class="chip bg-orange-300 text-ink-900 mb-4">🔗 Related</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">More construction tools.</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-8">
          {relatedCalcs.map((c) => (
            <a href={c.href} class={`group ${c.color} border-[2.5px] border-ink-900 rounded-3xl p-5 no-underline shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200`}>
              <div class="text-3xl mb-3 group-hover:rotate-12 transition-transform inline-block">{c.icon}</div>
              <div class="font-extrabold text-ink-900 text-base leading-tight" style="font-family: 'Inter Tight', sans-serif;">{c.name}</div>
              <p class="text-xs text-ink-800 mt-1.5 leading-snug font-medium">{c.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
