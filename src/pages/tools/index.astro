---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import { buildBreadcrumbSchema } from '../../lib/seo';
import { buildHubCards } from '../../lib/category-hub';

// Derived from the calculators registry — see src/lib/category-hub.ts.
const liveCalcs = buildHubCards('tools', {
  copy: {
    'word-counter': { desc: 'Count words, characters, sentences, paragraphs and reading time as you type — nothing is uploaded.' },
  },
});

const upcomingCalcs = [
  { name: 'Character Counter', desc: 'Live character count against tweet, SMS and meta-tag limits.', icon: '🔤' },
  { name: 'Case Converter', desc: 'Convert text to UPPER, lower, Title and sentence case.', icon: '🔠' },
];

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Tools', url: '/tools/' },
];

const faqs = [
  { q: 'Do the text tools upload or store my text?', a: 'No. Every text tool runs entirely in your browser using JavaScript — your text never leaves your device and nothing is saved to a server. You can safely paste private drafts, essays or confidential documents; closing the tab clears everything.' },
  { q: 'Are the tools free to use?', a: 'Yes, completely free with no signup, no account and no limits. Paste as much text as you like, as often as you like.' },
];

const schemas = [
  buildBreadcrumbSchema(breadcrumbs),
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Text Tools — Calctube',
    description: 'Free browser-based text tools — word counter, character counter and more.',
    url: 'https://calctube.com/tools/',
    isPartOf: { '@id': 'https://calctube.com/#website' },
    mainEntity: {
      '@type': 'ItemList',
      itemListElement: liveCalcs.map((c, i) => ({ '@type': 'ListItem', position: i + 1, url: `https://calctube.com${c.href}`, name: c.name })),
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
  },
];
---

<BaseLayout
  title="Text Tools — Word Counter & More"
  description="Free browser-based text tools: word counter, character counter, reading-time estimator and more. Everything runs locally — nothing is uploaded. No signup."
  schemas={schemas}
>
  <div class="container-prose py-8">
    <Breadcrumbs items={breadcrumbs} />
    <h1>Text Tools</h1>
    <p class="text-lg text-slate-700 mt-3">
      Fast, private text utilities that run entirely in your browser — no uploads, no signup. Count words, characters and reading time in a click.
    </p>

    <h2 class="mt-10">Available now</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
      {liveCalcs.map((c) => (
        <a href={c.href} class="card hover:border-brand-300 no-underline block">
          <div class="text-3xl mb-2">{c.icon}</div>
          <div class="font-semibold text-slate-900">{c.name}</div>
          <p class="text-sm text-slate-600 mt-1 !leading-snug">{c.desc}</p>
        </a>
      ))}
    </div>

    <h2 class="mt-10">Coming soon</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
      {upcomingCalcs.map((c) => (
        <div class="card opacity-70">
          <div class="flex items-start gap-3">
            <div class="text-3xl">{c.icon}</div>
            <div class="flex-1">
              <div class="font-semibold text-slate-900 flex items-center gap-2">
                {c.name}
                <span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-amber-100 text-amber-800 uppercase">Soon</span>
              </div>
              <p class="text-sm text-slate-600 mt-1 !leading-snug">{c.desc}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <h2 class="mt-10">Frequently asked questions</h2>
    <div class="space-y-3 mt-4">
      {faqs.map((f) => (
        <details class="card">
          <summary class="cursor-pointer font-semibold text-slate-900">{f.q}</summary>
          <p class="text-sm text-slate-700 mt-2 !leading-relaxed">{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</BaseLayout>
