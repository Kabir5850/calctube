---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AuthorBadge from '../../components/ui/AuthorBadge.astro';
import WordCounter from '../../components/calculators/WordCounter.tsx';
import { buildCalculatorSchema, buildBreadcrumbSchema, buildFAQSchema, buildHowToSchema, buildSpeakableSchema } from '../../lib/seo';
import { getAuthor } from '../../data/authors';

const meta = {
  slug: 'word-counter', name: 'Word Counter',
  description: 'Free word counter and character counter. Count words, characters, sentences, paragraphs and reading time as you type — with common limits for essays, tweets and meta tags.',
  category: 'other' as const,
  keywords: ['word counter', 'character counter', 'count words', 'word count tool', 'letter counter', 'reading time calculator'],
  lastUpdated: '2026-07-19',
};
const path = '/tools/word-counter';
const reviewer = getAuthor('calctube-editorial')!;
const breadcrumbs = [
  { name: 'Home', url: '/' }, { name: 'Word Counter', url: path },
];

// Build-time reference of common word/character limits.
const limits = [
  { item: 'Tweet / X post', limit: '280 characters' },
  { item: 'SMS text message', limit: '160 characters' },
  { item: 'SEO title tag', limit: '~60 characters' },
  { item: 'SEO meta description', limit: '~155 characters' },
  { item: 'Instagram caption', limit: '2,200 characters' },
  { item: 'College essay (Common App)', limit: '650 words' },
  { item: 'Standard blog post', limit: '600–1,500 words' },
  { item: 'Reading time (average)', limit: '~200 words per minute' },
];

const faqs = [
  { q: 'How does the word counter count words?', a: 'It splits your text on spaces and line breaks and counts the resulting chunks, ignoring empty gaps — the same way most word processors do. So "New York" counts as two words and "well-being" as one. Numbers and standalone symbols separated by spaces count as words too. The count updates instantly as you type or paste, with no button to press.' },
  { q: 'What is the difference between characters with and without spaces?', a: '"Characters" counts every keystroke including spaces, tabs and line breaks — this is what platforms like Twitter/X and SMS use for their limits. "Characters without spaces" strips all whitespace, which some assignments and forms ask for. This tool shows both so you can match whichever limit applies.' },
  { q: 'How is reading time calculated?', a: 'Reading time is the word count divided by an average silent reading speed of about 200 words per minute, so a 1,000-word article is roughly a 5-minute read. Speaking time uses a slower ~130 words per minute, since talking aloud is slower than reading — useful for estimating how long a speech or script will run. Both are estimates; individual speeds vary.' },
  { q: 'Is my text stored or uploaded anywhere?', a: 'No. The counter runs entirely in your browser using JavaScript — your text never leaves your device and nothing is sent to a server or saved. You can safely paste private drafts, essays or confidential documents. Closing the tab clears everything.' },
  { q: 'How many pages is a certain word count?', a: 'A rough rule for standard formatting (12pt, double-spaced) is about 250 words per page, so 500 words is ~2 pages and 1,000 words is ~4 pages. Single-spaced roughly doubles the words per page (~500). Actual length depends on font, spacing and margins, so treat page estimates as approximate.' },
];
const schemas = [
  buildCalculatorSchema(meta, path),
  buildBreadcrumbSchema(breadcrumbs),
  buildFAQSchema(faqs),
  buildSpeakableSchema(path),
  buildHowToSchema({
    name: 'How to count words in your text',
    description: 'Count words, characters, sentences and reading time by pasting text into the word counter.',
    totalTime: 'PT1M',
    estimatedCost: { value: '0', currency: 'USD' },
    steps: [
      { name: 'Paste your text', text: 'Type or paste your text into the box.' },
      { name: 'Read the counts', text: 'Words, characters, sentences, paragraphs and reading time update instantly.' },
    ],
  }),
];
const relatedCalcs = [
  { name: 'Percentage Calculator', href: '/math/percentage-calculator/', desc: 'X% of Y, % change.', icon: '🧮', color: 'bg-lime-accent' },
  { name: 'GPA Calculator', href: '/math/gpa-calculator/', desc: 'Weighted 4.0 GPA.', icon: '🎓', color: 'bg-cyan-accent' },
  { name: 'CGPA to Percentage', href: '/math/cgpa-to-percentage-calculator/', desc: 'CGPA ↔ % converter.', icon: '🎓', color: 'bg-yellow-accent' },
  { name: 'Countdown Timer', href: '/date-time/countdown-timer/', desc: 'Days until any date.', icon: '⏳', color: 'bg-violet-300' },
];
---

<BaseLayout title="Word Counter — Count Words, Characters & Reading Time" description={meta.description} schemas={schemas} publishedTime={meta.lastUpdated} modifiedTime={meta.lastUpdated}>
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-lime-accent/30 rounded-full blur-[120px] float-slow"></div>
      <div class="absolute top-[5%] right-[-10%] w-[400px] h-[400px] bg-cyan-accent/25 rounded-full blur-[120px] float-slow-2"></div>
    </div>
    <div class="container-wide relative pt-8 pb-10 md:pt-12 md:pb-14">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-1.5 text-xs sm:text-sm">
          {breadcrumbs.map((item, idx) => (
            <li class="flex items-center gap-1.5">
              {idx === breadcrumbs.length - 1 ? (
                <span class="px-3 py-1 rounded-full bg-ink-900 text-white font-bold border-2 border-ink-900">{item.name}</span>
              ) : (
                <>
                  <a href={item.url} class="px-3 py-1 rounded-full bg-white border-2 border-ink-200 text-ink-700 font-semibold hover:border-ink-900 hover:text-ink-900 no-underline transition-colors">{item.name}</a>
                  <svg class="w-3 h-3 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </>
              )}
            </li>
          ))}
        </ol>
      </nav>
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="chip bg-lime-accent text-ink-900">📝 Text tools</span>
          <span class="chip-white"><span class="text-ink-500">Updated</span><span>{meta.lastUpdated}</span></span>
        </div>
        <h1 class="!text-4xl sm:!text-5xl md:!text-6xl !font-extrabold !tracking-tight !leading-[1.05] text-ink-900" style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.035em;">
          Word <span class="text-gradient-brand">Counter.</span>
        </h1>
        <div class="mt-7 bg-yellow-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker">
          <div class="flex items-start gap-3">
            <div class="text-2xl">⚡</div>
            <div>
              <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-1">Quick answer</div>
              <p class="speakable-answer text-ink-900 text-base sm:text-lg leading-relaxed font-medium !m-0">
                Paste your text below to count <strong>words, characters, sentences and paragraphs</strong> instantly, plus an estimated <strong>reading time</strong> (about 200 words per minute). Everything runs in your browser — nothing is uploaded.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wide pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto">
      <WordCounter client:load />
      {reviewer && <div class="mt-4"><AuthorBadge author={reviewer} verb="Reviewed" /></div>}
    </div>
  </section>

  <!-- LIMITS TABLE -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-3xl mx-auto">
        <span class="chip bg-lime-accent text-ink-900 mb-4">📊 Quick reference</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Common word & character limits.</h2>
        <div class="mt-8 overflow-x-auto">
          <table class="w-full bg-white border-[2.5px] border-ink-900 rounded-2xl shadow-sticker-sm overflow-hidden border-separate border-spacing-0 text-sm">
            <thead><tr class="bg-ink-900 text-white">
              <th class="text-left p-3 font-extrabold">Where</th>
              <th class="text-right p-3 font-extrabold">Typical limit</th>
            </tr></thead>
            <tbody>
              {limits.map((r, i) => (
                <tr class={`border-b-2 border-ink-100 ${i % 2 ? 'bg-ink-50' : ''}`}>
                  <td class="p-3 font-extrabold text-ink-900">{r.item}</td>
                  <td class="p-3 text-right font-mono font-bold text-ink-900">{r.limit}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-3xl mx-auto">
      <span class="chip-yellow mb-4">❓ FAQ</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Common questions.</h2>
      <div class="space-y-3 mt-8">
        {faqs.map((faq, idx) => (
          <details class="group bg-white border-2 border-ink-900 rounded-2xl shadow-sticker-sm hover:shadow-sticker transition-all" open={idx === 0}>
            <summary class="cursor-pointer p-5 md:p-6 font-extrabold text-ink-900 flex items-center justify-between gap-4 list-none">
              <span class="text-base md:text-lg" style="font-family: 'Inter Tight', sans-serif;">{faq.q}</span>
              <span class="flex-shrink-0 w-9 h-9 rounded-full bg-ink-900 group-open:bg-lime-accent flex items-center justify-center transition-colors">
                <svg class="w-4 h-4 text-white group-open:text-ink-900 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </span>
            </summary>
            <div class="px-5 md:px-6 pb-5 md:pb-6 text-ink-700 leading-relaxed font-medium">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <span class="chip bg-lime-accent text-ink-900 mb-4">🔗 Related</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Try these next.</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-8">
          {relatedCalcs.map((c) => (
            <a href={c.href} class={`group ${c.color} border-[2.5px] border-ink-900 rounded-3xl p-5 no-underline shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200`}>
              <div class="text-3xl mb-3 group-hover:rotate-12 transition-transform inline-block">{c.icon}</div>
              <div class="font-extrabold text-ink-900 text-base leading-tight" style="font-family: 'Inter Tight', sans-serif;">{c.name}</div>
              <p class="text-xs text-ink-800 mt-1.5 leading-snug font-medium">{c.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
