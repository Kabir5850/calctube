---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import EmiCalculator from '../../../../components/calculators/EmiCalculator.tsx';
import { emiBanks, type BankData } from '../../../../data/emi-banks';
import { indiaStates, type IndiaStateData } from '../../../../data/india-states';
import { bankStateCombos, type BankStateCombo } from '../../../../data/bank-state-grid';
import {
  buildCalculatorSchema,
  buildBreadcrumbSchema,
  buildFAQSchema,
  buildSpeakableSchema,
  buildHowToSchema,
  buildEditorialTeamSchema,
} from '../../../../lib/seo';

export async function getStaticPaths() {
  return bankStateCombos.map((combo) => {
    const bank = emiBanks.find((b) => b.slug === combo.bankSlug)!;
    const state = indiaStates.find((s) => s.slug === combo.stateSlug)!;
    return {
      params: { bank: combo.bankSlug, state: combo.stateSlug },
      props: { combo, bank, state },
    };
  });
}

interface Props {
  combo: BankStateCombo;
  bank: BankData;
  state: IndiaStateData;
}

const { combo, bank, state } = Astro.props;
const path = `/finance/emi-calculator/${bank.slug}/${state.slug}`;

// Compute EMI for state's average ticket size at bank's typical rate
function emi(p: number, r: number, years: number): number {
  const m = r / 100 / 12;
  const n = years * 12;
  return (p * m * Math.pow(1 + m, n)) / (Math.pow(1 + m, n) - 1);
}
const stateAvgEmi = Math.round(emi(combo.averageLoanTicket, bank.homeLoanRate.typical, 20));
const stampDutyAmount = Math.round(combo.averageLoanTicket * combo.stateStampDutyPct / 100);

const meta = {
  slug: `emi-calculator-${bank.slug}-${state.slug}`,
  name: `${bank.bankName} Home Loan EMI in ${state.name}`,
  description: `${bank.bankName} home loan EMI calculator for ${state.name}. Rate ${bank.homeLoanRate.typical}%, ${combo.bankBranchesInState}+ branches, ${combo.stateStampDutyPct}% stamp duty. Free 2026 calculator.`,
  category: 'finance' as const,
  keywords: [
    `${bank.bankName.toLowerCase()} home loan ${state.name.toLowerCase()}`,
    `${bank.bankName.toLowerCase()} emi ${state.name.toLowerCase()}`,
    `${bank.bankName.toLowerCase()} ${state.capital.toLowerCase()} home loan`,
    `home loan ${state.name.toLowerCase()}`,
  ],
  lastUpdated: '2026-05-13',
};

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Finance', url: '/finance/' },
  { name: 'EMI Calculator', url: '/finance/emi-calculator/' },
  { name: bank.bankName, url: `/finance/emi-calculator/${bank.slug}/` },
  { name: state.name, url: path },
];

const fmtINR = (v: number) => new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 }).format(v);
function formatINRShort(value: number): string {
  if (value >= 10000000) return `₹${(value / 10000000).toFixed(2)} Cr`;
  if (value >= 100000) return `₹${(value / 100000).toFixed(2)} L`;
  return `₹${value.toLocaleString('en-IN')}`;
}

const schemas = [
  buildCalculatorSchema(meta, path),
  buildBreadcrumbSchema(breadcrumbs),
  buildFAQSchema(combo.faqs),
  buildSpeakableSchema(path),
  buildEditorialTeamSchema(),
  buildHowToSchema({
    name: `How to calculate your ${bank.bankName} home loan EMI in ${state.name}`,
    description: `Step-by-step instructions to estimate your monthly EMI for a ${bank.bankName} home loan in ${state.name} including stamp duty (${combo.stateStampDutyPct}%) and current 2026 interest rates.`,
    totalTime: 'PT3M',
    estimatedCost: { value: '0', currency: 'INR' },
    steps: [
      {
        name: 'Enter the loan amount',
        text: `Type your principal amount. In ${state.name} the average ${bank.bankName} home loan ticket is around ${formatINRShort(combo.averageLoanTicket)}.`,
      },
      {
        name: `Enter ${bank.bankName}'s interest rate`,
        text: `Use the current ${bank.bankName} rate range of ${bank.homeLoanRate.min}-${bank.homeLoanRate.max}% (typical ${bank.homeLoanRate.typical}%). Rates are repo-linked and reset on RBI policy changes.`,
      },
      {
        name: 'Choose the tenure',
        text: `${bank.bankName} offers terms up to 30 years. A 20-year term balances EMI affordability and total interest cost. The calculator updates instantly as you change the tenure.`,
      },
      {
        name: `Factor in ${state.name} stamp duty`,
        text: `${state.name} stamp duty is ${combo.stateStampDutyPct}% — about ${formatINRShort(stampDutyAmount)} on a ${formatINRShort(combo.averageLoanTicket)} property. ${bank.bankName} top-up loan can finance this on top of principal.`,
      },
      {
        name: 'Read the EMI and amortization split',
        text: `The calculator shows your monthly EMI, total interest, and the principal-vs-interest split. For ${formatINRShort(combo.averageLoanTicket)} at ${bank.homeLoanRate.typical}% over 20 years, EMI is approximately ${fmtINR(stateAvgEmi)}/month.`,
      },
    ],
  }),
];

// Related combos: same bank, different states; same state, different banks
const sameBank = bankStateCombos.filter((c) => c.bankSlug === bank.slug && c.stateSlug !== state.slug).slice(0, 5);
const sameState = bankStateCombos.filter((c) => c.stateSlug === state.slug && c.bankSlug !== bank.slug);
---

<BaseLayout
  title={`${bank.bankName} Home Loan EMI in ${state.name}`}
  description={meta.description}
  schemas={schemas}
  publishedTime={meta.lastUpdated}
  modifiedTime={meta.lastUpdated}
>
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-yellow-accent/30 rounded-full blur-[120px] float-slow"></div>
    </div>
    <div class="container-wide relative pt-8 pb-10 md:pt-12 md:pb-14">
      <nav class="mb-6"><ol class="flex flex-wrap items-center gap-1.5 text-xs sm:text-sm">{breadcrumbs.map((item, idx) => (<li class="flex items-center gap-1.5">{idx === breadcrumbs.length - 1 ? (<span class="px-3 py-1 rounded-full bg-ink-900 text-white font-bold border-2 border-ink-900">{item.name}</span>) : (<><a href={item.url} class="px-3 py-1 rounded-full bg-white border-2 border-ink-200 text-ink-700 font-semibold hover:border-ink-900 hover:text-ink-900 no-underline transition-colors">{item.name}</a><svg class="w-3 h-3 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></>)}</li>))}</ol></nav>
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="chip-yellow">🇮🇳 India</span>
          <span class="chip-cyan">{bank.emoji} {bank.bankName}</span>
          <span class="chip-lime">{state.emoji} {state.name}</span>
          <span class="chip-white">{combo.bankBranchesInState}+ branches</span>
        </div>
        <h1 class="!text-4xl sm:!text-5xl md:!text-6xl !font-extrabold !tracking-tight !leading-[1.05] text-ink-900" style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.035em;">
          {bank.bankName} Home Loan
          <span class="text-gradient-brand">in {state.name}.</span>
        </h1>
        <div class="speakable-answer mt-7 bg-yellow-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker">
          <p class="text-ink-900 text-base sm:text-lg !m-0 leading-relaxed font-medium">
            <strong>Quick answer:</strong> {bank.bankName} home loan rate in {state.name}: {bank.homeLoanRate.min}-{bank.homeLoanRate.max}% (typical {bank.homeLoanRate.typical}%). Average {state.name} home loan ticket: {formatINRShort(combo.averageLoanTicket)}. State stamp duty: {combo.stateStampDutyPct}% (~{formatINRShort(stampDutyAmount)} extra). Typical EMI on a 20-year loan: <strong>{fmtINR(stateAvgEmi)}/month</strong>.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wide pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto"><EmiCalculator client:load /></div>
  </section>

  <!-- BANK-STATE INSIGHT -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <span class="chip-cyan mb-4">📍 {bank.bankName} in {state.name}</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">
          {bank.bankName}'s {state.name} positioning.
        </h2>
        <p class="text-ink-700 mt-4 text-lg font-medium leading-relaxed">{combo.marketAngle}</p>

        <div class="mt-8 grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div class="bg-lime-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker-sm">
            <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-2">{bank.bankName} branches in {state.name}</div>
            <div class="text-2xl font-extrabold text-ink-900" style="font-family: 'Inter Tight', sans-serif;">{combo.bankBranchesInState}+</div>
          </div>
          <div class="bg-pink-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker-sm">
            <div class="text-xs font-extrabold uppercase tracking-wider text-white mb-2">{state.name} stamp duty</div>
            <div class="text-2xl font-extrabold text-white" style="font-family: 'Inter Tight', sans-serif;">{combo.stateStampDutyPct}%</div>
            <div class="text-xs text-white/90 mt-2 font-semibold">of property value</div>
          </div>
          <div class="bg-cyan-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker-sm">
            <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-2">Avg loan ticket</div>
            <div class="text-2xl font-extrabold text-ink-900" style="font-family: 'Inter Tight', sans-serif;">{formatINRShort(combo.averageLoanTicket)}</div>
            <div class="text-xs text-ink-800 mt-2 font-semibold">in {state.name}</div>
          </div>
        </div>

        <div class="mt-8 bg-yellow-accent/30 border-2 border-ink-900 rounded-2xl p-6 shadow-sticker-sm">
          <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-2">💡 Why this combination is interesting</div>
          <p class="text-ink-900 font-semibold !m-0 leading-relaxed">{combo.uniqueInsight}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- STATE TAX CONTEXT -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-4xl mx-auto">
      <span class="chip-pink mb-4">🧾 {state.name} tax context</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">
        How {state.name} taxes affect your {bank.bankName} EMI.
      </h2>

      <div class="mt-6 grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="bg-white border-2 border-ink-900 rounded-2xl p-5 shadow-sticker-sm">
          <div class="text-xs font-extrabold uppercase tracking-wider text-ink-700 mb-2">Professional Tax ({state.name})</div>
          <p class="text-sm text-ink-900 font-semibold !m-0">
            {state.monthlyProfessionalTax === 0 ? `${state.name} does NOT levy Professional Tax. Saves ₹2,500/year vs Maharashtra/Karnataka.` : `₹${state.monthlyProfessionalTax}/month (₹${state.monthlyProfessionalTax * 12}/year). Reduces net take-home pay, affecting EMI affordability calculations.`}
          </p>
        </div>
        <div class="bg-white border-2 border-ink-900 rounded-2xl p-5 shadow-sticker-sm">
          <div class="text-xs font-extrabold uppercase tracking-wider text-ink-700 mb-2">HRA tier (Section 10(13A))</div>
          <p class="text-sm text-ink-900 font-semibold !m-0">
            {state.name} {state.capital} is HRA tier-{state.hraTier === 'metro' ? '1 metro' : '2 non-metro'}: <strong>{state.hraTier === 'metro' ? '50%' : '40%'} of basic salary</strong> as HRA exemption. {state.hraTier === 'metro' ? 'Best tier — meaningful tax saving on rent.' : 'Lower than metros — limits HRA benefit despite local rent costs.'}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-3xl mx-auto">
        <span class="chip-yellow mb-4">❓ FAQ</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">{bank.bankName} in {state.name} — common questions.</h2>
        <div class="space-y-3 mt-8">
          {combo.faqs.map((faq, idx) => (
            <details class="group bg-white border-2 border-ink-900 rounded-2xl shadow-sticker-sm hover:shadow-sticker transition-all" open={idx === 0}>
              <summary class="cursor-pointer p-5 md:p-6 font-extrabold text-ink-900 flex items-center justify-between gap-4 list-none">
                <span class="text-base md:text-lg" style="font-family: 'Inter Tight', sans-serif;">{faq.q}</span>
                <span class="flex-shrink-0 w-9 h-9 rounded-full bg-ink-900 group-open:bg-lime-accent flex items-center justify-center transition-colors">
                  <svg class="w-4 h-4 text-white group-open:text-ink-900 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </span>
              </summary>
              <div class="px-5 md:px-6 pb-5 md:pb-6 text-ink-700 leading-relaxed font-medium">{faq.a}</div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CROSS-LINKS -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-4xl mx-auto">
      <span class="chip bg-violet-300 text-ink-900 mb-4">🔗 Related</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">More combinations.</h2>

      <h3 class="!text-lg !mt-6 !mb-3" style="font-family: 'Inter Tight', sans-serif;">{bank.bankName} in other states</h3>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3">
        {sameBank.map((c) => {
          const s = indiaStates.find((st) => st.slug === c.stateSlug)!;
          return (
            <a href={`/finance/emi-calculator/${bank.slug}/${c.stateSlug}/`} class="group bg-white border-[2.5px] border-ink-900 rounded-2xl p-3 no-underline shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200">
              <div class="text-lg">{s.emoji}</div>
              <div class="font-extrabold text-ink-900 text-xs leading-tight mt-1" style="font-family: 'Inter Tight', sans-serif;">{s.name}</div>
            </a>
          );
        })}
      </div>

      <h3 class="!text-lg !mt-8 !mb-3" style="font-family: 'Inter Tight', sans-serif;">Other banks in {state.name}</h3>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
        {sameState.map((c) => {
          const b = emiBanks.find((bk) => bk.slug === c.bankSlug)!;
          return (
            <a href={`/finance/emi-calculator/${c.bankSlug}/${state.slug}/`} class="group bg-white border-[2.5px] border-ink-900 rounded-2xl p-3 no-underline shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200">
              <div class="text-lg">{b.emoji}</div>
              <div class="font-extrabold text-ink-900 text-xs leading-tight mt-1" style="font-family: 'Inter Tight', sans-serif;">{b.bankName}</div>
              <div class="text-[10px] text-ink-600 mt-1">from {b.homeLoanRate.min}%</div>
            </a>
          );
        })}
      </div>

      <!-- Parent links for hierarchy clarity (helps Google understand bank > state nesting) -->
      <div class="mt-10 flex flex-wrap gap-4 text-sm">
        <a href={`/finance/emi-calculator/${bank.slug}/`} class="font-bold underline decoration-2 underline-offset-4 decoration-lime-accent text-ink-900">
          ← {bank.bankName} EMI calculator (all states)
        </a>
        <span class="text-ink-400">·</span>
        <a href="/finance/emi-calculator/" class="font-bold underline decoration-2 underline-offset-4 decoration-cyan-accent text-ink-900">
          ← All bank EMI calculators
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
