---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import EmiCalculator from '../../../components/calculators/EmiCalculator.tsx';
import BankIcon from '../../../components/ui/BankIcon.astro';
import { emiBanks, type BankData } from '../../../data/emi-banks';
import {
  buildCalculatorSchema,
  buildBreadcrumbSchema,
  buildFAQSchema,
  buildSpeakableSchema,
  buildHowToSchema,
  buildEditorialTeamSchema,
} from '../../../lib/seo';

export async function getStaticPaths() {
  return emiBanks.map((bank) => ({
    params: { bank: bank.slug },
    props: { bank },
  }));
}

interface Props {
  bank: BankData;
}

const { bank } = Astro.props;
const path = `/finance/emi-calculator/${bank.slug}`;

const meta = {
  slug: `emi-calculator-${bank.slug}`,
  name: `${bank.bankName} EMI Calculator`,
  description: `Free ${bank.bankName} EMI calculator for home, personal, and car loans. Current rates: home ${bank.homeLoanRate.typical}%, personal ${bank.personalLoanRate.typical}%, car ${bank.carLoanRate.typical}% p.a.`,
  category: 'finance' as const,
  keywords: bank.metaKeywords,
  lastUpdated: '2026-05-13',
};

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Finance', url: '/finance/' },
  { name: 'EMI Calculator', url: '/finance/emi-calculator/' },
  { name: bank.bankName, url: path },
];

const schemas = [
  buildCalculatorSchema(meta, path),
  buildBreadcrumbSchema(breadcrumbs),
  buildFAQSchema(bank.faqs),
  buildSpeakableSchema(path),
  buildEditorialTeamSchema(),
  buildHowToSchema({
    name: `How to calculate your ${bank.bankName} EMI`,
    description: `Step-by-step instructions to estimate your monthly EMI for ${bank.bankName} home, personal, or car loan using current 2026 interest rates.`,
    totalTime: 'PT2M',
    estimatedCost: { value: '0', currency: 'INR' },
    steps: [
      {
        name: 'Choose the loan type',
        text: `Pick home, personal, or car loan. ${bank.bankName} current typical rates: home ${bank.homeLoanRate.typical}%, personal ${bank.personalLoanRate.typical}%, car ${bank.carLoanRate.typical}%.`,
      },
      {
        name: 'Enter the loan amount',
        text: `Type the principal amount you want to borrow. For ${bank.bankName} home loans, the typical range is ₹15 lakh to ₹5 crore based on your income eligibility.`,
      },
      {
        name: 'Enter the interest rate',
        text: `Use ${bank.bankName}'s quoted rate or the typical rate. As of 2026, ${bank.bankName} home loan rate is ${bank.homeLoanRate.min}-${bank.homeLoanRate.max}% (typical ${bank.homeLoanRate.typical}%).`,
      },
      {
        name: 'Choose the tenure',
        text: `Pick the number of years to repay. ${bank.bankName} offers up to 30 years on home loans, 5 years on personal loans, and 7 years on car loans.`,
      },
      {
        name: 'Read the EMI and total interest',
        text: `The calculator shows your monthly EMI, total interest paid, and an amortization schedule. Factor in ${bank.bankName} processing fee: ${bank.processingFee}`,
      },
    ],
  }),
];

// Related banks — prefer those with similar home loan typical rate (within 50 bps) first,
// then fall back to other banks. Provides stronger topical clustering (PSU vs private positioning).
const sameTierBanks = emiBanks
  .filter((b) => b.slug !== bank.slug && Math.abs(b.homeLoanRate.typical - bank.homeLoanRate.typical) <= 0.5)
  .sort((a, b) => Math.abs(a.homeLoanRate.typical - bank.homeLoanRate.typical) - Math.abs(b.homeLoanRate.typical - bank.homeLoanRate.typical));
const otherTierBanks = emiBanks
  .filter((b) => b.slug !== bank.slug && Math.abs(b.homeLoanRate.typical - bank.homeLoanRate.typical) > 0.5);
const otherBanks = [...sameTierBanks, ...otherTierBanks].slice(0, 8);
---

<BaseLayout
  title={`${bank.bankName} EMI Calculator — Home, Personal & Car Loans`}
  description={meta.description}
  schemas={schemas}
  publishedTime={meta.lastUpdated}
  modifiedTime={meta.lastUpdated}
>
  <!-- HERO -->
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-yellow-accent/30 rounded-full blur-[120px] float-slow"></div>
      <div class="absolute top-[5%] right-[-10%] w-[400px] h-[400px] bg-pink-accent/20 rounded-full blur-[120px] float-slow-2"></div>
    </div>

    <div class="container-wide relative pt-8 pb-10 md:pt-12 md:pb-14">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-1.5 text-xs sm:text-sm">
          {breadcrumbs.map((item, idx) => (
            <li class="flex items-center gap-1.5">
              {idx === breadcrumbs.length - 1 ? (
                <span class="px-3 py-1 rounded-full bg-ink-900 text-white font-bold border-2 border-ink-900">{item.name}</span>
              ) : (
                <>
                  <a href={item.url} class="px-3 py-1 rounded-full bg-white border-2 border-ink-200 text-ink-700 font-semibold hover:border-ink-900 hover:text-ink-900 no-underline transition-colors">{item.name}</a>
                  <svg class="w-3 h-3 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </>
              )}
            </li>
          ))}
        </ol>
      </nav>

      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="chip-yellow">🇮🇳 India</span>
          <span class="chip-cyan inline-flex items-center gap-1.5"><BankIcon slug={bank.slug} size={18} alt={bank.bankName} /> {bank.bankName}</span>
          <span class="chip-white"><span class="text-ink-500">Last updated</span><span>{meta.lastUpdated}</span></span>
        </div>

        <h1 class="!text-4xl sm:!text-5xl md:!text-6xl !font-extrabold !tracking-tight !leading-[1.05] text-ink-900" style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.035em;">
          {bank.bankName} EMI Calculator
          <span class="text-gradient-brand">2026 rates.</span>
        </h1>

        <div class="speakable-answer mt-7 bg-yellow-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker">
          <div class="flex items-start gap-3">
            <div class="text-2xl">⚡</div>
            <div>
              <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-1">Quick answer</div>
              <p class="text-ink-900 text-base sm:text-lg leading-relaxed font-medium !m-0">
                {bank.bankName} home loan rate starts at <strong>{bank.homeLoanRate.min}%</strong> (typical {bank.homeLoanRate.typical}%) as of 2026. A ₹50 lakh loan at {bank.homeLoanRate.typical}% over 20 years = an EMI of approximately ₹{Math.round(((5000000 * (bank.homeLoanRate.typical / 100 / 12)) * Math.pow(1 + bank.homeLoanRate.typical / 100 / 12, 240)) / (Math.pow(1 + bank.homeLoanRate.typical / 100 / 12, 240) - 1)).toLocaleString('en-IN')}/month.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CALCULATOR -->
  <section class="container-wide pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto"><EmiCalculator client:load /></div>
  </section>

  <!-- BANK RATES -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <span class="chip-pink mb-4">📊 Current rates</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">
          {bank.bankName} loan rates (May 2026)
        </h2>

        <div class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-4">
          <div class="bg-lime-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker-sm">
            <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-2">🏠 Home Loan</div>
            <div class="text-2xl font-extrabold text-ink-900 leading-none" style="font-family: 'Inter Tight', sans-serif;">
              {bank.homeLoanRate.min}–{bank.homeLoanRate.max}%
            </div>
            <div class="text-xs text-ink-800 mt-2 font-semibold">typical: {bank.homeLoanRate.typical}% p.a.</div>
          </div>
          <div class="bg-pink-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker-sm">
            <div class="text-xs font-extrabold uppercase tracking-wider text-white mb-2">💵 Personal Loan</div>
            <div class="text-2xl font-extrabold text-white leading-none" style="font-family: 'Inter Tight', sans-serif;">
              {bank.personalLoanRate.min}–{bank.personalLoanRate.max}%
            </div>
            <div class="text-xs text-white/90 mt-2 font-semibold">typical: {bank.personalLoanRate.typical}% p.a.</div>
          </div>
          <div class="bg-cyan-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker-sm">
            <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-2">🚗 Car Loan</div>
            <div class="text-2xl font-extrabold text-ink-900 leading-none" style="font-family: 'Inter Tight', sans-serif;">
              {bank.carLoanRate.min}–{bank.carLoanRate.max}%
            </div>
            <div class="text-xs text-ink-800 mt-2 font-semibold">typical: {bank.carLoanRate.typical}% p.a.</div>
          </div>
        </div>

        <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="bg-white border-2 border-ink-900 rounded-2xl p-5 shadow-sticker-sm">
            <div class="text-xs font-extrabold uppercase tracking-wider text-ink-700 mb-2">💳 Processing Fee</div>
            <p class="text-sm text-ink-900 font-medium !m-0">{bank.processingFee}</p>
          </div>
          <div class="bg-white border-2 border-ink-900 rounded-2xl p-5 shadow-sticker-sm">
            <div class="text-xs font-extrabold uppercase tracking-wider text-ink-700 mb-2">🔁 Prepayment</div>
            <p class="text-sm text-ink-900 font-medium !m-0">{bank.prepaymentPolicy}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WHY THIS BANK -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-4xl mx-auto">
      <span class="chip-cyan mb-4 inline-flex items-center gap-1.5"><BankIcon slug={bank.slug} size={18} alt={bank.bankName} /> About {bank.bankName}</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">
        Why choose {bank.bankName}?
      </h2>
      <p class="text-ink-700 mt-4 text-lg font-medium leading-relaxed">{bank.marketContext}</p>

      <div class="mt-8 bg-lime-accent/30 border-2 border-ink-900 rounded-2xl p-6 shadow-sticker-sm">
        <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-2">🎯 Unique angle</div>
        <p class="text-ink-900 font-semibold !m-0 leading-relaxed">{bank.uniqueAngle}</p>
      </div>

      <h3 class="!text-2xl mt-12 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Product highlights</h3>
      <ul class="mt-4 space-y-2.5">
        {bank.productHighlights.map((h) => (
          <li class="flex items-start gap-3">
            <span class="flex-shrink-0 w-6 h-6 rounded-full bg-lime-accent border-2 border-ink-900 flex items-center justify-center text-xs font-extrabold">✓</span>
            <span class="text-ink-800 font-medium">{h}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-3xl mx-auto">
        <span class="chip-yellow mb-4">❓ {bank.bankName} FAQ</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">
          Common questions.
        </h2>

        <div class="space-y-3 mt-8">
          {bank.faqs.map((faq, idx) => (
            <details class="group bg-white border-2 border-ink-900 rounded-2xl shadow-sticker-sm hover:shadow-sticker transition-all" open={idx === 0}>
              <summary class="cursor-pointer p-5 md:p-6 font-extrabold text-ink-900 flex items-center justify-between gap-4 list-none">
                <span class="text-base md:text-lg" style="font-family: 'Inter Tight', sans-serif;">{faq.q}</span>
                <span class="flex-shrink-0 w-9 h-9 rounded-full bg-ink-900 group-open:bg-lime-accent flex items-center justify-center transition-colors">
                  <svg class="w-4 h-4 text-white group-open:text-ink-900 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </span>
              </summary>
              <div class="px-5 md:px-6 pb-5 md:pb-6 text-ink-700 leading-relaxed font-medium">{faq.a}</div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- OTHER BANKS -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-4xl mx-auto">
      <span class="chip bg-violet-300 text-ink-900 mb-4">🏦 Other banks</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">
        Compare with other banks.
      </h2>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3 mt-8">
        {otherBanks.map((other) => (
          <a
            href={`/finance/emi-calculator/${other.slug}/`}
            class="group bg-white border-[2.5px] border-ink-900 rounded-2xl p-4 no-underline shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200"
          >
            <BankIcon slug={other.slug} size={32} alt={other.bankName} class="mb-2 group-hover:rotate-12 transition-transform" />
            <div class="font-extrabold text-ink-900 text-sm leading-tight" style="font-family: 'Inter Tight', sans-serif;">
              {other.bankName}
            </div>
            <div class="text-xs text-ink-600 mt-1 font-semibold">from {other.homeLoanRate.min}%</div>
          </a>
        ))}
      </div>

      <div class="mt-6">
        <a href="/finance/emi-calculator/" class="font-bold underline decoration-2 underline-offset-4 decoration-lime-accent">
          ← Back to main EMI calculator
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
