---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import { buildBreadcrumbSchema } from '../../lib/seo';

const calcs = [
  { name: 'Mortgage Calculator', href: '/finance/mortgage-calculator/', desc: 'Monthly payments, PITI breakdown, PMI, extra payments, biweekly savings — 160+ countries.' },
  { name: 'Loan Calculator', href: '/finance/loan-calculator/', desc: 'General-purpose loan payment calculator for any term.' },
  { name: 'Retirement Calculator', href: '/finance/retirement-calculator/', desc: 'Project your retirement savings with compound growth and inflation-adjusted values.' },
  { name: 'Inflation Calculator', href: '/finance/inflation-calculator/', desc: 'Purchasing power over time — what is $X from [year] worth today?' },
  { name: 'Net Worth Calculator', href: '/finance/net-worth-calculator/', desc: 'Track assets vs liabilities to see your true net worth and debt-to-asset ratio.' },
  { name: 'EMI Calculator', href: '/finance/emi-calculator/', desc: 'Indian-style equated monthly installment calculator with bank-by-bank breakdowns.' },
  { name: 'Compound Interest', href: '/finance/compound-interest-calculator/', desc: 'See how investments and savings grow over time.' },
  { name: 'SIP Calculator', href: '/finance/sip-calculator/', desc: 'Indian mutual fund SIP returns calculator with goal planning.' },
  { name: 'FD Calculator', href: '/finance/fd-calculator/', desc: 'Fixed deposit maturity and interest by bank.' },
  { name: 'PPF Calculator', href: '/finance/ppf-calculator/', desc: 'Public Provident Fund returns over 15 years.' },
  { name: 'RD Calculator', href: '/finance/rd-calculator/', desc: 'Recurring deposit maturity calculator for Indian banks.' },
  { name: 'HRA Calculator', href: '/finance/hra-calculator/', desc: 'House Rent Allowance exemption for Indian income tax.' },
  { name: 'GST Calculator', href: '/finance/gst-calculator/', desc: 'India GST inclusive/exclusive amount and rate finder.' },
  { name: 'Income Tax India', href: '/finance/income-tax-india/', desc: 'Old vs New regime with state Professional Tax & HRA tier — all 16 states.' },
  { name: 'Old vs New Regime', href: '/finance/old-vs-new-tax-regime-india/', desc: 'Side-by-side comparison of India\'s two income-tax regimes.' },
  { name: 'Indian City EMI Calculators', href: '/finance/mortgage-calculator/cities/', desc: 'Home loan EMI by Indian city — Mumbai, Bengaluru, Chennai, Delhi-NCR and 280+ more with local stamp duty and lender notes.' },
  { name: 'SBI vs HDFC Home Loan', href: '/finance/sbi-vs-hdfc-home-loan/', desc: 'Compare SBI and HDFC home loan rates, processing speed, and real EMI.' },
  { name: 'HDFC vs ICICI Personal Loan', href: '/finance/hdfc-vs-icici-personal-loan/', desc: 'HDFC vs ICICI personal loan — EMI, rates, and disbursal speed compared.' },
  { name: 'FHA vs Conventional Mortgage', href: '/finance/fha-vs-conventional-mortgage/', desc: 'US homebuyer comparison — FHA vs conventional down payment, rates, and PMI.' },
  { name: 'PPF vs ELSS', href: '/finance/ppf-vs-elss-investment/', desc: 'Section 80C comparison — PPF vs ELSS over 15-year returns.' },
  { name: 'SIP vs Lump Sum', href: '/finance/sip-vs-lump-sum-investment/', desc: 'Which investment style wins — SIP vs lump sum over 10 years.' },
  { name: '10-Year vs 30-Year Mortgage', href: '/finance/10-year-vs-30-year-mortgage/', desc: 'Total interest, EMI, and payoff tradeoffs between short and long mortgages.' },
  { name: '15-Year vs 30-Year Mortgage', href: '/finance/15-year-vs-30-year-mortgage/', desc: 'The classic mid-tenure decision for US homebuyers.' },
];

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Finance', url: '/finance/' },
];
---

<BaseLayout
  title="Finance Calculators — Mortgage, Loan, EMI, Tax & More"
  description="Free finance calculators for mortgages, loans, EMIs, taxes, salary, compound interest, and more. Accurate, fast, no signup."
  schemas={[buildBreadcrumbSchema(breadcrumbs)]}
>
  <div class="container-prose py-8">
    <Breadcrumbs items={breadcrumbs} />
    <h1>Finance Calculators</h1>
    <p class="text-lg text-slate-700 mt-3">
      Mortgage, loan, EMI, tax, salary, and investment calculators. All free, all instant.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-8">
      {
        calcs.map((c) => (
          <a href={c.href} class="card hover:border-brand-300 no-underline block">
            <div class="font-semibold text-slate-900">{c.name}</div>
            <p class="text-sm text-slate-600 mt-1 !leading-snug">{c.desc}</p>
          </a>
        ))
      }
    </div>
  </div>
</BaseLayout>
