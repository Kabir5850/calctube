---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildBreadcrumbSchema, buildFAQSchema } from '../../lib/seo';

const path = '/finance/10-year-vs-30-year-mortgage';
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Finance', url: '/finance/' },
  { name: 'Mortgage Calculator', url: '/finance/mortgage-calculator/' },
  { name: '10-year vs 30-year', url: path },
];
const faqs = [
  { q: 'Is a 10-year mortgage worth it?', a: 'For high-income borrowers with strong cash reserves, yes. The interest savings vs 30-year are typically 70-75% of total interest, and the rate is 0.5-1.0% lower. The trade-off: monthly payment is roughly 2x a 30-year. Most worth considering for refinancers in their 50s who want to be mortgage-free by retirement.' },
  { q: '10-year mortgage vs 15-year: which is more aggressive?', a: 'The 10-year is the most aggressive standard term offered. On a $400K loan: 10-year at 5.75% = $4,393/mo and $127K interest; 15-year at 5.75% = $3,322/mo and $198K interest. The 10-year saves $71K more in interest but costs $1,071/mo more.' },
  { q: 'Why do banks offer such a low rate for 10-year mortgages?', a: 'Three reasons: (1) Shorter duration = less interest rate risk for the bank. (2) 10-year borrowers self-select for high income and creditworthiness, reducing default risk. (3) The 10-year amortization schedule means much faster principal paydown, reducing the bank\'s loan-to-value risk every year.' },
  { q: 'Can I refinance into a 10-year mortgage?', a: 'Yes. Many borrowers 10-15 years into a 30-year refinance into a 10-year as their equity and income improve. The math often works: the original 30-year has 20 years left, the refi-into-10 ends 10 years earlier with significant interest savings. Run the break-even on closing costs.' },
];

function emi(p: number, r: number, years: number): number {
  const m = r / 100 / 12;
  const n = years * 12;
  return (p * m * Math.pow(1 + m, n)) / (Math.pow(1 + m, n) - 1);
}
const loanAmount = 400000;
const m10 = emi(loanAmount, 5.5, 10);
const m30 = emi(loanAmount, 6.5, 30);
const t10 = m10 * 10 * 12;
const t30 = m30 * 30 * 12;
const i10 = t10 - loanAmount;
const i30 = t30 - loanAmount;
const fmtUSD = (v: number) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(v);
const schemas = [buildBreadcrumbSchema(breadcrumbs), buildFAQSchema(faqs)];
---

<BaseLayout title="10-Year vs 30-Year Mortgage Calculator" description="10-year vs 30-year mortgage. See real numbers (monthly payment, total interest, total cost) and when the aggressive payoff makes financial sense." schemas={schemas}>
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-cyan-accent/30 rounded-full blur-[120px] float-slow"></div>
    </div>
    <div class="container-wide relative pt-8 pb-10 md:pt-12 md:pb-14">
      <nav class="mb-6"><ol class="flex flex-wrap items-center gap-1.5 text-xs sm:text-sm">{breadcrumbs.map((item, idx) => (<li class="flex items-center gap-1.5">{idx === breadcrumbs.length - 1 ? (<span class="px-3 py-1 rounded-full bg-ink-900 text-white font-bold border-2 border-ink-900">{item.name}</span>) : (<><a href={item.url} class="px-3 py-1 rounded-full bg-white border-2 border-ink-200 text-ink-700 font-semibold hover:border-ink-900 hover:text-ink-900 no-underline transition-colors">{item.name}</a><svg class="w-3 h-3 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></>)}</li>))}</ol></nav>
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="chip-cyan">10-year</span>
          <span class="text-xl font-bold text-ink-500">vs</span>
          <span class="chip-pink">30-year</span>
        </div>
        <h1 class="!text-4xl sm:!text-5xl md:!text-6xl !font-extrabold !tracking-tight !leading-[1.05] text-ink-900" style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.035em;">10-Year vs 30-Year <span class="text-gradient-brand">Mortgage.</span></h1>
        <div class="mt-7 bg-yellow-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker">
          <p class="text-ink-900 text-base sm:text-lg !m-0 leading-relaxed font-medium"><strong>TL;DR:</strong> On a $400K loan, 10-year saves <strong>{fmtUSD(i30 - i10)}</strong> in total interest but costs <strong>{fmtUSD(m10 - m30)}/mo</strong> more. Best for high-income borrowers approaching retirement.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wide pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto">
      <h2 class="!text-3xl sm:!text-4xl !mt-0 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">$400,000 loan, head-to-head.</h2>
      <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-5">
        <div class="bg-cyan-accent border-[2.5px] border-ink-900 rounded-2xl p-6 shadow-sticker">
          <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-2">10-year</div>
          <div class="text-4xl font-extrabold text-ink-900" style="font-family: 'Inter Tight', sans-serif;">{fmtUSD(m10)}</div>
          <div class="text-sm text-ink-800 mt-1 font-bold">/month at 5.5%</div>
          <div class="mt-5 space-y-2 text-sm font-semibold">
            <div class="flex justify-between"><span>Total interest</span><strong>{fmtUSD(i10)}</strong></div>
            <div class="flex justify-between"><span>Total paid</span><strong>{fmtUSD(t10)}</strong></div>
            <div class="flex justify-between"><span>Done in</span><strong>10 years</strong></div>
          </div>
        </div>
        <div class="bg-pink-accent border-[2.5px] border-ink-900 rounded-2xl p-6 shadow-sticker">
          <div class="text-xs font-extrabold uppercase tracking-wider text-white mb-2">30-year</div>
          <div class="text-4xl font-extrabold text-white" style="font-family: 'Inter Tight', sans-serif;">{fmtUSD(m30)}</div>
          <div class="text-sm text-white mt-1 font-bold">/month at 6.5%</div>
          <div class="mt-5 space-y-2 text-sm font-semibold text-white">
            <div class="flex justify-between"><span>Total interest</span><strong>{fmtUSD(i30)}</strong></div>
            <div class="flex justify-between"><span>Total paid</span><strong>{fmtUSD(t30)}</strong></div>
            <div class="flex justify-between"><span>Done in</span><strong>30 years</strong></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-3xl mx-auto">
        <span class="chip-yellow mb-4">💡 The math</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">$1,865/month buys you $383,000 over 10 years.</h2>
        <p class="text-ink-700 mt-4 text-lg font-medium leading-relaxed">Your monthly cash flow is being asked to absorb {fmtUSD(m10 - m30)} extra to save {fmtUSD(i30 - i10)} in total interest. That\'s an effective return of roughly 13-15% per year on the extra payment, far above any safe investment available in 2026. The only reason NOT to take this trade is if you can\'t actually afford the higher payment.</p>
      </div>
    </div>
  </section>

  <section class="container-wide py-12 md:py-16">
    <div class="max-w-3xl mx-auto">
      <span class="chip-yellow mb-4">❓ FAQ</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Common questions.</h2>
      <div class="space-y-3 mt-8">
        {faqs.map((faq, idx) => (
          <details class="group bg-white border-2 border-ink-900 rounded-2xl shadow-sticker-sm hover:shadow-sticker transition-all" open={idx === 0}>
            <summary class="cursor-pointer p-5 md:p-6 font-extrabold text-ink-900 flex items-center justify-between gap-4 list-none">
              <span class="text-base md:text-lg" style="font-family: 'Inter Tight', sans-serif;">{faq.q}</span>
              <span class="flex-shrink-0 w-9 h-9 rounded-full bg-ink-900 group-open:bg-lime-accent flex items-center justify-center transition-colors">
                <svg class="w-4 h-4 text-white group-open:text-ink-900 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </span>
            </summary>
            <div class="px-5 md:px-6 pb-5 md:pb-6 text-ink-700 leading-relaxed font-medium">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
