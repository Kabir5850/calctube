---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NetWorthCalculator from '../../components/calculators/NetWorthCalculator.tsx';
import { buildCalculatorSchema, buildBreadcrumbSchema, buildFAQSchema } from '../../lib/seo';

const meta = {
  slug: 'net-worth-calculator',
  name: 'Net Worth Calculator',
  description:
    'Free net worth calculator. Add your assets and liabilities to instantly calculate your net worth, debt-to-asset ratio, and financial snapshot.',
  category: 'finance' as const,
  keywords: [
    'net worth calculator',
    'assets and liabilities calculator',
    'personal net worth',
    'debt to asset ratio',
    'wealth calculator',
  ],
  lastUpdated: '2026-05-25',
  ratingValue: '4.8',
  ratingCount: '197',
};

const path = '/finance/net-worth-calculator';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Finance', url: '/finance/' },
  { name: 'Net Worth Calculator', url: path },
];

const faqs = [
  {
    q: 'What is net worth and how is it calculated?',
    a: 'Net worth is the difference between everything you own (assets) and everything you owe (liabilities): Net Worth = Total Assets − Total Liabilities. It\'s the clearest single-number snapshot of your financial position. A positive net worth means assets exceed debts; negative means you owe more than you own, which is common early in life when student loans and mortgages dominate.',
  },
  {
    q: 'What should I include as assets?',
    a: 'Include the current market value of everything you own that has monetary value: your home and any real estate, vehicles, savings accounts, checking accounts, brokerage investments, retirement accounts (401k, IRA, pension), business ownership stakes, valuable personal property (jewelry, collectibles), and any money owed to you. Use realistic current values, not purchase prices.',
  },
  {
    q: 'What counts as a liability?',
    a: 'All outstanding debts and financial obligations: mortgage balance (not the home value, but the loan you still owe), car loans, student loans, credit card balances, personal loans, medical debt, business loans, tax obligations, and any other amount you legally owe. Use the current outstanding principal, not original loan amounts.',
  },
  {
    q: 'What is a good debt-to-asset ratio?',
    a: 'Below 30% is generally considered healthy. It means your debts are a small fraction of what you own. Between 30–60% is manageable but means debt is a significant portion of your balance sheet. Above 60% signals high financial leverage and potential vulnerability. A high ratio doesn\'t mean financial disaster. Many homeowners have 70–80% ratios when mortgages are large relative to home equity.',
  },
  {
    q: 'What is the average net worth by age?',
    a: 'According to US Federal Reserve data, median net worth rises significantly with age: roughly $39,000 for under-35, $135,000 for 35–44, $247,000 for 45–54, $365,000 for 55–64, and $410,000 for 65–74. These are medians. The averages are much higher due to wealth concentration. Focus on your own trajectory and whether your net worth is growing year over year.',
  },
];

const schemas = [buildCalculatorSchema(meta, path), buildBreadcrumbSchema(breadcrumbs), buildFAQSchema(faqs)];

const relatedCalcs = [
  { name: 'Mortgage Calculator', href: '/finance/mortgage-calculator/', desc: 'Calculate monthly mortgage payments.', icon: '🏠', color: 'bg-lime-accent' },
  { name: 'Loan Calculator', href: '/finance/loan-calculator/', desc: 'Personal, auto, or any loan payments.', icon: '💵', color: 'bg-cyan-accent' },
  { name: 'Retirement Calculator', href: '/finance/retirement-calculator/', desc: 'Project your future retirement savings.', icon: '🏖️', color: 'bg-yellow-accent' },
  { name: 'Inflation Calculator', href: '/finance/inflation-calculator/', desc: 'See how inflation erodes purchasing power.', icon: '📈', color: 'bg-pink-accent' },
];

---

<BaseLayout
  title="Net Worth Calculator: Assets Minus Liabilities"
  description={meta.description}
  schemas={schemas}
  publishedTime={meta.lastUpdated}
  modifiedTime={meta.lastUpdated}
>

  <!-- HERO -->
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-lime-accent/30 rounded-full blur-[120px] float-slow"></div>
      <div class="absolute top-[5%] right-[-10%] w-[400px] h-[400px] bg-brand-400/30 rounded-full blur-[120px] float-slow-2"></div>
    </div>
    <div class="absolute inset-0 -z-10 bg-grain opacity-50" aria-hidden="true"></div>

    <div class="container-wide relative pt-8 pb-10 md:pt-12 md:pb-14">
      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-1.5 text-xs sm:text-sm">
          {breadcrumbs.map((item, idx) => (
            <li class="flex items-center gap-1.5">
              {idx === breadcrumbs.length - 1 ? (
                <span class="px-3 py-1 rounded-full bg-ink-900 text-white font-bold border-2 border-ink-900">
                  {item.name}
                </span>
              ) : (
                <>
                  <a
                    href={item.url}
                    class="px-3 py-1 rounded-full bg-white border-2 border-ink-200 text-ink-700 font-semibold hover:border-ink-900 hover:text-ink-900 no-underline transition-colors"
                  >
                    {item.name}
                  </a>
                  <svg class="w-3 h-3 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                  </svg>
                </>
              )}
            </li>
          ))}
        </ol>
      </nav>

      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="chip-lime">💰 Finance</span>
          <span class="chip-yellow">📊 Net Worth</span>
          <span class="chip-white">
            <span class="text-ink-500">Updated</span>
            <span>{meta.lastUpdated}</span>
          </span>
        </div>

        <h1
          class="fade-in !text-4xl sm:!text-5xl md:!text-6xl !font-extrabold !tracking-tight !leading-[1.05] text-ink-900"
          style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.035em;"
        >
          Net Worth
          <span class="text-gradient-brand">Calculator.</span>
        </h1>

        <!-- Quick answer -->
        <div class="fade-in fade-in-delay-1 mt-7 bg-lime-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker">
          <div class="flex items-start gap-3">
            <div class="text-2xl flex-shrink-0">⚡</div>
            <div>
              <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-1">Quick Answer</div>
              <p class="text-ink-900 text-base sm:text-lg leading-relaxed font-medium !m-0">
                Someone with <strong class="font-extrabold">$350K home equity</strong>, <strong class="font-extrabold">$45K savings</strong>, and <strong class="font-extrabold">$80K investments</strong>, offset by a <strong class="font-extrabold">$180K mortgage</strong> and <strong class="font-extrabold">$15K credit card debt</strong>, has a <strong class="font-extrabold">net worth of $280,000</strong>.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CALCULATOR -->
  <section class="container-wide pb-12 md:pb-16">
    <div class="max-w-5xl mx-auto">
      <NetWorthCalculator client:visible />
    </div>
  </section>

  <!-- CONTENT -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-3xl mx-auto prose prose-ink">

        <h2 style="font-family: 'Inter Tight', sans-serif;">Why Tracking Net Worth Matters</h2>
        <p>
          Net worth is the most important single number in personal finance. It's your financial score, cutting through income, spending, and debt to show whether you're actually building wealth. Most people focus on income, but a high income paired with high spending and debt can produce a lower net worth than a moderate income lived frugally. Checking net worth annually lets you see if you're making real progress: paying down mortgage principal, growing investments, and reducing liabilities over time.
        </p>

        <h2 style="font-family: 'Inter Tight', sans-serif;">Tips to Improve Your Net Worth</h2>
        <p>
          The two levers for net worth growth are increasing assets and reducing liabilities. On the asset side: maximize retirement account contributions, invest consistently in low-cost index funds, build an emergency fund, and avoid depreciating assets like luxury vehicles. On the liability side: prioritize high-interest debt (credit cards first), make extra mortgage principal payments when possible, and avoid taking on new debt for non-essential purchases. Small consistent actions compound dramatically over a 10–20 year horizon.
        </p>

      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-3xl mx-auto">
      <span class="chip-yellow mb-4">❓ FAQ</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">
        Common questions.
      </h2>

      <div class="space-y-3 mt-8">
        {faqs.map((faq, idx) => (
          <details
            class="group bg-white border-2 border-ink-900 rounded-2xl shadow-sticker-sm hover:shadow-sticker transition-all overflow-hidden"
            open={idx === 0}
          >
            <summary class="cursor-pointer p-5 md:p-6 font-extrabold text-ink-900 flex items-center justify-between gap-4 list-none">
              <span class="text-base md:text-lg" style="font-family: 'Inter Tight', sans-serif;">{faq.q}</span>
              <span class="flex-shrink-0 w-9 h-9 rounded-full bg-ink-900 group-open:bg-lime-accent flex items-center justify-center transition-colors">
                <svg class="w-4 h-4 text-white group-open:text-ink-900 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </span>
            </summary>
            <div class="px-5 md:px-6 pb-5 md:pb-6 text-ink-700 leading-relaxed font-medium">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <span class="chip bg-violet-300 text-ink-900 mb-4">🔗 Related</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Try these next.</h2>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-8">
          {relatedCalcs.map((calc) => (
            <a
              href={calc.href}
              class={`group ${calc.color} border-[2.5px] border-ink-900 rounded-3xl p-5 no-underline shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200`}
            >
              <div class="text-3xl mb-3 group-hover:rotate-12 transition-transform inline-block">{calc.icon}</div>
              <div class="font-extrabold text-ink-900 text-base leading-tight" style="font-family: 'Inter Tight', sans-serif;">{calc.name}</div>
              <p class="text-xs text-ink-800 mt-1.5 leading-snug font-medium">{calc.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
