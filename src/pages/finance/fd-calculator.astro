---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FdCalculator from '../../components/calculators/FdCalculator.tsx';
import {
  buildCalculatorSchema, buildBreadcrumbSchema, buildFAQSchema,
  buildSpeakableSchema, buildHowToSchema,
} from '../../lib/seo';

const path = '/finance/fd-calculator';

const meta = {
  slug: 'fd-calculator',
  name: 'FD Calculator',
  description: 'Free Fixed Deposit (FD) calculator for Indian banks. Calculate maturity value, interest earned for SBI, HDFC, ICICI, Axis, Kotak FDs at any rate, tenure, and compounding frequency.',
  category: 'finance' as const,
  keywords: ['fd calculator', 'fixed deposit calculator', 'fd maturity calculator', 'sbi fd calculator', 'hdfc fd calculator'],
  lastUpdated: '2026-05-17',
};

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Finance', url: '/finance/' },
  { name: 'FD Calculator', url: path },
];

const faqs = [
  { q: 'What is the typical FD interest rate in India in 2026?', a: 'As of early 2026, Indian bank FD rates range from 6.5% to 7.5% for 1-3 year tenures, slightly higher (7.0-8.0%) for 5+ year tenures. Senior citizens get an additional 0.5% premium. Small finance banks (AU SFB, Equitas SFB, Ujjivan SFB) offer 8.0-9.0% rates for similar tenures. RBI cut policy rate during 2024-2025, bringing FD rates down ~75 bps from 2023 peaks.' },
  { q: 'How is FD interest calculated, compound or simple?', a: 'Most Indian bank FDs compound interest quarterly (every 3 months). Formula: Maturity = P × (1 + r/n)^(n × t), where P is principal, r is annual rate, n is compounding frequency (4 for quarterly), and t is tenure in years. Some FDs offer monthly compounding for marginally better returns. Cumulative FDs reinvest interest; non-cumulative FDs pay interest periodically without reinvestment.' },
  { q: 'Is FD interest taxable?', a: 'Yes. FD interest is added to your total income and taxed at your applicable slab rate. Banks deduct 10% TDS if your annual FD interest exceeds ₹40,000 (₹50,000 for senior citizens). You can submit Form 15G/15H if your total income is below the taxable limit to avoid TDS. The 5-year tax-saving FD qualifies for Section 80C deduction up to ₹1.5 lakh/year but the maturity interest is still taxable.' },
  { q: 'FD vs SIP: which is better?', a: 'Different tools for different goals. FDs offer capital protection and predictable returns (6.5-7.5% in 2026), suitable for short-term goals (1-5 years), emergency funds, and risk-averse retirees. SIPs in equity mutual funds offer higher long-term returns (~12% historical average) but with significant short-term volatility, suitable for long-term goals (10-20+ years) like retirement or children\'s education. Most balanced portfolios use both: FDs for stability + SIPs for growth.' },
];

const schemas = [
  buildCalculatorSchema(meta, path),
  buildBreadcrumbSchema(breadcrumbs),
  buildFAQSchema(faqs),
  buildSpeakableSchema(path),
  buildHowToSchema({
    name: 'How to calculate FD maturity value',
    description: 'Step-by-step instructions for calculating Fixed Deposit maturity value at any Indian bank.',
    totalTime: 'PT1M',
    estimatedCost: { value: '0', currency: 'INR' },
    steps: [
      { name: 'Enter deposit amount', text: 'Type the lump sum you plan to deposit. Indian bank FDs typically accept minimum ₹1,000-5,000.' },
      { name: 'Enter the FD interest rate', text: 'Use your bank\'s quoted rate. Typical 2026 rates: 6.5-7.5% (1-3 yr), 7.0-8.0% (5+ yr), +0.5% for senior citizens.' },
      { name: 'Choose tenure in months', text: 'Indian bank FDs allow tenures from 7 days to 10 years. Common picks: 1, 2, 3, 5 years.' },
      { name: 'Select compounding frequency', text: 'Most Indian banks compound quarterly. Some FDs offer monthly compounding for slightly higher returns.' },
      { name: 'Read maturity value and interest earned', text: 'Calculator shows total maturity, principal (your money), and interest earned. Note FD interest is taxable at your slab rate.' },
    ],
  }),
];

---

<BaseLayout title="FD Calculator India: Fixed Deposit Maturity 🏦" description={meta.description} schemas={schemas} publishedTime={meta.lastUpdated} modifiedTime={meta.lastUpdated}>
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-cyan-accent/30 rounded-full blur-[120px] float-slow"></div>
      <div class="absolute top-[5%] right-[-10%] w-[400px] h-[400px] bg-lime-accent/30 rounded-full blur-[120px] float-slow-2"></div>
    </div>
    <div class="container-wide relative pt-8 pb-10 md:pt-12 md:pb-14">
      <nav aria-label="Breadcrumb" class="mb-6"><ol class="flex flex-wrap items-center gap-1.5 text-xs sm:text-sm">{breadcrumbs.map((item, idx) => (<li class="flex items-center gap-1.5">{idx === breadcrumbs.length - 1 ? (<span class="px-3 py-1 rounded-full bg-ink-900 text-white font-bold border-2 border-ink-900">{item.name}</span>) : (<><a href={item.url} class="px-3 py-1 rounded-full bg-white border-2 border-ink-200 text-ink-700 font-semibold hover:border-ink-900 hover:text-ink-900 no-underline transition-colors">{item.name}</a><svg class="w-3 h-3 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></>)}</li>))}</ol></nav>

      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="chip-cyan">🏦 FD</span>
          <span class="chip-lime">🇮🇳 India</span>
          <span class="chip-white"><span class="text-ink-500">Updated</span><span>{meta.lastUpdated}</span></span>
        </div>
        <h1 class="!text-4xl sm:!text-5xl md:!text-6xl !font-extrabold !tracking-tight !leading-[1.05] text-ink-900" style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.035em;">
          FD Calculator.
          <span class="text-gradient-brand">India.</span>
        </h1>
        <div class="speakable-answer mt-7 bg-yellow-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker">
          <div class="flex items-start gap-3">
            <div class="text-2xl">⚡</div>
            <div>
              <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-1">Quick answer</div>
              <p class="text-ink-900 text-base sm:text-lg leading-relaxed font-medium !m-0">
                ₹5,00,000 FD at <strong>7.25%</strong> (quarterly compounding) over <strong>5 years</strong> = approximately <strong>₹7.16 lakh maturity</strong>. Interest earned: ₹2.16 lakh. India\'s 2026 FD rates range from 6.5-7.5% (1-3 yr) to 7.0-8.0% (5+ yr); senior citizens get +0.5% premium. Most banks compound quarterly.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <section class="container-wide pb-12 md:pb-16"><div class="max-w-4xl mx-auto"><FdCalculator client:visible /></div></section>
  <section class="bg-ink-50 border-y-2 border-ink-900"><div class="container-wide py-12 md:py-16"><div class="max-w-4xl mx-auto"><span class="chip-cyan mb-4">❓ FAQ</span><h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">FD calculator FAQ.</h2><div class="mt-8 space-y-4">{faqs.map((faq) => (<details class="bg-white border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker-sm group"><summary class="cursor-pointer font-bold text-ink-900 list-none flex items-start justify-between gap-4"><span style="font-family: 'Inter Tight', sans-serif;">{faq.q}</span><span class="text-ink-500 group-open:rotate-180 transition-transform">▾</span></summary><p class="mt-3 text-ink-700 font-medium leading-relaxed !mb-0">{faq.a}</p></details>))}</div></div></div></section>
</BaseLayout>
