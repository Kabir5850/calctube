---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import StateIcon from '../../../components/ui/StateIcon.astro';
import IncomeTaxIndiaCalculator from '../../../components/calculators/IncomeTaxIndiaCalculator.tsx';
import { indiaStates } from '../../../data/india-states';
import {
  buildCalculatorSchema,
  buildBreadcrumbSchema,
  buildFAQSchema,
} from '../../../lib/seo';
import AuthorBadge from '../../../components/ui/AuthorBadge.astro';
import { getAuthor } from '../../../data/authors';

const path = '/finance/income-tax-india';

const meta = {
  slug: 'income-tax-india',
  name: 'India Income Tax Calculator',
  description: 'Free India income tax calculator FY 2025-26. Compare Old vs New regime, Professional Tax by state, HRA exemption & Section 80C. All 16 states covered.',
  category: 'finance' as const,
  keywords: ['income tax calculator india', 'old vs new tax regime', 'professional tax india', 'hra exemption', 'section 80c'],
  lastUpdated: '2026-05-29',
  ratingValue: '4.8',
  ratingCount: '156',
};

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Finance', url: '/finance/' },
  { name: 'India Income Tax', url: path },
];

const faqs = [
  {
    q: 'Should I choose Old or New tax regime in FY 2025-26?',
    a: 'New regime is better if you have few deductions (HRA not applicable, minimal 80C investments). Old regime wins if you claim full ₹1.5L under 80C, HRA exemption, and NPS deduction. Rule of thumb: if your total deductions exceed ₹3.75 lakh, Old regime likely saves more tax.',
  },
  {
    q: 'What is the ₹12 lakh tax-free income under the New regime?',
    a: 'From FY 2025-26, income up to ₹12 lakh is effectively tax-free under the New regime due to Section 87A rebate (₹60,000 max rebate). Salaried employees get an additional ₹75,000 standard deduction, making salary up to ₹12.75 lakh fully tax-free.',
  },
  {
    q: 'Is Professional Tax deductible from income tax?',
    a: 'Yes. Professional Tax (PT) paid is fully deductible under Section 16(iii) of the Income Tax Act, regardless of which regime you choose. PT is a state-level levy capped at ₹2,500/year — it is automatically deducted by employers and reflected in Form 16.',
  },
  {
    q: 'How is HRA exemption calculated?',
    a: 'HRA exemption is the minimum of: (1) Actual HRA received, (2) Rent paid minus 10% of basic salary, (3) 50% of basic salary for metro cities (Delhi, Mumbai, Chennai, Kolkata) or 40% for others. Only available under the Old regime.',
  },
  {
    q: 'Does state of employment affect income tax?',
    a: 'Yes, indirectly. The state affects: (1) Professional Tax slab (varies by state, max ₹2,500/yr), (2) HRA tier (metro vs non-metro = 50% vs 40%), and (3) Stamp duty on property. The central income tax rate is uniform across India.',
  },
  {
    q: 'What is the surcharge on income above ₹50 lakh?',
    a: 'Surcharge: 10% on tax for income ₹50L-1Cr, 15% for ₹1Cr-2Cr, 25% for ₹2Cr-5Cr, and 37% above ₹5Cr (Old regime only; New regime caps surcharge at 25%). Marginal relief applies near the surcharge thresholds to prevent net-income inversions.',
  },
];

const schemas = [
  buildCalculatorSchema(meta, path),
  buildBreadcrumbSchema(breadcrumbs),
  buildFAQSchema(faqs),
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'India Income Tax Calculator — All States FY 2025-26',
    description: meta.description,
    url: `https://calctube.com${path}/`,
    isPartOf: { '@id': 'https://calctube.com/#website' },
    hasPart: indiaStates.map((s) => ({
      '@type': 'WebPage',
      name: `Income Tax Calculator — ${s.name}`,
      url: `https://calctube.com/finance/income-tax-india/${s.slug}/`,
    })),
  },
];

const relatedCalcs = [
  { name: 'EMI Calculator', href: '/finance/emi-calculator/', desc: 'Home, personal & car loan EMIs.', icon: '🏦', color: 'bg-cyan-accent' },
  { name: 'HRA Calculator', href: '/finance/hra-calculator/', desc: 'House Rent Allowance exemption.', icon: '🏠', color: 'bg-lime-accent' },
  { name: 'SIP Calculator', href: '/finance/sip-calculator/', desc: 'Mutual fund SIP returns.', icon: '📈', color: 'bg-yellow-accent' },
  { name: 'Old vs New Regime', href: '/finance/old-vs-new-tax-regime-india/', desc: 'Side-by-side tax regime comparison.', icon: '⚖️', color: 'bg-violet-300' },
];
const reviewer = getAuthor('aisha-rahman');
---

<BaseLayout
  title="India Income Tax Calculator FY 2025-26"
  description={meta.description}
  schemas={schemas}
  publishedTime={meta.lastUpdated}
  modifiedTime={meta.lastUpdated}
>
  <!-- HERO -->
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-yellow-accent/30 rounded-full blur-[120px] float-slow"></div>
      <div class="absolute top-[5%] right-[-10%] w-[400px] h-[400px] bg-lime-accent/20 rounded-full blur-[120px] float-slow-2"></div>
    </div>
    <div class="container-wide relative pt-8 pb-10 md:pt-12 md:pb-14">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-1.5 text-xs sm:text-sm">
          {breadcrumbs.map((item, idx) => (
            <li class="flex items-center gap-1.5">
              {idx === breadcrumbs.length - 1 ? (
                <span class="px-3 py-1 rounded-full bg-ink-900 text-white font-bold border-2 border-ink-900">{item.name}</span>
              ) : (
                <>
                  <a href={item.url} class="px-3 py-1 rounded-full bg-white border-2 border-ink-200 text-ink-700 font-semibold hover:border-ink-900 hover:text-ink-900 no-underline transition-colors">{item.name}</a>
                  <svg class="w-3 h-3 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </>
              )}
            </li>
          ))}
        </ol>
      </nav>

      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="chip-yellow">🇮🇳 India</span>
          <span class="chip-lime">FY 2025-26</span>
          <span class="chip-white"><span class="text-ink-500">Last updated</span><span>{meta.lastUpdated}</span></span>
        </div>
        <h1 class="!text-4xl sm:!text-5xl md:!text-6xl !font-extrabold !tracking-tight !leading-[1.05] text-ink-900" style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.035em;">
          India Income Tax Calculator
          <span class="text-gradient-brand">FY 2025-26.</span>
        </h1>
        <div class="mt-7 bg-yellow-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker">
          <div class="flex items-start gap-3">
            <div class="text-2xl">⚡</div>
            <div>
              <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-1">Quick answer</div>
              <p class="text-ink-900 text-base sm:text-lg leading-relaxed font-medium !m-0">
                On a <strong>₹15 lakh salary</strong> in Mumbai: New regime tax ≈ <strong>₹1,17,000</strong> vs Old regime (with 80C + HRA) ≈ <strong>₹78,000</strong>. Pick your state below for exact Professional Tax and HRA tier.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CALCULATOR -->
  <section class="container-wide pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto">
      <IncomeTaxIndiaCalculator client:load />
    </div>
  </section>

  <!-- Reviewer attribution — E-E-A-T signal -->
  <section class="container-wide pt-2 pb-8">
    <div class="max-w-4xl mx-auto">
      {reviewer && <AuthorBadge author={reviewer} verb="Reviewed" />}
    </div>
  </section>

  <!-- STATE-BY-STATE (pSEO) -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <span class="chip-yellow mb-4">📍 By state</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">
          State-specific calculators.
        </h2>
        <p class="text-ink-700 mt-3 text-lg font-medium max-w-2xl">
          Professional Tax slabs, HRA metro tier, and cost-of-living context — all localised per state.
        </p>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 mt-8">
          {indiaStates.map((s) => (
            <a
              href={`/finance/income-tax-india/${s.slug}/`}
              class="group bg-white border-[2.5px] border-ink-900 rounded-2xl p-4 no-underline shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200"
            >
              <StateIcon slug={s.slug} size={32} alt={s.name} class="mb-2 group-hover:rotate-12 transition-transform" />
              <div class="font-extrabold text-ink-900 text-sm leading-tight" style="font-family: 'Inter Tight', sans-serif;">{s.name}</div>
              <div class="text-xs text-ink-600 mt-1 font-semibold">
                PT {s.monthlyProfessionalTax > 0 ? `₹${s.monthlyProfessionalTax}/mo` : 'Exempt'} · HRA {s.hraTier === 'metro' ? '50%' : '40%'}
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- HOW TO USE -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-4xl mx-auto">
      <span class="chip-cyan mb-4">📖 How to use</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">3 inputs. Instant answer.</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 md:gap-5 mt-8">
        {[
          { num: '1', text: 'Enter your gross annual salary (CTC or take-home — use CTC for tax calculation)', color: 'bg-yellow-accent' },
          { num: '2', text: 'Enter your deductions — 80C, HRA, NPS, home loan interest, standard deduction', color: 'bg-pink-accent text-white' },
          { num: '3', text: 'Pick your state to include the correct Professional Tax slab and HRA tier', color: 'bg-cyan-accent' },
        ].map((step) => (
          <div class={`${step.color} border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker-sm`}>
            <div class="text-3xl font-extrabold mb-3 leading-none" style="font-family: 'Inter Tight', sans-serif;">{step.num}</div>
            <p class="text-sm font-semibold leading-snug !m-0 !text-current">{step.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- KEY NUMBERS FY 2025-26 -->
  <section class="bg-ink-900 text-white">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <span class="chip bg-lime-accent text-ink-900 mb-4">📊 FY 2025-26 key numbers</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight !text-white" style="font-family: 'Inter Tight', sans-serif;">Slabs at a glance.</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-8">
          <!-- New Regime -->
          <div class="bg-white/[0.06] border border-white/10 rounded-2xl p-6">
            <div class="text-lime-accent font-extrabold text-sm uppercase tracking-wider mb-4">New Regime (Default)</div>
            <table class="w-full text-sm">
              <thead><tr class="text-ink-400 border-b border-white/10"><th class="text-left pb-2 font-semibold">Income</th><th class="text-right pb-2 font-semibold">Rate</th></tr></thead>
              <tbody class="text-ink-200 divide-y divide-white/5">
                <tr><td class="py-2">Up to ₹4L</td><td class="text-right">0%</td></tr>
                <tr><td class="py-2">₹4L – ₹8L</td><td class="text-right">5%</td></tr>
                <tr><td class="py-2">₹8L – ₹12L</td><td class="text-right">10%</td></tr>
                <tr><td class="py-2">₹12L – ₹16L</td><td class="text-right">15%</td></tr>
                <tr><td class="py-2">₹16L – ₹20L</td><td class="text-right">20%</td></tr>
                <tr><td class="py-2">₹20L – ₹24L</td><td class="text-right">25%</td></tr>
                <tr><td class="py-2">Above ₹24L</td><td class="text-right">30%</td></tr>
              </tbody>
            </table>
            <p class="text-xs text-ink-400 mt-3">87A rebate: up to ₹60,000 (effective ₹12.75L tax-free for salaried)</p>
          </div>
          <!-- Old Regime -->
          <div class="bg-white/[0.06] border border-white/10 rounded-2xl p-6">
            <div class="text-pink-accent font-extrabold text-sm uppercase tracking-wider mb-4">Old Regime</div>
            <table class="w-full text-sm">
              <thead><tr class="text-ink-400 border-b border-white/10"><th class="text-left pb-2 font-semibold">Income</th><th class="text-right pb-2 font-semibold">Rate</th></tr></thead>
              <tbody class="text-ink-200 divide-y divide-white/5">
                <tr><td class="py-2">Up to ₹2.5L</td><td class="text-right">0%</td></tr>
                <tr><td class="py-2">₹2.5L – ₹5L</td><td class="text-right">5%</td></tr>
                <tr><td class="py-2">₹5L – ₹10L</td><td class="text-right">20%</td></tr>
                <tr><td class="py-2">Above ₹10L</td><td class="text-right">30%</td></tr>
              </tbody>
            </table>
            <p class="text-xs text-ink-400 mt-3">Key deductions: 80C ₹1.5L · 80D ₹25K · HRA · NPS ₹50K · Std. deduction ₹75K</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-3xl mx-auto">
        <span class="chip-yellow mb-4">❓ FAQ</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Common questions.</h2>
        <div class="space-y-3 mt-8">
          {faqs.map((faq, idx) => (
            <details class="group bg-white border-2 border-ink-900 rounded-2xl shadow-sticker-sm hover:shadow-sticker transition-all" open={idx === 0}>
              <summary class="cursor-pointer p-5 md:p-6 font-extrabold text-ink-900 flex items-center justify-between gap-4 list-none">
                <span class="text-base md:text-lg" style="font-family: 'Inter Tight', sans-serif;">{faq.q}</span>
                <span class="flex-shrink-0 w-9 h-9 rounded-full bg-ink-900 group-open:bg-lime-accent flex items-center justify-center transition-colors">
                  <svg class="w-4 h-4 text-white group-open:text-ink-900 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </span>
              </summary>
              <div class="px-5 md:px-6 pb-5 md:pb-6 text-ink-700 leading-relaxed font-medium">{faq.a}</div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- RELATED -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-4xl mx-auto">
      <span class="chip bg-violet-300 text-ink-900 mb-4">🔗 Related</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Try these next.</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-8">
        {relatedCalcs.map((c) => (
          <a href={c.href} class={`group ${c.color} border-[2.5px] border-ink-900 rounded-3xl p-5 no-underline shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200`}>
            <div class="text-3xl mb-3 group-hover:rotate-12 transition-transform inline-block">{c.icon}</div>
            <div class="font-extrabold text-ink-900 text-base leading-tight" style="font-family: 'Inter Tight', sans-serif;">{c.name}</div>
            <p class="text-xs text-ink-800 mt-1.5 leading-snug font-medium">{c.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
