---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MortgageCalculator from '../../components/calculators/MortgageCalculator.tsx';
import {
  mortgageTerms,
  computeComparison,
  type TermVariant,
} from '../../data/mortgage-terms';
import {
  buildCalculatorSchema,
  buildBreadcrumbSchema,
  buildFAQSchema,
} from '../../lib/seo';

export async function getStaticPaths() {
  return mortgageTerms.map((variant) => ({
    params: { term: String(variant.years) },
    props: { variant },
  }));
}

interface Props {
  variant: TermVariant;
}

const { variant } = Astro.props;
const path = `/finance/${variant.slug}-mortgage-calculator`;

// Calculate this term's worked example
function emi(p: number, r: number, years: number): number {
  const m = r / 100 / 12;
  const n = years * 12;
  return m === 0 ? p / n : (p * m * Math.pow(1 + m, n)) / (Math.pow(1 + m, n) - 1);
}
const thisMonthly = emi(variant.defaultAmount, variant.defaultRate, variant.years);
const thisTotal = thisMonthly * variant.years * 12;
const thisInterest = thisTotal - variant.defaultAmount;

// Comparison to other terms at the same loan amount
const comparison = computeComparison(variant.defaultAmount, variant.defaultRate);

const fmtUSD = (v: number) =>
  new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(v);

const meta = {
  slug: `${variant.slug}-mortgage-calculator`,
  name: `${variant.years}-Year Mortgage Calculator`,
  description: `Free ${variant.years}-year fixed mortgage calculator. Compare monthly payment, total interest, and payoff timeline against 10/15/20/25/30/40-year mortgages. ${variant.positioning}`,
  category: 'finance' as const,
  keywords: variant.metaKeywords,
  lastUpdated: '2026-05-13',
};

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Finance', url: '/finance/' },
  { name: 'Mortgage Calculator', url: '/finance/mortgage-calculator/' },
  { name: `${variant.years}-Year`, url: path },
];

const schemas = [
  buildCalculatorSchema(meta, path),
  buildBreadcrumbSchema(breadcrumbs),
  buildFAQSchema(variant.faqs),
];

// Other terms to link to (3 closest variants)
const otherTerms = mortgageTerms
  .filter((t) => t.years !== variant.years)
  .sort((a, b) => Math.abs(a.years - variant.years) - Math.abs(b.years - variant.years))
  .slice(0, 4);
---

<BaseLayout
  title={`${variant.years}-Year Mortgage Calculator — Payment, Interest & Comparison`}
  description={meta.description}
  schemas={schemas}
  publishedTime={meta.lastUpdated}
  modifiedTime={meta.lastUpdated}
>
  <!-- HERO -->
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-lime-accent/30 rounded-full blur-[120px] float-slow"></div>
      <div class="absolute top-[5%] right-[-10%] w-[400px] h-[400px] bg-brand-400/30 rounded-full blur-[120px] float-slow-2"></div>
    </div>

    <div class="container-wide relative pt-8 pb-10 md:pt-12 md:pb-14">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-1.5 text-xs sm:text-sm">
          {breadcrumbs.map((item, idx) => (
            <li class="flex items-center gap-1.5">
              {idx === breadcrumbs.length - 1 ? (
                <span class="px-3 py-1 rounded-full bg-ink-900 text-white font-bold border-2 border-ink-900">{item.name}</span>
              ) : (
                <>
                  <a href={item.url} class="px-3 py-1 rounded-full bg-white border-2 border-ink-200 text-ink-700 font-semibold hover:border-ink-900 hover:text-ink-900 no-underline transition-colors">{item.name}</a>
                  <svg class="w-3 h-3 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </>
              )}
            </li>
          ))}
        </ol>
      </nav>

      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="chip-lime">⏱️ {variant.years}-year fixed</span>
          {variant.popularity === 'common' && <span class="chip-yellow">🔥 Most common</span>}
          {variant.popularity === 'uncommon' && <span class="chip-cyan">💎 Underused</span>}
          {variant.popularity === 'rare' && <span class="chip-pink">⚡ Aggressive</span>}
          <span class="chip-white"><span class="text-ink-500">Last updated</span><span>{meta.lastUpdated}</span></span>
        </div>

        <h1 class="!text-4xl sm:!text-5xl md:!text-6xl !font-extrabold !tracking-tight !leading-[1.05] text-ink-900" style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.035em;">
          {variant.years}-Year Mortgage <span class="text-gradient-brand">Calculator.</span>
        </h1>

        <p class="text-lg text-ink-700 mt-5 font-medium leading-relaxed">{variant.positioning}</p>

        <div class="mt-7 bg-yellow-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker">
          <div class="flex items-start gap-3">
            <div class="text-2xl">⚡</div>
            <div>
              <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-1">Quick answer</div>
              <p class="text-ink-900 text-base sm:text-lg leading-relaxed font-medium !m-0">
                A <strong>{fmtUSD(variant.defaultAmount)} loan at {variant.defaultRate}%</strong> over {variant.years} years = monthly payment of <strong>{fmtUSD(thisMonthly)}</strong>, total interest <strong>{fmtUSD(thisInterest)}</strong>. Adjust amount and rate in the calculator below.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CALCULATOR -->
  <section class="container-wide pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto"><MortgageCalculator client:load /></div>
  </section>

  <!-- WHO IT'S FOR / PROS & CONS -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <span class="chip-cyan mb-4">👤 Who it's for</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">
          Is the {variant.years}-year right for you?
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mt-8">
          <div class="bg-lime-accent border-[2.5px] border-ink-900 rounded-2xl p-6 shadow-sticker-sm">
            <h3 class="!text-xl !mt-0 !mb-4 !text-ink-900" style="font-family: 'Inter Tight', sans-serif;">✅ Pros</h3>
            <ul class="space-y-2">
              {variant.pros.map((p) => (
                <li class="flex items-start gap-2 text-sm font-semibold text-ink-900">
                  <span class="flex-shrink-0 mt-0.5">→</span><span>{p}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="bg-pink-accent border-[2.5px] border-ink-900 rounded-2xl p-6 shadow-sticker-sm">
            <h3 class="!text-xl !mt-0 !mb-4 !text-white" style="font-family: 'Inter Tight', sans-serif;">⚠️ Cons</h3>
            <ul class="space-y-2">
              {variant.cons.map((c) => (
                <li class="flex items-start gap-2 text-sm font-semibold text-white">
                  <span class="flex-shrink-0 mt-0.5">→</span><span>{c}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <div class="mt-8">
          <h3 class="!text-xl !mt-0 !mb-3" style="font-family: 'Inter Tight', sans-serif;">Ideal borrower profile</h3>
          <ul class="space-y-2">
            {variant.whoItsFor.map((p) => (
              <li class="flex items-start gap-3">
                <span class="flex-shrink-0 w-6 h-6 rounded-full bg-yellow-accent border-2 border-ink-900 flex items-center justify-center text-xs font-extrabold">✓</span>
                <span class="text-ink-800 font-medium">{p}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- TERM COMPARISON TABLE -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-4xl mx-auto">
      <span class="chip-pink mb-4">📊 Side-by-side</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">
        How the {variant.years}-year compares.
      </h2>
      <p class="text-ink-700 mt-3 font-medium">
        Same {fmtUSD(variant.defaultAmount)} loan, different terms. Each at the typical rate for that term.
      </p>

      <div class="mt-8 bg-white border-2 border-ink-900 rounded-2xl shadow-sticker-sm overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-ink-900 text-white">
            <tr>
              <th class="text-left px-3 py-3 font-extrabold uppercase text-xs tracking-wider">Term</th>
              <th class="text-right px-3 py-3 font-extrabold uppercase text-xs tracking-wider">Rate</th>
              <th class="text-right px-3 py-3 font-extrabold uppercase text-xs tracking-wider">Monthly</th>
              <th class="text-right px-3 py-3 font-extrabold uppercase text-xs tracking-wider">Total Interest</th>
              <th class="text-right px-3 py-3 font-extrabold uppercase text-xs tracking-wider">Total Paid</th>
            </tr>
          </thead>
          <tbody>
            {comparison.map((c) => (
              <tr class={`border-b border-ink-100 ${c.years === variant.years ? 'bg-lime-accent/30' : ''}`}>
                <td class="px-3 py-3 font-extrabold text-ink-900">
                  {c.years === variant.years ? (
                    <span>{c.years} yr <span class="text-xs">←</span></span>
                  ) : (
                    <a href={`/finance/${c.slug}-mortgage-calculator/`} class="text-brand-600 hover:underline no-underline font-extrabold">{c.years} yr</a>
                  )}
                </td>
                <td class="px-3 py-3 text-right font-semibold text-ink-900">{c.rate}%</td>
                <td class="px-3 py-3 text-right font-bold text-ink-900">{fmtUSD(c.monthly)}</td>
                <td class="px-3 py-3 text-right font-semibold text-pink-accent">{fmtUSD(c.totalInterest)}</td>
                <td class="px-3 py-3 text-right font-bold text-ink-900">{fmtUSD(c.totalPaid)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-xs text-ink-500 mt-3 italic">
        Highlighted row = current page. Rates shown are typical for prime borrowers in May 2026.
      </p>
    </div>
  </section>

  <!-- UNIQUE INSIGHT -->
  <section class="bg-ink-950 text-white border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-3xl mx-auto">
        <span class="chip bg-lime-accent text-ink-900 mb-4">💡 Sharp take</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !text-white !leading-tight" style="font-family: 'Inter Tight', sans-serif;">
          The math nobody shows you.
        </h2>
        <p class="text-ink-200 mt-5 text-lg leading-relaxed font-medium">{variant.uniqueAngle}</p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-3xl mx-auto">
      <span class="chip-yellow mb-4">❓ FAQ ({variant.years}-year)</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">
        Common questions.
      </h2>

      <div class="space-y-3 mt-8">
        {variant.faqs.map((faq, idx) => (
          <details class="group bg-white border-2 border-ink-900 rounded-2xl shadow-sticker-sm hover:shadow-sticker transition-all" open={idx === 0}>
            <summary class="cursor-pointer p-5 md:p-6 font-extrabold text-ink-900 flex items-center justify-between gap-4 list-none">
              <span class="text-base md:text-lg" style="font-family: 'Inter Tight', sans-serif;">{faq.q}</span>
              <span class="flex-shrink-0 w-9 h-9 rounded-full bg-ink-900 group-open:bg-lime-accent flex items-center justify-center transition-colors">
                <svg class="w-4 h-4 text-white group-open:text-ink-900 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </span>
            </summary>
            <div class="px-5 md:px-6 pb-5 md:pb-6 text-ink-700 leading-relaxed font-medium">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- OTHER TERMS -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <span class="chip bg-violet-300 text-ink-900 mb-4">⏱️ Other terms</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">
          Compare other mortgage terms.
        </h2>

        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 sm:gap-4 mt-8">
          {otherTerms.map((other) => (
            <a
              href={`/finance/${other.slug}-mortgage-calculator/`}
              class="group bg-white border-[2.5px] border-ink-900 rounded-3xl p-4 sm:p-5 no-underline shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200"
            >
              <div class="text-2xl mb-2 group-hover:scale-110 transition-transform inline-block">⏱️</div>
              <div class="font-extrabold text-ink-900 text-base leading-tight" style="font-family: 'Inter Tight', sans-serif;">
                {other.years}-year
              </div>
              <div class="text-xs text-ink-600 mt-1 font-semibold">~{other.defaultRate}% rate</div>
            </a>
          ))}
        </div>

        <div class="mt-6">
          <a href="/finance/mortgage-calculator/" class="font-bold underline decoration-2 underline-offset-4 decoration-lime-accent">
            ← Back to main mortgage calculator
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
