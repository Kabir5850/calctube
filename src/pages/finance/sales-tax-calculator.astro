---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AuthorBadge from '../../components/ui/AuthorBadge.astro';
import SalesTaxCalculator from '../../components/calculators/SalesTaxCalculator.tsx';
import { buildCalculatorSchema, buildBreadcrumbSchema, buildFAQSchema, buildHowToSchema, buildSpeakableSchema } from '../../lib/seo';
import { getAuthor } from '../../data/authors';

const meta = {
  slug: 'sales-tax-calculator', name: 'Sales Tax & VAT Calculator',
  description: 'Free sales tax and VAT calculator. Add tax to a net price or remove tax from a gross (tax-inclusive) price at any rate, with a reference table of VAT/GST rates around the world.',
  category: 'finance' as const,
  keywords: ['sales tax calculator', 'vat calculator', 'add vat', 'remove vat', 'reverse vat calculator', 'tax calculator', 'gst vat'],
  lastUpdated: '2026-07-18',
};
const path = '/finance/sales-tax-calculator';
const reviewer = getAuthor('aisha-rahman')!;
const breadcrumbs = [
  { name: 'Home', url: '/' }, { name: 'Finance', url: '/finance/' }, { name: 'Sales Tax & VAT', url: path },
];

// Build-time standard-rate reference (indicative headline rates).
const rates = [
  { place: 'India (GST, standard)', rate: '18%' },
  { place: 'United Kingdom (VAT)', rate: '20%' },
  { place: 'European Union (typical)', rate: '19–25%' },
  { place: 'UAE (VAT)', rate: '5%' },
  { place: 'Saudi Arabia (VAT)', rate: '15%' },
  { place: 'Australia (GST)', rate: '10%' },
  { place: 'Singapore (GST)', rate: '9%' },
  { place: 'United States (sales tax)', rate: '0–~10% by state' },
];

const faqs = [
  { q: 'How do I add sales tax or VAT to a price?', a: 'Multiply the net price by the tax rate and add it on. For a ₹1,000 item at 18%: tax = 1,000 × 0.18 = ₹180, so the total is ₹1,180. As a one-step formula, gross = net × (1 + rate). Switch this calculator to "Add tax" and enter the pre-tax amount.' },
  { q: 'How do I remove VAT from a tax-inclusive price?', a: 'Divide the gross (tax-inclusive) price by 1 plus the rate — don\'t just subtract the percentage. For a £120 price that includes 20% VAT: net = 120 ÷ 1.20 = £100, so the VAT is £20. Subtracting 20% of £120 (£24) would be wrong because the 20% applies to the net, not the gross. The "Remove tax" mode does this reverse calculation for you.' },
  { q: 'What is the difference between VAT, GST and sales tax?', a: 'They\'re all consumption taxes but collected differently. VAT (value-added tax) and GST (goods and services tax) are charged at each stage of the supply chain, with businesses reclaiming the tax they paid, so only the final consumer bears it. US-style sales tax is charged once, at the final retail sale. For the shopper the maths is the same — a percentage on top of the price — which is why this one calculator handles all three.' },
  { q: 'Why is reverse VAT not just subtracting the percentage?', a: 'Because the tax was calculated on the smaller net amount, not the larger gross. If VAT is 20%, the gross is 120% of the net. To get back to 100% (net) you divide by 1.20, which is about a 16.7% reduction — not 20%. This is the single most common VAT mistake, and the reason a dedicated reverse calculation matters.' },
  { q: 'Do sales tax rates vary within a country?', a: 'Often, yes. In the United States there\'s no national sales tax — each state (and many cities and counties) sets its own, so the combined rate ranges from 0% in a few states to around 10% in parts of others. VAT/GST countries usually have one standard national rate plus reduced rates for essentials like food or books. Always check the specific rate that applies to your location and product.' },
];
const schemas = [
  buildCalculatorSchema(meta, path),
  buildBreadcrumbSchema(breadcrumbs),
  buildFAQSchema(faqs),
  buildSpeakableSchema(path),
  buildHowToSchema({
    name: 'How to calculate sales tax or VAT',
    description: 'Add tax to a net price or remove tax from a gross price at any rate.',
    totalTime: 'PT1M',
    estimatedCost: { value: '0', currency: 'USD' },
    steps: [
      { name: 'Choose add or remove', text: 'Pick "Add tax" for a pre-tax price, or "Remove tax" for a tax-inclusive price.' },
      { name: 'Enter the amount and rate', text: 'Type the price and the tax percentage.' },
      { name: 'Read the breakdown', text: 'The tool shows the net, the tax amount, and the gross total.' },
    ],
  }),
];
const relatedCalcs = [
  { name: 'GST Calculator', href: '/finance/gst-calculator/', desc: 'India GST inclusive/exclusive.', icon: '🧾', color: 'bg-cyan-accent' },
  { name: 'Discount Calculator', href: '/math/discount-calculator/', desc: 'Sale price & savings.', icon: '🏷️', color: 'bg-lime-accent' },
  { name: 'Percentage Calculator', href: '/math/percentage-calculator/', desc: 'X% of Y, % change.', icon: '🧮', color: 'bg-yellow-accent' },
  { name: 'Tip Calculator', href: '/math/tip-calculator/', desc: 'Split bills + tip.', icon: '🍽️', color: 'bg-rose-300' },
];
---

<BaseLayout title="Sales Tax & VAT Calculator — Add or Remove Tax" description={meta.description} schemas={schemas} publishedTime={meta.lastUpdated} modifiedTime={meta.lastUpdated}>
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-lime-accent/30 rounded-full blur-[120px] float-slow"></div>
      <div class="absolute top-[5%] right-[-10%] w-[400px] h-[400px] bg-cyan-accent/25 rounded-full blur-[120px] float-slow-2"></div>
    </div>
    <div class="container-wide relative pt-8 pb-10 md:pt-12 md:pb-14">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-1.5 text-xs sm:text-sm">
          {breadcrumbs.map((item, idx) => (
            <li class="flex items-center gap-1.5">
              {idx === breadcrumbs.length - 1 ? (
                <span class="px-3 py-1 rounded-full bg-ink-900 text-white font-bold border-2 border-ink-900">{item.name}</span>
              ) : (
                <>
                  <a href={item.url} class="px-3 py-1 rounded-full bg-white border-2 border-ink-200 text-ink-700 font-semibold hover:border-ink-900 hover:text-ink-900 no-underline transition-colors">{item.name}</a>
                  <svg class="w-3 h-3 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </>
              )}
            </li>
          ))}
        </ol>
      </nav>
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="chip bg-lime-accent text-ink-900">🧾 Tax</span>
          <span class="chip-white"><span class="text-ink-500">Updated</span><span>{meta.lastUpdated}</span></span>
        </div>
        <h1 class="!text-4xl sm:!text-5xl md:!text-6xl !font-extrabold !tracking-tight !leading-[1.05] text-ink-900" style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.035em;">
          Sales Tax & VAT <span class="text-gradient-brand">Calculator.</span>
        </h1>
        <div class="mt-7 bg-yellow-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker">
          <div class="flex items-start gap-3">
            <div class="text-2xl">⚡</div>
            <div>
              <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-1">Quick answer</div>
              <p class="speakable-answer text-ink-900 text-base sm:text-lg leading-relaxed font-medium !m-0">
                To <strong>add tax</strong>: gross = net × (1 + rate). To <strong>remove tax</strong> from an inclusive price: net = gross ÷ (1 + rate) — not a plain subtraction. At 20% VAT, £120 inclusive = £100 net + £20 tax. Enter your amount and rate below.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wide pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto">
      <SalesTaxCalculator client:load />
      {reviewer && <div class="mt-4"><AuthorBadge author={reviewer} verb="Reviewed" /></div>}
    </div>
  </section>

  <!-- RATES TABLE -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-3xl mx-auto">
        <span class="chip bg-lime-accent text-ink-900 mb-4">📊 Quick reference</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Standard VAT / GST / sales-tax rates.</h2>
        <p class="mt-3 text-ink-700 font-medium">Indicative headline rates — reduced rates apply to some goods, and US rates vary by state and city. Confirm the exact current rate for your case.</p>
        <div class="mt-8 overflow-x-auto">
          <table class="w-full bg-white border-[2.5px] border-ink-900 rounded-2xl shadow-sticker-sm overflow-hidden border-separate border-spacing-0 text-sm">
            <thead><tr class="bg-ink-900 text-white">
              <th class="text-left p-3 font-extrabold">Country / region</th>
              <th class="text-right p-3 font-extrabold">Standard rate</th>
            </tr></thead>
            <tbody>
              {rates.map((r, i) => (
                <tr class={`border-b-2 border-ink-100 ${i % 2 ? 'bg-ink-50' : ''}`}>
                  <td class="p-3 font-extrabold text-ink-900">{r.place}</td>
                  <td class="p-3 text-right font-mono font-bold text-ink-900">{r.rate}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-3xl mx-auto">
      <span class="chip-yellow mb-4">❓ FAQ</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Common questions.</h2>
      <div class="space-y-3 mt-8">
        {faqs.map((faq, idx) => (
          <details class="group bg-white border-2 border-ink-900 rounded-2xl shadow-sticker-sm hover:shadow-sticker transition-all" open={idx === 0}>
            <summary class="cursor-pointer p-5 md:p-6 font-extrabold text-ink-900 flex items-center justify-between gap-4 list-none">
              <span class="text-base md:text-lg" style="font-family: 'Inter Tight', sans-serif;">{faq.q}</span>
              <span class="flex-shrink-0 w-9 h-9 rounded-full bg-ink-900 group-open:bg-lime-accent flex items-center justify-center transition-colors">
                <svg class="w-4 h-4 text-white group-open:text-ink-900 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </span>
            </summary>
            <div class="px-5 md:px-6 pb-5 md:pb-6 text-ink-700 leading-relaxed font-medium">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <span class="chip bg-lime-accent text-ink-900 mb-4">🔗 Related</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Try these next.</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-8">
          {relatedCalcs.map((c) => (
            <a href={c.href} class={`group ${c.color} border-[2.5px] border-ink-900 rounded-3xl p-5 no-underline shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200`}>
              <div class="text-3xl mb-3 group-hover:rotate-12 transition-transform inline-block">{c.icon}</div>
              <div class="font-extrabold text-ink-900 text-base leading-tight" style="font-family: 'Inter Tight', sans-serif;">{c.name}</div>
              <p class="text-xs text-ink-800 mt-1.5 leading-snug font-medium">{c.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
