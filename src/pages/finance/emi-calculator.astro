---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EmiCalculator from '../../components/calculators/EmiCalculator.tsx';
import BankIcon from '../../components/ui/BankIcon.astro';
import { emiBanks } from '../../data/emi-banks';
import { buildCalculatorSchema, buildBreadcrumbSchema, buildFAQSchema } from '../../lib/seo';

const meta = {
  slug: 'emi-calculator', name: 'EMI Calculator',
  description: 'Free EMI calculator for home, personal, auto, and education loans in India. Calculate monthly EMI, total interest, and total payable.',
  category: 'finance' as const,
  keywords: ['emi calculator', 'home loan emi', 'personal loan emi', 'india', 'equated monthly installment'],
  lastUpdated: '2026-05-13', ratingValue: '4.9', ratingCount: '203',
};
const path = '/finance/emi-calculator';
const breadcrumbs = [
  { name: 'Home', url: '/' }, { name: 'Finance', url: '/finance/' }, { name: 'EMI Calculator', url: path },
];
const faqs = [
  { q: 'What is EMI?', a: 'EMI (Equated Monthly Installment) is the fixed amount you pay your lender every month for a loan. It includes both principal repayment and interest. Indian banks standardize loan repayments around the EMI structure.' },
  { q: 'How is EMI calculated?', a: 'EMI = [P × r × (1+r)^n] / [(1+r)^n − 1], where P is the principal, r is the monthly interest rate (annual ÷ 12), and n is the tenure in months. This is the same formula RBI-regulated banks use.' },
  { q: 'Does this work for home, auto, and personal loans?', a: 'Yes — the EMI math is identical across loan types. Only the typical rate range differs: home (8–10% p.a.), auto (8–12%), personal (10–18%), education (8–12%).' },
  { q: 'Does it include processing fees?', a: "No — this shows pure interest + principal. Indian banks typically charge a 0.25–2% processing fee upfront. Ask your lender for the effective APR which folds those in." },
  { q: 'Can I reduce my EMI?', a: 'Three ways: (1) negotiate a lower rate (especially if MCLR/repo rate has dropped), (2) extend the tenure (lowers EMI but raises total interest), (3) part-prepayment (allowed without penalty on most floating-rate loans).' },
  { q: 'Tax benefits on home loans?', a: 'Under Indian Income Tax Act, you can claim up to ₹1.5 lakh deduction on principal repayment (Section 80C) and ₹2 lakh on interest (Section 24b) for a self-occupied property. Consult a CA for your specific case.' },
];
const schemas = [buildCalculatorSchema(meta, path), buildBreadcrumbSchema(breadcrumbs), buildFAQSchema(faqs)];
const relatedCalcs = [
  { name: 'SIP Calculator', href: '/finance/sip-calculator/', desc: 'Mutual fund SIP returns.', icon: '📈', color: 'bg-lime-accent' },
  { name: 'FD Calculator', href: '/finance/fd-calculator/', desc: 'Fixed deposit maturity.', icon: '🏦', color: 'bg-cyan-accent' },
  { name: 'Mortgage Calculator', href: '/finance/mortgage-calculator/', desc: 'Home loan + amortization.', icon: '🏠', color: 'bg-violet-300' },
  { name: 'PPF Calculator', href: '/finance/ppf-calculator/', desc: 'PPF returns over 15 years.', icon: '🪙', color: 'bg-rose-300' },
];
---

<BaseLayout title="EMI Calculator — Home, Personal, Auto Loan EMI" description={meta.description} schemas={schemas} publishedTime={meta.lastUpdated} modifiedTime={meta.lastUpdated}>
  <!-- HERO -->
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-yellow-accent/30 rounded-full blur-[120px] float-slow"></div>
      <div class="absolute top-[5%] right-[-10%] w-[400px] h-[400px] bg-pink-accent/20 rounded-full blur-[120px] float-slow-2"></div>
    </div>
    <div class="container-wide relative pt-8 pb-10 md:pt-12 md:pb-14">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-1.5 text-xs sm:text-sm">
          {breadcrumbs.map((item, idx) => (
            <li class="flex items-center gap-1.5">
              {idx === breadcrumbs.length - 1 ? (
                <span class="px-3 py-1 rounded-full bg-ink-900 text-white font-bold border-2 border-ink-900">{item.name}</span>
              ) : (
                <>
                  <a href={item.url} class="px-3 py-1 rounded-full bg-white border-2 border-ink-200 text-ink-700 font-semibold hover:border-ink-900 hover:text-ink-900 no-underline transition-colors">{item.name}</a>
                  <svg class="w-3 h-3 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </>
              )}
            </li>
          ))}
        </ol>
      </nav>
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="chip-yellow">🇮🇳 India</span>
          <span class="chip-lime">🔥 Most popular</span>
          <span class="chip-white"><span class="text-ink-500">Last tested</span><span>{meta.lastUpdated}</span></span>
        </div>
        <h1 class="!text-4xl sm:!text-5xl md:!text-6xl !font-extrabold !tracking-tight !leading-[1.05] text-ink-900" style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.035em;">
          EMI Calculator <span class="text-gradient-brand">made simple.</span>
        </h1>
        <div class="mt-7 bg-yellow-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker">
          <div class="flex items-start gap-3">
            <div class="text-2xl">⚡</div>
            <div>
              <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-1">Quick answer</div>
              <p class="text-ink-900 text-base sm:text-lg leading-relaxed font-medium !m-0">
                A <strong>₹25 lakh home loan at 8.5% p.a.</strong> over 20 years = an EMI of about <strong>₹21,696/month</strong>. Total payable: <strong>₹52 lakh</strong>. Total interest: <strong>₹27 lakh</strong>.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CALCULATOR -->
  <section class="container-wide pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto"><EmiCalculator client:load /></div>
  </section>

  <!-- HOW TO USE -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <span class="chip-cyan mb-4">📖 How to use</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">3 steps. 0 confusion.</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 md:gap-5 mt-8">
          {[
            { num: '1', text: 'Enter loan amount (₹) — home, auto, personal, anything', color: 'bg-yellow-accent' },
            { num: '2', text: 'Enter the annual interest rate (p.a.)', color: 'bg-pink-accent text-white' },
            { num: '3', text: 'Choose tenure in years (or use 10y/20y/30y quick pick)', color: 'bg-cyan-accent' },
          ].map((step) => (
            <div class={`${step.color} border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker-sm`}>
              <div class="text-3xl font-extrabold mb-3 leading-none" style="font-family: 'Inter Tight', sans-serif;">{step.num}</div>
              <p class="text-sm font-semibold leading-snug !m-0 !text-current">{step.text}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- THE MATH -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-4xl mx-auto">
      <span class="chip-pink mb-4">🧮 The math</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">The EMI formula, decoded.</h2>
      <div class="mt-8 bg-ink-900 text-white border-[2.5px] border-ink-900 rounded-3xl p-6 md:p-8 shadow-sticker">
        <div class="text-xs font-extrabold uppercase tracking-wider text-lime-accent mb-3">The formula</div>
        <div class="overflow-x-auto">
          <div class="font-mono text-xl md:text-2xl font-bold whitespace-nowrap">
            <span class="text-pink-accent">EMI</span> = [<span class="text-cyan-accent">P</span> × <span class="text-lime-accent">r</span> × (1+<span class="text-lime-accent">r</span>)<sup class="text-yellow-accent">n</sup>] / [(1+<span class="text-lime-accent">r</span>)<sup class="text-yellow-accent">n</sup> − 1]
          </div>
        </div>
        <ul class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm">
          <li><span class="font-extrabold text-pink-accent">EMI</span> = monthly installment</li>
          <li><span class="font-extrabold text-cyan-accent">P</span> = principal (loan amount)</li>
          <li><span class="font-extrabold text-lime-accent">r</span> = monthly rate (annual rate ÷ 12 ÷ 100)</li>
          <li><span class="font-extrabold text-yellow-accent">n</span> = tenure in months (years × 12)</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-3xl mx-auto">
        <span class="chip-yellow mb-4">❓ FAQ</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Common questions.</h2>
        <div class="space-y-3 mt-8">
          {faqs.map((faq, idx) => (
            <details class="group bg-white border-2 border-ink-900 rounded-2xl shadow-sticker-sm hover:shadow-sticker transition-all" open={idx === 0}>
              <summary class="cursor-pointer p-5 md:p-6 font-extrabold text-ink-900 flex items-center justify-between gap-4 list-none">
                <span class="text-base md:text-lg" style="font-family: 'Inter Tight', sans-serif;">{faq.q}</span>
                <span class="flex-shrink-0 w-9 h-9 rounded-full bg-ink-900 group-open:bg-lime-accent flex items-center justify-center transition-colors">
                  <svg class="w-4 h-4 text-white group-open:text-ink-900 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </span>
              </summary>
              <div class="px-5 md:px-6 pb-5 md:pb-6 text-ink-700 leading-relaxed font-medium">{faq.a}</div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- BANK-SPECIFIC (pSEO) -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-4xl mx-auto">
      <span class="chip-cyan mb-4">🏦 By bank</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">
        Bank-specific EMI calculators.
      </h2>
      <p class="text-ink-700 mt-3 text-lg font-medium max-w-2xl">
        See current rates, processing fees, and prepayment policies for each bank.
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3 mt-8">
        {emiBanks.map((b) => (
          <a
            href={`/finance/emi-calculator/${b.slug}/`}
            class="group bg-white border-[2.5px] border-ink-900 rounded-2xl p-4 no-underline shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200"
          >
            <BankIcon slug={b.slug} size={32} alt={b.bankName} class="mb-2 group-hover:rotate-12 transition-transform" />
            <div class="font-extrabold text-ink-900 text-sm leading-tight" style="font-family: 'Inter Tight', sans-serif;">
              {b.bankName}
            </div>
            <div class="text-xs text-ink-600 mt-1 font-semibold">from {b.homeLoanRate.min}%</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-4xl mx-auto">
      <span class="chip bg-violet-300 text-ink-900 mb-4">🔗 Related</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Try these next.</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-8">
        {relatedCalcs.map((c) => (
          <a href={c.href} class={`group ${c.color} border-[2.5px] border-ink-900 rounded-3xl p-5 no-underline shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200`}>
            <div class="text-3xl mb-3 group-hover:rotate-12 transition-transform inline-block">{c.icon}</div>
            <div class="font-extrabold text-ink-900 text-base leading-tight" style="font-family: 'Inter Tight', sans-serif;">{c.name}</div>
            <p class="text-xs text-ink-800 mt-1.5 leading-snug font-medium">{c.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
