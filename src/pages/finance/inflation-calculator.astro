---
import BaseLayout from '../../layouts/BaseLayout.astro';
import InflationCalculator from '../../components/calculators/InflationCalculator.tsx';
import { buildCalculatorSchema, buildBreadcrumbSchema, buildFAQSchema } from '../../lib/seo';

const meta = {
  slug: 'inflation-calculator',
  name: 'Inflation Calculator',
  description:
    'Free inflation calculator. Find the purchasing power of money over time, or how much you\'ll need in the future to match today\'s value.',
  category: 'finance' as const,
  keywords: [
    'inflation calculator',
    'purchasing power calculator',
    'CPI calculator',
    'future value inflation',
    'real value calculator',
  ],
  lastUpdated: '2026-05-25',
  ratingValue: '4.8',
  ratingCount: '182',
};

const path = '/finance/inflation-calculator';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Finance', url: '/finance/' },
  { name: 'Inflation Calculator', url: path },
];

const faqs = [
  {
    q: 'What is inflation and how does it affect money?',
    a: 'Inflation is the rate at which the general level of prices for goods and services rises over time, reducing the purchasing power of money. At 3% annual inflation, something that costs $100 today will cost about $134 in ten years. This is why a dollar saved today buys less in the future. Your money needs to grow faster than inflation to maintain real value.',
  },
  {
    q: 'Why does this calculator use 3% as the default inflation rate?',
    a: 'The US Bureau of Labor Statistics shows the long-run average CPI inflation has been close to 3% per year since 1926. We use compounding at this rate as a simplified approximation since we don\'t embed actual year-by-year CPI data. For precise historical calculations, you can adjust the rate or consult the BLS CPI tables directly.',
  },
  {
    q: 'What is purchasing power?',
    a: 'Purchasing power is the quantity of goods or services that one unit of currency can buy. When inflation rises, each dollar buys fewer goods, so purchasing power falls. The "Purchasing Power" mode shows how much money from a past year is equivalent to in a later year, useful for comparing historical salaries, prices, or savings.',
  },
  {
    q: 'What is the difference between nominal and real value?',
    a: 'Nominal value is the face-value amount in current dollars without adjusting for inflation. Real value adjusts for inflation and reflects actual purchasing power. For example, a salary of $50,000 in 2010 vs $50,000 in 2024 is the same nominally, but the 2010 salary had significantly more purchasing power because prices have risen.',
  },
  {
    q: 'How can I protect my money against inflation?',
    a: 'Common inflation hedges include investing in equities (historically outpacing inflation at ~7% annually), Treasury Inflation-Protected Securities (TIPS), real estate, commodities like gold, and I-Bonds. Keeping large amounts in low-interest savings accounts or cash means your real purchasing power erodes every year inflation exceeds your interest rate.',
  },
];

const schemas = [buildCalculatorSchema(meta, path), buildBreadcrumbSchema(breadcrumbs), buildFAQSchema(faqs)];

const relatedCalcs = [
  { name: 'Retirement Calculator', href: '/finance/retirement-calculator/', desc: 'Project your inflation-adjusted nest egg.', icon: '🏖️', color: 'bg-lime-accent' },
  { name: 'Compound Interest', href: '/finance/compound-interest-calculator/', desc: 'Grow savings faster than inflation.', icon: '💹', color: 'bg-cyan-accent' },
  { name: 'Mortgage Calculator', href: '/finance/mortgage-calculator/', desc: 'Calculate monthly mortgage payments.', icon: '🏠', color: 'bg-yellow-accent' },
  { name: 'Net Worth Calculator', href: '/finance/net-worth-calculator/', desc: 'Track your assets and liabilities.', icon: '💰', color: 'bg-pink-accent' },
];

---

<BaseLayout
  title="Inflation Calculator: Purchasing Power Over Time"
  description={meta.description}
  schemas={schemas}
  publishedTime={meta.lastUpdated}
  modifiedTime={meta.lastUpdated}
>

  <!-- HERO -->
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-lime-accent/30 rounded-full blur-[120px] float-slow"></div>
      <div class="absolute top-[5%] right-[-10%] w-[400px] h-[400px] bg-brand-400/30 rounded-full blur-[120px] float-slow-2"></div>
    </div>
    <div class="absolute inset-0 -z-10 bg-grain opacity-50" aria-hidden="true"></div>

    <div class="container-wide relative pt-8 pb-10 md:pt-12 md:pb-14">
      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-1.5 text-xs sm:text-sm">
          {breadcrumbs.map((item, idx) => (
            <li class="flex items-center gap-1.5">
              {idx === breadcrumbs.length - 1 ? (
                <span class="px-3 py-1 rounded-full bg-ink-900 text-white font-bold border-2 border-ink-900">
                  {item.name}
                </span>
              ) : (
                <>
                  <a
                    href={item.url}
                    class="px-3 py-1 rounded-full bg-white border-2 border-ink-200 text-ink-700 font-semibold hover:border-ink-900 hover:text-ink-900 no-underline transition-colors"
                  >
                    {item.name}
                  </a>
                  <svg class="w-3 h-3 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                  </svg>
                </>
              )}
            </li>
          ))}
        </ol>
      </nav>

      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="chip-lime">💰 Finance</span>
          <span class="chip-cyan">📈 Inflation</span>
          <span class="chip-white">
            <span class="text-ink-500">Updated</span>
            <span>{meta.lastUpdated}</span>
          </span>
        </div>

        <h1
          class="fade-in !text-4xl sm:!text-5xl md:!text-6xl !font-extrabold !tracking-tight !leading-[1.05] text-ink-900"
          style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.035em;"
        >
          Inflation
          <span class="text-gradient-brand">Calculator.</span>
        </h1>

        <!-- Quick answer -->
        <div class="fade-in fade-in-delay-1 mt-7 bg-lime-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker">
          <div class="flex items-start gap-3">
            <div class="text-2xl flex-shrink-0">⚡</div>
            <div>
              <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-1">Quick Answer</div>
              <p class="text-ink-900 text-base sm:text-lg leading-relaxed font-medium !m-0">
                At <strong class="font-extrabold">3% average inflation</strong>, <strong class="font-extrabold">$10,000 in 2006</strong> is equivalent to about <strong class="font-extrabold">$18,061 in 2026</strong>. Inflation has cut its purchasing power roughly in half over 20 years.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CALCULATOR -->
  <section class="container-wide pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto">
      <InflationCalculator client:visible />
    </div>
  </section>

  <!-- CONTENT -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-3xl mx-auto prose prose-ink">

        <h2 style="font-family: 'Inter Tight', sans-serif;">Understanding the Inflation Formula</h2>
        <p>
          This calculator uses the standard compound inflation formula: <strong>FV = PV × (1 + r)^n</strong>, where PV is the original amount, r is the annual inflation rate, and n is the number of years. For purchasing power, the result tells you how much a past sum is worth in future dollars. For future value, it shows how much you'll need in the future to match today's spending. The 3% default reflects the US CPI historical average since the mid-20th century.
        </p>

        <h2 style="font-family: 'Inter Tight', sans-serif;">Two Modes Explained</h2>
        <p>
          <strong>Purchasing Power mode</strong> answers: "If I had $X in year Y, how much is that equivalent to in year Z?" This is useful for comparing historical wages, understanding old prices, or benchmarking savings over time. <strong>Future Value mode</strong> answers: "How much money will I need in N years to maintain the same standard of living?" This is critical for retirement planning, long-term budgets, and understanding the true cost of delaying savings.
        </p>

        <p class="text-xs text-ink-500 mt-6 font-medium">Sources: <a href="https://www.bls.gov/cpi/" rel="noopener noreferrer" target="_blank" class="underline hover:text-ink-700">BLS Consumer Price Index</a> · <a href="https://www.clevelandfed.org/indicators-and-data/inflation-expectations" rel="noopener noreferrer" target="_blank" class="underline hover:text-ink-700">Federal Reserve Bank of Cleveland Inflation Expectations</a></p>

      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-3xl mx-auto">
      <span class="chip-yellow mb-4">❓ FAQ</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">
        Common questions.
      </h2>

      <div class="space-y-3 mt-8">
        {faqs.map((faq, idx) => (
          <details
            class="group bg-white border-2 border-ink-900 rounded-2xl shadow-sticker-sm hover:shadow-sticker transition-all overflow-hidden"
            open={idx === 0}
          >
            <summary class="cursor-pointer p-5 md:p-6 font-extrabold text-ink-900 flex items-center justify-between gap-4 list-none">
              <span class="text-base md:text-lg" style="font-family: 'Inter Tight', sans-serif;">{faq.q}</span>
              <span class="flex-shrink-0 w-9 h-9 rounded-full bg-ink-900 group-open:bg-lime-accent flex items-center justify-center transition-colors">
                <svg class="w-4 h-4 text-white group-open:text-ink-900 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </span>
            </summary>
            <div class="px-5 md:px-6 pb-5 md:pb-6 text-ink-700 leading-relaxed font-medium">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <span class="chip bg-violet-300 text-ink-900 mb-4">🔗 Related</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Try these next.</h2>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-8">
          {relatedCalcs.map((calc) => (
            <a
              href={calc.href}
              class={`group ${calc.color} border-[2.5px] border-ink-900 rounded-3xl p-5 no-underline shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200`}
            >
              <div class="text-3xl mb-3 group-hover:rotate-12 transition-transform inline-block">{calc.icon}</div>
              <div class="font-extrabold text-ink-900 text-base leading-tight" style="font-family: 'Inter Tight', sans-serif;">{calc.name}</div>
              <p class="text-xs text-ink-800 mt-1.5 leading-snug font-medium">{calc.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
