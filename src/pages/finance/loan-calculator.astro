---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AuthorBadge from '../../components/ui/AuthorBadge.astro';
import LoanCalculator from '../../components/calculators/LoanCalculator.tsx';
import { loanTerms } from '../../data/loan-terms';
import { buildCalculatorSchema, buildBreadcrumbSchema, buildFAQSchema } from '../../lib/seo';
import { getAuthor } from '../../data/authors';

const meta = {
  slug: 'loan-calculator',
  name: 'Loan Calculator',
  description: 'Free loan calculator for personal, auto, student, or business loans. Calculate monthly payment, total interest, and total paid.',
  category: 'finance' as const,
  keywords: ['loan calculator', 'personal loan', 'monthly payment', 'auto loan', 'student loan'],
  lastUpdated: '2026-05-28',
  ratingValue: '4.8', ratingCount: '94',
};
const path = '/finance/loan-calculator';
const reviewer = getAuthor('aisha-rahman')!;
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Finance', url: '/finance/' },
  { name: 'Loan Calculator', url: path },
];
const faqs = [
  { q: 'How is a loan payment calculated?', a: 'The standard formula is M = P × [r(1+r)^n] / [(1+r)^n − 1], where P is the principal, r is the monthly interest rate (annual ÷ 12), and n is the number of monthly payments (years × 12).' },
  { q: 'Does this work for any kind of loan?', a: 'Yes — personal, auto, student, business, or any installment loan with a fixed rate and term. The math is identical.' },
  { q: 'Does it include fees or origination charges?', a: 'No. The calculator shows pure interest and principal. Most lenders charge an origination fee (1–8% of the loan amount) on top. Ask your lender for the APR which folds those fees in.' },
  { q: 'Fixed vs variable rate — which does this assume?', a: 'Fixed. The rate you enter is treated as constant for the entire term. If you have a variable-rate loan, your actual payment will vary.' },
  { q: 'How can I reduce the total interest I pay?', a: 'Three options: a shorter term, a lower rate (refinance or improve credit), or extra principal payments. Even one extra payment per year cuts a 30-year loan by ~4 years.' },
];
const schemas = [buildCalculatorSchema(meta, path), buildBreadcrumbSchema(breadcrumbs), buildFAQSchema(faqs)];
const relatedCalcs = [
  { name: 'Mortgage Calculator', href: '/finance/mortgage-calculator/', desc: 'Home loan + amortization schedule.', icon: '🏠', color: 'bg-lime-accent' },
  { name: 'EMI Calculator', href: '/finance/emi-calculator/', desc: 'Indian EMI for any loan type.', icon: '🇮🇳', color: 'bg-yellow-accent' },
  { name: 'Compound Interest', href: '/finance/compound-interest-calculator/', desc: 'See how savings grow.', icon: '💹', color: 'bg-violet-300' },
  { name: 'Salary Calculator', href: '/finance/salary-calculator/', desc: 'Gross-to-net by country.', icon: '💼', color: 'bg-rose-300' },
];
---

<BaseLayout title="Loan Calculator — Monthly Payment & Total" description={meta.description} schemas={schemas} publishedTime={meta.lastUpdated} modifiedTime={meta.lastUpdated}>
  <!-- HERO -->
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-cyan-accent/30 rounded-full blur-[120px] float-slow"></div>
      <div class="absolute top-[5%] right-[-10%] w-[400px] h-[400px] bg-pink-accent/20 rounded-full blur-[120px] float-slow-2"></div>
    </div>
    <div class="container-wide relative pt-8 pb-10 md:pt-12 md:pb-14">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-1.5 text-xs sm:text-sm">
          {breadcrumbs.map((item, idx) => (
            <li class="flex items-center gap-1.5">
              {idx === breadcrumbs.length - 1 ? (
                <span class="px-3 py-1 rounded-full bg-ink-900 text-white font-bold border-2 border-ink-900">{item.name}</span>
              ) : (
                <>
                  <a href={item.url} class="px-3 py-1 rounded-full bg-white border-2 border-ink-200 text-ink-700 font-semibold hover:border-ink-900 hover:text-ink-900 no-underline transition-colors">{item.name}</a>
                  <svg class="w-3 h-3 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </>
              )}
            </li>
          ))}
        </ol>
      </nav>
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="chip-cyan">💰 Finance</span>
          <span class="chip-white"><span class="text-ink-500">Last tested</span><span>{meta.lastUpdated}</span></span>
        </div>
        <h1 class="!text-4xl sm:!text-5xl md:!text-6xl !font-extrabold !tracking-tight !leading-[1.05] text-ink-900" style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.035em;">
          Loan Calculator <span class="text-gradient-brand">(any type).</span>
        </h1>
        <div class="mt-7 bg-yellow-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker">
          <div class="flex items-start gap-3">
            <div class="text-2xl">⚡</div>
            <div>
              <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-1">Quick answer</div>
              <p class="text-ink-900 text-base sm:text-lg leading-relaxed font-medium !m-0">
                A <strong>$20,000 loan at 9.5%</strong> over 5 years works out to <strong>$420/month</strong> with about <strong>$5,194 in total interest</strong>. Adjust below.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CALCULATOR -->
  <section class="container-wide pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto">
      <LoanCalculator client:load />
      {reviewer && <div class="mt-4"><AuthorBadge author={reviewer} verb="Reviewed" /></div>}
    </div>
  </section>

  <!-- HOW TO USE -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <span class="chip-cyan mb-4">📖 How to use</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">3 steps to your monthly payment.</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 md:gap-5 mt-8">
          {[
            { num: '1', text: 'Enter the loan amount (what you want to borrow)', color: 'bg-cyan-accent' },
            { num: '2', text: 'Enter the annual interest rate (or APR if known)', color: 'bg-pink-accent text-white' },
            { num: '3', text: 'Pick the loan term in years', color: 'bg-yellow-accent' },
          ].map((step) => (
            <div class={`${step.color} border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker-sm`}>
              <div class="text-3xl font-extrabold mb-3 leading-none" style="font-family: 'Inter Tight', sans-serif;">{step.num}</div>
              <p class="text-sm font-semibold leading-snug !m-0 !text-current">{step.text}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- THE MATH -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-4xl mx-auto">
      <span class="chip-pink mb-4">🧮 The math</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">The formula, demystified.</h2>
      <div class="mt-8 bg-ink-900 text-white border-[2.5px] border-ink-900 rounded-3xl p-6 md:p-8 shadow-sticker">
        <div class="text-xs font-extrabold uppercase tracking-wider text-lime-accent mb-3">The formula</div>
        <div class="overflow-x-auto">
          <div class="font-mono text-xl md:text-2xl font-bold whitespace-nowrap">
            <span class="text-pink-accent">M</span> = <span class="text-cyan-accent">P</span> × [<span class="text-lime-accent">r</span>(1+<span class="text-lime-accent">r</span>)<sup class="text-yellow-accent">n</sup>] / [(1+<span class="text-lime-accent">r</span>)<sup class="text-yellow-accent">n</sup> − 1]
          </div>
        </div>
        <ul class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm">
          <li><span class="font-extrabold text-pink-accent">M</span> = monthly payment</li>
          <li><span class="font-extrabold text-cyan-accent">P</span> = principal (loan amount)</li>
          <li><span class="font-extrabold text-lime-accent">r</span> = monthly interest rate (annual ÷ 12)</li>
          <li><span class="font-extrabold text-yellow-accent">n</span> = total monthly payments (years × 12)</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-3xl mx-auto">
        <span class="chip-yellow mb-4">❓ FAQ</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Quick answers.</h2>
        <div class="space-y-3 mt-8">
          {faqs.map((faq, idx) => (
            <details class="group bg-white border-2 border-ink-900 rounded-2xl shadow-sticker-sm hover:shadow-sticker transition-all" open={idx === 0}>
              <summary class="cursor-pointer p-5 md:p-6 font-extrabold text-ink-900 flex items-center justify-between gap-4 list-none">
                <span class="text-base md:text-lg" style="font-family: 'Inter Tight', sans-serif;">{faq.q}</span>
                <span class="flex-shrink-0 w-9 h-9 rounded-full bg-ink-900 group-open:bg-lime-accent flex items-center justify-center transition-colors">
                  <svg class="w-4 h-4 text-white group-open:text-ink-900 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </span>
              </summary>
              <div class="px-5 md:px-6 pb-5 md:pb-6 text-ink-700 leading-relaxed font-medium">{faq.a}</div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- BY TERM (pSEO) -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <span class="chip-cyan mb-4">⏱️ By term length</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">
          Personal loan by term length.
        </h2>
        <p class="text-ink-700 mt-3 text-lg font-medium max-w-2xl">
          Shorter terms = lower rates and less interest. Longer terms = lower monthly payment.
        </p>

        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mt-8">
          {loanTerms.map((t) => (
            <a
              href={`/finance/${t.slug}-loan-calculator/`}
              class="group bg-white border-[2.5px] border-ink-900 rounded-2xl p-4 no-underline shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200"
            >
              <div class="text-2xl mb-2 group-hover:scale-110 transition-transform inline-block">⏱️</div>
              <div class="font-extrabold text-ink-900 text-base leading-tight" style="font-family: 'Inter Tight', sans-serif;">
                {t.years}-year
              </div>
              <div class="text-xs text-ink-600 mt-1 font-semibold">~{t.defaultRate}% APR</div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- RELATED -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-4xl mx-auto">
      <span class="chip bg-violet-300 text-ink-900 mb-4">🔗 Related</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Try these next.</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-8">
        {relatedCalcs.map((c) => (
          <a href={c.href} class={`group ${c.color} border-[2.5px] border-ink-900 rounded-3xl p-5 no-underline shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200`}>
            <div class="text-3xl mb-3 group-hover:rotate-12 transition-transform inline-block">{c.icon}</div>
            <div class="font-extrabold text-ink-900 text-base leading-tight" style="font-family: 'Inter Tight', sans-serif;">{c.name}</div>
            <p class="text-xs text-ink-800 mt-1.5 leading-snug font-medium">{c.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
