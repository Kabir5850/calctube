---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildBreadcrumbSchema, buildFAQSchema } from '../../lib/seo';

const path = '/finance/ppf-vs-elss-investment';
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Finance', url: '/finance/' },
  { name: 'Compound Interest', url: '/finance/compound-interest-calculator/' },
  { name: 'PPF vs ELSS', url: path },
];
const faqs = [
  { q: 'PPF vs ELSS: which is better for Section 80C?', a: 'Both qualify for ₹1.5 lakh deduction under Section 80C. PPF gives ~7.1% guaranteed (tax-free) over 15 years. ELSS gives 12-15% historical (taxable LTCG above ₹1 lakh) over similar period. ELSS has higher returns but volatility; PPF has lower returns but absolute capital safety. The Old Tax Regime is required to claim 80C (irrelevant if you\'re on the New Regime).' },
  { q: 'Should I do PPF or ELSS for retirement?', a: 'For most Indian retirement portfolios, ELSS dominates over 15-20 year horizons. Historical data: ELSS funds have averaged 13-14% CAGR over 20 years vs PPF\'s 7.1%. The compounding gap is massive: ₹1.5L annually for 20 years yields ~₹70 lakh in PPF vs ~₹1.5 crore in ELSS. ELSS volatility is real but historically rewarded over decades.' },
  { q: 'PPF lock-in vs ELSS lock-in: what is the difference?', a: 'PPF: 15-year lock-in (with 5-year extensions). Partial withdrawals allowed after year 7. Premature closure only on serious medical grounds. ELSS: 3-year lock-in (the shortest among Section 80C options). After 3 years, units are freely redeemable. For flexibility, ELSS wins clearly.' },
  { q: 'Can I do both PPF and ELSS for tax saving?', a: 'Yes, and many investors do. Split ₹1.5L between PPF (₹50K for the guaranteed-return anchor) and ELSS (₹1L for growth). This hybrid gives you both the safety and the growth components. After 80C is maxed, consider NPS Tier 1 (₹50K extra under Section 80CCD-1B) for additional tax-saving + retirement planning.' },
];
const schemas = [buildBreadcrumbSchema(breadcrumbs), buildFAQSchema(faqs)];

// Simulation: ₹1.5L/year for 15 years
const annualInvestment = 150000;
const ppfRate = 0.071;
const elssRate = 0.13;
const years = 15;

// FV of annual investment compounded annually (deposit at start of year)
function fvAnnual(annual: number, rate: number, n: number): number {
  return annual * ((Math.pow(1 + rate, n) - 1) / rate) * (1 + rate);
}
const ppfFinal = fvAnnual(annualInvestment, ppfRate, years);
const elssFinal = fvAnnual(annualInvestment, elssRate, years);
const totalInvested = annualInvestment * years;
const fmtINR = (v: number) => new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 }).format(v);
---

<BaseLayout title="PPF vs ELSS: 15-Year Return Comparison" description="PPF vs ELSS compared for Indian investors. Real 15-year math on ₹1.5L/year investment. Lock-in, tax treatment, risk, and the smart hybrid approach." schemas={schemas}>
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-yellow-accent/30 rounded-full blur-[120px] float-slow"></div>
    </div>
    <div class="container-wide relative pt-8 pb-10 md:pt-12 md:pb-14">
      <nav class="mb-6"><ol class="flex flex-wrap items-center gap-1.5 text-xs sm:text-sm">{breadcrumbs.map((item, idx) => (<li class="flex items-center gap-1.5">{idx === breadcrumbs.length - 1 ? (<span class="px-3 py-1 rounded-full bg-ink-900 text-white font-bold border-2 border-ink-900">{item.name}</span>) : (<><a href={item.url} class="px-3 py-1 rounded-full bg-white border-2 border-ink-200 text-ink-700 font-semibold hover:border-ink-900 hover:text-ink-900 no-underline transition-colors">{item.name}</a><svg class="w-3 h-3 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></>)}</li>))}</ol></nav>
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="chip-yellow">🇮🇳 India · 80C</span>
          <span class="chip-cyan">🏦 PPF</span>
          <span class="text-xl font-bold text-ink-500">vs</span>
          <span class="chip-pink">📈 ELSS</span>
        </div>
        <h1 class="!text-4xl sm:!text-5xl md:!text-6xl !font-extrabold !tracking-tight !leading-[1.05] text-ink-900" style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.035em;">PPF vs ELSS <span class="text-gradient-brand">Investment.</span></h1>
        <div class="mt-7 bg-yellow-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker">
          <p class="text-ink-900 text-base sm:text-lg !m-0 leading-relaxed font-medium"><strong>TL;DR:</strong> ELSS dominates over 15+ years if you can stomach equity volatility. ₹1.5L/year for 15 years: PPF yields ~₹{Math.round(ppfFinal / 100000)}L (tax-free); ELSS yields ~₹{Math.round(elssFinal / 100000)}L (LTCG taxable above ₹1L). ELSS wins by ~₹{Math.round((elssFinal - ppfFinal) / 100000)}L on historical averages.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wide pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto">
      <h2 class="!text-3xl sm:!text-4xl !mt-0 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">₹1.5 lakh/year for 15 years.</h2>
      <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-5">
        <div class="bg-cyan-accent border-[2.5px] border-ink-900 rounded-2xl p-6 shadow-sticker">
          <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-2">🏦 PPF (7.1% guaranteed)</div>
          <div class="text-4xl font-extrabold text-ink-900" style="font-family: 'Inter Tight', sans-serif;">{fmtINR(ppfFinal)}</div>
          <div class="text-sm text-ink-800 mt-1 font-bold">after 15 years (tax-free)</div>
          <div class="mt-5 space-y-2 text-sm font-semibold">
            <div class="flex justify-between"><span>Total invested</span><strong>{fmtINR(totalInvested)}</strong></div>
            <div class="flex justify-between"><span>Returns earned</span><strong>{fmtINR(ppfFinal - totalInvested)}</strong></div>
            <div class="flex justify-between"><span>Tax on returns</span><strong>0%</strong></div>
            <div class="flex justify-between"><span>Lock-in</span><strong>15 years</strong></div>
            <div class="flex justify-between"><span>Risk</span><strong>Sovereign-backed</strong></div>
          </div>
        </div>
        <div class="bg-pink-accent border-[2.5px] border-ink-900 rounded-2xl p-6 shadow-sticker">
          <div class="text-xs font-extrabold uppercase tracking-wider text-white mb-2">📈 ELSS (13% historical avg)</div>
          <div class="text-4xl font-extrabold text-white" style="font-family: 'Inter Tight', sans-serif;">{fmtINR(elssFinal)}</div>
          <div class="text-sm text-white mt-1 font-bold">after 15 years (LTCG taxable)</div>
          <div class="mt-5 space-y-2 text-sm font-semibold text-white">
            <div class="flex justify-between"><span>Total invested</span><strong>{fmtINR(totalInvested)}</strong></div>
            <div class="flex justify-between"><span>Returns earned</span><strong>{fmtINR(elssFinal - totalInvested)}</strong></div>
            <div class="flex justify-between"><span>Tax on returns</span><strong>10% LTCG (above ₹1L)</strong></div>
            <div class="flex justify-between"><span>Lock-in</span><strong>3 years</strong></div>
            <div class="flex justify-between"><span>Risk</span><strong>Equity market volatility</strong></div>
          </div>
        </div>
      </div>
      <div class="mt-5 bg-lime-accent border-[2.5px] border-ink-900 rounded-2xl p-6 shadow-sticker">
        <p class="text-ink-900 font-semibold !m-0 leading-relaxed"><strong>The compounding gap is massive.</strong> The same ₹22.5L invested over 15 years grows to ~₹{Math.round(ppfFinal / 100000)}L in PPF (a 2x multiple) but ~₹{Math.round(elssFinal / 100000)}L in ELSS (a {Math.round(elssFinal / totalInvested)}x multiple). The 6 percentage point return gap compounds into a {Math.round((elssFinal - ppfFinal) / 100000)}-lakh wealth gap. ELSS\'s short lock-in (3 years) means you also have flexibility PPF can\'t match.</p>
      </div>
    </div>
  </section>

  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-3xl mx-auto">
        <span class="chip-yellow mb-4">💡 The smart hybrid</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Why not both?</h2>
        <p class="text-ink-700 mt-4 text-lg font-medium leading-relaxed">Most balanced Indian portfolios split the Section 80C ₹1.5L between PPF and ELSS:</p>
        <ul class="mt-4 space-y-2 text-ink-800 font-medium">
          <li class="flex gap-2"><span class="text-lime-accent">→</span><span><strong>PPF ₹50,000/year</strong> as the safety anchor, guaranteed 7%+ tax-free over 15 years</span></li>
          <li class="flex gap-2"><span class="text-lime-accent">→</span><span><strong>ELSS ₹1,00,000/year</strong> as the growth engine: accept volatility for ~13% historical CAGR</span></li>
          <li class="flex gap-2"><span class="text-lime-accent">→</span><span>Both qualify for 80C; both lock up money but with different horizons (15 vs 3 years)</span></li>
          <li class="flex gap-2"><span class="text-lime-accent">→</span><span>Combined returns: ~10-11% blended IRR with significantly reduced downside risk vs pure ELSS</span></li>
        </ul>
        <p class="text-ink-700 mt-4 font-medium leading-relaxed">After maxing 80C, the next stop is NPS Tier 1 (₹50K under 80CCD-1B) for additional tax-saving + retirement-planning leverage.</p>
      </div>
    </div>
  </section>

  <section class="container-wide py-12 md:py-16">
    <div class="max-w-3xl mx-auto">
      <span class="chip-yellow mb-4">❓ FAQ</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Common questions.</h2>
      <div class="space-y-3 mt-8">{faqs.map((faq, idx) => (<details class="group bg-white border-2 border-ink-900 rounded-2xl shadow-sticker-sm hover:shadow-sticker transition-all" open={idx === 0}><summary class="cursor-pointer p-5 md:p-6 font-extrabold text-ink-900 flex items-center justify-between gap-4 list-none"><span class="text-base md:text-lg" style="font-family: 'Inter Tight', sans-serif;">{faq.q}</span><span class="flex-shrink-0 w-9 h-9 rounded-full bg-ink-900 group-open:bg-lime-accent flex items-center justify-center transition-colors"><svg class="w-4 h-4 text-white group-open:text-ink-900 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg></span></summary><div class="px-5 md:px-6 pb-5 md:pb-6 text-ink-700 leading-relaxed font-medium">{faq.a}</div></details>))}</div>
    </div>
  </section>
</BaseLayout>
