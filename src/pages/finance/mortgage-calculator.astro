---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MortgageCalculator from '../../components/calculators/MortgageCalculator.tsx';
import {
  buildCalculatorSchema,
  buildBreadcrumbSchema,
  buildFAQSchema,
} from '../../lib/seo';

const meta = {
  slug: 'mortgage-calculator',
  name: 'Mortgage Calculator',
  description:
    'Free mortgage calculator with full amortization schedule. Calculate monthly payment, total interest, and total paid for any home loan.',
  category: 'finance' as const,
  keywords: [
    'mortgage calculator',
    'home loan calculator',
    'monthly mortgage payment',
    'amortization schedule',
    'mortgage payment calculator',
  ],
  lastUpdated: '2026-05-13',
  ratingValue: '4.8',
  ratingCount: '127',
};

const path = '/finance/mortgage-calculator';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Finance', url: '/finance/' },
  { name: 'Mortgage Calculator', url: path },
];

const faqs = [
  {
    q: 'How is a mortgage payment calculated?',
    a: 'The monthly mortgage formula is P × [r(1+r)^n] / [(1+r)^n − 1], where P is the loan principal, r is the monthly interest rate (annual rate ÷ 12), and n is the total number of payments (years × 12). This gives the level payment needed to fully amortize the loan over the term.',
  },
  {
    q: 'What does this calculator include?',
    a: "Principal and interest only. It does NOT include property taxes, homeowners insurance, or PMI. Your total housing payment (PITI) will be higher than the number shown here.",
  },
  {
    q: '15-year vs 30-year mortgage — which is better?',
    a: 'A 15-year has a higher monthly payment but much lower total interest. On a $300,000 loan at 7%, a 30-year costs about $418,000 in interest while a 15-year costs about $185,000 — a difference of roughly $233,000 over the life of the loan.',
  },
  {
    q: 'What is amortization?',
    a: 'Amortization is paying down a loan with regular fixed payments. In early years, most of each payment goes to interest. As the balance shrinks, more of each payment goes to principal. The schedule shows this breakdown month by month.',
  },
  {
    q: 'Does this work for any country?',
    a: "Yes — the math is identical. Currency display defaults to USD but the calculation is the same for UK, Canada, Australia, India, or anywhere else. Country-specific taxes and insurance are not included.",
  },
  {
    q: 'How accurate is this calculator?',
    a: "Down to the cent. The amortization formula is the same one banks use. The only thing that may differ is rounding — banks typically round to the nearest cent on each payment.",
  },
];

const schemas = [
  buildCalculatorSchema(meta, path),
  buildBreadcrumbSchema(breadcrumbs),
  buildFAQSchema(faqs),
];

const relatedCalcs = [
  {
    name: 'Loan Calculator',
    href: '/finance/loan-calculator/',
    desc: 'Personal, auto, or any-purpose loan payments.',
    icon: '💵',
    color: 'bg-cyan-accent',
  },
  {
    name: 'EMI Calculator',
    href: '/finance/emi-calculator/',
    desc: 'Indian-style equated monthly installment.',
    icon: '🇮🇳',
    color: 'bg-yellow-accent',
  },
  {
    name: 'Compound Interest',
    href: '/finance/compound-interest-calculator/',
    desc: "See how savings grow over time.",
    icon: '💹',
    color: 'bg-violet-300',
  },
  {
    name: 'Refinance Calculator',
    href: '/finance/refinance-calculator/',
    desc: 'Break-even on refinancing your loan.',
    icon: '🔄',
    color: 'bg-rose-300',
  },
];
---

<BaseLayout
  title="Mortgage Calculator with Amortization Schedule"
  description={meta.description}
  schemas={schemas}
  publishedTime={meta.lastUpdated}
  modifiedTime={meta.lastUpdated}
>
  <!-- ============================================== -->
  <!--   HERO                                          -->
  <!-- ============================================== -->
  <section class="relative overflow-hidden bg-white">
    <!-- Aurora blobs -->
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-lime-accent/30 rounded-full blur-[120px] float-slow"></div>
      <div class="absolute top-[5%] right-[-10%] w-[400px] h-[400px] bg-brand-400/30 rounded-full blur-[120px] float-slow-2"></div>
    </div>
    <div class="absolute inset-0 -z-10 bg-grain opacity-50" aria-hidden="true"></div>

    <div class="container-wide relative pt-8 pb-10 md:pt-12 md:pb-14">
      <!-- Breadcrumb (sticker style) -->
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-1.5 text-xs sm:text-sm">
          {
            breadcrumbs.map((item, idx) => (
              <li class="flex items-center gap-1.5">
                {idx === breadcrumbs.length - 1 ? (
                  <span class="px-3 py-1 rounded-full bg-ink-900 text-white font-bold border-2 border-ink-900">
                    {item.name}
                  </span>
                ) : (
                  <>
                    <a
                      href={item.url}
                      class="px-3 py-1 rounded-full bg-white border-2 border-ink-200 text-ink-700 font-semibold hover:border-ink-900 hover:text-ink-900 no-underline transition-colors"
                    >
                      {item.name}
                    </a>
                    <svg class="w-3 h-3 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                    </svg>
                  </>
                )}
              </li>
            ))
          }
        </ol>
      </nav>

      <div class="max-w-3xl">
        <!-- Sticker chips -->
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="chip-lime">💰 Finance</span>
          <span class="chip-yellow">🔥 Most popular</span>
          <span class="chip-white">
            <span class="text-ink-500">Last tested</span>
            <span>{meta.lastUpdated}</span>
          </span>
        </div>

        <!-- Headline -->
        <h1
          class="fade-in !text-4xl sm:!text-5xl md:!text-6xl !font-extrabold !tracking-tight !leading-[1.05] text-ink-900"
          style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.035em;"
        >
          Mortgage Calculator
          <span class="text-gradient-brand">with amortization.</span>
        </h1>

        <!-- Quick answer sticker -->
        <div class="fade-in fade-in-delay-1 mt-7 bg-yellow-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker">
          <div class="flex items-start gap-3">
            <div class="text-2xl flex-shrink-0">⚡</div>
            <div>
              <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-1">
                Quick answer
              </div>
              <p class="text-ink-900 text-base sm:text-lg leading-relaxed font-medium !m-0">
                A <strong class="font-extrabold">$300,000 loan at 7%</strong> over 30 years works out to a monthly payment of about <strong class="font-extrabold">$1,996</strong> and total interest of <strong class="font-extrabold">$418,527</strong>. Adjust the inputs below to fit your loan.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================== -->
  <!--   THE CALCULATOR                                -->
  <!-- ============================================== -->
  <section class="container-wide pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto">
      <MortgageCalculator client:load />
    </div>
  </section>

  <!-- ============================================== -->
  <!--   HOW TO USE                                    -->
  <!-- ============================================== -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <span class="chip-cyan mb-4">📖 How to use</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">
          4 steps to your answer.
        </h2>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-5 mt-8">
          {
            [
              { num: '1', text: 'Enter your loan amount (home price minus down payment)', color: 'bg-lime-accent' },
              { num: '2', text: 'Enter the annual interest rate from your lender', color: 'bg-pink-accent text-white' },
              { num: '3', text: 'Pick your loan term (15 and 30 years are most common)', color: 'bg-yellow-accent' },
              { num: '4', text: "Read the monthly payment + click 'Show schedule' for year-by-year", color: 'bg-cyan-accent' },
            ].map((step) => (
              <div class={`${step.color} border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker-sm`}>
                <div class="text-3xl font-extrabold mb-3 leading-none" style="font-family: 'Inter Tight', sans-serif;">
                  {step.num}
                </div>
                <p class="text-sm font-semibold leading-snug !m-0 !text-current">{step.text}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================== -->
  <!--   HOW THE MATH WORKS                            -->
  <!-- ============================================== -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-4xl mx-auto">
      <span class="chip-pink mb-4">🧮 The math</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">
        How it actually works.
      </h2>
      <p class="text-ink-700 mt-3 text-lg font-medium max-w-2xl">
        The mortgage formula is one of the most-used equations in personal finance. Here it is, demystified.
      </p>

      <!-- The formula in a dark sticker card -->
      <div class="mt-8 bg-ink-900 text-white border-[2.5px] border-ink-900 rounded-3xl p-6 md:p-8 shadow-sticker">
        <div class="text-xs font-extrabold uppercase tracking-wider text-lime-accent mb-3">
          The formula
        </div>
        <div class="overflow-x-auto">
          <div class="font-mono text-xl md:text-2xl font-bold whitespace-nowrap">
            <span class="text-pink-accent">M</span> = <span class="text-cyan-accent">P</span> × [<span class="text-lime-accent">r</span>(1+<span class="text-lime-accent">r</span>)<sup class="text-yellow-accent">n</sup>] / [(1+<span class="text-lime-accent">r</span>)<sup class="text-yellow-accent">n</sup> − 1]
          </div>
        </div>
        <ul class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm">
          <li class="flex items-start gap-2">
            <span class="font-extrabold text-pink-accent w-8 flex-shrink-0">M</span>
            <span class="text-ink-300">= monthly payment</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="font-extrabold text-cyan-accent w-8 flex-shrink-0">P</span>
            <span class="text-ink-300">= principal (loan amount)</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="font-extrabold text-lime-accent w-8 flex-shrink-0">r</span>
            <span class="text-ink-300">= monthly interest rate (annual ÷ 12)</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="font-extrabold text-yellow-accent w-8 flex-shrink-0">n</span>
            <span class="text-ink-300">= total number of monthly payments (years × 12)</span>
          </li>
        </ul>
      </div>

      <!-- Worked example -->
      <h3 class="!text-2xl mt-12 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">
        Worked example
      </h3>
      <p class="text-ink-700 mt-2 font-medium">
        Take a <strong class="font-extrabold">$300,000 mortgage at 7% interest for 30 years</strong>:
      </p>
      <div class="mt-5 bg-white border-2 border-ink-900 rounded-2xl divide-y-2 divide-ink-100 shadow-sticker-sm overflow-hidden">
        <div class="flex items-center justify-between gap-4 p-4">
          <div class="text-sm font-semibold text-ink-700">Monthly rate (r)</div>
          <code class="font-mono font-bold text-ink-900">7% ÷ 12 = 0.005833</code>
        </div>
        <div class="flex items-center justify-between gap-4 p-4">
          <div class="text-sm font-semibold text-ink-700">Number of payments (n)</div>
          <code class="font-mono font-bold text-ink-900">30 × 12 = 360</code>
        </div>
        <div class="flex items-center justify-between gap-4 p-4 bg-lime-accent/30">
          <div class="text-sm font-semibold text-ink-700">Monthly payment</div>
          <code class="font-mono font-extrabold text-ink-900 text-base">$1,995.91</code>
        </div>
        <div class="flex items-center justify-between gap-4 p-4">
          <div class="text-sm font-semibold text-ink-700">Total paid (30 years)</div>
          <code class="font-mono font-bold text-ink-900">$1,995.91 × 360 = $718,527</code>
        </div>
        <div class="flex items-center justify-between gap-4 p-4 bg-pink-accent/20">
          <div class="text-sm font-semibold text-ink-700">Total interest</div>
          <code class="font-mono font-extrabold text-ink-900 text-base">$418,527</code>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================== -->
  <!--   FAQ                                           -->
  <!-- ============================================== -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-3xl mx-auto">
        <span class="chip-yellow mb-4">❓ FAQ</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">
          Quick answers.
        </h2>

        <div class="space-y-3 mt-8">
          {
            faqs.map((faq, idx) => (
              <details
                class="group bg-white border-2 border-ink-900 rounded-2xl shadow-sticker-sm hover:shadow-sticker transition-all overflow-hidden"
                open={idx === 0}
              >
                <summary class="cursor-pointer p-5 md:p-6 font-extrabold text-ink-900 flex items-center justify-between gap-4 list-none">
                  <span class="text-base md:text-lg" style="font-family: 'Inter Tight', sans-serif;">
                    {faq.q}
                  </span>
                  <span class="flex-shrink-0 w-9 h-9 rounded-full bg-ink-900 group-open:bg-lime-accent flex items-center justify-center transition-colors">
                    <svg
                      class="w-4 h-4 text-white group-open:text-ink-900 transition-transform group-open:rotate-180"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="3"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                    </svg>
                  </span>
                </summary>
                <div class="px-5 md:px-6 pb-5 md:pb-6 text-ink-700 leading-relaxed font-medium">
                  {faq.a}
                </div>
              </details>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================== -->
  <!--   RELATED CALCULATORS                           -->
  <!-- ============================================== -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-4xl mx-auto">
      <span class="chip bg-violet-300 text-ink-900 mb-4">🔗 Related</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">
        Try these next.
      </h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-8">
        {
          relatedCalcs.map((calc) => (
            <a
              href={calc.href}
              class={`group ${calc.color} border-[2.5px] border-ink-900 rounded-3xl p-5 no-underline shadow-sticker
                     hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1
                     transition-all duration-200`}
            >
              <div class="text-3xl mb-3 group-hover:rotate-12 transition-transform inline-block">
                {calc.icon}
              </div>
              <div class="font-extrabold text-ink-900 text-base leading-tight" style="font-family: 'Inter Tight', sans-serif;">
                {calc.name}
              </div>
              <p class="text-xs text-ink-800 mt-1.5 leading-snug font-medium">{calc.desc}</p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============================================== -->
  <!--   CTA                                           -->
  <!-- ============================================== -->
  <section class="px-4 sm:px-6 lg:px-8 pb-20">
    <div class="relative overflow-hidden bg-ink-900 text-white border-2 border-ink-900 rounded-3xl max-w-4xl mx-auto p-8 md:p-12 text-center shadow-sticker">
      <div class="absolute inset-0 bg-grid-dark opacity-30" aria-hidden="true"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-lime-accent/20 rounded-full blur-[100px]" aria-hidden="true"></div>
      <div class="relative z-10">
        <h2 class="!text-3xl sm:!text-4xl !mt-0 !text-white !leading-tight" style="font-family: 'Inter Tight', sans-serif;">
          Need a different calc?
        </h2>
        <p class="text-ink-300 mt-3 max-w-xl mx-auto font-medium">
          We've got 25+ calculators across finance, health, and more. All free, all instant.
        </p>
        <div class="mt-7 flex flex-col sm:flex-row items-center justify-center gap-3 max-w-md mx-auto sm:max-w-none">
          <a href="/" class="btn-primary-lime w-full sm:w-auto">
            See all calculators →
          </a>
          <a href="/contact/" class="btn-secondary w-full sm:w-auto !bg-white">
            Request a new one
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
