---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BodyFatCalculator from '../../components/calculators/BodyFatCalculator.tsx';
import { buildCalculatorSchema, buildBreadcrumbSchema, buildFAQSchema, buildHowToSchema, buildSpeakableSchema } from '../../lib/seo';

const meta = {
  slug: 'body-fat-calculator', name: 'Body Fat Calculator',
  description: 'Free body fat percentage calculator using the US Navy circumference method. Enter height, neck and waist to estimate body fat %, with the ACE category ranges for men and women.',
  category: 'health' as const,
  keywords: ['body fat calculator', 'body fat percentage', 'us navy body fat', 'how to calculate body fat', 'body fat percentage calculator'],
  lastUpdated: '2026-07-18',
};
const path = '/health/body-fat-calculator';
const breadcrumbs = [
  { name: 'Home', url: '/' }, { name: 'Health', url: '/health/' }, { name: 'Body Fat Calculator', url: path },
];

// Build-time ACE body-fat category reference for both sexes.
const ranges = [
  { cat: 'Essential fat', men: '2–5%', women: '10–13%' },
  { cat: 'Athletes', men: '6–13%', women: '14–20%' },
  { cat: 'Fitness', men: '14–17%', women: '21–24%' },
  { cat: 'Average / acceptable', men: '18–24%', women: '25–31%' },
  { cat: 'Obese', men: '25%+', women: '32%+' },
];

const faqs = [
  { q: 'How does the US Navy body fat method work?', a: 'It estimates body fat from a few tape-measure circumferences plus your height, using a formula validated against hydrostatic (underwater) weighing. For men: %BF = 86.010 × log₁₀(waist − neck) − 70.041 × log₁₀(height) + 36.76. For women it adds the hip measurement. Because fat tends to accumulate around the waist, the waist-to-neck (and hip) relationship is a decent proxy for overall body fat, no calipers or lab needed.' },
  { q: 'How do I measure correctly?', a: 'Use a flexible tape and don\'t pull it tight. Measure your neck just below the larynx (Adam\'s apple), sloping slightly down at the front. Measure your waist at the navel for men, and at the narrowest point for women. Women also measure the hips at the widest point. Take each measurement twice and average them. A 1 cm error can shift the result by about a percentage point.' },
  { q: 'How accurate is it?', a: 'The Navy method is typically within about 3–4% of a DEXA or hydrostatic result for most people, which is good for a free tape-measure test. It can be less accurate for very muscular or very lean individuals, since it doesn\'t distinguish where the circumference comes from. For tracking progress, consistency matters more than absolute accuracy. Measure the same way each time.' },
  { q: 'What is a healthy body fat percentage?', a: 'For men, roughly 14–24% is considered fitness-to-acceptable, and for women 21–31%, per American Council on Exercise (ACE) ranges. "Essential fat" (2–5% men, 10–13% women) is the minimum the body needs. Athletes often sit below the fitness band. Very low body fat carries health risks, so lower isn\'t automatically better. The category table on this page shows the full breakdown.' },
  { q: 'Is body fat percentage better than BMI?', a: 'They measure different things. BMI is just weight relative to height and can\'t tell muscle from fat. A muscular athlete can have a high BMI but low body fat. Body fat percentage directly estimates fat, so it\'s more informative for fitness. Used together they give a fuller picture; you can cross-check with our BMI calculator.' },
];
const schemas = [
  buildCalculatorSchema(meta, path),
  buildBreadcrumbSchema(breadcrumbs),
  buildFAQSchema(faqs),
  buildSpeakableSchema(path),
  buildHowToSchema({
    name: 'How to calculate body fat percentage',
    description: 'Estimate your body fat percentage with the US Navy circumference method.',
    totalTime: 'PT2M',
    estimatedCost: { value: '0', currency: 'USD' },
    steps: [
      { name: 'Choose your sex', text: 'The formula differs for men and women (women add a hip measurement).' },
      { name: 'Measure and enter', text: 'Enter height, neck and waist (and hip for women) in centimetres.' },
      { name: 'Read your result', text: 'The calculator applies the Navy formula and shows your category.' },
    ],
  }),
];
const relatedCalcs = [
  { name: 'BMI Calculator', href: '/health/bmi-calculator/', desc: 'Body mass index.', icon: '⚖️', color: 'bg-cyan-accent' },
  { name: 'Ideal Weight', href: '/health/ideal-weight-calculator/', desc: 'Healthy weight range.', icon: '🎯', color: 'bg-lime-accent' },
  { name: 'BMR Calculator', href: '/health/bmr-calculator/', desc: 'Resting calorie burn.', icon: '🫀', color: 'bg-yellow-accent' },
  { name: 'Calorie Calculator', href: '/health/calorie-calculator/', desc: 'Daily calorie target.', icon: '🍎', color: 'bg-rose-300' },
];
---

<BaseLayout title="Body Fat Calculator: US Navy Method (Men & Women)" description={meta.description} schemas={schemas} publishedTime={meta.lastUpdated} modifiedTime={meta.lastUpdated}>
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-rose-300/40 rounded-full blur-[120px] float-slow"></div>
      <div class="absolute top-[5%] right-[-10%] w-[400px] h-[400px] bg-lime-accent/25 rounded-full blur-[120px] float-slow-2"></div>
    </div>
    <div class="container-wide relative pt-8 pb-10 md:pt-12 md:pb-14">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-1.5 text-xs sm:text-sm">
          {breadcrumbs.map((item, idx) => (
            <li class="flex items-center gap-1.5">
              {idx === breadcrumbs.length - 1 ? (
                <span class="px-3 py-1 rounded-full bg-ink-900 text-white font-bold border-2 border-ink-900">{item.name}</span>
              ) : (
                <>
                  <a href={item.url} class="px-3 py-1 rounded-full bg-white border-2 border-ink-200 text-ink-700 font-semibold hover:border-ink-900 hover:text-ink-900 no-underline transition-colors">{item.name}</a>
                  <svg class="w-3 h-3 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </>
              )}
            </li>
          ))}
        </ol>
      </nav>
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="chip bg-rose-300 text-ink-900">💪 Fitness</span>
          <span class="chip-white"><span class="text-ink-500">Updated</span><span>{meta.lastUpdated}</span></span>
        </div>
        <h1 class="!text-4xl sm:!text-5xl md:!text-6xl !font-extrabold !tracking-tight !leading-[1.05] text-ink-900" style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.035em;">
          Body Fat <span class="text-gradient-brand">Calculator.</span>
        </h1>
        <div class="mt-7 bg-yellow-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker">
          <div class="flex items-start gap-3">
            <div class="text-2xl">⚡</div>
            <div>
              <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-1">Quick answer</div>
              <p class="speakable-answer text-ink-900 text-base sm:text-lg leading-relaxed font-medium !m-0">
                The <strong>US Navy method</strong> estimates body fat from tape measurements. For men: %BF = 86.010 × log₁₀(waist − neck) − 70.041 × log₁₀(height) + 36.76. A healthy range is roughly <strong>14–24% for men</strong> and <strong>21–31% for women</strong>. Enter your measurements below.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wide pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto">
      <BodyFatCalculator client:load />
    </div>
  </section>

  <!-- CATEGORY TABLE -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-3xl mx-auto">
        <span class="chip bg-rose-300 text-ink-900 mb-4">📊 Category ranges</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Body fat categories (ACE).</h2>
        <div class="mt-8 overflow-x-auto">
          <table class="w-full bg-white border-[2.5px] border-ink-900 rounded-2xl shadow-sticker-sm overflow-hidden border-separate border-spacing-0 text-sm">
            <thead><tr class="bg-ink-900 text-white">
              <th class="text-left p-3 font-extrabold">Category</th>
              <th class="text-center p-3 font-extrabold">Men</th>
              <th class="text-right p-3 font-extrabold">Women</th>
            </tr></thead>
            <tbody>
              {ranges.map((r, i) => (
                <tr class={`border-b-2 border-ink-100 ${i % 2 ? 'bg-ink-50' : ''}`}>
                  <td class="p-3 font-extrabold text-ink-900">{r.cat}</td>
                  <td class="p-3 text-center font-mono font-bold text-ink-900">{r.men}</td>
                  <td class="p-3 text-right font-mono font-bold text-ink-900">{r.women}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-3xl mx-auto">
      <span class="chip-yellow mb-4">❓ FAQ</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Common questions.</h2>
      <div class="space-y-3 mt-8">
        {faqs.map((faq, idx) => (
          <details class="group bg-white border-2 border-ink-900 rounded-2xl shadow-sticker-sm hover:shadow-sticker transition-all" open={idx === 0}>
            <summary class="cursor-pointer p-5 md:p-6 font-extrabold text-ink-900 flex items-center justify-between gap-4 list-none">
              <span class="text-base md:text-lg" style="font-family: 'Inter Tight', sans-serif;">{faq.q}</span>
              <span class="flex-shrink-0 w-9 h-9 rounded-full bg-ink-900 group-open:bg-lime-accent flex items-center justify-center transition-colors">
                <svg class="w-4 h-4 text-white group-open:text-ink-900 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </span>
            </summary>
            <div class="px-5 md:px-6 pb-5 md:pb-6 text-ink-700 leading-relaxed font-medium">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <span class="chip bg-rose-300 text-ink-900 mb-4">🔗 Related</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Try these next.</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-8">
          {relatedCalcs.map((c) => (
            <a href={c.href} class={`group ${c.color} border-[2.5px] border-ink-900 rounded-3xl p-5 no-underline shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200`}>
              <div class="text-3xl mb-3 group-hover:rotate-12 transition-transform inline-block">{c.icon}</div>
              <div class="font-extrabold text-ink-900 text-base leading-tight" style="font-family: 'Inter Tight', sans-serif;">{c.name}</div>
              <p class="text-xs text-ink-800 mt-1.5 leading-snug font-medium">{c.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
