---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import { buildBreadcrumbSchema } from '../../lib/seo';

const liveCalcs = [
  { name: 'BMI Calculator', href: '/health/bmi-calculator/', desc: 'Body Mass Index with metric and imperial units. Instant category lookup against WHO ranges.', icon: '⚖️' },
  { name: 'Calorie Calculator', href: '/health/calorie-calculator/', desc: 'Daily calorie target for weight loss, maintenance, or muscle gain — with estimated timeline.', icon: '🍎' },
  { name: 'BMR Calculator', href: '/health/bmr-calculator/', desc: 'Basal Metabolic Rate via Mifflin-St Jeor — calories burned at rest.', icon: '🔥' },
  { name: 'TDEE Calculator', href: '/health/tdee-calculator/', desc: 'Total Daily Energy Expenditure by activity level, with maintenance calories and macros.', icon: '⚡' },
  { name: 'Body Fat Calculator', href: '/health/body-fat-calculator/', desc: 'Body fat percentage via the US Navy tape method, with ACE category ranges.', icon: '💪' },
  { name: 'Ideal Weight Calculator', href: '/health/ideal-weight-calculator/', desc: 'Healthy weight range for your height — Devine, Robinson, Miller, Hamwi and BMI.', icon: '🎯' },
  { name: 'Water Intake Calculator', href: '/health/water-intake-calculator/', desc: 'Daily water need from body weight, activity level and climate.', icon: '💧' },
  { name: 'Pregnancy Due Date', href: '/health/pregnancy-calculator/', desc: "Due date, current week and trimester from your last period (Naegele's rule).", icon: '🤰' },
  { name: 'Ovulation Calculator', href: '/health/ovulation-calculator/', desc: 'Your fertile window and estimated ovulation date from your cycle.', icon: '🌸' },
];

const upcomingCalcs = [
  { name: 'Macro Calculator', desc: 'Protein, carb and fat gram targets from your daily calorie goal.', icon: '🥗' },
];

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Health', url: '/health/' },
];

const faqs = [
  {
    q: 'Are Calctube health calculators medically accurate?',
    a: 'Our formulas are sourced from established medical references — WHO BMI ranges, Mifflin-St Jeor for BMR, US Navy for body fat. They produce reasonable estimates for healthy adults but are not a substitute for clinical assessment by a doctor.',
  },
  {
    q: 'Why does the BMI calculator give different categories for the same weight?',
    a: 'BMI categories depend on the population standards selected. We default to WHO global ranges (underweight <18.5, normal 18.5–24.9, overweight 25–29.9, obese 30+). Asian populations use stricter cutoffs (overweight 23+, obese 27.5+) per WHO Asia-Pacific guidance — toggle this on the BMI page.',
  },
  {
    q: 'Do you store any of my health data?',
    a: 'No. All calculations run entirely in your browser. We never see your height, weight, age, or any other input. There is no account or login.',
  },
];

const schemas = [
  buildBreadcrumbSchema(breadcrumbs),
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Health Calculators — Calctube',
    description: 'Free BMI, calorie, body fat, and pregnancy calculators with medical references.',
    url: 'https://calctube.com/health/',
    isPartOf: { '@id': 'https://calctube.com/#website' },
    mainEntity: {
      '@type': 'ItemList',
      itemListElement: liveCalcs.map((c, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        url: `https://calctube.com${c.href}`,
        name: c.name,
      })),
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
];
---

<BaseLayout
  title="Health Calculators — BMI, Calorie, Body Fat & Pregnancy"
  description="Free, accurate health calculators — BMI, calorie need, body fat percentage, TDEE, BMR, and pregnancy due date. Formulas from WHO and Mifflin-St Jeor. No signup."
  schemas={schemas}
>
  <div class="container-prose py-8">
    <Breadcrumbs items={breadcrumbs} />
    <h1>Health Calculators</h1>
    <p class="text-lg text-slate-700 mt-3">
      BMI, calorie need, body fat percentage, and pregnancy tools. Every formula cites its medical reference — WHO, Mifflin-St Jeor, US Navy method.
    </p>

    <h2 class="mt-10">Available now</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
      {liveCalcs.map((c) => (
        <a href={c.href} class="card hover:border-brand-300 no-underline block">
          <div class="text-3xl mb-2">{c.icon}</div>
          <div class="font-semibold text-slate-900">{c.name}</div>
          <p class="text-sm text-slate-600 mt-1 !leading-snug">{c.desc}</p>
        </a>
      ))}
    </div>

    <h2 class="mt-10">Coming soon</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
      {upcomingCalcs.map((c) => (
        <div class="card opacity-70">
          <div class="flex items-start gap-3">
            <div class="text-3xl">{c.icon}</div>
            <div class="flex-1">
              <div class="font-semibold text-slate-900 flex items-center gap-2">
                {c.name}
                <span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-amber-100 text-amber-800 uppercase">Soon</span>
              </div>
              <p class="text-sm text-slate-600 mt-1 !leading-snug">{c.desc}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <h2 class="mt-10">About Calctube health tools</h2>
    <p class="text-slate-700 leading-relaxed">
      Calctube's health calculators target the most-searched fitness and clinical estimators on the web — BMI, calorie need, BMR, body fat percentage, TDEE, and pregnancy due date. Every page shows the exact formula and the medical reference behind it. Calculations run in your browser; we never see or store your inputs.
    </p>
    <p class="text-slate-700 leading-relaxed mt-3">
      These tools are designed for healthy adults and produce reasonable estimates only. They are not a substitute for clinical assessment, prescription, or diagnosis by a qualified physician.
    </p>

    <h2 class="mt-10">Frequently asked questions</h2>
    <div class="space-y-3 mt-4">
      {faqs.map((f) => (
        <details class="card">
          <summary class="cursor-pointer font-semibold text-slate-900">{f.q}</summary>
          <p class="text-sm text-slate-700 mt-2 !leading-relaxed">{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</BaseLayout>
