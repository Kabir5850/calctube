---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PregnancyCalculator from '../../components/calculators/PregnancyCalculator.tsx';
import { buildCalculatorSchema, buildBreadcrumbSchema, buildFAQSchema, buildHowToSchema, buildSpeakableSchema } from '../../lib/seo';

const meta = {
  slug: 'pregnancy-calculator', name: 'Pregnancy Due Date Calculator',
  description: 'Free pregnancy due date calculator using your last menstrual period (LMP). Estimate your due date (Naegele\'s rule), current week, trimester and conception date, with a full week-by-week guide.',
  category: 'health' as const,
  keywords: ['pregnancy due date calculator', 'due date calculator', 'edd calculator', 'how many weeks pregnant', 'pregnancy calculator', 'conception date'],
  lastUpdated: '2026-07-18',
};
const path = '/health/pregnancy-calculator';
const breadcrumbs = [
  { name: 'Home', url: '/' }, { name: 'Health', url: '/health/' }, { name: 'Pregnancy Due Date', url: path },
];

// Build-time trimester / milestone reference (unique content).
const milestones = [
  { wk: 'Weeks 1–4', ev: 'Conception and implantation; first missed period' },
  { wk: 'Week 6', ev: 'Heartbeat often detectable on ultrasound' },
  { wk: 'Weeks 11–13', ev: 'End of first trimester; NT scan window' },
  { wk: 'Week 20', ev: 'Anatomy scan; halfway point' },
  { wk: 'Week 24', ev: 'Viability milestone' },
  { wk: 'Week 28', ev: 'Third trimester begins' },
  { wk: 'Week 37', ev: 'Considered full term from here' },
  { wk: 'Week 40', ev: 'Estimated due date (EDD)' },
];

const faqs = [
  { q: 'How is a due date calculated?', a: 'The standard method is Naegele\'s rule: add 280 days (40 weeks) to the first day of your last menstrual period (LMP). Equivalently, take the LMP date, subtract 3 months, and add 7 days. This assumes a regular 28-day cycle with ovulation around day 14. Only about 4% of babies arrive exactly on the due date. It\'s a best estimate of a roughly two-week window, not a deadline.' },
  { q: 'Why does the calculator start counting from my last period, not conception?', a: 'Pregnancy is dated from the first day of your last menstrual period because most people know that date, whereas the exact day of conception is usually uncertain. This is why you\'re considered "2 weeks pregnant" at conception. The count includes the roughly two weeks before you actually ovulated. Gestational age (LMP-based) is the standard used by doctors worldwide.' },
  { q: 'How does my cycle length affect the due date?', a: 'Naegele\'s rule assumes a 28-day cycle. If your cycles are longer, you ovulate later, so your due date shifts later; shorter cycles shift it earlier. This calculator adjusts by the difference between your cycle length and 28 days. For example, a 32-day cycle pushes the estimate about 4 days later. An early ultrasound (dating scan) refines this further.' },
  { q: 'How accurate is an LMP due date compared to an ultrasound?', a: 'An LMP-based date is a good starting estimate but relies on regular cycles and an accurately remembered date. A first-trimester ultrasound (roughly weeks 8–13) measures the baby directly and is more accurate, often by several days. If the ultrasound date differs significantly from the LMP date, providers usually adopt the ultrasound date.' },
  { q: 'What are the three trimesters?', a: 'The first trimester runs from week 1 to the end of week 13, the second from week 14 to the end of week 27, and the third from week 28 to birth (around week 40). "Full term" is from 37 weeks. Each trimester has its own screenings and milestones. The table on this page maps the main ones.' },
];
const schemas = [
  buildCalculatorSchema(meta, path),
  buildBreadcrumbSchema(breadcrumbs),
  buildFAQSchema(faqs),
  buildSpeakableSchema(path),
  buildHowToSchema({
    name: 'How to calculate your pregnancy due date',
    description: 'Estimate your due date, current week and trimester from your last menstrual period.',
    totalTime: 'PT1M',
    estimatedCost: { value: '0', currency: 'USD' },
    steps: [
      { name: 'Enter your LMP', text: 'Select the first day of your last menstrual period.' },
      { name: 'Set your cycle length', text: 'Adjust if your cycle isn\'t the standard 28 days.' },
      { name: 'Read your due date', text: 'The calculator adds 280 days and shows your week, trimester and days to go.' },
    ],
  }),
];
const relatedCalcs = [
  { name: 'Ovulation Calculator', href: '/health/ovulation-calculator/', desc: 'Fertile window & ovulation.', icon: '🌸', color: 'bg-pink-accent' },
  { name: 'BMI Calculator', href: '/health/bmi-calculator/', desc: 'Body mass index.', icon: '⚖️', color: 'bg-cyan-accent' },
  { name: 'Age Calculator', href: '/date-time/age-calculator/', desc: 'Exact age in y/m/d.', icon: '🎂', color: 'bg-lime-accent' },
  { name: 'Date Difference', href: '/date-time/date-difference-calculator/', desc: 'Days between dates.', icon: '📆', color: 'bg-yellow-accent' },
];
---

<BaseLayout title="Pregnancy Due Date Calculator: Weeks, Trimester & EDD" description={meta.description} schemas={schemas} publishedTime={meta.lastUpdated} modifiedTime={meta.lastUpdated}>
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-rose-300/40 rounded-full blur-[120px] float-slow"></div>
      <div class="absolute top-[5%] right-[-10%] w-[400px] h-[400px] bg-cyan-accent/25 rounded-full blur-[120px] float-slow-2"></div>
    </div>
    <div class="container-wide relative pt-8 pb-10 md:pt-12 md:pb-14">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-1.5 text-xs sm:text-sm">
          {breadcrumbs.map((item, idx) => (
            <li class="flex items-center gap-1.5">
              {idx === breadcrumbs.length - 1 ? (
                <span class="px-3 py-1 rounded-full bg-ink-900 text-white font-bold border-2 border-ink-900">{item.name}</span>
              ) : (
                <>
                  <a href={item.url} class="px-3 py-1 rounded-full bg-white border-2 border-ink-200 text-ink-700 font-semibold hover:border-ink-900 hover:text-ink-900 no-underline transition-colors">{item.name}</a>
                  <svg class="w-3 h-3 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </>
              )}
            </li>
          ))}
        </ol>
      </nav>
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="chip bg-rose-300 text-ink-900">🤰 Pregnancy</span>
          <span class="chip-white"><span class="text-ink-500">Updated</span><span>{meta.lastUpdated}</span></span>
        </div>
        <h1 class="!text-4xl sm:!text-5xl md:!text-6xl !font-extrabold !tracking-tight !leading-[1.05] text-ink-900" style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.035em;">
          Pregnancy Due Date <span class="text-gradient-brand">Calculator.</span>
        </h1>
        <div class="mt-7 bg-yellow-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker">
          <div class="flex items-start gap-3">
            <div class="text-2xl">⚡</div>
            <div>
              <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-1">Quick answer</div>
              <p class="speakable-answer text-ink-900 text-base sm:text-lg leading-relaxed font-medium !m-0">
                Your <strong>estimated due date</strong> is your last period plus <strong>280 days (40 weeks)</strong>, per Naegele's rule. Or: LMP minus 3 months plus 7 days. Enter your dates below to see your due date, current week and trimester. An <strong>ultrasound scan</strong> gives the most accurate dating.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wide pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto">
      <PregnancyCalculator client:load />
    </div>
  </section>

  <!-- MILESTONES -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-3xl mx-auto">
        <span class="chip bg-rose-300 text-ink-900 mb-4">📊 Week by week</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Key pregnancy milestones.</h2>
        <div class="mt-8 overflow-x-auto">
          <table class="w-full bg-white border-[2.5px] border-ink-900 rounded-2xl shadow-sticker-sm overflow-hidden border-separate border-spacing-0 text-sm">
            <thead><tr class="bg-ink-900 text-white">
              <th class="text-left p-3 font-extrabold">When</th>
              <th class="text-left p-3 font-extrabold">Milestone</th>
            </tr></thead>
            <tbody>
              {milestones.map((r, i) => (
                <tr class={`border-b-2 border-ink-100 ${i % 2 ? 'bg-ink-50' : ''}`}>
                  <td class="p-3 font-extrabold text-ink-900 whitespace-nowrap">{r.wk}</td>
                  <td class="p-3 font-semibold text-ink-700">{r.ev}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-3xl mx-auto">
      <span class="chip-yellow mb-4">❓ FAQ</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Common questions.</h2>
      <div class="space-y-3 mt-8">
        {faqs.map((faq, idx) => (
          <details class="group bg-white border-2 border-ink-900 rounded-2xl shadow-sticker-sm hover:shadow-sticker transition-all" open={idx === 0}>
            <summary class="cursor-pointer p-5 md:p-6 font-extrabold text-ink-900 flex items-center justify-between gap-4 list-none">
              <span class="text-base md:text-lg" style="font-family: 'Inter Tight', sans-serif;">{faq.q}</span>
              <span class="flex-shrink-0 w-9 h-9 rounded-full bg-ink-900 group-open:bg-lime-accent flex items-center justify-center transition-colors">
                <svg class="w-4 h-4 text-white group-open:text-ink-900 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </span>
            </summary>
            <div class="px-5 md:px-6 pb-5 md:pb-6 text-ink-700 leading-relaxed font-medium">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <span class="chip bg-rose-300 text-ink-900 mb-4">🔗 Related</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Try these next.</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-8">
          {relatedCalcs.map((c) => (
            <a href={c.href} class={`group ${c.color} border-[2.5px] border-ink-900 rounded-3xl p-5 no-underline shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200`}>
              <div class="text-3xl mb-3 group-hover:rotate-12 transition-transform inline-block">{c.icon}</div>
              <div class="font-extrabold text-ink-900 text-base leading-tight" style="font-family: 'Inter Tight', sans-serif;">{c.name}</div>
              <p class="text-xs text-ink-800 mt-1.5 leading-snug font-medium">{c.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
