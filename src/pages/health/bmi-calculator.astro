---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BmiCalculator from '../../components/calculators/BmiCalculator.tsx';
import AuthorBadge from '../../components/ui/AuthorBadge.astro';
import { buildCalculatorSchema, buildBreadcrumbSchema, buildFAQSchema } from '../../lib/seo';
import { getAuthor } from '../../data/authors';

const meta = {
  slug: 'bmi-calculator', name: 'BMI Calculator',
  description: 'Free BMI calculator with metric and imperial units. See your Body Mass Index, category, and where you fall on the WHO health scale.',
  category: 'health' as const,
  keywords: ['bmi calculator', 'body mass index', 'weight calculator', 'health'],
  lastUpdated: '2026-05-13', ratingValue: '4.8', ratingCount: '189',
};
const path = '/health/bmi-calculator';
const breadcrumbs = [
  { name: 'Home', url: '/' }, { name: 'Health', url: '/health/' }, { name: 'BMI Calculator', url: path },
];
const faqs = [
  { q: 'What is BMI?', a: 'BMI (Body Mass Index) is a number calculated from your weight and height. It is used as a quick screening tool to categorize weight status. The formula is: BMI = weight (kg) ÷ height² (m).' },
  { q: 'What are the BMI categories (WHO)?', a: 'Below 18.5 = Underweight. 18.5–24.9 = Normal/healthy. 25.0–29.9 = Overweight. 30.0 and above = Obese (with three sub-classes). These are WHO standard ranges for adults.' },
  { q: 'Is BMI accurate for everyone?', a: "BMI is a screening tool, not a diagnosis. It doesn't distinguish muscle from fat. Athletes and bodybuilders often have BMI in the 'overweight' range despite low body fat. Pregnant women, children, and the elderly need different metrics." },
  { q: 'Should I use BMI or body fat percentage?', a: 'For everyday use, BMI is fine — it correlates with health outcomes at a population level. For more precision, combine BMI with waist-to-hip ratio or body-fat % measurement.' },
  { q: 'What is a healthy BMI?', a: 'Generally 18.5 to 24.9 for adults. However, for South and East Asian populations, the WHO suggests 18.5 to 22.9 due to differences in body composition and disease risk.' },
];
const schemas = [buildCalculatorSchema(meta, path), buildBreadcrumbSchema(breadcrumbs), buildFAQSchema(faqs)];
const reviewer = getAuthor('priya-nair')!;
const relatedCalcs = [
  { name: 'TDEE & BMR', href: '/health/tdee-calculator/', desc: 'Your daily calorie burn.', icon: '🔥', color: 'bg-pink-accent text-white' },
  { name: 'BMR Calculator', href: '/health/bmr-calculator/', desc: 'Your basal metabolic rate.', icon: '💪', color: 'bg-lime-accent' },
  { name: 'Calorie Need', href: '/health/calorie-calculator/', desc: 'Calories for your goal.', icon: '🍎', color: 'bg-cyan-accent' },
  { name: 'TDEE Calculator', href: '/health/tdee-calculator/', desc: 'Total daily energy burned.', icon: '🔥', color: 'bg-yellow-accent' },
];
---

<BaseLayout title="BMI Calculator — Body Mass Index, Metric & Imperial" description={meta.description} schemas={schemas} publishedTime={meta.lastUpdated} modifiedTime={meta.lastUpdated}>
  <!-- HERO -->
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-rose-300/40 rounded-full blur-[120px] float-slow"></div>
      <div class="absolute top-[5%] right-[-10%] w-[400px] h-[400px] bg-lime-accent/25 rounded-full blur-[120px] float-slow-2"></div>
    </div>
    <div class="container-wide relative pt-8 pb-10 md:pt-12 md:pb-14">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-1.5 text-xs sm:text-sm">
          {breadcrumbs.map((item, idx) => (
            <li class="flex items-center gap-1.5">
              {idx === breadcrumbs.length - 1 ? (
                <span class="px-3 py-1 rounded-full bg-ink-900 text-white font-bold border-2 border-ink-900">{item.name}</span>
              ) : (
                <>
                  <a href={item.url} class="px-3 py-1 rounded-full bg-white border-2 border-ink-200 text-ink-700 font-semibold hover:border-ink-900 hover:text-ink-900 no-underline transition-colors">{item.name}</a>
                  <svg class="w-3 h-3 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </>
              )}
            </li>
          ))}
        </ol>
      </nav>
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="chip bg-rose-300 text-ink-900">❤️ Health</span>
          <span class="chip-white"><span class="text-ink-500">Last tested</span><span>{meta.lastUpdated}</span></span>
        </div>
        <h1 class="!text-4xl sm:!text-5xl md:!text-6xl !font-extrabold !tracking-tight !leading-[1.05] text-ink-900" style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.035em;">
          BMI Calculator <span class="text-gradient-brand">in 2 seconds.</span>
        </h1>
        <div class="mt-7 bg-lime-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker">
          <div class="flex items-start gap-3">
            <div class="text-2xl">⚡</div>
            <div>
              <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-1">Quick answer</div>
              <p class="text-ink-900 text-base sm:text-lg leading-relaxed font-medium !m-0">
                A <strong>170 cm tall person weighing 70 kg</strong> has a BMI of <strong>24.2</strong> — in the healthy range (18.5–24.9). Enter your numbers below to see where you fall.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CALCULATOR -->
  <section class="container-wide pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto">
      <BmiCalculator client:visible />
      {reviewer && <div class="mt-4"><AuthorBadge author={reviewer} verb="Reviewed" /></div>}
    </div>
  </section>

  <!-- HOW TO USE -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <span class="chip-cyan mb-4">📖 How to use</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">3 steps. 5 seconds.</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 md:gap-5 mt-8">
          {[
            { num: '1', text: 'Pick metric or imperial units (top-right toggle)', color: 'bg-cyan-accent' },
            { num: '2', text: 'Enter your height and weight', color: 'bg-lime-accent' },
            { num: '3', text: 'See your BMI, category, and position on the WHO health scale', color: 'bg-yellow-accent' },
          ].map((step) => (
            <div class={`${step.color} border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker-sm`}>
              <div class="text-3xl font-extrabold mb-3 leading-none" style="font-family: 'Inter Tight', sans-serif;">{step.num}</div>
              <p class="text-sm font-semibold leading-snug !m-0 !text-current">{step.text}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- THE MATH -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-4xl mx-auto">
      <span class="chip-pink mb-4">🧮 The math</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">It's just a ratio.</h2>
      <div class="mt-8 bg-ink-900 text-white border-[2.5px] border-ink-900 rounded-3xl p-6 md:p-8 shadow-sticker">
        <div class="text-xs font-extrabold uppercase tracking-wider text-lime-accent mb-3">The formula</div>
        <div class="font-mono text-xl md:text-2xl font-bold">
          <span class="text-pink-accent">BMI</span> = <span class="text-cyan-accent">weight (kg)</span> ÷ <span class="text-lime-accent">height² (m)</span>
        </div>
        <p class="mt-6 text-sm text-ink-300">
          Imperial version: BMI = (weight in lbs × 703) ÷ height² (in inches).
          Both give identical results — units cancel out.
        </p>
      </div>
      <p class="text-xs text-ink-500 mt-6 font-medium">Sources: <a href="https://www.who.int/news-room/fact-sheets/detail/obesity-and-overweight" rel="noopener noreferrer" target="_blank" class="underline hover:text-ink-700">WHO Obesity and Overweight Fact Sheet</a> · <a href="https://www.nhlbi.nih.gov/health/educational/lose_wt/BMI/bmicalc.htm" rel="noopener noreferrer" target="_blank" class="underline hover:text-ink-700">NIH BMI Calculator</a></p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-3xl mx-auto">
        <span class="chip-yellow mb-4">❓ FAQ</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Common questions.</h2>
        <div class="space-y-3 mt-8">
          {faqs.map((faq, idx) => (
            <details class="group bg-white border-2 border-ink-900 rounded-2xl shadow-sticker-sm hover:shadow-sticker transition-all" open={idx === 0}>
              <summary class="cursor-pointer p-5 md:p-6 font-extrabold text-ink-900 flex items-center justify-between gap-4 list-none">
                <span class="text-base md:text-lg" style="font-family: 'Inter Tight', sans-serif;">{faq.q}</span>
                <span class="flex-shrink-0 w-9 h-9 rounded-full bg-ink-900 group-open:bg-lime-accent flex items-center justify-center transition-colors">
                  <svg class="w-4 h-4 text-white group-open:text-ink-900 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </span>
              </summary>
              <div class="px-5 md:px-6 pb-5 md:pb-6 text-ink-700 leading-relaxed font-medium">{faq.a}</div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- RELATED -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-4xl mx-auto">
      <span class="chip bg-violet-300 text-ink-900 mb-4">🔗 Related</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Try these next.</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-8">
        {relatedCalcs.map((c) => (
          <a href={c.href} class={`group ${c.color} border-[2.5px] border-ink-900 rounded-3xl p-5 no-underline shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200`}>
            <div class="text-3xl mb-3 group-hover:rotate-12 transition-transform inline-block">{c.icon}</div>
            <div class="font-extrabold text-ink-900 text-base leading-tight" style="font-family: 'Inter Tight', sans-serif;">{c.name}</div>
            <p class="text-xs text-ink-800 mt-1.5 leading-snug font-medium">{c.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
