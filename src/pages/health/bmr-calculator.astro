---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BmrCalculator from '../../components/calculators/BmrCalculator.tsx';
import AuthorBadge from '../../components/ui/AuthorBadge.astro';
import { buildCalculatorSchema, buildBreadcrumbSchema, buildFAQSchema } from '../../lib/seo';
import { getAuthor } from '../../data/authors';

const meta = {
  slug: 'bmr-calculator',
  name: 'BMR Calculator',
  description: 'Free BMR calculator using the Mifflin-St Jeor equation. Find your Basal Metabolic Rate in kcal/day for men and women, in metric and imperial units.',
  category: 'health' as const,
  keywords: ['bmr calculator', 'basal metabolic rate', 'calories at rest', 'mifflin st jeor', 'metabolism calculator'],
  lastUpdated: '2026-05-25',
  ratingValue: '4.8',
  ratingCount: '214',
};
const path = '/health/bmr-calculator';
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Health', url: '/health/' },
  { name: 'BMR Calculator', url: path },
];
const faqs = [
  {
    q: 'What is BMR?',
    a: 'Basal Metabolic Rate (BMR) is the number of calories your body burns at complete rest, the minimum energy needed to keep your heart beating, lungs breathing, and organs functioning. It excludes any activity, digestion, or movement.',
  },
  {
    q: 'Which formula does this BMR calculator use?',
    a: 'This calculator uses the Mifflin-St Jeor Equation (1990), the most accurate formula for most adults according to the American Dietetic Association. Men: BMR = (10 × kg) + (6.25 × cm) − (5 × age) + 5. Women: BMR = (10 × kg) + (6.25 × cm) − (5 × age) − 161.',
  },
  {
    q: 'What is a normal BMR for a woman?',
    a: 'For a 30-year-old woman at 165 cm and 65 kg, BMR is about 1,430 kcal/day. Most adult women range between 1,200 and 1,700 kcal/day depending on body size and age. BMR decreases roughly 1–2% per decade after age 20.',
  },
  {
    q: 'How is BMR different from TDEE?',
    a: 'BMR is your calorie burn at absolute rest. TDEE (Total Daily Energy Expenditure) multiplies BMR by an activity factor. Sedentary people multiply by 1.2, very active people by 1.725. Your actual daily calorie need is your TDEE, not your BMR.',
  },
  {
    q: 'Can I eat fewer calories than my BMR?',
    a: 'Consistently eating below BMR is not recommended. It can cause muscle loss, nutrient deficiencies, and metabolic adaptation. BMR is the floor, a hard minimum just to sustain organ function. Most dietitians recommend staying above 1,200 kcal/day for women and 1,500 kcal/day for men.',
  },
];
const schemas = [buildCalculatorSchema(meta, path), buildBreadcrumbSchema(breadcrumbs), buildFAQSchema(faqs)];
const relatedCalcs = [
  { name: 'TDEE Calculator', href: '/health/tdee-calculator/', desc: 'Total daily calories with activity.', icon: '⚡', color: 'bg-lime-accent' },
  { name: 'Calorie Calculator', href: '/health/calorie-calculator/', desc: 'Calories for your weight goal.', icon: '🍎', color: 'bg-cyan-accent' },
  { name: 'BMI Calculator', href: '/health/bmi-calculator/', desc: 'Body Mass Index & category.', icon: '⚖️', color: 'bg-yellow-accent' },
  { name: 'Age Calculator', href: '/date-time/age-calculator/', desc: 'Exact age instantly.', icon: '🎂', color: 'bg-pink-accent text-white' },
];

const reviewer = getAuthor('priya-nair')!;
---

<BaseLayout
  title="BMR Calculator: Basal Metabolic Rate (Mifflin-St Jeor)"
  description={meta.description}
  schemas={schemas}
  publishedTime={meta.lastUpdated}
  modifiedTime={meta.lastUpdated}
>
  <!-- HERO -->
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-lime-accent/30 rounded-full blur-[120px] float-slow"></div>
      <div class="absolute top-[5%] right-[-10%] w-[400px] h-[400px] bg-cyan-accent/20 rounded-full blur-[120px] float-slow-2"></div>
    </div>
    <div class="container-wide relative pt-8 pb-10 md:pt-12 md:pb-14">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-1.5 text-xs sm:text-sm">
          {breadcrumbs.map((item, idx) => (
            <li class="flex items-center gap-1.5">
              {idx === breadcrumbs.length - 1 ? (
                <span class="px-3 py-1 rounded-full bg-ink-900 text-white font-bold border-2 border-ink-900">{item.name}</span>
              ) : (
                <>
                  <a href={item.url} class="px-3 py-1 rounded-full bg-white border-2 border-ink-200 text-ink-700 font-semibold hover:border-ink-900 hover:text-ink-900 no-underline transition-colors">{item.name}</a>
                  <svg class="w-3 h-3 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </>
              )}
            </li>
          ))}
        </ol>
      </nav>
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="chip bg-lime-accent text-ink-900">🔥 Health</span>
          <span class="chip-white"><span class="text-ink-500">Last tested</span><span>{meta.lastUpdated}</span></span>
        </div>
        <h1 class="!text-4xl sm:!text-5xl md:!text-6xl !font-extrabold !tracking-tight !leading-[1.05] text-ink-900" style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.035em;">
          BMR Calculator <span class="text-gradient-brand">in seconds.</span>
        </h1>
        <div class="mt-7 bg-lime-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker">
          <div class="flex items-start gap-3">
            <div class="text-2xl">⚡</div>
            <div>
              <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-1">Quick answer</div>
              <p class="text-ink-900 text-base sm:text-lg leading-relaxed font-medium !m-0">
                A <strong>30-year-old woman, 165 cm, 65 kg</strong> has a BMR of about <strong>1,430 kcal/day</strong>, meaning her body burns that many calories just to keep organs functioning at rest.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CALCULATOR -->
  <section class="container-wide pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto">
      <BmrCalculator client:visible />
      {reviewer && <div class="mt-4"><AuthorBadge author={reviewer} verb="Reviewed" /></div>}
    </div>
  </section>

  <!-- HOW TO USE -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <span class="chip-cyan mb-4">📖 How to use</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">3 inputs. Instant result.</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 md:gap-5 mt-8">
          {[
            { num: '1', text: 'Select your biological sex and choose metric or imperial units', color: 'bg-cyan-accent' },
            { num: '2', text: 'Enter your age, height, and current weight using the fields or sliders', color: 'bg-lime-accent' },
            { num: '3', text: 'See your BMR instantly, plus a breakdown of daily calorie needs by activity level', color: 'bg-yellow-accent' },
          ].map((step) => (
            <div class={`${step.color} border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker-sm`}>
              <div class="text-3xl font-extrabold mb-3 leading-none" style="font-family: 'Inter Tight', sans-serif;">{step.num}</div>
              <p class="text-sm font-semibold leading-snug !m-0 !text-current">{step.text}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- THE MATH -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-4xl mx-auto">
      <span class="chip-pink mb-4">🧮 The formula</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Mifflin-St Jeor Equation.</h2>
      <div class="mt-8 bg-ink-900 text-white border-[2.5px] border-ink-900 rounded-3xl p-6 md:p-8 shadow-sticker">
        <div class="text-xs font-extrabold uppercase tracking-wider text-lime-accent mb-4">For Men</div>
        <div class="font-mono text-base md:text-lg font-bold mb-6">
          <span class="text-pink-accent">BMR</span> = (10 × <span class="text-cyan-accent">kg</span>) + (6.25 × <span class="text-lime-accent">cm</span>) − (5 × <span class="text-yellow-accent">age</span>) + 5
        </div>
        <div class="text-xs font-extrabold uppercase tracking-wider text-lime-accent mb-4">For Women</div>
        <div class="font-mono text-base md:text-lg font-bold mb-6">
          <span class="text-pink-accent">BMR</span> = (10 × <span class="text-cyan-accent">kg</span>) + (6.25 × <span class="text-lime-accent">cm</span>) − (5 × <span class="text-yellow-accent">age</span>) − 161
        </div>
        <p class="mt-4 text-sm text-ink-300">
          Imperial inputs are automatically converted: 1 lb = 0.453592 kg · 1 inch = 2.54 cm. Results are identical regardless of unit system.
        </p>
      </div>
      <div class="mt-8 prose prose-lg max-w-none">
        <p>
          Your <strong>Basal Metabolic Rate</strong> is the number of calories your body burns at complete rest: no movement, no digestion, no activity. It represents 60–75% of total daily calorie expenditure for most sedentary people. The Mifflin-St Jeor equation is the most widely validated formula for estimating BMR in healthy adults.
        </p>
        <p>
          BMR declines naturally with age (roughly 1–2% per decade after 20), mainly due to loss of muscle mass. Increasing lean muscle through resistance training is one of the most effective ways to counteract this decline and keep metabolic rate higher.
        </p>
        <p>
          Use the activity multiplier table in the calculator above to find your TDEE, the actual calories you need each day accounting for your lifestyle. Sedentary office workers typically land at 1.2–1.375× BMR, while athletes can reach 1.7–1.9×.
        </p>
        <p class="text-xs text-ink-500 mt-6 font-medium">Sources: <a href="https://pubmed.ncbi.nlm.nih.gov/2305711/" rel="noopener noreferrer" target="_blank" class="underline hover:text-ink-700">Mifflin MD et al. (1990), Am J Clin Nutr</a> · <a href="https://www.ncbi.nlm.nih.gov/books/NBK278991/" rel="noopener noreferrer" target="_blank" class="underline hover:text-ink-700">Institute of Medicine Dietary Reference Intakes</a></p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-3xl mx-auto">
        <span class="chip-yellow mb-4">❓ FAQ</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Common questions.</h2>
        <div class="space-y-3 mt-8">
          {faqs.map((faq, idx) => (
            <details class="group bg-white border-2 border-ink-900 rounded-2xl shadow-sticker-sm hover:shadow-sticker transition-all" open={idx === 0}>
              <summary class="cursor-pointer p-5 md:p-6 font-extrabold text-ink-900 flex items-center justify-between gap-4 list-none">
                <span class="text-base md:text-lg" style="font-family: 'Inter Tight', sans-serif;">{faq.q}</span>
                <span class="flex-shrink-0 w-9 h-9 rounded-full bg-ink-900 group-open:bg-lime-accent flex items-center justify-center transition-colors">
                  <svg class="w-4 h-4 text-white group-open:text-ink-900 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </span>
              </summary>
              <div class="px-5 md:px-6 pb-5 md:pb-6 text-ink-700 leading-relaxed font-medium">{faq.a}</div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- RELATED -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-4xl mx-auto">
      <span class="chip bg-violet-300 text-ink-900 mb-4">🔗 Related</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Try these next.</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-8">
        {relatedCalcs.map((c) => (
          <a href={c.href} class={`group ${c.color} border-[2.5px] border-ink-900 rounded-3xl p-5 no-underline shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200`}>
            <div class="text-3xl mb-3 group-hover:rotate-12 transition-transform inline-block">{c.icon}</div>
            <div class="font-extrabold text-ink-900 text-base leading-tight" style="font-family: 'Inter Tight', sans-serif;">{c.name}</div>
            <p class="text-xs text-ink-800 mt-1.5 leading-snug font-medium">{c.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
