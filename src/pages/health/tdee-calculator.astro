---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TdeeCalculator from '../../components/calculators/TdeeCalculator.tsx';
import AuthorBadge from '../../components/ui/AuthorBadge.astro';
import { buildCalculatorSchema, buildBreadcrumbSchema, buildFAQSchema } from '../../lib/seo';
import { getAuthor } from '../../data/authors';

const meta = {
  slug: 'tdee-calculator',
  name: 'TDEE Calculator',
  description: 'Free TDEE calculator: Total Daily Energy Expenditure with activity level, goal calories, and macro breakdown. Metric and imperial. Updated 2026.',
  category: 'health' as const,
  keywords: ['tdee calculator', 'total daily energy expenditure', 'maintenance calories', 'calorie needs', 'macro calculator'],
  lastUpdated: '2026-05-25',
  ratingValue: '4.9',
  ratingCount: '342',
};
const path = '/health/tdee-calculator';
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Health', url: '/health/' },
  { name: 'TDEE Calculator', url: path },
];
const faqs = [
  {
    q: 'What is TDEE?',
    a: 'TDEE stands for Total Daily Energy Expenditure, the total number of calories you burn in a day, including physical activity, digestion (thermic effect of food), and resting metabolism (BMR). It is the single most important number for managing weight.',
  },
  {
    q: 'How is TDEE calculated?',
    a: 'TDEE = BMR × Activity Multiplier. BMR is calculated via the Mifflin-St Jeor equation. Then you multiply by your activity level: Sedentary ×1.2, Lightly Active ×1.375, Moderately Active ×1.55, Very Active ×1.725, Extra Active ×1.9.',
  },
  {
    q: 'What is the TDEE for a moderately active man?',
    a: 'A moderately active 28-year-old man (180 cm, 80 kg) has a TDEE of about 2,635 kcal/day. To lose 0.5 kg/week, he would aim for roughly 2,135 kcal/day (a 500 kcal/day deficit).',
  },
  {
    q: 'How many calories should I eat to lose weight?',
    a: 'A common and safe approach is to eat 500 kcal below your TDEE per day, which creates a weekly deficit of 3,500 kcal, roughly 0.45 kg (1 lb) of fat loss per week. This calculator automatically calculates this for you when you select the "Lose Weight" goal.',
  },
  {
    q: 'How accurate is TDEE estimation?',
    a: 'TDEE formulas have a margin of error of roughly ±10–15%. Real-world factors like NEAT (non-exercise activity thermogenesis), sleep quality, hormones, and gut microbiome all influence actual expenditure. Use the result as a starting point and adjust calories by ±100–200 kcal based on weekly weight trends.',
  },
];
const schemas = [buildCalculatorSchema(meta, path), buildBreadcrumbSchema(breadcrumbs), buildFAQSchema(faqs)];
const relatedCalcs = [
  { name: 'BMR Calculator', href: '/health/bmr-calculator/', desc: 'Calories burned at rest.', icon: '🔥', color: 'bg-lime-accent' },
  { name: 'Calorie Calculator', href: '/health/calorie-calculator/', desc: 'Deficit & weeks to goal.', icon: '🍎', color: 'bg-pink-accent text-white' },
  { name: 'BMI Calculator', href: '/health/bmi-calculator/', desc: 'Body Mass Index & category.', icon: '⚖️', color: 'bg-cyan-accent' },
  { name: 'Age Calculator', href: '/date-time/age-calculator/', desc: 'Calculate your exact age.', icon: '🎂', color: 'bg-yellow-accent' },
];

const reviewer = getAuthor('priya-nair')!;
---

<BaseLayout
  title="TDEE Calculator: Total Daily Energy Expenditure + Macros"
  description={meta.description}
  schemas={schemas}
  publishedTime={meta.lastUpdated}
  modifiedTime={meta.lastUpdated}
>
  <!-- HERO -->
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-pink-accent/20 rounded-full blur-[120px] float-slow"></div>
      <div class="absolute top-[5%] right-[-10%] w-[400px] h-[400px] bg-lime-accent/25 rounded-full blur-[120px] float-slow-2"></div>
    </div>
    <div class="container-wide relative pt-8 pb-10 md:pt-12 md:pb-14">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-1.5 text-xs sm:text-sm">
          {breadcrumbs.map((item, idx) => (
            <li class="flex items-center gap-1.5">
              {idx === breadcrumbs.length - 1 ? (
                <span class="px-3 py-1 rounded-full bg-ink-900 text-white font-bold border-2 border-ink-900">{item.name}</span>
              ) : (
                <>
                  <a href={item.url} class="px-3 py-1 rounded-full bg-white border-2 border-ink-200 text-ink-700 font-semibold hover:border-ink-900 hover:text-ink-900 no-underline transition-colors">{item.name}</a>
                  <svg class="w-3 h-3 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </>
              )}
            </li>
          ))}
        </ol>
      </nav>
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="chip bg-pink-accent text-white">⚡ Health</span>
          <span class="chip-white"><span class="text-ink-500">Last tested</span><span>{meta.lastUpdated}</span></span>
        </div>
        <h1 class="!text-4xl sm:!text-5xl md:!text-6xl !font-extrabold !tracking-tight !leading-[1.05] text-ink-900" style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.035em;">
          TDEE Calculator <span class="text-gradient-brand">+ Macros.</span>
        </h1>
        <div class="mt-7 bg-lime-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker">
          <div class="flex items-start gap-3">
            <div class="text-2xl">⚡</div>
            <div>
              <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-1">Quick answer</div>
              <p class="text-ink-900 text-base sm:text-lg leading-relaxed font-medium !m-0">
                A <strong>moderately active 28-year-old man (180 cm, 80 kg)</strong> has a TDEE of about <strong>2,635 kcal/day</strong>. To lose 0.5 kg/week, aim for <strong>~2,135 kcal</strong>.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CALCULATOR -->
  <section class="container-wide pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto">
      <TdeeCalculator client:visible />
      {reviewer && <div class="mt-4"><AuthorBadge author={reviewer} verb="Reviewed" /></div>}
    </div>
  </section>

  <!-- HOW TO USE -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <span class="chip-cyan mb-4">📖 How to use</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">4 steps. Instant answer.</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-5 mt-8">
          {[
            { num: '1', text: 'Enter sex, age, height, and weight', color: 'bg-cyan-accent' },
            { num: '2', text: 'Select your activity level honestly', color: 'bg-lime-accent' },
            { num: '3', text: 'Choose your goal: lose, maintain, or gain', color: 'bg-yellow-accent' },
            { num: '4', text: 'See TDEE, goal calories, and estimated macros', color: 'bg-pink-accent' },
          ].map((step) => (
            <div class={`${step.color} border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker-sm`}>
              <div class="text-3xl font-extrabold mb-3 leading-none" style="font-family: 'Inter Tight', sans-serif;">{step.num}</div>
              <p class="text-sm font-semibold leading-snug !m-0 !text-current">{step.text}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- THE MATH -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-4xl mx-auto">
      <span class="chip-pink mb-4">🧮 The formula</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">BMR × Activity = TDEE.</h2>
      <div class="mt-8 bg-ink-900 text-white border-[2.5px] border-ink-900 rounded-3xl p-6 md:p-8 shadow-sticker">
        <div class="text-xs font-extrabold uppercase tracking-wider text-lime-accent mb-3">Step 1: Calculate BMR (Mifflin-St Jeor)</div>
        <div class="font-mono text-sm md:text-base font-bold mb-6">
          Men: <span class="text-pink-accent">BMR</span> = (10 × kg) + (6.25 × cm) − (5 × age) + 5<br />
          Women: <span class="text-pink-accent">BMR</span> = (10 × kg) + (6.25 × cm) − (5 × age) − 161
        </div>
        <div class="text-xs font-extrabold uppercase tracking-wider text-lime-accent mb-3">Step 2: Multiply by Activity Factor</div>
        <div class="font-mono text-sm md:text-base font-bold">
          <span class="text-cyan-accent">TDEE</span> = <span class="text-pink-accent">BMR</span> × <span class="text-yellow-accent">Activity Multiplier</span>
        </div>
        <p class="mt-6 text-sm text-ink-300">
          Activity multipliers: Sedentary ×1.2 · Lightly Active ×1.375 · Moderately Active ×1.55 · Very Active ×1.725 · Extra Active ×1.9
        </p>
      </div>
      <div class="mt-8 prose prose-lg max-w-none">
        <p>
          <strong>TDEE</strong> is the most practical calorie number for everyday use. Unlike BMR (which assumes you never move), TDEE accounts for all the energy you expend over a full day: walking, exercise, fidgeting, and digesting food.
        </p>
        <p>
          For weight management, the key relationship is simple: eat below TDEE to lose weight, match TDEE to maintain, eat above TDEE to gain. A deficit of 500 kcal/day produces roughly 0.45 kg (1 lb) of fat loss per week, a widely accepted, safe rate for most adults.
        </p>
        <p>
          The macro split shown (30% protein, 25% fat, 45% carbs) is a common performance-oriented ratio. Adjust fat and carbs to personal preference. Protein is the most important lever for satiety and muscle retention during a deficit.
        </p>
        <p class="text-xs text-ink-500 mt-6 font-medium">Sources: <a href="https://www.nap.edu/read/10490/chapter/1" rel="noopener noreferrer" target="_blank" class="underline hover:text-ink-700">IOM Dietary Reference Intakes for Energy (2002)</a> · <a href="https://pubmed.ncbi.nlm.nih.gov/12082089/" rel="noopener noreferrer" target="_blank" class="underline hover:text-ink-700">Institute of Medicine Physical Activity Multipliers</a></p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-3xl mx-auto">
        <span class="chip-yellow mb-4">❓ FAQ</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Common questions.</h2>
        <div class="space-y-3 mt-8">
          {faqs.map((faq, idx) => (
            <details class="group bg-white border-2 border-ink-900 rounded-2xl shadow-sticker-sm hover:shadow-sticker transition-all" open={idx === 0}>
              <summary class="cursor-pointer p-5 md:p-6 font-extrabold text-ink-900 flex items-center justify-between gap-4 list-none">
                <span class="text-base md:text-lg" style="font-family: 'Inter Tight', sans-serif;">{faq.q}</span>
                <span class="flex-shrink-0 w-9 h-9 rounded-full bg-ink-900 group-open:bg-lime-accent flex items-center justify-center transition-colors">
                  <svg class="w-4 h-4 text-white group-open:text-ink-900 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </span>
              </summary>
              <div class="px-5 md:px-6 pb-5 md:pb-6 text-ink-700 leading-relaxed font-medium">{faq.a}</div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- RELATED -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-4xl mx-auto">
      <span class="chip bg-violet-300 text-ink-900 mb-4">🔗 Related</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Try these next.</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-8">
        {relatedCalcs.map((c) => (
          <a href={c.href} class={`group ${c.color} border-[2.5px] border-ink-900 rounded-3xl p-5 no-underline shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200`}>
            <div class="text-3xl mb-3 group-hover:rotate-12 transition-transform inline-block">{c.icon}</div>
            <div class="font-extrabold text-ink-900 text-base leading-tight" style="font-family: 'Inter Tight', sans-serif;">{c.name}</div>
            <p class="text-xs text-ink-800 mt-1.5 leading-snug font-medium">{c.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
