---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AuthorBadge from '../../components/ui/AuthorBadge.astro';
import IdealWeightCalculator from '../../components/calculators/IdealWeightCalculator.tsx';
import { buildCalculatorSchema, buildBreadcrumbSchema, buildFAQSchema, buildHowToSchema, buildSpeakableSchema } from '../../lib/seo';
import { getAuthor } from '../../data/authors';

const meta = {
  slug: 'ideal-weight-calculator', name: 'Ideal Weight Calculator',
  description: 'Free ideal body weight calculator using the Devine, Robinson, Miller and Hamwi formulas plus the healthy BMI weight range for your height, for men and women.',
  category: 'health' as const,
  keywords: ['ideal weight calculator', 'ideal body weight', 'healthy weight for height', 'devine formula', 'ideal weight for height'],
  lastUpdated: '2026-07-18',
};
const path = '/health/ideal-weight-calculator';
const reviewer = getAuthor('priya-nair')!;
const breadcrumbs = [
  { name: 'Home', url: '/' }, { name: 'Health', url: '/health/' }, { name: 'Ideal Weight Calculator', url: path },
];

// Build-time healthy BMI weight-range table by height (18.5–24.9).
const heights = [150, 155, 160, 165, 170, 175, 180, 185, 190];
const table = heights.map((cm) => {
  const m = cm / 100;
  return { cm, low: (18.5 * m * m).toFixed(0), high: (24.9 * m * m).toFixed(0) };
});

const faqs = [
  { q: 'What is "ideal body weight" and how is it calculated?', a: 'Ideal body weight (IBW) is an estimate of a healthy weight based only on your height and sex, originally created to help doctors dose medication. The best-known is the Devine formula: men 50 kg + 2.3 kg for each inch over 5 feet; women 45.5 kg + 2.3 kg per inch over 5 feet. The Robinson, Miller and Hamwi formulas tweak the constants. This calculator shows all four plus the healthy BMI range so you can compare.' },
  { q: 'Which formula should I use?', a: 'No single formula is "correct". They were derived from different populations and give slightly different numbers. For a practical target, the healthy BMI range (a BMI of 18.5–24.9 for your height) is more widely used today because it gives a range rather than a single number, allowing for natural variation. Treat the formula figures as reference points within that range.' },
  { q: 'Why do the formulas ignore my body frame and muscle?', a: 'They were built as simple height-based estimates, so they can\'t account for a larger frame, higher muscle mass, or age. A muscular athlete may weigh well above their "ideal" figure yet have low body fat. That\'s why IBW is a starting point, not a verdict. Pair it with body fat percentage and how you feel and perform.' },
  { q: 'Is ideal weight different for men and women?', a: 'Yes. Every formula uses a lower base weight for women, reflecting average differences in build and muscle mass. For the same height, a woman\'s ideal-weight figure comes out a few kilograms lower than a man\'s. This calculator switches the constants automatically when you pick your sex.' },
  { q: 'How do I find my healthy weight range from BMI?', a: 'Multiply the BMI limits by your height in metres squared. For a healthy BMI of 18.5–24.9 at 170 cm (1.7 m): low = 18.5 × 1.7² = 53.5 kg, high = 24.9 × 1.7² = 72 kg. The table on this page lists the range for common heights so you can look yours up directly.' },
];
const schemas = [
  buildCalculatorSchema(meta, path),
  buildBreadcrumbSchema(breadcrumbs),
  buildFAQSchema(faqs),
  buildSpeakableSchema(path),
  buildHowToSchema({
    name: 'How to calculate your ideal weight',
    description: 'Estimate ideal body weight from your height and sex using standard formulas and the healthy BMI range.',
    totalTime: 'PT1M',
    estimatedCost: { value: '0', currency: 'USD' },
    steps: [
      { name: 'Select your sex', text: 'The formulas use different constants for men and women.' },
      { name: 'Enter your height', text: 'Type your height in centimetres.' },
      { name: 'Compare the results', text: 'See the Devine, Robinson, Miller and Hamwi figures and your healthy BMI range.' },
    ],
  }),
];
const relatedCalcs = [
  { name: 'BMI Calculator', href: '/health/bmi-calculator/', desc: 'Body mass index.', icon: '⚖️', color: 'bg-cyan-accent' },
  { name: 'Body Fat', href: '/health/body-fat-calculator/', desc: 'US Navy body fat %.', icon: '💪', color: 'bg-rose-300' },
  { name: 'Calorie Calculator', href: '/health/calorie-calculator/', desc: 'Daily calorie target.', icon: '🍎', color: 'bg-yellow-accent' },
  { name: 'Water Intake', href: '/health/water-intake-calculator/', desc: 'Daily water need.', icon: '💧', color: 'bg-lime-accent' },
];
---

<BaseLayout title="Ideal Weight Calculator: Healthy Weight for Your Height" description={meta.description} schemas={schemas} publishedTime={meta.lastUpdated} modifiedTime={meta.lastUpdated}>
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-lime-accent/30 rounded-full blur-[120px] float-slow"></div>
      <div class="absolute top-[5%] right-[-10%] w-[400px] h-[400px] bg-cyan-accent/25 rounded-full blur-[120px] float-slow-2"></div>
    </div>
    <div class="container-wide relative pt-8 pb-10 md:pt-12 md:pb-14">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-1.5 text-xs sm:text-sm">
          {breadcrumbs.map((item, idx) => (
            <li class="flex items-center gap-1.5">
              {idx === breadcrumbs.length - 1 ? (
                <span class="px-3 py-1 rounded-full bg-ink-900 text-white font-bold border-2 border-ink-900">{item.name}</span>
              ) : (
                <>
                  <a href={item.url} class="px-3 py-1 rounded-full bg-white border-2 border-ink-200 text-ink-700 font-semibold hover:border-ink-900 hover:text-ink-900 no-underline transition-colors">{item.name}</a>
                  <svg class="w-3 h-3 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </>
              )}
            </li>
          ))}
        </ol>
      </nav>
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="chip bg-lime-accent text-ink-900">🎯 Fitness</span>
          <span class="chip-white"><span class="text-ink-500">Updated</span><span>{meta.lastUpdated}</span></span>
        </div>
        <h1 class="!text-4xl sm:!text-5xl md:!text-6xl !font-extrabold !tracking-tight !leading-[1.05] text-ink-900" style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.035em;">
          Ideal Weight <span class="text-gradient-brand">Calculator.</span>
        </h1>
        <div class="mt-7 bg-yellow-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker">
          <div class="flex items-start gap-3">
            <div class="text-2xl">⚡</div>
            <div>
              <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-1">Quick answer</div>
              <p class="speakable-answer text-ink-900 text-base sm:text-lg leading-relaxed font-medium !m-0">
                A practical <strong>ideal weight</strong> is the range for a <strong>healthy BMI (18.5–24.9)</strong> at your height. The classic <strong>Devine formula</strong> gives men 50 kg + 2.3 kg per inch over 5 ft (women 45.5 kg). Enter your height below to compare all four formulas with your BMI range.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wide pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto">
      <IdealWeightCalculator client:load />
      {reviewer && <div class="mt-4"><AuthorBadge author={reviewer} verb="Reviewed" /></div>}
    </div>
  </section>

  <!-- HEIGHT TABLE -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-3xl mx-auto">
        <span class="chip bg-lime-accent text-ink-900 mb-4">📊 Quick reference</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Healthy weight range by height.</h2>
        <p class="mt-3 text-ink-700 font-medium">Based on a BMI of 18.5–24.9. The same height covers a wide healthy band. There's no single "correct" number.</p>
        <div class="mt-8 overflow-x-auto">
          <table class="w-full bg-white border-[2.5px] border-ink-900 rounded-2xl shadow-sticker-sm overflow-hidden border-separate border-spacing-0 text-sm">
            <thead><tr class="bg-ink-900 text-white">
              <th class="text-left p-3 font-extrabold">Height</th>
              <th class="text-right p-3 font-extrabold">Healthy weight range</th>
            </tr></thead>
            <tbody>
              {table.map((r, i) => (
                <tr class={`border-b-2 border-ink-100 ${i % 2 ? 'bg-ink-50' : ''}`}>
                  <td class="p-3 font-extrabold text-ink-900">{r.cm} cm</td>
                  <td class="p-3 text-right font-mono font-bold text-ink-900">{r.low} – {r.high} kg</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-3xl mx-auto">
      <span class="chip-yellow mb-4">❓ FAQ</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Common questions.</h2>
      <div class="space-y-3 mt-8">
        {faqs.map((faq, idx) => (
          <details class="group bg-white border-2 border-ink-900 rounded-2xl shadow-sticker-sm hover:shadow-sticker transition-all" open={idx === 0}>
            <summary class="cursor-pointer p-5 md:p-6 font-extrabold text-ink-900 flex items-center justify-between gap-4 list-none">
              <span class="text-base md:text-lg" style="font-family: 'Inter Tight', sans-serif;">{faq.q}</span>
              <span class="flex-shrink-0 w-9 h-9 rounded-full bg-ink-900 group-open:bg-lime-accent flex items-center justify-center transition-colors">
                <svg class="w-4 h-4 text-white group-open:text-ink-900 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </span>
            </summary>
            <div class="px-5 md:px-6 pb-5 md:pb-6 text-ink-700 leading-relaxed font-medium">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <span class="chip bg-lime-accent text-ink-900 mb-4">🔗 Related</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Try these next.</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-8">
          {relatedCalcs.map((c) => (
            <a href={c.href} class={`group ${c.color} border-[2.5px] border-ink-900 rounded-3xl p-5 no-underline shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200`}>
              <div class="text-3xl mb-3 group-hover:rotate-12 transition-transform inline-block">{c.icon}</div>
              <div class="font-extrabold text-ink-900 text-base leading-tight" style="font-family: 'Inter Tight', sans-serif;">{c.name}</div>
              <p class="text-xs text-ink-800 mt-1.5 leading-snug font-medium">{c.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
