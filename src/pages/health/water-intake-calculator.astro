---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AuthorBadge from '../../components/ui/AuthorBadge.astro';
import WaterIntakeCalculator from '../../components/calculators/WaterIntakeCalculator.tsx';
import { buildCalculatorSchema, buildBreadcrumbSchema, buildFAQSchema, buildHowToSchema, buildSpeakableSchema } from '../../lib/seo';
import { getAuthor } from '../../data/authors';

const meta = {
  slug: 'water-intake-calculator', name: 'Water Intake Calculator',
  description: 'Free daily water intake calculator. Estimate how much water you should drink per day from your body weight, activity level and climate — in litres, glasses and fluid ounces.',
  category: 'health' as const,
  keywords: ['water intake calculator', 'how much water should i drink', 'daily water intake', 'water calculator', 'hydration calculator'],
  lastUpdated: '2026-07-18',
};
const path = '/health/water-intake-calculator';
const reviewer = getAuthor('priya-nair')!;
const breadcrumbs = [
  { name: 'Home', url: '/' }, { name: 'Health', url: '/health/' }, { name: 'Water Intake Calculator', url: path },
];

// Build-time baseline water need by body weight (~33 ml/kg), temperate, light activity.
const weights = [50, 60, 70, 80, 90, 100];
const table = weights.map((kg) => {
  const litres = kg * 0.033 + 0.35;
  return { kg, litres: litres.toFixed(1), glasses: Math.round(litres / 0.25) };
});

const faqs = [
  { q: 'How much water should I drink a day?', a: 'A practical estimate is about 30–35 ml of fluid per kilogram of body weight, before adjusting for exercise and heat. For a 70 kg adult that\'s roughly 2.3 litres a day from all fluids. The old "8 glasses (2 litres)" rule is a reasonable average for many people, but a lighter or heavier person needs proportionally less or more. This calculator scales the figure to you.' },
  { q: 'Does exercise change how much water I need?', a: 'Yes. You lose fluid through sweat, so active days need more. A common guideline is an extra 350–500 ml for every 30 minutes of exercise, and more in heat. This calculator adds roughly 350 ml per 30 minutes of activity you enter. For long or intense sessions, also replace electrolytes (sodium, potassium), not just water.' },
  { q: 'Do coffee, tea and food count toward my water intake?', a: 'Yes. All beverages — including tea and coffee — count toward hydration; the mild diuretic effect of caffeine at normal amounts doesn\'t cancel out the fluid. Food contributes too, supplying about 20% of most people\'s water through fruit, vegetables, soups and other moist foods. The target here refers to total fluid, so you don\'t need to drink it all as plain water.' },
  { q: 'Can you drink too much water?', a: 'Rarely, but yes. Drinking a very large amount in a short time can dilute blood sodium (hyponatraemia), which is dangerous. This is mostly a risk for endurance athletes over-drinking during events, or certain medical conditions. For everyday life, spreading fluids through the day and drinking to thirst keeps you safe. If you have kidney, heart or liver conditions, follow your doctor\'s fluid advice over any calculator.' },
  { q: 'How do I know if I\'m drinking enough?', a: 'The simplest check is urine colour: pale straw yellow usually means well hydrated, while dark yellow suggests you need more. Thirst, dry mouth, headaches and tiredness can be early signs of mild dehydration. Your needs rise in hot weather, at altitude, when ill with fever, and during pregnancy or breastfeeding.' },
];
const schemas = [
  buildCalculatorSchema(meta, path),
  buildBreadcrumbSchema(breadcrumbs),
  buildFAQSchema(faqs),
  buildSpeakableSchema(path),
  buildHowToSchema({
    name: 'How to calculate your daily water intake',
    description: 'Estimate how much water to drink per day from body weight, activity and climate.',
    totalTime: 'PT1M',
    estimatedCost: { value: '0', currency: 'USD' },
    steps: [
      { name: 'Enter your weight', text: 'Type your body weight in kilograms.' },
      { name: 'Add activity and climate', text: 'Enter daily exercise minutes and pick your climate.' },
      { name: 'Read your target', text: 'The calculator shows litres, glasses and fluid ounces of total fluid.' },
    ],
  }),
];
const relatedCalcs = [
  { name: 'Calorie Calculator', href: '/health/calorie-calculator/', desc: 'Daily calorie target.', icon: '🍎', color: 'bg-lime-accent' },
  { name: 'BMI Calculator', href: '/health/bmi-calculator/', desc: 'Body mass index.', icon: '⚖️', color: 'bg-cyan-accent' },
  { name: 'TDEE Calculator', href: '/health/tdee-calculator/', desc: 'Daily calorie burn.', icon: '🔥', color: 'bg-yellow-accent' },
  { name: 'Ideal Weight', href: '/health/ideal-weight-calculator/', desc: 'Healthy weight range.', icon: '🎯', color: 'bg-rose-300' },
];
---

<BaseLayout title="Water Intake Calculator — How Much Water Should You Drink?" description={meta.description} schemas={schemas} publishedTime={meta.lastUpdated} modifiedTime={meta.lastUpdated}>
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-cyan-accent/30 rounded-full blur-[120px] float-slow"></div>
      <div class="absolute top-[5%] right-[-10%] w-[400px] h-[400px] bg-lime-accent/25 rounded-full blur-[120px] float-slow-2"></div>
    </div>
    <div class="container-wide relative pt-8 pb-10 md:pt-12 md:pb-14">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-1.5 text-xs sm:text-sm">
          {breadcrumbs.map((item, idx) => (
            <li class="flex items-center gap-1.5">
              {idx === breadcrumbs.length - 1 ? (
                <span class="px-3 py-1 rounded-full bg-ink-900 text-white font-bold border-2 border-ink-900">{item.name}</span>
              ) : (
                <>
                  <a href={item.url} class="px-3 py-1 rounded-full bg-white border-2 border-ink-200 text-ink-700 font-semibold hover:border-ink-900 hover:text-ink-900 no-underline transition-colors">{item.name}</a>
                  <svg class="w-3 h-3 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </>
              )}
            </li>
          ))}
        </ol>
      </nav>
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="chip bg-cyan-accent text-ink-900">💧 Hydration</span>
          <span class="chip-white"><span class="text-ink-500">Updated</span><span>{meta.lastUpdated}</span></span>
        </div>
        <h1 class="!text-4xl sm:!text-5xl md:!text-6xl !font-extrabold !tracking-tight !leading-[1.05] text-ink-900" style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.035em;">
          Water Intake <span class="text-gradient-brand">Calculator.</span>
        </h1>
        <div class="mt-7 bg-yellow-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker">
          <div class="flex items-start gap-3">
            <div class="text-2xl">⚡</div>
            <div>
              <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-1">Quick answer</div>
              <p class="speakable-answer text-ink-900 text-base sm:text-lg leading-relaxed font-medium !m-0">
                A good estimate is <strong>about 33 ml of fluid per kg of body weight</strong> — roughly <strong>2.3 litres for a 70 kg adult</strong> — plus ~350 ml per 30 minutes of exercise and more in heat. Enter your details below for a personalised target in litres and glasses.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wide pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto">
      <WaterIntakeCalculator client:load />
      {reviewer && <div class="mt-4"><AuthorBadge author={reviewer} verb="Reviewed" /></div>}
    </div>
  </section>

  <!-- WEIGHT TABLE -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-3xl mx-auto">
        <span class="chip bg-cyan-accent text-ink-900 mb-4">📊 Quick reference</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Baseline water need by weight.</h2>
        <p class="mt-3 text-ink-700 font-medium">Temperate climate with light daily activity. Add more on hot days and after exercise.</p>
        <div class="mt-8 overflow-x-auto">
          <table class="w-full bg-white border-[2.5px] border-ink-900 rounded-2xl shadow-sticker-sm overflow-hidden border-separate border-spacing-0 text-sm">
            <thead><tr class="bg-ink-900 text-white">
              <th class="text-left p-3 font-extrabold">Body weight</th>
              <th class="text-center p-3 font-extrabold">Water / day</th>
              <th class="text-right p-3 font-extrabold">Glasses (250 ml)</th>
            </tr></thead>
            <tbody>
              {table.map((r, i) => (
                <tr class={`border-b-2 border-ink-100 ${i % 2 ? 'bg-ink-50' : ''}`}>
                  <td class="p-3 font-extrabold text-ink-900">{r.kg} kg</td>
                  <td class="p-3 text-center font-mono font-bold text-ink-900">{r.litres} L</td>
                  <td class="p-3 text-right font-mono font-bold text-ink-900">{r.glasses}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-3xl mx-auto">
      <span class="chip-yellow mb-4">❓ FAQ</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Common questions.</h2>
      <div class="space-y-3 mt-8">
        {faqs.map((faq, idx) => (
          <details class="group bg-white border-2 border-ink-900 rounded-2xl shadow-sticker-sm hover:shadow-sticker transition-all" open={idx === 0}>
            <summary class="cursor-pointer p-5 md:p-6 font-extrabold text-ink-900 flex items-center justify-between gap-4 list-none">
              <span class="text-base md:text-lg" style="font-family: 'Inter Tight', sans-serif;">{faq.q}</span>
              <span class="flex-shrink-0 w-9 h-9 rounded-full bg-ink-900 group-open:bg-lime-accent flex items-center justify-center transition-colors">
                <svg class="w-4 h-4 text-white group-open:text-ink-900 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </span>
            </summary>
            <div class="px-5 md:px-6 pb-5 md:pb-6 text-ink-700 leading-relaxed font-medium">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <span class="chip bg-cyan-accent text-ink-900 mb-4">🔗 Related</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Try these next.</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-8">
          {relatedCalcs.map((c) => (
            <a href={c.href} class={`group ${c.color} border-[2.5px] border-ink-900 rounded-3xl p-5 no-underline shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200`}>
              <div class="text-3xl mb-3 group-hover:rotate-12 transition-transform inline-block">{c.icon}</div>
              <div class="font-extrabold text-ink-900 text-base leading-tight" style="font-family: 'Inter Tight', sans-serif;">{c.name}</div>
              <p class="text-xs text-ink-800 mt-1.5 leading-snug font-medium">{c.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
