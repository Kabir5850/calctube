---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PercentageCalculator from '../../components/calculators/PercentageCalculator.tsx';
import { buildCalculatorSchema, buildBreadcrumbSchema, buildFAQSchema } from '../../lib/seo';
import AuthorBadge from '../../components/ui/AuthorBadge.astro';
import { getAuthor } from '../../data/authors';

const meta = {
  slug: 'percentage-calculator', name: 'Percentage Calculator',
  description: 'Free percentage calculator. Find X% of Y, what percent X is of Y, or % change between two numbers. Instant results.',
  category: 'math' as const,
  keywords: ['percentage calculator', 'percent', 'percentage change', 'percent of', 'percent increase'],
  lastUpdated: '2026-05-13', ratingValue: '4.9', ratingCount: '241',
};
const path = '/math/percentage-calculator';
const breadcrumbs = [
  { name: 'Home', url: '/' }, { name: 'Math', url: '/math/' }, { name: 'Percentage', url: path },
];
const faqs = [
  { q: 'How do I find a percentage of a number?', a: 'Multiply the percentage (as a decimal) by the number. For example, 15% of 200 = 0.15 × 200 = 30.' },
  { q: 'How do I find what percent one number is of another?', a: 'Divide the part by the whole, then multiply by 100. For example, 30 out of 120 = (30 ÷ 120) × 100 = 25%.' },
  { q: 'How do I calculate percentage change?', a: 'Subtract the old value from the new, divide by the old value, multiply by 100. From 100 to 150: ((150 − 100) ÷ 100) × 100 = 50% increase.' },
  { q: 'Whats the difference between percentage points and percent?', a: 'Percentage points are a direct subtraction. Going from 5% to 8% is +3 percentage points, but a 60% relative increase. The distinction matters when discussing rates.' },
  { q: 'How do I reverse-engineer a percentage?', a: 'If 20 is 25% of some number, that number = 20 ÷ 0.25 = 80. Divide the part by the percentage (as a decimal) to find the whole.' },
];
const schemas = [buildCalculatorSchema(meta, path), buildBreadcrumbSchema(breadcrumbs), buildFAQSchema(faqs)];
const relatedCalcs = [
  { name: 'Discount Calculator', href: '/finance/discount-calculator/', desc: 'Sale price + savings.', icon: '🏷️', color: 'bg-lime-accent' },
  { name: 'Tip Calculator', href: '/finance/tip-calculator/', desc: 'Bills + tip split.', icon: '🍽️', color: 'bg-yellow-accent' },
  { name: 'Tax Calculator', href: '/finance/tax-calculator-india/', desc: 'Income tax estimator.', icon: '🪙', color: 'bg-cyan-accent' },
  { name: 'Fraction Calculator', href: '/math/fraction-calculator/', desc: 'Add, simplify fractions.', icon: '½', color: 'bg-rose-300' },
];
const reviewer = getAuthor('calctube-editorial');
---

<BaseLayout title="Percentage Calculator — 3 Modes in One Tool" description={meta.description} schemas={schemas} publishedTime={meta.lastUpdated} modifiedTime={meta.lastUpdated}>
  <!-- HERO -->
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-violet-300/50 rounded-full blur-[120px] float-slow"></div>
      <div class="absolute top-[5%] right-[-10%] w-[400px] h-[400px] bg-lime-accent/25 rounded-full blur-[120px] float-slow-2"></div>
    </div>
    <div class="container-wide relative pt-8 pb-10 md:pt-12 md:pb-14">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-1.5 text-xs sm:text-sm">
          {breadcrumbs.map((item, idx) => (
            <li class="flex items-center gap-1.5">
              {idx === breadcrumbs.length - 1 ? (
                <span class="px-3 py-1 rounded-full bg-ink-900 text-white font-bold border-2 border-ink-900">{item.name}</span>
              ) : (
                <>
                  <a href={item.url} class="px-3 py-1 rounded-full bg-white border-2 border-ink-200 text-ink-700 font-semibold hover:border-ink-900 hover:text-ink-900 no-underline transition-colors">{item.name}</a>
                  <svg class="w-3 h-3 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </>
              )}
            </li>
          ))}
        </ol>
      </nav>
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="chip bg-violet-300 text-ink-900">🧮 Math</span>
          <span class="chip-lime">3 modes</span>
          <span class="chip-white"><span class="text-ink-500">Last tested</span><span>{meta.lastUpdated}</span></span>
        </div>
        <h1 class="!text-4xl sm:!text-5xl md:!text-6xl !font-extrabold !tracking-tight !leading-[1.05] text-ink-900" style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.035em;">
          Percentage <span class="text-gradient-brand">made stupid easy.</span>
        </h1>
        <div class="mt-7 bg-lime-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker">
          <div class="flex items-start gap-3">
            <div class="text-2xl">⚡</div>
            <div>
              <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-1">Quick answer</div>
              <p class="text-ink-900 text-base sm:text-lg leading-relaxed font-medium !m-0">
                <strong>15% of 200 = 30.</strong> Three modes in one calculator: percent of a number, what % a number is of another, and the % change between two numbers.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CALCULATOR -->
  <section class="container-wide pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto"><PercentageCalculator client:load /></div>
  </section>

  <!-- Reviewer attribution — E-E-A-T signal -->
  <section class="container-wide pt-2 pb-8">
    <div class="max-w-4xl mx-auto">
      {reviewer && <AuthorBadge author={reviewer} verb="Reviewed" />}
    </div>
  </section>

  <!-- THE MATH -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <span class="chip-pink mb-4">🧮 The 3 formulas</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Three modes. Three formulas.</h2>
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-5 mt-8">
          <div class="bg-lime-accent border-[2.5px] border-ink-900 rounded-2xl p-6 shadow-sticker-sm">
            <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-2">Mode 1: X% of Y</div>
            <div class="font-mono font-bold text-ink-900 text-base">result = (X / 100) × Y</div>
            <p class="text-sm text-ink-900 mt-3 font-medium">e.g. 15% of 200 → (15/100) × 200 = <strong>30</strong></p>
          </div>
          <div class="bg-pink-accent border-[2.5px] border-ink-900 rounded-2xl p-6 shadow-sticker-sm">
            <div class="text-xs font-extrabold uppercase tracking-wider text-white mb-2">Mode 2: X is % of Y</div>
            <div class="font-mono font-bold text-white text-base">result = (X / Y) × 100</div>
            <p class="text-sm text-white mt-3 font-medium">e.g. 30 of 120 → (30/120) × 100 = <strong>25%</strong></p>
          </div>
          <div class="bg-cyan-accent border-[2.5px] border-ink-900 rounded-2xl p-6 shadow-sticker-sm">
            <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-2">Mode 3: % Change</div>
            <div class="font-mono font-bold text-ink-900 text-base">result = ((Y − X) / |X|) × 100</div>
            <p class="text-sm text-ink-900 mt-3 font-medium">e.g. 100 to 150 → ((150−100)/100) × 100 = <strong>+50%</strong></p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-3xl mx-auto">
      <span class="chip-yellow mb-4">❓ FAQ</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Common questions.</h2>
      <div class="space-y-3 mt-8">
        {faqs.map((faq, idx) => (
          <details class="group bg-white border-2 border-ink-900 rounded-2xl shadow-sticker-sm hover:shadow-sticker transition-all" open={idx === 0}>
            <summary class="cursor-pointer p-5 md:p-6 font-extrabold text-ink-900 flex items-center justify-between gap-4 list-none">
              <span class="text-base md:text-lg" style="font-family: 'Inter Tight', sans-serif;">{faq.q}</span>
              <span class="flex-shrink-0 w-9 h-9 rounded-full bg-ink-900 group-open:bg-lime-accent flex items-center justify-center transition-colors">
                <svg class="w-4 h-4 text-white group-open:text-ink-900 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </span>
            </summary>
            <div class="px-5 md:px-6 pb-5 md:pb-6 text-ink-700 leading-relaxed font-medium">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <span class="chip bg-violet-300 text-ink-900 mb-4">🔗 Related</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Try these next.</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-8">
          {relatedCalcs.map((c) => (
            <a href={c.href} class={`group ${c.color} border-[2.5px] border-ink-900 rounded-3xl p-5 no-underline shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200`}>
              <div class="text-3xl mb-3 group-hover:rotate-12 transition-transform inline-block">{c.icon}</div>
              <div class="font-extrabold text-ink-900 text-base leading-tight" style="font-family: 'Inter Tight', sans-serif;">{c.name}</div>
              <p class="text-xs text-ink-800 mt-1.5 leading-snug font-medium">{c.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
