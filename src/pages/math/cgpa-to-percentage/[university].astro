---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CgpaCalculator from '../../../components/calculators/CgpaCalculator.tsx';
import { universities, getUniversity, type University } from '../../../data/cgpa-universities';
import { buildCalculatorSchema, buildBreadcrumbSchema, buildFAQSchema, buildHowToSchema, buildSpeakableSchema } from '../../../lib/seo';

export async function getStaticPaths() {
  return universities.map((u) => ({ params: { university: u.slug }, props: { uni: u } }));
}

interface Props { uni: University; }
const { uni } = Astro.props;
const path = `/math/cgpa-to-percentage/${uni.slug}`;

const ex = 8.5;
const exPct = uni.toPct(ex);
const fmtPct = (n: number) => Number(n.toFixed(2));

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Math', url: '/math/' },
  { name: 'CGPA to Percentage', url: '/math/cgpa-to-percentage-calculator/' },
  { name: uni.shortName, url: path },
];

// Build-time conversion table using THIS university's formula.
const table = [10, 9.5, 9, 8.5, 8, 7.5, 7, 6.5, 6, 5.5, 5].map((c) => ({ cgpa: c, pct: fmtPct(uni.toPct(c)) }));

const meta = {
  slug: `${uni.slug}-cgpa-to-percentage`,
  name: `${uni.shortName} CGPA to Percentage Calculator`,
  description: `Convert ${uni.shortName} CGPA to percentage using the official formula: ${uni.formulaText}. So a CGPA of ${ex} = ${fmtPct(exPct)}%. Free instant calculator with a full conversion chart.`.slice(0, 155),
  category: 'math' as const,
  keywords: [
    `${uni.shortName.toLowerCase()} cgpa to percentage`, `${uni.shortName.toLowerCase()} percentage calculator`,
    `${uni.fullName.toLowerCase()} cgpa`, `cgpa to percentage ${uni.shortName.toLowerCase()}`,
    `${uni.shortName.toLowerCase()} cgpa calculator`,
  ],
  lastUpdated: '2026-07-19',
};

const faqs = [
  { q: `How do I convert ${uni.shortName} CGPA to percentage?`, a: `${uni.fullName} uses the formula ${uni.formulaText}. For example, a CGPA of ${ex} converts to ${fmtPct(exPct)}%. Enter your CGPA in the calculator above and it applies this formula instantly, or use the conversion chart on this page. ${uni.blurb}` },
  { q: `What is ${ex} CGPA in percentage at ${uni.shortName}?`, a: `Using ${uni.formulaText}, a ${ex} CGPA equals ${fmtPct(exPct)}% at ${uni.shortName}. Note this differs from the CBSE-style CGPA × 9.5 rule (which would give ${fmtPct(ex * 9.5)}%), because ${uni.shortName} publishes its own conversion.` },
  { q: `Is the ${uni.shortName} CGPA formula the same as CBSE (×9.5)?`, a: `No. CBSE and many 10-point universities multiply CGPA by 9.5, but ${uni.shortName} uses ${uni.formulaText}. Using the wrong formula can put you above or below an eligibility cut-off, so always apply your own university's method, the one built into this page.` },
  { q: `Where do I find my official ${uni.shortName} percentage?`, a: `Your official percentage or conversion certificate comes from ${uni.fullName} itself. Check your grade card, marksheet, or the university's conversion circular. Conversion formulas can change between regulation years and programs, so treat this calculator as a quick estimate and confirm the exact figure with your university when it matters for admissions or jobs.` },
];

const schemas = [
  buildCalculatorSchema(meta, path),
  buildBreadcrumbSchema(breadcrumbs),
  buildFAQSchema(faqs),
  buildSpeakableSchema(path),
  buildHowToSchema({
    name: `How to convert ${uni.shortName} CGPA to percentage`,
    description: `Convert your ${uni.shortName} CGPA to a percentage using ${uni.formulaText}.`,
    totalTime: 'PT1M',
    estimatedCost: { value: '0', currency: 'INR' },
    steps: [
      { name: 'Enter your CGPA', text: `Type your ${uni.shortName} CGPA (out of 10) into the calculator.` },
      { name: 'Apply the formula', text: `The calculator uses ${uni.formulaText}.` },
      { name: 'Read your percentage', text: `A CGPA of ${ex} gives ${fmtPct(exPct)}% under the ${uni.shortName} scheme.` },
    ],
  }),
];

const others = universities.filter((u) => u.slug !== uni.slug);
---

<BaseLayout title={`${uni.shortName} CGPA to Percentage Calculator`} description={meta.description} schemas={schemas} publishedTime={meta.lastUpdated} modifiedTime={meta.lastUpdated}>
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-violet-300/40 rounded-full blur-[120px] float-slow"></div>
      <div class="absolute top-[5%] right-[-10%] w-[400px] h-[400px] bg-lime-accent/25 rounded-full blur-[120px] float-slow-2"></div>
    </div>
    <div class="container-wide relative pt-8 pb-10 md:pt-12 md:pb-14">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-1.5 text-xs sm:text-sm">
          {breadcrumbs.map((item, idx) => (
            <li class="flex items-center gap-1.5">
              {idx === breadcrumbs.length - 1 ? (
                <span class="px-3 py-1 rounded-full bg-ink-900 text-white font-bold border-2 border-ink-900">{item.name}</span>
              ) : (
                <>
                  <a href={item.url} class="px-3 py-1 rounded-full bg-white border-2 border-ink-200 text-ink-700 font-semibold hover:border-ink-900 hover:text-ink-900 no-underline transition-colors">{item.name}</a>
                  <svg class="w-3 h-3 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </>
              )}
            </li>
          ))}
        </ol>
      </nav>
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="chip bg-violet-300 text-ink-900">🎓 {uni.region}</span>
          <span class="chip-lime">🧮 Academic</span>
          <span class="chip-white"><span class="text-ink-500">Updated</span><span>{meta.lastUpdated}</span></span>
        </div>
        <h1 class="!text-4xl sm:!text-5xl md:!text-6xl !font-extrabold !tracking-tight !leading-[1.05] text-ink-900" style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.035em;">
          {uni.shortName} CGPA to Percentage <span class="text-gradient-brand">Calculator.</span>
        </h1>
        <div class="mt-7 bg-yellow-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker">
          <div class="flex items-start gap-3">
            <div class="text-2xl">⚡</div>
            <div>
              <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-1">Quick answer</div>
              <p class="speakable-answer text-ink-900 text-base sm:text-lg leading-relaxed font-medium !m-0">
                {uni.fullName} converts CGPA to percentage with <strong>{uni.formulaText}</strong>. So a CGPA of <strong>{ex} = {fmtPct(exPct)}%</strong>. This differs from the CBSE ×9.5 rule. Enter your CGPA below to use the correct {uni.shortName} formula.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wide pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto">
      <CgpaCalculator client:load initialFormula={uni.formulaKey} />
    </div>
  </section>

  <!-- CONVERSION TABLE -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-3xl mx-auto">
        <span class="chip bg-violet-300 text-ink-900 mb-4">📊 Quick reference</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">{uni.shortName} CGPA to percentage chart.</h2>
        <p class="mt-3 text-ink-700 font-medium">Computed with {uni.shortName}'s formula: {uni.formulaText}.</p>
        <div class="mt-8 overflow-x-auto">
          <table class="w-full bg-white border-[2.5px] border-ink-900 rounded-2xl shadow-sticker-sm overflow-hidden border-separate border-spacing-0 text-sm">
            <thead><tr class="bg-ink-900 text-white">
              <th class="text-left p-3 font-extrabold">CGPA</th>
              <th class="text-right p-3 font-extrabold">Percentage ({uni.shortName})</th>
            </tr></thead>
            <tbody>
              {table.map((r, i) => (
                <tr class={`border-b-2 border-ink-100 ${i % 2 ? 'bg-ink-50' : ''}`}>
                  <td class="p-3 font-bold text-ink-900">{r.cgpa}</td>
                  <td class="p-3 text-right font-mono font-extrabold text-ink-900">{r.pct.toFixed(2)}%</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="text-xs text-ink-500 mt-3 font-medium">Conversion formulas can vary by regulation year and program. Confirm the exact figure on your official {uni.shortName} grade card.</p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-3xl mx-auto">
      <span class="chip-yellow mb-4">❓ FAQ</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">{uni.shortName} conversion questions.</h2>
      <div class="space-y-3 mt-8">
        {faqs.map((faq, idx) => (
          <details class="group bg-white border-2 border-ink-900 rounded-2xl shadow-sticker-sm hover:shadow-sticker transition-all" open={idx === 0}>
            <summary class="cursor-pointer p-5 md:p-6 font-extrabold text-ink-900 flex items-center justify-between gap-4 list-none">
              <span class="text-base md:text-lg" style="font-family: 'Inter Tight', sans-serif;">{faq.q}</span>
              <span class="flex-shrink-0 w-9 h-9 rounded-full bg-ink-900 group-open:bg-lime-accent flex items-center justify-center transition-colors">
                <svg class="w-4 h-4 text-white group-open:text-ink-900 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </span>
            </summary>
            <div class="px-5 md:px-6 pb-5 md:pb-6 text-ink-700 leading-relaxed font-medium">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- OTHER UNIVERSITIES -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <span class="chip bg-violet-300 text-ink-900 mb-4">🎓 Other universities</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">CGPA formulas by university.</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4 mt-8">
          {others.map((u) => (
            <a href={`/math/cgpa-to-percentage/${u.slug}/`} class="group bg-white border-[2.5px] border-ink-900 rounded-2xl p-4 no-underline shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200">
              <div class="font-extrabold text-ink-900 text-base leading-tight" style="font-family: 'Inter Tight', sans-serif;">{u.shortName}</div>
              <div class="text-xs text-ink-600 mt-1 font-semibold">{u.formulaText}</div>
            </a>
          ))}
        </div>
        <div class="mt-8">
          <a href="/math/cgpa-to-percentage-calculator/" class="font-bold underline decoration-2 underline-offset-4 decoration-lime-accent text-ink-900">← Main CGPA to percentage calculator (all formulas)</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
