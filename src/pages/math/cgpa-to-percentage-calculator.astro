---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AuthorBadge from '../../components/ui/AuthorBadge.astro';
import CgpaCalculator from '../../components/calculators/CgpaCalculator.tsx';
import { buildCalculatorSchema, buildBreadcrumbSchema, buildFAQSchema, buildHowToSchema } from '../../lib/seo';
import { getAuthor } from '../../data/authors';
import { universities } from '../../data/cgpa-universities';

const meta = {
  slug: 'cgpa-to-percentage-calculator', name: 'CGPA to Percentage Calculator',
  description: 'Free CGPA to percentage calculator with CBSE, VTU, Anna & Mumbai University formulas. Convert CGPA to percentage (CGPA × 9.5) and percentage to CGPA both ways, instantly.',
  category: 'math' as const,
  keywords: ['cgpa to percentage', 'cgpa calculator', 'cgpa to percentage calculator', 'percentage to cgpa', 'cbse cgpa to percentage', 'convert cgpa to percentage'],
  lastUpdated: '2026-07-10',
};
const path = '/math/cgpa-to-percentage-calculator';
const reviewer = getAuthor('aisha-rahman')!;
const breadcrumbs = [
  { name: 'Home', url: '/' }, { name: 'Math', url: '/math/' }, { name: 'CGPA to Percentage', url: path },
];

// Build-time conversion table (CBSE ×9.5) — unique, extractable content.
const table = [10, 9.5, 9, 8.5, 8, 7.5, 7, 6.5, 6, 5.5, 5].map((c) => ({ cgpa: c, pct: c * 9.5 }));

const faqs = [
  { q: 'How do I convert CGPA to percentage?', a: 'For CBSE and most Indian 10-point universities, multiply your CGPA by 9.5. So a CGPA of 8.5 = 8.5 × 9.5 = 80.75%. This "×9.5" factor is the CBSE-recommended formula, derived from averaging the percentage ranges of grade points. Some universities use their own formula. VTU uses (CGPA − 0.75) × 10, Anna University uses (CGPA − 0.5) × 10, and Mumbai University uses 7.1 × CGPA + 11. Always check your grade card or university handbook for the exact method.' },
  { q: 'Why multiply CGPA by 9.5?', a: 'CBSE arrived at 9.5 by taking the average of the upper and lower percentage bounds of grades A1 to E, across the five subjects with the highest grade points. It\'s an official, board-recommended approximation, not an exact science, which is why a CGPA of 10 maps to 95%, not 100%. Different boards and universities use different multipliers because their grade-to-percentage bands differ.' },
  { q: 'How do I convert percentage to CGPA?', a: 'Reverse the formula: divide your percentage by 9.5 (for the CBSE ×9.5 system). So 76% ÷ 9.5 = 8.0 CGPA. Toggle this calculator to "Percentage → CGPA" and it does it for you across the different university formulas. Note that because these are approximations, converting back and forth can shift the last decimal slightly.' },
  { q: 'Is CGPA out of 10 the same everywhere?', a: 'No. India\'s 10-point CGPA (CBSE, most universities) is the most common, but the US uses a 4.0 GPA scale, and some Indian universities use a 7-point or 4-point scale. A 9.0 CGPA on the 10-point scale is roughly a 3.7-3.8 GPA on the US 4.0 scale, but exact conversion for study-abroad applications should follow WES or the target university\'s official method, not a simple formula.' },
  { q: 'Does a higher CGPA always mean a higher percentage?', a: 'Within the same formula, yes. The conversion is a straight line. But the same CGPA gives different percentages under different formulas: a CGPA of 8.0 is 76% under CBSE (×9.5), 72.5% under VTU, and 75% under Anna University. That\'s why you must use your own university\'s formula when it matters for eligibility or applications. A wrong formula can put you above or below a cut-off.' },
];
const schemas = [
  buildCalculatorSchema(meta, path),
  buildBreadcrumbSchema(breadcrumbs),
  buildFAQSchema(faqs),
  buildHowToSchema({
    name: 'How to convert CGPA to percentage',
    description: 'Convert your CGPA to a percentage using the CBSE and university-specific formulas.',
    totalTime: 'PT1M',
    estimatedCost: { value: '0', currency: 'INR' },
    steps: [
      { name: 'Pick your university formula', text: 'Select CBSE/Generic (×9.5), VTU, Anna University, Mumbai University, or a custom multiplier.' },
      { name: 'Enter your CGPA', text: 'Type your CGPA out of 10 (e.g. 8.5).' },
      { name: 'Read the percentage', text: 'The calculator applies the formula: CGPA 8.5 × 9.5 = 80.75% under CBSE.' },
    ],
  }),
];
const relatedCalcs = [
  { name: 'Percentage Calculator', href: '/math/percentage-calculator/', desc: 'X% of Y, increase/decrease.', icon: '🧮', color: 'bg-lime-accent' },
  { name: 'Discount Calculator', href: '/math/discount-calculator/', desc: 'Sale price & savings.', icon: '🏷️', color: 'bg-cyan-accent' },
  { name: 'Tip Calculator', href: '/math/tip-calculator/', desc: 'Split bills + tip.', icon: '🍽️', color: 'bg-yellow-accent' },
  { name: 'Age Calculator', href: '/date-time/age-calculator/', desc: 'Exact age in y/m/d.', icon: '🎂', color: 'bg-rose-300' },
];
---

<BaseLayout title="CGPA to Percentage Calculator: CBSE, VTU, Anna & Mumbai University" description={meta.description} schemas={schemas} publishedTime={meta.lastUpdated} modifiedTime={meta.lastUpdated}>
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-violet-300/40 rounded-full blur-[120px] float-slow"></div>
      <div class="absolute top-[5%] right-[-10%] w-[400px] h-[400px] bg-lime-accent/25 rounded-full blur-[120px] float-slow-2"></div>
    </div>
    <div class="container-wide relative pt-8 pb-10 md:pt-12 md:pb-14">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-1.5 text-xs sm:text-sm">
          {breadcrumbs.map((item, idx) => (
            <li class="flex items-center gap-1.5">
              {idx === breadcrumbs.length - 1 ? (
                <span class="px-3 py-1 rounded-full bg-ink-900 text-white font-bold border-2 border-ink-900">{item.name}</span>
              ) : (
                <>
                  <a href={item.url} class="px-3 py-1 rounded-full bg-white border-2 border-ink-200 text-ink-700 font-semibold hover:border-ink-900 hover:text-ink-900 no-underline transition-colors">{item.name}</a>
                  <svg class="w-3 h-3 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </>
              )}
            </li>
          ))}
        </ol>
      </nav>
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="chip bg-violet-300 text-ink-900">🎓 Academic</span>
          <span class="chip-lime">🧮 Math</span>
          <span class="chip-white"><span class="text-ink-500">Updated</span><span>{meta.lastUpdated}</span></span>
        </div>
        <h1 class="!text-4xl sm:!text-5xl md:!text-6xl !font-extrabold !tracking-tight !leading-[1.05] text-ink-900" style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.035em;">
          CGPA to Percentage <span class="text-gradient-brand">Calculator.</span>
        </h1>
        <div class="mt-7 bg-yellow-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker">
          <div class="flex items-start gap-3">
            <div class="text-2xl">⚡</div>
            <div>
              <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-1">Quick answer</div>
              <p class="text-ink-900 text-base sm:text-lg leading-relaxed font-medium !m-0">
                For <strong>CBSE and most Indian universities</strong>, Percentage = <strong>CGPA × 9.5</strong>. So a CGPA of <strong>8.5 = 80.75%</strong>, and a CGPA of 9.2 = 87.4%. VTU, Anna and Mumbai University use different formulas. Pick yours below, and convert <strong>both ways</strong>.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wide pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto">
      <CgpaCalculator client:load />
      {reviewer && <div class="mt-4"><AuthorBadge author={reviewer} verb="Reviewed" /></div>}
    </div>
  </section>

  <!-- CONVERSION TABLE -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-3xl mx-auto">
        <span class="chip bg-violet-300 text-ink-900 mb-4">📊 Quick reference</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">CGPA to percentage chart (×9.5).</h2>
        <div class="mt-8 overflow-x-auto">
          <table class="w-full bg-white border-[2.5px] border-ink-900 rounded-2xl shadow-sticker-sm overflow-hidden border-separate border-spacing-0 text-sm">
            <thead><tr class="bg-ink-900 text-white">
              <th class="text-left p-3 font-extrabold">CGPA</th>
              <th class="text-right p-3 font-extrabold">Percentage (CBSE ×9.5)</th>
            </tr></thead>
            <tbody>
              {table.map((r, i) => (
                <tr class={`border-b-2 border-ink-100 ${i % 2 ? 'bg-ink-50' : ''}`}>
                  <td class="p-3 font-bold text-ink-900">{r.cgpa}</td>
                  <td class="p-3 text-right font-mono font-extrabold text-ink-900">{r.pct.toFixed(2)}%</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="text-xs text-ink-500 mt-3 font-medium">CBSE/generic 10-point formula. VTU, Anna University and Mumbai University use different formulas. Switch the formula in the calculator above.</p>
      </div>
    </div>
  </section>

  <!-- BY UNIVERSITY -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-4xl mx-auto">
      <span class="chip bg-violet-300 text-ink-900 mb-4">🎓 By university</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Your university uses its own formula.</h2>
      <p class="mt-3 text-ink-700 font-medium">Many Indian universities don't use the CBSE ×9.5 rule. Pick yours for the exact conversion:</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4 mt-8">
        {universities.map((u) => (
          <a href={`/math/cgpa-to-percentage/${u.slug}/`} class="group bg-white border-[2.5px] border-ink-900 rounded-2xl p-4 no-underline shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200">
            <div class="font-extrabold text-ink-900 text-base leading-tight" style="font-family: 'Inter Tight', sans-serif;">{u.shortName} CGPA to %</div>
            <div class="text-xs text-ink-600 mt-1 font-semibold">{u.formulaText}</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-3xl mx-auto">
      <span class="chip-yellow mb-4">❓ FAQ</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Common questions.</h2>
      <div class="space-y-3 mt-8">
        {faqs.map((faq, idx) => (
          <details class="group bg-white border-2 border-ink-900 rounded-2xl shadow-sticker-sm hover:shadow-sticker transition-all" open={idx === 0}>
            <summary class="cursor-pointer p-5 md:p-6 font-extrabold text-ink-900 flex items-center justify-between gap-4 list-none">
              <span class="text-base md:text-lg" style="font-family: 'Inter Tight', sans-serif;">{faq.q}</span>
              <span class="flex-shrink-0 w-9 h-9 rounded-full bg-ink-900 group-open:bg-lime-accent flex items-center justify-center transition-colors">
                <svg class="w-4 h-4 text-white group-open:text-ink-900 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </span>
            </summary>
            <div class="px-5 md:px-6 pb-5 md:pb-6 text-ink-700 leading-relaxed font-medium">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <span class="chip bg-violet-300 text-ink-900 mb-4">🔗 Related</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Try these next.</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-8">
          {relatedCalcs.map((c) => (
            <a href={c.href} class={`group ${c.color} border-[2.5px] border-ink-900 rounded-3xl p-5 no-underline shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200`}>
              <div class="text-3xl mb-3 group-hover:rotate-12 transition-transform inline-block">{c.icon}</div>
              <div class="font-extrabold text-ink-900 text-base leading-tight" style="font-family: 'Inter Tight', sans-serif;">{c.name}</div>
              <p class="text-xs text-ink-800 mt-1.5 leading-snug font-medium">{c.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
