---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GradeCalculator from '../../components/calculators/GradeCalculator.tsx';
import { buildCalculatorSchema, buildBreadcrumbSchema, buildFAQSchema, buildHowToSchema, buildSpeakableSchema } from '../../lib/seo';

const meta = {
  slug: 'grade-calculator', name: 'Grade Calculator',
  description: 'Free grade calculator for your weighted class grade from homework, tests and projects, plus a "what do I need on the final" mode. Enter scores and weights to see your overall grade and letter.',
  category: 'math' as const,
  keywords: ['grade calculator', 'final grade calculator', 'weighted grade calculator', 'what do i need on my final', 'test grade calculator', 'class grade'],
  lastUpdated: '2026-07-18',
};
const path = '/math/grade-calculator';
const breadcrumbs = [
  { name: 'Home', url: '/' }, { name: 'Math', url: '/math/' }, { name: 'Grade Calculator', url: path },
];

// Build-time letter-grade band reference.
const bands = [
  { l: 'A', r: '93–100%' }, { l: 'A-', r: '90–92%' }, { l: 'B+', r: '87–89%' }, { l: 'B', r: '83–86%' },
  { l: 'B-', r: '80–82%' }, { l: 'C+', r: '77–79%' }, { l: 'C', r: '73–76%' }, { l: 'C-', r: '70–72%' },
  { l: 'D+', r: '67–69%' }, { l: 'D', r: '60–66%' }, { l: 'F', r: 'Below 60%' },
];

const faqs = [
  { q: 'How do you calculate a weighted grade?', a: 'Multiply each category\'s score by its weight, add them up, then divide by the total weight. If homework (92%) is worth 20%, the midterm (78%) 30%, and a project (88%) 20%, the weighted grade so far is (92×20 + 78×30 + 88×20) ÷ (20+30+20) = 6900 ÷ 70 = 84.6%. Categories that are worth more move your grade more. A great homework score barely helps if homework is only 10% of the grade.' },
  { q: 'What grade do I need on the final to get an A?', a: 'Use the formula: needed = (goal − current × (1 − finalWeight)) ÷ finalWeight. Say you have 82% going in, want 90%, and the final is worth 30%. Then needed = (90 − 82 × 0.70) ÷ 0.30 = (90 − 57.4) ÷ 0.30 = 108.7%, meaning a 90% overall isn\'t reachable with only a 30% final. Switch to the "Grade needed on final" tab and the calculator does this instantly.' },
  { q: 'Why is the number I need on my final over 100%?', a: 'It means your target is out of reach given how little the final is worth. If the final counts for 20% of your grade, it can move your overall grade by at most 20 points from where a 0 would put you, so a large gap between your current and desired grade can require an impossible score. Lower the target, or check whether extra credit is available.' },
  { q: 'Do my category weights have to add up to 100%?', a: 'Not while the term is in progress. This calculator normalizes by the total weight you\'ve entered, so it shows your grade among the work graded so far. Once every category is entered and the weights total 100%, the number is your true final grade. Watch the "weight entered" note under the result to see where you stand.' },
  { q: 'How do percentages become letter grades?', a: 'Most US schools use a 10-point scale with pluses and minuses: A is 93–100, B is 83–86, C is 73–76, and so on, with F below 60. Some use a straight scale (A = 90+) or different cut-offs. The table on this page shows the common bands, but always defer to your syllabus. A single point can change a B+ to an A-.' },
];
const schemas = [
  buildCalculatorSchema(meta, path),
  buildBreadcrumbSchema(breadcrumbs),
  buildFAQSchema(faqs),
  buildSpeakableSchema(path),
  buildHowToSchema({
    name: 'How to calculate your class grade',
    description: 'Find your weighted class grade and the score you need on the final exam.',
    totalTime: 'PT2M',
    estimatedCost: { value: '0', currency: 'USD' },
    steps: [
      { name: 'Enter each category', text: 'Add homework, tests and projects with their score % and weight %.' },
      { name: 'Read your weighted grade', text: 'The tool weights each score and shows your overall percentage and letter.' },
      { name: 'Plan the final', text: 'Switch tabs, enter your current grade, target and the final\'s weight to see what you need.' },
    ],
  }),
];
const relatedCalcs = [
  { name: 'GPA Calculator', href: '/math/gpa-calculator/', desc: 'Weighted 4.0 GPA.', icon: '🎓', color: 'bg-lime-accent' },
  { name: 'CGPA to Percentage', href: '/math/cgpa-to-percentage-calculator/', desc: 'CGPA ↔ % converter.', icon: '🎓', color: 'bg-violet-300' },
  { name: 'Percentage Calculator', href: '/math/percentage-calculator/', desc: 'X% of Y, % change.', icon: '🧮', color: 'bg-yellow-accent' },
  { name: 'Fraction Calculator', href: '/math/fraction-calculator/', desc: 'Add, simplify fractions.', icon: '½', color: 'bg-cyan-accent' },
];
---

<BaseLayout title="Grade Calculator: Weighted Grade & Final Exam Needed" description={meta.description} schemas={schemas} publishedTime={meta.lastUpdated} modifiedTime={meta.lastUpdated}>
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-cyan-accent/30 rounded-full blur-[120px] float-slow"></div>
      <div class="absolute top-[5%] right-[-10%] w-[400px] h-[400px] bg-lime-accent/25 rounded-full blur-[120px] float-slow-2"></div>
    </div>
    <div class="container-wide relative pt-8 pb-10 md:pt-12 md:pb-14">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-1.5 text-xs sm:text-sm">
          {breadcrumbs.map((item, idx) => (
            <li class="flex items-center gap-1.5">
              {idx === breadcrumbs.length - 1 ? (
                <span class="px-3 py-1 rounded-full bg-ink-900 text-white font-bold border-2 border-ink-900">{item.name}</span>
              ) : (
                <>
                  <a href={item.url} class="px-3 py-1 rounded-full bg-white border-2 border-ink-200 text-ink-700 font-semibold hover:border-ink-900 hover:text-ink-900 no-underline transition-colors">{item.name}</a>
                  <svg class="w-3 h-3 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </>
              )}
            </li>
          ))}
        </ol>
      </nav>
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="chip bg-cyan-accent text-ink-900">📝 School</span>
          <span class="chip-lime">🧮 Math</span>
          <span class="chip-white"><span class="text-ink-500">Updated</span><span>{meta.lastUpdated}</span></span>
        </div>
        <h1 class="!text-4xl sm:!text-5xl md:!text-6xl !font-extrabold !tracking-tight !leading-[1.05] text-ink-900" style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.035em;">
          Grade <span class="text-gradient-brand">Calculator.</span>
        </h1>
        <div class="mt-7 bg-yellow-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker">
          <div class="flex items-start gap-3">
            <div class="text-2xl">⚡</div>
            <div>
              <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-1">Quick answer</div>
              <p class="speakable-answer text-ink-900 text-base sm:text-lg leading-relaxed font-medium !m-0">
                Your <strong>weighted grade</strong> = Σ(score × weight) ÷ Σ(weight). To find the score you need on a final: <strong>needed = (goal − current × (1 − finalWeight)) ÷ finalWeight</strong>. Enter your categories below, or switch tabs to plan the final exam.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wide pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto">
      <GradeCalculator client:load />
    </div>
  </section>

  <!-- BANDS TABLE -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-3xl mx-auto">
        <span class="chip bg-cyan-accent text-ink-900 mb-4">📊 Quick reference</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Percentage to letter grade.</h2>
        <div class="mt-8 overflow-x-auto">
          <table class="w-full bg-white border-[2.5px] border-ink-900 rounded-2xl shadow-sticker-sm overflow-hidden border-separate border-spacing-0 text-sm">
            <thead><tr class="bg-ink-900 text-white">
              <th class="text-left p-3 font-extrabold">Letter</th>
              <th class="text-right p-3 font-extrabold">Percentage range</th>
            </tr></thead>
            <tbody>
              {bands.map((r, i) => (
                <tr class={`border-b-2 border-ink-100 ${i % 2 ? 'bg-ink-50' : ''}`}>
                  <td class="p-3 font-extrabold text-ink-900">{r.l}</td>
                  <td class="p-3 text-right font-semibold text-ink-700">{r.r}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-3xl mx-auto">
      <span class="chip-yellow mb-4">❓ FAQ</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Common questions.</h2>
      <div class="space-y-3 mt-8">
        {faqs.map((faq, idx) => (
          <details class="group bg-white border-2 border-ink-900 rounded-2xl shadow-sticker-sm hover:shadow-sticker transition-all" open={idx === 0}>
            <summary class="cursor-pointer p-5 md:p-6 font-extrabold text-ink-900 flex items-center justify-between gap-4 list-none">
              <span class="text-base md:text-lg" style="font-family: 'Inter Tight', sans-serif;">{faq.q}</span>
              <span class="flex-shrink-0 w-9 h-9 rounded-full bg-ink-900 group-open:bg-lime-accent flex items-center justify-center transition-colors">
                <svg class="w-4 h-4 text-white group-open:text-ink-900 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </span>
            </summary>
            <div class="px-5 md:px-6 pb-5 md:pb-6 text-ink-700 leading-relaxed font-medium">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <span class="chip bg-cyan-accent text-ink-900 mb-4">🔗 Related</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Try these next.</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-8">
          {relatedCalcs.map((c) => (
            <a href={c.href} class={`group ${c.color} border-[2.5px] border-ink-900 rounded-3xl p-5 no-underline shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200`}>
              <div class="text-3xl mb-3 group-hover:rotate-12 transition-transform inline-block">{c.icon}</div>
              <div class="font-extrabold text-ink-900 text-base leading-tight" style="font-family: 'Inter Tight', sans-serif;">{c.name}</div>
              <p class="text-xs text-ink-800 mt-1.5 leading-snug font-medium">{c.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
