---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DiscountCalculator from '../../components/calculators/DiscountCalculator.tsx';
import { buildCalculatorSchema, buildBreadcrumbSchema, buildFAQSchema } from '../../lib/seo';

const meta = {
  slug: 'discount-calculator',
  name: 'Discount Calculator',
  description: 'Free discount calculator. Find sale price from % off, compute discount % from original vs sale price, or reverse-engineer the original price. Three modes in one.',
  category: 'math' as const,
  keywords: ['discount calculator', 'percent off calculator', 'sale price calculator', 'how much is X off', 'discount percentage', 'savings calculator'],
  lastUpdated: '2026-05-25',
  ratingValue: '4.8',
  ratingCount: '294',
};
const path = '/math/discount-calculator';
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Math', url: '/math/' },
  { name: 'Discount Calculator', url: path },
];
const faqs = [
  {
    q: 'How do I calculate a percentage discount?',
    a: 'Sale price = Original price × (1 − discount% / 100). For example, $120 at 35% off: 120 × (1 − 0.35) = 120 × 0.65 = $78. You save $42.',
  },
  {
    q: 'How do I find the discount percentage from two prices?',
    a: 'Discount % = ((Original − Sale) / Original) × 100. For example, $120 original, $78 sale: ((120 − 78) / 120) × 100 = 35%. Use "Sale Price" mode in the calculator.',
  },
  {
    q: 'How do I find the original price from a discounted price?',
    a: 'Original price = Sale price / (1 − discount% / 100). If you paid $78 and there was a 35% discount: 78 / 0.65 = $120. Use "Original" mode in the calculator.',
  },
  {
    q: 'What is the bulk savings feature?',
    a: 'The bulk savings row shows the total cost and total savings if you buy 1, 2, or 3 units at the same discounted price. Useful for comparing multi-unit purchases.',
  },
  {
    q: 'Does this calculator handle tiered or stacked discounts?',
    a: 'This calculator handles a single discount. For stacked discounts (e.g., 20% off then an extra 10% off), apply the first discount to get a new price, then apply the second discount to that result.',
  },
];
const schemas = [buildCalculatorSchema(meta, path), buildBreadcrumbSchema(breadcrumbs), buildFAQSchema(faqs)];
const relatedCalcs = [
  { name: 'Tip Calculator', href: '/math/tip-calculator/', desc: 'Split bills & tips.', icon: '🍽️', color: 'bg-yellow-accent' },
  { name: 'Percentage Calculator', href: '/math/percentage-calculator/', desc: 'Percents in 3 modes.', icon: '🧮', color: 'bg-lime-accent' },
  { name: 'Age Calculator', href: '/date-time/age-calculator/', desc: 'Exact age instantly.', icon: '🎂', color: 'bg-cyan-accent' },
  { name: 'Date Difference', href: '/date-time/date-difference-calculator/', desc: 'Days between dates.', icon: '📅', color: 'bg-pink-accent' },
];

---

<BaseLayout
  title="Discount Calculator: Sale Price & % Off"
  description={meta.description}
  schemas={schemas}
  publishedTime={meta.lastUpdated}
  modifiedTime={meta.lastUpdated}
>
  <!-- HERO -->
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-pink-accent/30 rounded-full blur-[120px] float-slow"></div>
      <div class="absolute top-[5%] right-[-10%] w-[400px] h-[400px] bg-lime-accent/25 rounded-full blur-[120px] float-slow-2"></div>
    </div>
    <div class="container-wide relative pt-8 pb-10 md:pt-12 md:pb-14">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-1.5 text-xs sm:text-sm">
          {breadcrumbs.map((item, idx) => (
            <li class="flex items-center gap-1.5">
              {idx === breadcrumbs.length - 1 ? (
                <span class="px-3 py-1 rounded-full bg-ink-900 text-white font-bold border-2 border-ink-900">{item.name}</span>
              ) : (
                <>
                  <a href={item.url} class="px-3 py-1 rounded-full bg-white border-2 border-ink-200 text-ink-700 font-semibold hover:border-ink-900 hover:text-ink-900 no-underline transition-colors">{item.name}</a>
                  <svg class="w-3 h-3 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </>
              )}
            </li>
          ))}
        </ol>
      </nav>
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="chip bg-pink-accent text-white">🏷️ Math</span>
          <span class="chip-lime">3 modes</span>
          <span class="chip-white"><span class="text-ink-500">Last tested</span><span>{meta.lastUpdated}</span></span>
        </div>
        <h1
          class="!text-4xl sm:!text-5xl md:!text-6xl !font-extrabold !tracking-tight !leading-[1.05] text-ink-900"
          style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.035em;"
        >
          Discount Calculator <span class="text-gradient-brand">3 ways to solve it.</span>
        </h1>
        <div class="mt-7 bg-lime-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker speakable-answer">
          <div class="flex items-start gap-3">
            <div class="text-2xl">⚡</div>
            <div>
              <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-1">Quick answer</div>
              <p class="text-ink-900 text-base sm:text-lg leading-relaxed font-medium !m-0">
                A <strong>$120 item at 35% off</strong> costs <strong>$78</strong>. You save <strong>$42</strong>. Switch modes to find the discount %, original price, or how much you'd save buying 2–3 units.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CALCULATOR -->
  <section class="container-wide pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto">
      <DiscountCalculator client:visible />
    </div>
  </section>

  <!-- THE 3 MODES -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <span class="chip-pink mb-4">🧮 Three formulas</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">One unknown, three ways.</h2>
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-5 mt-8">
          <div class="bg-lime-accent border-[2.5px] border-ink-900 rounded-2xl p-6 shadow-sticker-sm">
            <div class="text-[10px] font-extrabold uppercase tracking-wider text-ink-900 mb-2">Mode 1: % Off</div>
            <div class="font-mono font-bold text-ink-900 text-sm">Sale = Original × (1 − %/100)</div>
            <p class="text-sm text-ink-900 mt-3 font-medium">$120 at 35% off → $120 × 0.65 = <strong>$78</strong></p>
          </div>
          <div class="bg-cyan-accent border-[2.5px] border-ink-900 rounded-2xl p-6 shadow-sticker-sm">
            <div class="text-[10px] font-extrabold uppercase tracking-wider text-ink-900 mb-2">Mode 2: Sale Price → %</div>
            <div class="font-mono font-bold text-ink-900 text-sm">% = ((Orig − Sale) / Orig) × 100</div>
            <p class="text-sm text-ink-900 mt-3 font-medium">$120 → $78 → ((120−78)/120) × 100 = <strong>35%</strong></p>
          </div>
          <div class="bg-pink-accent border-[2.5px] border-ink-900 rounded-2xl p-6 shadow-sticker-sm">
            <div class="text-[10px] font-extrabold uppercase tracking-wider text-white mb-2">Mode 3: Find Original</div>
            <div class="font-mono font-bold text-white text-sm">Orig = Sale / (1 − %/100)</div>
            <p class="text-sm text-white mt-3 font-medium">Paid $78 at 35% off → $78 / 0.65 = <strong>$120</strong></p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-3xl mx-auto speakable-summary">
      <span class="chip-yellow mb-4">❓ FAQ</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Common questions.</h2>
      <div class="space-y-3 mt-8">
        {faqs.map((faq, idx) => (
          <details class="group bg-white border-2 border-ink-900 rounded-2xl shadow-sticker-sm hover:shadow-sticker transition-all" open={idx === 0}>
            <summary class="cursor-pointer p-5 md:p-6 font-extrabold text-ink-900 flex items-center justify-between gap-4 list-none">
              <span class="text-base md:text-lg" style="font-family: 'Inter Tight', sans-serif;">{faq.q}</span>
              <span class="flex-shrink-0 w-9 h-9 rounded-full bg-ink-900 group-open:bg-lime-accent flex items-center justify-center transition-colors">
                <svg class="w-4 h-4 text-white group-open:text-ink-900 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </span>
            </summary>
            <div class="px-5 md:px-6 pb-5 md:pb-6 text-ink-700 leading-relaxed font-medium">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <span class="chip bg-violet-300 text-ink-900 mb-4">🔗 Related</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Try these next.</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-8">
          {relatedCalcs.map((c) => (
            <a href={c.href} class={`group ${c.color} border-[2.5px] border-ink-900 rounded-3xl p-5 no-underline shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200`}>
              <div class="text-3xl mb-3 group-hover:rotate-12 transition-transform inline-block">{c.icon}</div>
              <div class="font-extrabold text-ink-900 text-base leading-tight" style="font-family: 'Inter Tight', sans-serif;">{c.name}</div>
              <p class="text-xs text-ink-800 mt-1.5 leading-snug font-medium">{c.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
