---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RatioCalculator from '../../components/calculators/RatioCalculator.tsx';
import { buildCalculatorSchema, buildBreadcrumbSchema, buildFAQSchema, buildHowToSchema, buildSpeakableSchema } from '../../lib/seo';

const meta = {
  slug: 'ratio-calculator', name: 'Ratio Calculator',
  description: 'Free ratio calculator to solve proportions (A:B = C:D), find a missing value, simplify ratios to lowest terms, and scale recipes or mixes. Enter any three values and solve the fourth.',
  category: 'math' as const,
  keywords: ['ratio calculator', 'proportion calculator', 'simplify ratio', 'ratio solver', 'scale ratio', 'equivalent ratios'],
  lastUpdated: '2026-07-18',
};
const path = '/math/ratio-calculator';
const breadcrumbs = [
  { name: 'Home', url: '/' }, { name: 'Math', url: '/math/' }, { name: 'Ratio Calculator', url: path },
];

// Build-time equivalent-ratio reference for a common 2:3 ratio.
const scale = [1, 2, 3, 4, 5, 10].map((k) => ({ k, a: 2 * k, b: 3 * k }));

const faqs = [
  { q: 'How do you solve a ratio proportion?', a: 'A proportion says two ratios are equal: A:B = C:D, which is the same as A/B = C/D. Cross-multiply to get A×D = B×C, then solve for the unknown. For example, if 2:3 = 8:x, then 2×x = 3×8 = 24, so x = 12. Enter any three of the four values above and leave the fourth blank. The calculator cross-multiplies for you.' },
  { q: 'How do you simplify a ratio?', a: 'Divide both sides by their greatest common divisor (GCD). For 12:18, the GCD is 6, so it simplifies to 2:3. A ratio is in simplest form when the only whole number dividing both parts is 1. For ratios with decimals, first multiply both sides by 10, 100, etc. to clear the decimals, then reduce.' },
  { q: 'How do you scale a ratio up or down?', a: 'Multiply (or divide) both parts by the same number. To scale a 2:3 paint mix to make more, multiply both by 5 → 10:15, which keeps the same proportion. This is exactly how recipes are doubled or halved. The scaling table on this page shows the 2:3 ratio scaled from 1× to 10×.' },
  { q: 'What is the difference between a ratio and a fraction?', a: 'They\'re closely related but describe different things. A ratio A:B compares two quantities (e.g. 2 parts water to 3 parts cordial). A fraction expresses one part of a whole. That same mix is 2/5 water and 3/5 cordial. You can always turn a two-part ratio into fractions by putting each part over the total (2+3 = 5).' },
  { q: 'How do you convert a ratio to a percentage?', a: 'Add the parts to get the total, then divide each part by the total and multiply by 100. For 2:3, the total is 5, so the split is 40% (2/5) and 60% (3/5). This is useful for turning odds, mixes, and allocations into percentages.' },
];
const schemas = [
  buildCalculatorSchema(meta, path),
  buildBreadcrumbSchema(breadcrumbs),
  buildFAQSchema(faqs),
  buildSpeakableSchema(path),
  buildHowToSchema({
    name: 'How to solve a ratio proportion',
    description: 'Find a missing value in a proportion A:B = C:D by cross-multiplying.',
    totalTime: 'PT1M',
    estimatedCost: { value: '0', currency: 'USD' },
    steps: [
      { name: 'Enter three values', text: 'Fill in three of the four boxes in A : B = C : D.' },
      { name: 'Leave one blank', text: 'The empty box is the unknown you want to find.' },
      { name: 'Read the answer', text: 'The calculator cross-multiplies (A×D = B×C) and solves for the missing term.' },
    ],
  }),
];
const relatedCalcs = [
  { name: 'Fraction Calculator', href: '/math/fraction-calculator/', desc: 'Add, simplify fractions.', icon: '½', color: 'bg-cyan-accent' },
  { name: 'Percentage Calculator', href: '/math/percentage-calculator/', desc: 'X% of Y, % change.', icon: '🧮', color: 'bg-lime-accent' },
  { name: 'Discount Calculator', href: '/math/discount-calculator/', desc: 'Sale price & savings.', icon: '🏷️', color: 'bg-yellow-accent' },
  { name: 'GPA Calculator', href: '/math/gpa-calculator/', desc: 'Weighted 4.0 GPA.', icon: '🎓', color: 'bg-violet-300' },
];
---

<BaseLayout title="Ratio Calculator: Solve Proportions & Simplify Ratios" description={meta.description} schemas={schemas} publishedTime={meta.lastUpdated} modifiedTime={meta.lastUpdated}>
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-lime-accent/30 rounded-full blur-[120px] float-slow"></div>
      <div class="absolute top-[5%] right-[-10%] w-[400px] h-[400px] bg-cyan-accent/25 rounded-full blur-[120px] float-slow-2"></div>
    </div>
    <div class="container-wide relative pt-8 pb-10 md:pt-12 md:pb-14">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-1.5 text-xs sm:text-sm">
          {breadcrumbs.map((item, idx) => (
            <li class="flex items-center gap-1.5">
              {idx === breadcrumbs.length - 1 ? (
                <span class="px-3 py-1 rounded-full bg-ink-900 text-white font-bold border-2 border-ink-900">{item.name}</span>
              ) : (
                <>
                  <a href={item.url} class="px-3 py-1 rounded-full bg-white border-2 border-ink-200 text-ink-700 font-semibold hover:border-ink-900 hover:text-ink-900 no-underline transition-colors">{item.name}</a>
                  <svg class="w-3 h-3 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </>
              )}
            </li>
          ))}
        </ol>
      </nav>
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="chip bg-lime-accent text-ink-900">➗ Proportions</span>
          <span class="chip-lime">🧮 Math</span>
          <span class="chip-white"><span class="text-ink-500">Updated</span><span>{meta.lastUpdated}</span></span>
        </div>
        <h1 class="!text-4xl sm:!text-5xl md:!text-6xl !font-extrabold !tracking-tight !leading-[1.05] text-ink-900" style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.035em;">
          Ratio <span class="text-gradient-brand">Calculator.</span>
        </h1>
        <div class="mt-7 bg-yellow-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker">
          <div class="flex items-start gap-3">
            <div class="text-2xl">⚡</div>
            <div>
              <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-1">Quick answer</div>
              <p class="speakable-answer text-ink-900 text-base sm:text-lg leading-relaxed font-medium !m-0">
                A proportion <strong>A : B = C : D</strong> means A/B = C/D. To find a missing value, <strong>cross-multiply</strong>: A×D = B×C. Enter any three values below and leave one blank to solve it. The tool also <strong>simplifies A : B to lowest terms</strong>.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wide pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto">
      <RatioCalculator client:load />
    </div>
  </section>

  <!-- SCALING TABLE -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-3xl mx-auto">
        <span class="chip bg-lime-accent text-ink-900 mb-4">📊 Worked example</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Scaling a 2 : 3 ratio.</h2>
        <p class="mt-3 text-ink-700 font-medium">Multiply both parts by the same number and the ratio stays equivalent, the basis for doubling recipes or mixing paint.</p>
        <div class="mt-8 overflow-x-auto">
          <table class="w-full bg-white border-[2.5px] border-ink-900 rounded-2xl shadow-sticker-sm overflow-hidden border-separate border-spacing-0 text-sm">
            <thead><tr class="bg-ink-900 text-white">
              <th class="text-left p-3 font-extrabold">Scale</th>
              <th class="text-center p-3 font-extrabold">Part A</th>
              <th class="text-right p-3 font-extrabold">Part B</th>
            </tr></thead>
            <tbody>
              {scale.map((r, i) => (
                <tr class={`border-b-2 border-ink-100 ${i % 2 ? 'bg-ink-50' : ''}`}>
                  <td class="p-3 font-extrabold text-ink-900">×{r.k}</td>
                  <td class="p-3 text-center font-mono font-bold text-ink-900">{r.a}</td>
                  <td class="p-3 text-right font-mono font-bold text-ink-900">{r.b}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-3xl mx-auto">
      <span class="chip-yellow mb-4">❓ FAQ</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Common questions.</h2>
      <div class="space-y-3 mt-8">
        {faqs.map((faq, idx) => (
          <details class="group bg-white border-2 border-ink-900 rounded-2xl shadow-sticker-sm hover:shadow-sticker transition-all" open={idx === 0}>
            <summary class="cursor-pointer p-5 md:p-6 font-extrabold text-ink-900 flex items-center justify-between gap-4 list-none">
              <span class="text-base md:text-lg" style="font-family: 'Inter Tight', sans-serif;">{faq.q}</span>
              <span class="flex-shrink-0 w-9 h-9 rounded-full bg-ink-900 group-open:bg-lime-accent flex items-center justify-center transition-colors">
                <svg class="w-4 h-4 text-white group-open:text-ink-900 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </span>
            </summary>
            <div class="px-5 md:px-6 pb-5 md:pb-6 text-ink-700 leading-relaxed font-medium">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <span class="chip bg-lime-accent text-ink-900 mb-4">🔗 Related</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Try these next.</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-8">
          {relatedCalcs.map((c) => (
            <a href={c.href} class={`group ${c.color} border-[2.5px] border-ink-900 rounded-3xl p-5 no-underline shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200`}>
              <div class="text-3xl mb-3 group-hover:rotate-12 transition-transform inline-block">{c.icon}</div>
              <div class="font-extrabold text-ink-900 text-base leading-tight" style="font-family: 'Inter Tight', sans-serif;">{c.name}</div>
              <p class="text-xs text-ink-800 mt-1.5 leading-snug font-medium">{c.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
