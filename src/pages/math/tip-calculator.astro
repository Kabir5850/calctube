---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TipCalculator from '../../components/calculators/TipCalculator.tsx';
import AuthorBadge from '../../components/ui/AuthorBadge.astro';
import { buildCalculatorSchema, buildBreadcrumbSchema, buildFAQSchema } from '../../lib/seo';
import { getAuthor } from '../../data/authors';

const meta = {
  slug: 'tip-calculator',
  name: 'Tip Calculator',
  description: 'Free tip calculator. Enter bill amount, choose a tip percentage, and split between any number of people. Instant per-person totals.',
  category: 'math' as const,
  keywords: ['tip calculator', 'how much to tip', 'bill splitter', 'restaurant tip', 'tip split calculator', 'gratuity calculator'],
  lastUpdated: '2026-05-25',
  ratingValue: '4.9',
  ratingCount: '347',
};
const path = '/math/tip-calculator';
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Math', url: '/math/' },
  { name: 'Tip Calculator', url: path },
];
const faqs = [
  {
    q: 'What is a standard tip percentage?',
    a: '15% is the traditional minimum for sit-down restaurants in the US. 18–20% is now standard for good service. 25% is generous. For takeout, 10–15% is common. Bars typically see $1–2 per drink or 15–20% of the tab.',
  },
  {
    q: 'Should I tip on the pre-tax or post-tax amount?',
    a: 'Tipping on the pre-tax amount is technically correct, but most people tip on the total bill for simplicity. The difference on a typical restaurant check is only a dollar or two.',
  },
  {
    q: 'How do I split a bill unevenly?',
    a: 'This calculator assumes an even split. For uneven splits, calculate the total bill per-item first, then each person pays their items plus their share of the tip.',
  },
  {
    q: 'Is 20% the new standard tip?',
    a: 'In the US, yes — 20% has become the de-facto standard for full-service restaurants as of 2024–2026, reflecting rising costs and the decline of sub-minimum tipped wages in many states.',
  },
  {
    q: 'How do I calculate a 18% tip mentally?',
    a: 'Quick trick: find 10% (move decimal left one place), then add half of 10% to get 15%, then add ~3% more. For a $60 bill: 10% = $6, 15% = $9, 18% ≈ $10.80.',
  },
];
const schemas = [buildCalculatorSchema(meta, path), buildBreadcrumbSchema(breadcrumbs), buildFAQSchema(faqs)];
const relatedCalcs = [
  { name: 'Discount Calculator', href: '/math/discount-calculator/', desc: 'Sale price & savings.', icon: '🏷️', color: 'bg-lime-accent' },
  { name: 'Percentage Calculator', href: '/math/percentage-calculator/', desc: 'Percents in 3 modes.', icon: '🧮', color: 'bg-cyan-accent' },
  { name: 'Date Difference', href: '/date-time/date-difference-calculator/', desc: 'Days between dates.', icon: '📅', color: 'bg-yellow-accent' },
  { name: 'Age Calculator', href: '/date-time/age-calculator/', desc: 'Exact age in years.', icon: '🎂', color: 'bg-pink-accent' },
];

const reviewer = getAuthor('calctube-editorial')!;
---

<BaseLayout
  title="Tip Calculator — Split Bills & Gratuity in Seconds"
  description={meta.description}
  schemas={schemas}
  publishedTime={meta.lastUpdated}
  modifiedTime={meta.lastUpdated}
>
  <!-- HERO -->
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-yellow-accent/40 rounded-full blur-[120px] float-slow"></div>
      <div class="absolute top-[5%] right-[-10%] w-[400px] h-[400px] bg-lime-accent/30 rounded-full blur-[120px] float-slow-2"></div>
    </div>
    <div class="container-wide relative pt-8 pb-10 md:pt-12 md:pb-14">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-1.5 text-xs sm:text-sm">
          {breadcrumbs.map((item, idx) => (
            <li class="flex items-center gap-1.5">
              {idx === breadcrumbs.length - 1 ? (
                <span class="px-3 py-1 rounded-full bg-ink-900 text-white font-bold border-2 border-ink-900">{item.name}</span>
              ) : (
                <>
                  <a href={item.url} class="px-3 py-1 rounded-full bg-white border-2 border-ink-200 text-ink-700 font-semibold hover:border-ink-900 hover:text-ink-900 no-underline transition-colors">{item.name}</a>
                  <svg class="w-3 h-3 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </>
              )}
            </li>
          ))}
        </ol>
      </nav>
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="chip bg-yellow-accent text-ink-900">🍽️ Math</span>
          <span class="chip-lime">Bill splitter</span>
          <span class="chip-white"><span class="text-ink-500">Last tested</span><span>{meta.lastUpdated}</span></span>
        </div>
        <h1
          class="!text-4xl sm:!text-5xl md:!text-6xl !font-extrabold !tracking-tight !leading-[1.05] text-ink-900"
          style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.035em;"
        >
          Tip Calculator <span class="text-gradient-brand">no awkward math.</span>
        </h1>
        <div class="mt-7 bg-lime-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker speakable-answer">
          <div class="flex items-start gap-3">
            <div class="text-2xl">⚡</div>
            <div>
              <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-1">Quick answer</div>
              <p class="text-ink-900 text-base sm:text-lg leading-relaxed font-medium !m-0">
                On a <strong>$85 dinner with 18% tip split 4 ways</strong>: tip = <strong>$15.30</strong>, total = <strong>$100.30</strong>, per person = <strong>$25.08</strong>.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CALCULATOR -->
  <section class="container-wide pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto">
      <TipCalculator client:visible />
      {reviewer && <div class="mt-4"><AuthorBadge author={reviewer} verb="Verified" /></div>}
    </div>
  </section>

  <!-- TIP GUIDE -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <span class="chip-cyan mb-4">📋 Tipping guide</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">What's the right tip?</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mt-8">
          {[
            { service: 'Full-service restaurant', range: '18–25%', note: '20% is now standard in the US', color: 'bg-lime-accent' },
            { service: 'Takeout / Delivery', range: '10–15%', note: 'Optional but appreciated', color: 'bg-cyan-accent' },
            { service: 'Bar / Bartender', range: '$1–2/drink or 15–20%', note: 'Per drink or on total tab', color: 'bg-yellow-accent' },
            { service: 'Hotel housekeeping', range: '$3–5/night', note: 'Leave daily, not at checkout', color: 'bg-pink-accent' },
            { service: 'Taxi / Rideshare', range: '15–20%', note: 'Round up for short trips', color: 'bg-lime-accent' },
            { service: 'Hair / Beauty salon', range: '15–20%', note: 'On service total, not products', color: 'bg-cyan-accent' },
          ].map((row) => (
            <div class={`${row.color} border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker-sm`}>
              <div class="text-[10px] font-extrabold uppercase tracking-wider text-ink-700 mb-1">{row.service}</div>
              <div class="text-xl font-extrabold text-ink-900 mb-1" style="font-family: 'Inter Tight', sans-serif;">{row.range}</div>
              <div class="text-xs font-medium text-ink-700">{row.note}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-3xl mx-auto speakable-summary">
      <span class="chip-yellow mb-4">❓ FAQ</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Common questions.</h2>
      <div class="space-y-3 mt-8">
        {faqs.map((faq, idx) => (
          <details class="group bg-white border-2 border-ink-900 rounded-2xl shadow-sticker-sm hover:shadow-sticker transition-all" open={idx === 0}>
            <summary class="cursor-pointer p-5 md:p-6 font-extrabold text-ink-900 flex items-center justify-between gap-4 list-none">
              <span class="text-base md:text-lg" style="font-family: 'Inter Tight', sans-serif;">{faq.q}</span>
              <span class="flex-shrink-0 w-9 h-9 rounded-full bg-ink-900 group-open:bg-lime-accent flex items-center justify-center transition-colors">
                <svg class="w-4 h-4 text-white group-open:text-ink-900 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </span>
            </summary>
            <div class="px-5 md:px-6 pb-5 md:pb-6 text-ink-700 leading-relaxed font-medium">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <span class="chip bg-violet-300 text-ink-900 mb-4">🔗 Related</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Try these next.</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-8">
          {relatedCalcs.map((c) => (
            <a href={c.href} class={`group ${c.color} border-[2.5px] border-ink-900 rounded-3xl p-5 no-underline shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200`}>
              <div class="text-3xl mb-3 group-hover:rotate-12 transition-transform inline-block">{c.icon}</div>
              <div class="font-extrabold text-ink-900 text-base leading-tight" style="font-family: 'Inter Tight', sans-serif;">{c.name}</div>
              <p class="text-xs text-ink-800 mt-1.5 leading-snug font-medium">{c.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
