---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FractionCalculator from '../../components/calculators/FractionCalculator.tsx';
import { buildCalculatorSchema, buildBreadcrumbSchema, buildFAQSchema, buildHowToSchema, buildSpeakableSchema } from '../../lib/seo';

const meta = {
  slug: 'fraction-calculator', name: 'Fraction Calculator',
  description: 'Free fraction calculator to add, subtract, multiply and divide fractions. Get the answer reduced to lowest terms, as a mixed number, and as a decimal, with the steps.',
  category: 'math' as const,
  keywords: ['fraction calculator', 'adding fractions', 'multiply fractions', 'divide fractions', 'simplify fractions', 'fractions to decimal'],
  lastUpdated: '2026-07-18',
};
const path = '/math/fraction-calculator';
const breadcrumbs = [
  { name: 'Home', url: '/' }, { name: 'Math', url: '/math/' }, { name: 'Fraction Calculator', url: path },
];

// Build-time common fraction → decimal → percent reference (unique, extractable content).
const table = [
  { f: '1/2', d: '0.5', p: '50%' },
  { f: '1/3', d: '0.333…', p: '33.33%' },
  { f: '2/3', d: '0.667…', p: '66.67%' },
  { f: '1/4', d: '0.25', p: '25%' },
  { f: '3/4', d: '0.75', p: '75%' },
  { f: '1/5', d: '0.2', p: '20%' },
  { f: '1/8', d: '0.125', p: '12.5%' },
  { f: '3/8', d: '0.375', p: '37.5%' },
  { f: '5/8', d: '0.625', p: '62.5%' },
  { f: '1/10', d: '0.1', p: '10%' },
  { f: '1/16', d: '0.0625', p: '6.25%' },
];

const faqs = [
  { q: 'How do you add fractions with different denominators?', a: 'Give them a common denominator, then add the numerators. The quick method: multiply crosswise. For a/b + c/d, the sum is (a×d + c×b) ÷ (b×d). For example 1/2 + 3/4 = (1×4 + 3×2)/(2×4) = (4 + 6)/8 = 10/8, which reduces to 5/4 or 1¼. This calculator does the cross-multiplication and the reducing for you.' },
  { q: 'How do you multiply and divide fractions?', a: 'To multiply, multiply the numerators together and the denominators together: 2/3 × 3/4 = 6/12 = 1/2. To divide, flip the second fraction and multiply (multiply by the reciprocal): 1/2 ÷ 3/4 = 1/2 × 4/3 = 4/6 = 2/3. Dividing by a fraction is the same as multiplying by its upside-down version.' },
  { q: 'How do you simplify (reduce) a fraction?', a: 'Divide the numerator and denominator by their greatest common divisor (GCD). For 10/8, the GCD is 2, so it reduces to 5/4. A fraction is in "lowest terms" when the only number that divides both top and bottom is 1. This tool always returns the fully reduced answer.' },
  { q: 'How do you convert a fraction to a decimal or percentage?', a: 'Divide the numerator by the denominator to get the decimal: 3/8 = 3 ÷ 8 = 0.375. Multiply the decimal by 100 for the percentage: 0.375 = 37.5%. Some fractions like 1/3 give repeating decimals (0.333…). The reference table on this page lists the most common conversions.' },
  { q: 'What is a mixed number vs an improper fraction?', a: 'An improper fraction has a numerator larger than its denominator, like 5/4. A mixed number writes the same value as a whole part plus a proper fraction: 5/4 = 1¼. To convert, divide: 5 ÷ 4 = 1 remainder 1, so it\'s 1 and 1/4. This calculator shows both forms whenever the answer is bigger than 1.' },
];
const schemas = [
  buildCalculatorSchema(meta, path),
  buildBreadcrumbSchema(breadcrumbs),
  buildFAQSchema(faqs),
  buildSpeakableSchema(path),
  buildHowToSchema({
    name: 'How to add two fractions',
    description: 'Add, subtract, multiply or divide two fractions and reduce the answer.',
    totalTime: 'PT1M',
    estimatedCost: { value: '0', currency: 'USD' },
    steps: [
      { name: 'Enter the fractions', text: 'Type the numerator and denominator of each fraction.' },
      { name: 'Pick the operation', text: 'Choose add (+), subtract (−), multiply (×) or divide (÷).' },
      { name: 'Read the reduced answer', text: 'The result is shown in lowest terms, as a mixed number, and as a decimal.' },
    ],
  }),
];
const relatedCalcs = [
  { name: 'Percentage Calculator', href: '/math/percentage-calculator/', desc: 'X% of Y, % change.', icon: '🧮', color: 'bg-lime-accent' },
  { name: 'Ratio Calculator', href: '/math/ratio-calculator/', desc: 'Solve & simplify ratios.', icon: '➗', color: 'bg-cyan-accent' },
  { name: 'Discount Calculator', href: '/math/discount-calculator/', desc: 'Sale price & savings.', icon: '🏷️', color: 'bg-yellow-accent' },
  { name: 'GPA Calculator', href: '/math/gpa-calculator/', desc: 'Weighted 4.0 GPA.', icon: '🎓', color: 'bg-violet-300' },
];
---

<BaseLayout title="Fraction Calculator: Add, Subtract, Multiply & Divide" description={meta.description} schemas={schemas} publishedTime={meta.lastUpdated} modifiedTime={meta.lastUpdated}>
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-cyan-accent/30 rounded-full blur-[120px] float-slow"></div>
      <div class="absolute top-[5%] right-[-10%] w-[400px] h-[400px] bg-lime-accent/25 rounded-full blur-[120px] float-slow-2"></div>
    </div>
    <div class="container-wide relative pt-8 pb-10 md:pt-12 md:pb-14">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-1.5 text-xs sm:text-sm">
          {breadcrumbs.map((item, idx) => (
            <li class="flex items-center gap-1.5">
              {idx === breadcrumbs.length - 1 ? (
                <span class="px-3 py-1 rounded-full bg-ink-900 text-white font-bold border-2 border-ink-900">{item.name}</span>
              ) : (
                <>
                  <a href={item.url} class="px-3 py-1 rounded-full bg-white border-2 border-ink-200 text-ink-700 font-semibold hover:border-ink-900 hover:text-ink-900 no-underline transition-colors">{item.name}</a>
                  <svg class="w-3 h-3 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </>
              )}
            </li>
          ))}
        </ol>
      </nav>
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="chip bg-cyan-accent text-ink-900">➗ Arithmetic</span>
          <span class="chip-lime">🧮 Math</span>
          <span class="chip-white"><span class="text-ink-500">Updated</span><span>{meta.lastUpdated}</span></span>
        </div>
        <h1 class="!text-4xl sm:!text-5xl md:!text-6xl !font-extrabold !tracking-tight !leading-[1.05] text-ink-900" style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.035em;">
          Fraction <span class="text-gradient-brand">Calculator.</span>
        </h1>
        <div class="mt-7 bg-yellow-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker">
          <div class="flex items-start gap-3">
            <div class="text-2xl">⚡</div>
            <div>
              <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-1">Quick answer</div>
              <p class="speakable-answer text-ink-900 text-base sm:text-lg leading-relaxed font-medium !m-0">
                Enter two fractions and an operation. To <strong>add or subtract</strong>, use a common denominator: a/b ± c/d = (a·d ± c·b)/(b·d). To <strong>multiply</strong>, go straight across; to <strong>divide</strong>, flip the second and multiply. Every answer is <strong>reduced to lowest terms</strong> and shown as a decimal.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wide pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto">
      <FractionCalculator client:load />
    </div>
  </section>

  <!-- REFERENCE TABLE -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-3xl mx-auto">
        <span class="chip bg-cyan-accent text-ink-900 mb-4">📊 Quick reference</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Common fractions to decimals & percent.</h2>
        <div class="mt-8 overflow-x-auto">
          <table class="w-full bg-white border-[2.5px] border-ink-900 rounded-2xl shadow-sticker-sm overflow-hidden border-separate border-spacing-0 text-sm">
            <thead><tr class="bg-ink-900 text-white">
              <th class="text-left p-3 font-extrabold">Fraction</th>
              <th class="text-center p-3 font-extrabold">Decimal</th>
              <th class="text-right p-3 font-extrabold">Percentage</th>
            </tr></thead>
            <tbody>
              {table.map((r, i) => (
                <tr class={`border-b-2 border-ink-100 ${i % 2 ? 'bg-ink-50' : ''}`}>
                  <td class="p-3 font-extrabold text-ink-900">{r.f}</td>
                  <td class="p-3 text-center font-mono font-bold text-ink-900">{r.d}</td>
                  <td class="p-3 text-right font-semibold text-ink-700">{r.p}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-3xl mx-auto">
      <span class="chip-yellow mb-4">❓ FAQ</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Common questions.</h2>
      <div class="space-y-3 mt-8">
        {faqs.map((faq, idx) => (
          <details class="group bg-white border-2 border-ink-900 rounded-2xl shadow-sticker-sm hover:shadow-sticker transition-all" open={idx === 0}>
            <summary class="cursor-pointer p-5 md:p-6 font-extrabold text-ink-900 flex items-center justify-between gap-4 list-none">
              <span class="text-base md:text-lg" style="font-family: 'Inter Tight', sans-serif;">{faq.q}</span>
              <span class="flex-shrink-0 w-9 h-9 rounded-full bg-ink-900 group-open:bg-lime-accent flex items-center justify-center transition-colors">
                <svg class="w-4 h-4 text-white group-open:text-ink-900 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </span>
            </summary>
            <div class="px-5 md:px-6 pb-5 md:pb-6 text-ink-700 leading-relaxed font-medium">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <span class="chip bg-cyan-accent text-ink-900 mb-4">🔗 Related</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Try these next.</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-8">
          {relatedCalcs.map((c) => (
            <a href={c.href} class={`group ${c.color} border-[2.5px] border-ink-900 rounded-3xl p-5 no-underline shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200`}>
              <div class="text-3xl mb-3 group-hover:rotate-12 transition-transform inline-block">{c.icon}</div>
              <div class="font-extrabold text-ink-900 text-base leading-tight" style="font-family: 'Inter Tight', sans-serif;">{c.name}</div>
              <p class="text-xs text-ink-800 mt-1.5 leading-snug font-medium">{c.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
