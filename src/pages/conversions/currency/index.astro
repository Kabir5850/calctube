---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/ui/Breadcrumbs.astro';
import FlagIcon from '../../../components/ui/FlagIcon.astro';
import { buildBreadcrumbSchema, buildFAQSchema } from '../../../lib/seo';
import { currencyPairs, currencies } from '../../../data/currency-pairs';
import { flagSlugForCurrency } from '../../../lib/flag-helpers';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Conversions', url: '/conversions/' },
  { name: 'Currency', url: '/conversions/currency/' },
];

// Group by source currency for the hub layout
const byFrom = new Map<string, typeof currencyPairs>();
for (const p of currencyPairs) {
  if (!byFrom.has(p.from)) byFrom.set(p.from, [] as any);
  byFrom.get(p.from)!.push(p);
}
const groups = [...byFrom.entries()]
  .map(([code, pairs]) => ({ code, currency: currencies[code], pairs }))
  .filter((g) => g.currency)
  .sort((a, b) => b.pairs.length - a.pairs.length);

const huge = currencyPairs.filter((p) => p.popularity === 'huge');

const faqs = [
  { q: 'How many currency converters does Calctube offer?', a: `Calctube currently offers ${currencyPairs.length} live currency converters covering all major global pairs, GCC remittance corridors, Indian diaspora flows, African and Latin American emerging currencies, and Pacific markets.` },
  { q: 'How accurate are the rates?', a: 'Rates are mid-market reference rates updated at build time. For live transactional rates (with bank or remitter spread), check your provider — Wise, Remitly, Western Union, and direct bank rails will all differ from mid-market by 0.3–3%.' },
  { q: 'Which is the most-searched currency pair?', a: 'Globally, EUR/USD has the highest forex trading volume. For Indian remittance users, USD/INR is most-searched, followed by AED/INR (UAE diaspora), GBP/INR (UK), CAD/INR (Canada), and AUD/INR (Australia).' },
  { q: 'Are these rates good for forex trading?', a: 'No — Calctube rates are for reference and remittance planning, not for trading. Forex traders should use a regulated broker with live tick data and a trading platform.' },
];
---

<BaseLayout
  title={`Currency Converter — ${currencyPairs.length}+ Live Exchange Rates | Calctube`}
  description={`Free currency converters for ${currencyPairs.length}+ pairs. USD INR, EUR GBP, AED SAR remittance rates, plus 30+ exotic emerging-market pairs. Mid-market rates, no signup.`}
  schemas={[buildBreadcrumbSchema(breadcrumbs), buildFAQSchema(faqs)]}
>
  <div class="container-prose py-8">
    <Breadcrumbs items={breadcrumbs} />
    <h1>Currency Converters</h1>
    <p class="text-lg text-slate-700 mt-3">
      {currencyPairs.length} live currency pairs — major global crosses, GCC remittance corridors, Indian diaspora flows, plus emerging-market exotics.
    </p>

    <h2 class="mt-10">Most-searched pairs</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3 mt-4">
      {
        huge.map((p) => (
          <a
            href={`/conversions/currency/${p.slug}/`}
            class="card hover:border-brand-300 no-underline block"
          >
            <div class="font-semibold text-slate-900 text-sm flex items-center gap-1.5 flex-wrap">
              {flagSlugForCurrency(p.from) && <FlagIcon slug={flagSlugForCurrency(p.from)!} size={18} alt={p.from} />}
              <span>{p.from} → {p.to}</span>
              {flagSlugForCurrency(p.to) && <FlagIcon slug={flagSlugForCurrency(p.to)!} size={18} alt={p.to} />}
            </div>
            <div class="text-xs text-slate-600 mt-1">1 {p.from} = {p.rate} {p.to}</div>
          </a>
        ))
      }
    </div>

    {
      groups.map((g) => (
        <section class="mt-12">
          <h2 class="!mt-0 flex items-center gap-2 flex-wrap">
            <span>From</span>
            {flagSlugForCurrency(g.code) && <FlagIcon slug={flagSlugForCurrency(g.code)!} size={24} alt={g.currency.name} />}
            <span>{g.currency.name} ({g.code})</span>
            <span class="text-sm text-slate-500 font-normal ml-2">{g.pairs.length} pairs</span>
          </h2>
          <p class="text-sm text-slate-600 !mt-1">{g.currency.popularUses.join(' · ')}</p>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-2 mt-4">
            {g.pairs.map((p) => (
              <a
                href={`/conversions/currency/${p.slug}/`}
                class="block px-3 py-2 rounded-lg border border-slate-200 hover:border-brand-400 hover:bg-brand-50 no-underline text-sm"
              >
                <span class="font-semibold text-slate-900">{p.from} → {p.to}</span>
                <span class="text-slate-500 ml-2">{p.rate}</span>
              </a>
            ))}
          </div>
        </section>
      ))
    }

    <section class="mt-12">
      <h2>FAQ</h2>
      <dl class="mt-4 space-y-4">
        {
          faqs.map((f) => (
            <div class="card">
              <dt class="font-semibold text-slate-900">{f.q}</dt>
              <dd class="text-sm text-slate-700 mt-1 !leading-snug">{f.a}</dd>
            </div>
          ))
        }
      </dl>
    </section>
  </div>
</BaseLayout>
