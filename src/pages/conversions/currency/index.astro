---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/ui/Breadcrumbs.astro';
import FlagIcon from '../../../components/ui/FlagIcon.astro';
import { buildBreadcrumbSchema, buildFAQSchema } from '../../../lib/seo';
import { currencyPairs, currencies } from '../../../data/currency-pairs';
import { flagSlugForCurrency } from '../../../lib/flag-helpers';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Conversions', url: '/conversions/' },
  { name: 'Currency', url: '/conversions/currency/' },
];

// Group by source currency for the hub layout
const byFrom = new Map<string, typeof currencyPairs>();
for (const p of currencyPairs) {
  if (!byFrom.has(p.from)) byFrom.set(p.from, [] as any);
  byFrom.get(p.from)!.push(p);
}
const groups = [...byFrom.entries()]
  .map(([code, pairs]) => ({ code, currency: currencies[code], pairs }))
  .filter((g) => g.currency)
  .sort((a, b) => b.pairs.length - a.pairs.length);

const huge = currencyPairs.filter((p) => p.popularity === 'huge');

const faqs = [
  { q: 'How many currency converters does Calctube offer?', a: `Calctube currently offers ${currencyPairs.length} live currency converters covering all major global pairs, GCC remittance corridors, Indian diaspora flows, African and Latin American emerging currencies, and Pacific markets.` },
  { q: 'How accurate are the rates?', a: 'Rates are mid-market reference rates updated at build time. For live transactional rates (with bank or remitter spread), check your provider. Wise, Remitly, Western Union, and direct bank rails will all differ from mid-market by 0.3–3%.' },
  { q: 'Which is the most-searched currency pair?', a: 'Globally, EUR/USD has the highest forex trading volume. For Indian remittance users, USD/INR is most-searched, followed by AED/INR (UAE diaspora), GBP/INR (UK), CAD/INR (Canada), and AUD/INR (Australia).' },
  { q: 'Are these rates good for forex trading?', a: 'No. Calctube rates are for reference and remittance planning, not for trading. Forex traders should use a regulated broker with live tick data and a trading platform.' },
];
---

<BaseLayout
  title={`Currency Converter: ${currencyPairs.length}+ Live Exchange Rates | Calctube`}
  description={`Free currency converters for ${currencyPairs.length}+ pairs. USD INR, EUR GBP, AED SAR remittance rates, plus 30+ exotic emerging-market pairs. Mid-market rates, no signup.`}
  schemas={[buildBreadcrumbSchema(breadcrumbs), buildFAQSchema(faqs)]}
>
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-cyan-accent/25 rounded-full blur-[120px] float-slow"></div>
      <div class="absolute top-[5%] right-[-10%] w-[400px] h-[400px] bg-lime-accent/30 rounded-full blur-[120px] float-slow-2"></div>
    </div>
    <div class="container-wide relative pt-10 pb-10 md:pt-14 md:pb-12">
      <Breadcrumbs items={breadcrumbs} />
      <div class="flex flex-wrap items-center gap-2 mb-5">
        <span class="chip-cyan">💱 Currency</span>
        <span class="chip-white"><span class="text-ink-500">Pairs</span><span>{currencyPairs.length}</span></span>
        <span class="chip-white"><span class="text-ink-500">Base currencies</span><span>{groups.length}</span></span>
      </div>
      <h1 class="!text-4xl sm:!text-5xl md:!text-6xl !font-extrabold !tracking-tight !leading-[1.05] text-ink-900" style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.035em;">
        Currency Converters. <span class="text-gradient-brand">Live rates.</span>
      </h1>
      <p class="mt-5 text-lg text-ink-700 font-medium leading-relaxed max-w-3xl">
        {currencyPairs.length} live currency pairs: major global crosses, GCC remittance corridors, Indian diaspora flows, plus emerging-market exotics.
      </p>
    </div>
  </section>

  <section class="container-wide pb-16 md:pb-24">
    <h2 class="!text-2xl sm:!text-3xl !font-extrabold text-ink-900 !mt-0 !mb-4" style="font-family: 'Inter Tight', sans-serif;">Most-searched pairs</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
      {
        huge.map((p) => (
          <a
            href={`/conversions/currency/${p.slug}/`}
            class="group block bg-white border-[2.5px] border-ink-900 rounded-2xl p-4 no-underline shadow-sticker-sm hover:shadow-sticker hover:-translate-x-0.5 hover:-translate-y-0.5 transition-all duration-200"
          >
            <div class="font-extrabold text-ink-900 text-sm flex items-center gap-1.5 flex-wrap">
              {flagSlugForCurrency(p.from) && <FlagIcon slug={flagSlugForCurrency(p.from)!} size={18} alt={p.from} />}
              <span>{p.from} → {p.to}</span>
              {flagSlugForCurrency(p.to) && <FlagIcon slug={flagSlugForCurrency(p.to)!} size={18} alt={p.to} />}
            </div>
            <div class="text-xs text-ink-600 mt-1.5 font-semibold">1 {p.from} = {p.rate} {p.to}</div>
          </a>
        ))
      }
    </div>

    {
      groups.map((g) => (
        <section class="mt-14">
          <h2 class="!text-2xl sm:!text-3xl !font-extrabold text-ink-900 !mt-0 !mb-2 flex items-center gap-2 flex-wrap" style="font-family: 'Inter Tight', sans-serif;">
            <span>From</span>
            {flagSlugForCurrency(g.code) && <FlagIcon slug={flagSlugForCurrency(g.code)!} size={24} alt={g.currency.name} />}
            <span>{g.currency.name} ({g.code})</span>
            <span class="text-xs font-extrabold uppercase tracking-wider bg-white border-2 border-ink-900 rounded-full px-2.5 py-0.5 text-ink-900">{g.pairs.length} pairs</span>
          </h2>
          <p class="text-sm text-ink-600 font-medium max-w-3xl">{g.currency.popularUses.join(' · ')}</p>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-2 mt-4">
            {g.pairs.map((p) => (
              <a
                href={`/conversions/currency/${p.slug}/`}
                class="block px-3 py-2 rounded-xl bg-white border-2 border-ink-200 hover:border-ink-900 hover:bg-lime-accent/20 no-underline text-sm font-semibold text-ink-900 transition-colors"
              >
                <span>{p.from} → {p.to}</span>
                <span class="text-ink-500 ml-2">{p.rate}</span>
              </a>
            ))}
          </div>
        </section>
      ))
    }

    <section class="mt-14">
      <h2 class="!text-2xl sm:!text-3xl !font-extrabold text-ink-900 !mt-0 !mb-4" style="font-family: 'Inter Tight', sans-serif;">FAQ</h2>
      <dl class="grid gap-4 md:grid-cols-2">
        {
          faqs.map((f) => (
            <div class="card">
              <dt class="font-extrabold text-ink-900">{f.q}</dt>
              <dd class="text-sm text-ink-700 mt-2 !leading-snug font-medium">{f.a}</dd>
            </div>
          ))
        }
      </dl>
    </section>
  </section>
</BaseLayout>
