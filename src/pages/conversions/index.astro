---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HubHero from '../../components/ui/HubHero.astro';
import HubCard from '../../components/ui/HubCard.astro';
import { buildBreadcrumbSchema } from '../../lib/seo';
import { currencyPairs } from '../../data/currency-pairs';
import { buildHubCards } from '../../lib/category-hub';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Conversions', url: '/conversions/' },
];

// Derived from the calculators registry: see src/lib/category-hub.ts.
const cards = buildHubCards('conversion', {
  order: ['currency-converter-hub', 'unit-converter', 'temperature-converter', 'time-zone-converter'],
  copy: {
    'currency-converter-hub': {
      name: 'Currency Converters',
      desc: `Live exchange rates for ${currencyPairs.length}+ currency pairs: USD, INR, GBP, EUR, AED, SAR, and more.`,
      icon: '💱',
    },
    'unit-converter': { desc: 'Length, weight, volume, area, speed and data: km to miles, kg to lbs, cm to inches and more.' },
    'temperature-converter': { desc: 'Celsius, Fahrenheit and Kelvin: convert instantly, with a reference table from freezing to boiling.' },
    'time-zone-converter': { desc: 'Convert a time between world zones (EST, IST, GMT, PST) with daylight saving handled automatically.' },
  },
});

// The currency hub gets its own card with a live pair count; the rest are plain converters.
const currencyHub = cards.find((c) => c.slug === 'currency-converter-hub');
if (!currencyHub) throw new Error('[conversions] currency-converter-hub is missing from the calculators registry');
const categories = [{ ...currencyHub, count: currencyPairs.length }];
const converters = cards.filter((c) => c.slug !== 'currency-converter-hub');

const popular = currencyPairs.filter((p) => p.popularity === 'huge').slice(0, 12);
---

<BaseLayout
  title="Conversion Calculators: Currency & Units"
  description={`Free conversion calculators for currency (${currencyPairs.length}+ pairs), units, and more. Live rates, no signup, mobile-first.`}
  schemas={[buildBreadcrumbSchema(breadcrumbs)]}
>
  <HubHero
    breadcrumbs={breadcrumbs}
    chip="🔄 Conversions"
    chipClass="chip-yellow"
    stats={[
      { label: 'Currency pairs', value: String(currencyPairs.length) },
      { label: 'Converters', value: String(cards.length) },
    ]}
    titleLead="Conversion Calculators."
    titleAccent="Units and currency."
    intro="Free currency and unit converters. Live exchange rates updated regularly."
  />

  <section class="container-wide pb-16 md:pb-24">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {
        // The meta string carries a leading space: Astro trims the whitespace
        // between {name} and {meta} inside HubCard, so it has to come from here.
        categories.map((c) => (
          <HubCard href={c.href} name={c.name} desc={c.desc} icon={c.icon} meta={`· ${c.count} pairs`} />
        ))
      }
    </div>

    <h2
      class="!text-2xl sm:!text-3xl !font-extrabold text-ink-900 !mt-12 !mb-4"
      style="font-family: 'Inter Tight', sans-serif;"
    >
      Unit &amp; time converters
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {
        converters.map((c) => (
          <HubCard href={c.href} name={c.name} desc={c.desc} icon={c.icon} />
        ))
      }
    </div>

    <h2
      class="!text-2xl sm:!text-3xl !font-extrabold text-ink-900 !mt-12 !mb-4"
      style="font-family: 'Inter Tight', sans-serif;"
    >
      Most-searched currency pairs
    </h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
      {
        popular.map((p) => (
          <a
            href={`/conversions/currency/${p.slug}/`}
            class="block bg-white border-[2.5px] border-ink-900 rounded-2xl p-4 no-underline text-center shadow-sticker-sm hover:shadow-[6px_6px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-0.5 hover:-translate-y-0.5 transition-all duration-200"
          >
            <div class="font-extrabold text-ink-900" style="font-family: 'Inter Tight', sans-serif;">
              {p.from} → {p.to}
            </div>
            <div class="text-xs text-ink-600 mt-1 font-medium">1 {p.from} = {p.rate} {p.to}</div>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
