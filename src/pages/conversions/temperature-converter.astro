---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AuthorBadge from '../../components/ui/AuthorBadge.astro';
import TemperatureConverter from '../../components/calculators/TemperatureConverter.tsx';
import { buildCalculatorSchema, buildBreadcrumbSchema, buildFAQSchema, buildHowToSchema, buildSpeakableSchema } from '../../lib/seo';
import { getAuthor } from '../../data/authors';

const meta = {
  slug: 'temperature-converter', name: 'Temperature Converter',
  description: 'Free temperature converter for Celsius, Fahrenheit and Kelvin. Convert °C to °F and back instantly (°F = °C × 9/5 + 32), with a reference table from freezing to boiling.',
  category: 'conversion' as const,
  keywords: ['temperature converter', 'celsius to fahrenheit', 'fahrenheit to celsius', 'c to f', 'kelvin converter', 'celsius fahrenheit kelvin'],
  lastUpdated: '2026-07-18',
};
const path = '/conversions/temperature-converter';
const reviewer = getAuthor('calctube-editorial')!;
const breadcrumbs = [
  { name: 'Home', url: '/' }, { name: 'Conversions', url: '/conversions/' }, { name: 'Temperature Converter', url: path },
];

// Build-time C→F→K reference across meaningful points.
const points = [-40, -18, 0, 10, 20, 25, 30, 37, 40, 100];
const table = points.map((c) => ({ c, f: c * 9 / 5 + 32, k: c + 273.15 }));

const faqs = [
  { q: 'How do you convert Celsius to Fahrenheit?', a: 'Multiply the Celsius temperature by 9/5 (which is 1.8), then add 32: °F = °C × 9/5 + 32. So 20 °C = 20 × 1.8 + 32 = 68 °F, and 37 °C (body temperature) = 98.6 °F. A rough mental shortcut is "double it and add 30" — 20 °C → 40 + 30 = 70 °F, close to the exact 68.' },
  { q: 'How do you convert Fahrenheit to Celsius?', a: 'Subtract 32 first, then multiply by 5/9: °C = (°F − 32) × 5/9. So 98.6 °F = (98.6 − 32) × 5/9 = 37 °C, and 100 °F = 37.8 °C. The subtract-then-scale order matters — doing it the other way gives the wrong answer.' },
  { q: 'At what temperature do Celsius and Fahrenheit read the same?', a: 'At −40 degrees. −40 °C = −40 °F exactly — it\'s the single point where the two scales cross. You can verify it with the formula: −40 × 9/5 + 32 = −72 + 32 = −40. It\'s a handy sanity check that you\'ve got the conversion right.' },
  { q: 'What is Kelvin and how does it relate to Celsius?', a: 'Kelvin is the SI base unit of temperature, used in science. It has the same degree size as Celsius but starts at absolute zero — the coldest possible temperature — instead of water\'s freezing point. To convert, just add 273.15: K = °C + 273.15. So 0 °C = 273.15 K and 25 °C = 298.15 K. Kelvin never uses a degree symbol or negative values in normal use.' },
  { q: 'What is normal body temperature in Celsius and Fahrenheit?', a: 'Normal human body temperature is about 37 °C, which equals 98.6 °F. A reading of 38 °C (100.4 °F) or above is generally considered a fever. Because thermometers and individuals vary, anything from roughly 36.1–37.2 °C (97–99 °F) is within the normal range.' },
];
const schemas = [
  buildCalculatorSchema(meta, path),
  buildBreadcrumbSchema(breadcrumbs),
  buildFAQSchema(faqs),
  buildSpeakableSchema(path),
  buildHowToSchema({
    name: 'How to convert Celsius to Fahrenheit',
    description: 'Convert temperatures between Celsius, Fahrenheit and Kelvin.',
    totalTime: 'PT1M',
    estimatedCost: { value: '0', currency: 'USD' },
    steps: [
      { name: 'Enter a temperature', text: 'Type a value into the Celsius, Fahrenheit or Kelvin box.' },
      { name: 'Read the other two', text: 'The other scales update instantly using °F = °C × 9/5 + 32 and K = °C + 273.15.' },
    ],
  }),
];
const relatedCalcs = [
  { name: 'Unit Converter', href: '/conversions/unit-converter/', desc: 'Length, weight, volume…', icon: '🔄', color: 'bg-yellow-accent' },
  { name: 'Currency Converter', href: '/conversions/currency/', desc: '240+ live currency pairs.', icon: '💱', color: 'bg-lime-accent' },
  { name: 'BMI Calculator', href: '/health/bmi-calculator/', desc: 'Metric & imperial BMI.', icon: '⚖️', color: 'bg-rose-300' },
  { name: 'Age Calculator', href: '/date-time/age-calculator/', desc: 'Exact age in y/m/d.', icon: '🎂', color: 'bg-cyan-accent' },
];
---

<BaseLayout title="Temperature Converter — Celsius, Fahrenheit & Kelvin" description={meta.description} schemas={schemas} publishedTime={meta.lastUpdated} modifiedTime={meta.lastUpdated}>
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-cyan-accent/30 rounded-full blur-[120px] float-slow"></div>
      <div class="absolute top-[5%] right-[-10%] w-[400px] h-[400px] bg-yellow-accent/25 rounded-full blur-[120px] float-slow-2"></div>
    </div>
    <div class="container-wide relative pt-8 pb-10 md:pt-12 md:pb-14">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-1.5 text-xs sm:text-sm">
          {breadcrumbs.map((item, idx) => (
            <li class="flex items-center gap-1.5">
              {idx === breadcrumbs.length - 1 ? (
                <span class="px-3 py-1 rounded-full bg-ink-900 text-white font-bold border-2 border-ink-900">{item.name}</span>
              ) : (
                <>
                  <a href={item.url} class="px-3 py-1 rounded-full bg-white border-2 border-ink-200 text-ink-700 font-semibold hover:border-ink-900 hover:text-ink-900 no-underline transition-colors">{item.name}</a>
                  <svg class="w-3 h-3 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </>
              )}
            </li>
          ))}
        </ol>
      </nav>
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="chip bg-cyan-accent text-ink-900">🌡️ Conversions</span>
          <span class="chip-white"><span class="text-ink-500">Updated</span><span>{meta.lastUpdated}</span></span>
        </div>
        <h1 class="!text-4xl sm:!text-5xl md:!text-6xl !font-extrabold !tracking-tight !leading-[1.05] text-ink-900" style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.035em;">
          Temperature <span class="text-gradient-brand">Converter.</span>
        </h1>
        <div class="mt-7 bg-yellow-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker">
          <div class="flex items-start gap-3">
            <div class="text-2xl">⚡</div>
            <div>
              <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-1">Quick answer</div>
              <p class="speakable-answer text-ink-900 text-base sm:text-lg leading-relaxed font-medium !m-0">
                <strong>°F = °C × 9/5 + 32</strong> and <strong>°C = (°F − 32) × 5/9</strong>. For Kelvin, <strong>K = °C + 273.15</strong>. So 20 °C = 68 °F = 293.15 K, and −40 °C = −40 °F (the one point both scales agree). Type any value below.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wide pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto">
      <TemperatureConverter client:load />
      {reviewer && <div class="mt-4"><AuthorBadge author={reviewer} verb="Reviewed" /></div>}
    </div>
  </section>

  <!-- REFERENCE TABLE -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-3xl mx-auto">
        <span class="chip bg-cyan-accent text-ink-900 mb-4">📊 Quick reference</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Celsius, Fahrenheit & Kelvin at a glance.</h2>
        <div class="mt-8 overflow-x-auto">
          <table class="w-full bg-white border-[2.5px] border-ink-900 rounded-2xl shadow-sticker-sm overflow-hidden border-separate border-spacing-0 text-sm">
            <thead><tr class="bg-ink-900 text-white">
              <th class="text-left p-3 font-extrabold">Celsius</th>
              <th class="text-center p-3 font-extrabold">Fahrenheit</th>
              <th class="text-right p-3 font-extrabold">Kelvin</th>
            </tr></thead>
            <tbody>
              {table.map((r, i) => (
                <tr class={`border-b-2 border-ink-100 ${i % 2 ? 'bg-ink-50' : ''}`}>
                  <td class="p-3 font-extrabold text-ink-900">{r.c} °C</td>
                  <td class="p-3 text-center font-mono font-bold text-ink-900">{r.f.toFixed(1)} °F</td>
                  <td class="p-3 text-right font-mono font-bold text-ink-900">{r.k.toFixed(2)} K</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-3xl mx-auto">
      <span class="chip-yellow mb-4">❓ FAQ</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Common questions.</h2>
      <div class="space-y-3 mt-8">
        {faqs.map((faq, idx) => (
          <details class="group bg-white border-2 border-ink-900 rounded-2xl shadow-sticker-sm hover:shadow-sticker transition-all" open={idx === 0}>
            <summary class="cursor-pointer p-5 md:p-6 font-extrabold text-ink-900 flex items-center justify-between gap-4 list-none">
              <span class="text-base md:text-lg" style="font-family: 'Inter Tight', sans-serif;">{faq.q}</span>
              <span class="flex-shrink-0 w-9 h-9 rounded-full bg-ink-900 group-open:bg-lime-accent flex items-center justify-center transition-colors">
                <svg class="w-4 h-4 text-white group-open:text-ink-900 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </span>
            </summary>
            <div class="px-5 md:px-6 pb-5 md:pb-6 text-ink-700 leading-relaxed font-medium">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <span class="chip bg-cyan-accent text-ink-900 mb-4">🔗 Related</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Try these next.</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-8">
          {relatedCalcs.map((c) => (
            <a href={c.href} class={`group ${c.color} border-[2.5px] border-ink-900 rounded-3xl p-5 no-underline shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200`}>
              <div class="text-3xl mb-3 group-hover:rotate-12 transition-transform inline-block">{c.icon}</div>
              <div class="font-extrabold text-ink-900 text-base leading-tight" style="font-family: 'Inter Tight', sans-serif;">{c.name}</div>
              <p class="text-xs text-ink-800 mt-1.5 leading-snug font-medium">{c.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
