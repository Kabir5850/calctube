export function getStaticPaths() {
  // No WIRED_SLUGS reference here: Astro hoists getStaticPaths out of the
  // frontmatter, so consts declared below are not in scope at call time.
  return embeddableCalculators.map((calc) => ({
    params: { calculator: calc.slug },
    props: { calc },
  }));
}

const { calc } = Astro.props;
if (!WIRED_SLUGS.has(calc.slug)) {
  throw new Error(
    `[embed] no component wired for "${calc.slug}". Add its import, WIRED_SLUGS entry and ` +
      `tag in src/pages/embed/[calculator].astro, or exclude it via NOT_EMBEDDABLE in src/lib/embeds.ts.`
  );
}
const canonical = new URL(calc.href, SITE.url).toString();
