---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { AUTHORS, getAuthor } from '../../data/authors';
import { SITE } from '../../lib/seo';

export function getStaticPaths() {
  return AUTHORS.map((author) => ({
    params: { slug: author.slug },
    props: { author },
  }));
}

const { author } = Astro.props;
const pageUrl = `${SITE.url}/authors/${author.slug}/`;

// Other Calctube reviewers — cross-linked for internal-link signal
const otherAuthors = AUTHORS.filter((a) => a.slug !== author.slug);
const displayName = author.credentials
  ? `${author.name}, ${author.credentials}`
  : author.name;

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': `${pageUrl}#person`,
  name: author.name,
  jobTitle: author.jobTitle,
  description: author.shortBio,
  url: pageUrl,
  ...(author.linkedin ? { sameAs: [author.linkedin] } : {}),
  ...(author.avatar ? { image: { '@type': 'ImageObject', url: `${SITE.url}${author.avatar}` } } : {}),
  worksFor: {
    '@type': 'Organization',
    name: SITE.name,
    url: SITE.url,
  },
  knowsAbout: author.expertise,
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Authors', item: `${SITE.url}/authors/` },
    { '@type': 'ListItem', position: 3, name: displayName, item: pageUrl },
  ],
};
---

<BaseLayout
  title={`${displayName} — Calculator Expert`}
  description={`About ${displayName}: ${author.shortBio} Reviewer and contributor at Calctube.`}
  canonical={pageUrl}
  schemas={[personSchema, breadcrumbSchema]}
>
  <main class="container-prose py-12 sm:py-16">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="mb-8">
      <ol class="flex flex-wrap items-center gap-x-2 gap-y-1 text-xs font-bold text-ink-500">
        <li><a href="/" class="hover:text-ink-900 no-underline">Home</a></li>
        <li class="text-ink-300">›</li>
        <li><a href="/authors/" class="hover:text-ink-900 no-underline">Authors</a></li>
        <li class="text-ink-300">›</li>
        <li class="text-ink-800">{author.name}</li>
      </ol>
    </nav>

    <!-- Author Hero -->
    <div class="flex flex-col sm:flex-row items-start gap-6 mb-10">
      <!-- Avatar -->
      {author.avatar ? (
        <img
          src={author.avatar}
          alt={`${author.name} headshot`}
          class="w-24 h-24 rounded-full object-cover border-[3px] border-ink-900 shadow-sticker-sm flex-shrink-0"
          width="96"
          height="96"
          loading="eager"
        />
      ) : (
        <div class="w-24 h-24 rounded-full bg-gradient-to-br from-brand-400 via-violet-500 to-pink-accent flex items-center justify-center text-white font-extrabold text-3xl flex-shrink-0 border-[3px] border-ink-900 shadow-sticker-sm">
          {author.name.split(' ').map((n: string) => n[0]).join('').slice(0, 2)}
        </div>
      )}

      <div>
        <div class="chip chip-lime mb-3">{author.jobTitle}</div>
        <h1 class="!mt-0 !mb-2">{displayName}</h1>
        <p class="text-ink-600 font-semibold text-sm">{author.shortBio}</p>

        {author.linkedin && (
          <a
            href={author.linkedin}
            target="_blank"
            rel="noopener noreferrer nofollow"
            class="inline-flex items-center gap-1.5 mt-3 text-xs font-bold text-brand-600 hover:text-brand-700 no-underline hover:underline"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            View LinkedIn
          </a>
        )}
      </div>
    </div>

    <!-- Bio -->
    <section class="mb-10">
      <h2>About {author.name}</h2>
      <p>{author.bio}</p>
    </section>

    <!-- Expertise -->
    {author.expertise.length > 0 && (
      <section class="mb-10">
        <h2>Areas of Expertise</h2>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2 not-prose mt-4">
          {author.expertise.map((item: string) => (
            <li class="flex items-center gap-2.5 px-4 py-3 bg-ink-50 border-2 border-ink-200 rounded-xl text-sm font-bold text-ink-800">
              <span class="w-5 h-5 rounded-full bg-lime-accent border-2 border-ink-900 flex items-center justify-center flex-shrink-0">
                <svg class="w-2.5 h-2.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              </span>
              {item}
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- Reviewed calculators -->
    {author.reviewedPages.length > 0 && (
      <section class="mb-10">
        <h2>Calculators Reviewed</h2>
        <div class="not-prose grid grid-cols-1 sm:grid-cols-2 gap-3 mt-4">
          {author.reviewedPages.map((page: { title: string; url: string }) => (
            <a
              href={page.url}
              class="flex items-center justify-between gap-3 px-4 py-3 card card-hover no-underline group"
            >
              <span class="font-bold text-ink-900 text-sm group-hover:text-brand-600 transition-colors">{page.title}</span>
              <svg class="w-4 h-4 text-ink-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Editorial standards note -->
    <section class="bg-ink-50 border-2 border-ink-200 rounded-2xl p-5 sm:p-6 not-prose">
      <h3 class="!mt-0 !mb-2 text-base">Calctube Editorial Standards</h3>
      <p class="text-sm text-ink-600 leading-relaxed">
        All calculator formulas on Calctube are verified against industry-standard references,
        including actuarial tables, government financial guidelines, and peer-reviewed mathematical literature.
        Our reviewers check for formula accuracy, edge-case handling, and real-world applicability
        before any calculator is published.
      </p>
    </section>

    {/* Other Calctube reviewers — internal-link signal so Google treats authors/ as a cluster */}
    {otherAuthors.length > 0 && (
      <section class="not-prose mt-10">
        <h2 class="text-2xl font-extrabold text-ink-900 mb-4" style="font-family: 'Inter Tight', sans-serif;">
          Other Calctube reviewers
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {otherAuthors.map((a: { slug: string; name: string; credentials?: string; shortBio: string }) => (
            <a
              href={`/authors/${a.slug}/`}
              class="block bg-white border-[2.5px] border-ink-900 rounded-2xl p-4 no-underline shadow-sticker-sm hover:shadow-[6px_6px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-0.5 hover:-translate-y-0.5 transition-all"
            >
              <div class="font-extrabold text-ink-900 text-base" style="font-family: 'Inter Tight', sans-serif;">
                {a.name}{a.credentials ? `, ${a.credentials}` : ''}
              </div>
              <div class="text-xs text-ink-600 mt-1 leading-snug">{a.shortBio}</div>
            </a>
          ))}
        </div>
        <div class="mt-6">
          <a href="/authors/" class="font-bold underline decoration-2 underline-offset-4 decoration-lime-accent text-ink-900 text-sm">
            ← All Calctube authors
          </a>
        </div>
      </section>
    )}
  </main>
</BaseLayout>
