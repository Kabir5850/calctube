---
import BaseLayout from '../layouts/BaseLayout.astro';
import CalcSearch from '../components/ui/CalcSearch.tsx';
import CountUp from '../components/ui/CountUp.tsx';
import {
  calculators,
  popularCalculators,
  categoryMeta,
  totalCalculatorCount,
  calculatorsByCategory,
  type CalcCategory,
} from '../data/calculators';
import { buildFAQSchema } from '../lib/seo';

const totalCount = totalCalculatorCount;
const categories: CalcCategory[] = [
  'finance',
  'health',
  'math',
  'conversion',
  'date-time',
  'construction',
];

const categoryColorBg: Record<string, string> = {
  emerald: 'bg-emerald-100',
  rose: 'bg-rose-100',
  violet: 'bg-violet-100',
  amber: 'bg-amber-100',
  sky: 'bg-sky-100',
  orange: 'bg-orange-100',
};

const categoryColorIcon: Record<string, string> = {
  emerald: 'bg-emerald-400',
  rose: 'bg-rose-400',
  violet: 'bg-violet-400',
  amber: 'bg-amber-400',
  sky: 'bg-sky-400',
  orange: 'bg-orange-400',
};

const popularColors = [
  'bg-lime-accent',
  'bg-pink-accent text-white',
  'bg-yellow-accent',
  'bg-cyan-accent',
  'bg-violet-300',
  'bg-orange-300',
  'bg-rose-300',
  'bg-emerald-300',
];

// Marquee items — featured calculators that scroll in the strip
const marqueeItems = [
  '🏠 Mortgage', '💰 Tax', '⚖️ BMI', '📈 SIP', '💱 Currency', '🔥 TDEE',
  '🇮🇳 EMI', '🎂 Age', '🧮 Percentage', '🧱 Concrete', '🍽️ Tip', '💪 Body Fat',
  '🍎 Calorie', '📆 Date', '🌡️ Temperature', '🪙 Income Tax', '💼 Salary',
];

const useCases = [
  {
    title: 'Buying a home?',
    icon: '🏠',
    desc: 'Estimate mortgage, compare loan terms, plan down payment.',
    cta: 'Mortgage Calculator',
    href: '/finance/mortgage-calculator/',
    chipColor: 'chip-lime',
  },
  {
    title: 'Tracking fitness?',
    icon: '💪',
    desc: 'BMI, calorie need, and macros to hit your goals.',
    cta: 'BMI Calculator',
    href: '/health/bmi-calculator/',
    chipColor: 'chip-pink',
  },
  {
    title: 'Investing in your future?',
    icon: '📈',
    desc: 'See how compound interest and SIP returns build wealth.',
    cta: 'SIP Calculator',
    href: '/finance/sip-calculator/',
    chipColor: 'chip-yellow',
  },
  {
    title: 'Filing taxes?',
    icon: '🪙',
    desc: 'Compare old vs new regime by Indian state.',
    cta: 'Old vs New Regime',
    href: '/finance/old-vs-new-tax-regime-india/',
    chipColor: 'chip-cyan',
  },
];

const faqs = [
  {
    q: 'Are all calculators really free?',
    a: 'Yep. 100% free, no signup, no email gate, no premium tier. We make money from ads — never your data.',
  },
  {
    q: 'How accurate is the math?',
    a: 'Every formula is sourced from authoritative references (IRS, USDA, central banks, etc.) and tested against known outputs before publishing. Each page shows the formula used.',
  },
  {
    q: 'Is my data private?',
    a: 'Yes. Calculations run entirely in your browser. The values you enter never leave your device.',
  },
  {
    q: 'Does it work on phones?',
    a: 'Built mobile-first. One-handed, in a coffee shop, in 5 seconds. That\'s the bar.',
  },
  {
    q: 'Can I embed a calculator on my site?',
    a: 'Yes. Every page has a free embed code with a small "Powered by Calctube" link as the only requirement.',
  },
  {
    q: 'How do I request a new calculator?',
    a: 'Email ideas@calctube.com or use the contact form. We ship a new calc roughly every 3 days.',
  },
];

const schemas = [buildFAQSchema(faqs)];
---

<BaseLayout
  title="Calctube — Free Online Calculators"
  description="100+ free, fast, accurate calculators. Mortgage, BMI, EMI, SIP, currency, tax, percentage and more. No signup. Mobile-first. Free forever."
  schemas={schemas}
>
  <!-- ============================================== -->
  <!--   HERO — AURORA + STICKER VIBE                  -->
  <!-- ============================================== -->
  <section class="relative overflow-hidden bg-white">
    <!-- Aurora background blur layers -->
    <div class="absolute inset-0 -z-10" aria-hidden="true" style="contain: layout style paint;">
      <div class="absolute top-[-10%] left-[-5%] w-[300px] h-[300px] md:w-[600px] md:h-[600px] bg-brand-400/40 rounded-full blur-[60px] md:blur-[120px] float-slow"></div>
      <div class="absolute top-[-5%] right-[-10%] w-[250px] h-[250px] md:w-[500px] md:h-[500px] bg-pink-accent/30 rounded-full blur-[60px] md:blur-[120px] float-slow-2"></div>
      <div class="hidden md:block absolute bottom-[-15%] left-[30%] w-[600px] h-[600px] bg-lime-accent/30 rounded-full blur-[140px] float-slow" style="animation-delay: -3s;"></div>
    </div>

    <!-- Grain texture -->
    <div class="absolute inset-0 -z-10 bg-grain opacity-50" aria-hidden="true"></div>

    <div class="container-wide relative pt-10 pb-14 md:pt-16 md:pb-20 lg:pt-20 lg:pb-24">
      <div class="max-w-5xl mx-auto text-center">
        <!-- ✨ Sticker pill -->
        <div class="fade-in inline-flex items-center gap-2 chip-lime mb-7">
          <span class="text-base">✨</span>
          <span>{totalCount}+ Free Calculators · 0 Signups · Lifetime Free</span>
        </div>

        <!-- Massive headline -->
        <h1
          class="fade-in fade-in-delay-1 !text-5xl xs:!text-6xl sm:!text-7xl md:!text-8xl lg:!text-[9rem] !font-extrabold !tracking-tight !leading-[0.95] text-ink-900"
          style="font-family: 'Inter Tight', 'Inter', sans-serif;"
        >
          Every calc.
          <br />
          <span class="relative inline-block">
            <span class="text-gradient-brand">One tap.</span>
            <span class="absolute -right-8 -top-2 sm:-right-10 sm:-top-4 text-4xl sm:text-5xl md:text-6xl rotate-12">✨</span>
          </span>
        </h1>

        <!-- Tag -->
        <p
          class="fade-in fade-in-delay-2 mt-5 md:mt-7 text-base sm:text-lg md:text-xl text-ink-700 max-w-2xl mx-auto leading-relaxed font-medium"
        >
          Mortgage, BMI, tax, EMI, currency, percentage, and 100+ more.
          <br class="hidden sm:block" />
          <span class="text-ink-900 font-bold">Built different.</span> Free forever.
        </p>

        <!-- Search -->
        <!-- z-30 so the search dropdown stacks above later .fade-in siblings -->
        <div class="fade-in fade-in-delay-3 mt-9 md:mt-12 relative z-30">
          <CalcSearch calculators={calculators} client:load />
        </div>

        <!-- Quick-launch grid — 6 direct calculator tiles, fully above-fold -->
        <!-- Replaces vague "Try Mortgage" + "Browse all" CTAs that caused 73% bounce -->
        <div class="fade-in fade-in-delay-4 mt-7 md:mt-8 relative z-10">
          <p class="text-xs font-bold uppercase tracking-widest text-ink-400 mb-4 text-center">Popular right now</p>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-2 sm:gap-3 max-w-2xl mx-auto">
            {[
              { icon: '🏠', name: 'Mortgage',    href: '/finance/mortgage-calculator/',              color: 'bg-lime-accent' },
              { icon: '⚖️', name: 'BMI',          href: '/health/bmi-calculator/',                   color: 'bg-pink-accent' },
              { icon: '🇮🇳', name: 'EMI',         href: '/finance/emi-calculator/',                  color: 'bg-yellow-accent' },
              { icon: '📈', name: 'SIP',           href: '/finance/sip-calculator/',                  color: 'bg-cyan-accent' },
              { icon: '💱', name: 'Currency',      href: '/conversions/currency/',                    color: 'bg-violet-300' },
              { icon: '🪙', name: 'Income Tax',    href: '/finance/income-tax-india/maharashtra/',    color: 'bg-orange-300' },
            ].map((c) => (
              <a
                href={c.href}
                class={`group ${c.color} border-2 border-ink-900 rounded-2xl px-4 py-3.5 flex items-center gap-2.5 shadow-sticker-sm hover:shadow-sticker hover:-translate-x-0.5 hover:-translate-y-0.5 transition-all duration-150 no-underline`}
              >
                <span class="text-xl sm:text-2xl flex-shrink-0 group-hover:scale-110 transition-transform">{c.icon}</span>
                <span class="font-extrabold text-ink-900 text-sm sm:text-base leading-tight flex-1">{c.name}</span>
                <svg class="w-3.5 h-3.5 flex-shrink-0 text-ink-900/50 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            ))}
          </div>
          <div class="text-center mt-5">
            <a href="#popular" class="text-sm font-semibold text-ink-500 hover:text-ink-900 underline decoration-2 underline-offset-4 decoration-ink-200 hover:decoration-ink-900 transition-all">
              See all {totalCount}+ calculators ↓
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom transition -->
    <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-b from-transparent to-ink-900 -z-10" aria-hidden="true"></div>
  </section>

  <!-- ============================================== -->
  <!--   MARQUEE STRIP — Featured calculators          -->
  <!-- ============================================== -->
  <section class="bg-ink-900 text-white py-6 md:py-8 border-y-4 border-ink-900 overflow-hidden">
    <div class="marquee">
      <div class="marquee-track gap-8 md:gap-12">
        {
          [...marqueeItems, ...marqueeItems].map((item) => (
            <span class="inline-flex items-center text-lg md:text-2xl font-extrabold tracking-tight whitespace-nowrap">
              {item}
              <span class="mx-8 md:mx-12 text-lime-accent">●</span>
            </span>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============================================== -->
  <!--   POPULAR — Bento style                         -->
  <!-- ============================================== -->
  <section id="popular" class="container-wide py-16 md:py-24 relative">
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-10 md:mb-14">
      <div>
        <span class="chip-yellow mb-4">🔥 Trending now</span>
        <h2 class="!text-4xl sm:!text-5xl md:!text-6xl !mt-4 !mb-3 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">
          The hits.
        </h2>
        <p class="text-base md:text-lg text-ink-600 max-w-2xl">
          Most-used calculators by real humans this week.
        </p>
      </div>
      <a
        href="#categories"
        class="hidden sm:inline-flex items-center gap-1 text-sm font-bold text-ink-900 hover:text-brand-700 no-underline whitespace-nowrap underline decoration-2 underline-offset-4 decoration-lime-accent hover:decoration-brand-500"
      >
        See all →
      </a>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 sm:gap-4">
      {
        popularCalculators.map((calc, idx) => {
          const bgClass = popularColors[idx % popularColors.length];
          const isLive = calc.status === 'live';
          const cardClass = `group relative ${bgClass} border-2 border-ink-900 rounded-3xl p-5 sm:p-6 no-underline shadow-sticker ${isLive ? 'hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200' : 'opacity-80'}`;
          const inner = (
            <>
              {!isLive && (
                <span class="absolute -top-2 -right-2 chip-white !text-[9px] !px-2 !py-0.5">
                  Soon
                </span>
              )}
              <div class={`text-4xl sm:text-5xl mb-3 sm:mb-4 inline-block ${isLive ? 'transition-transform group-hover:scale-110 group-hover:rotate-6' : ''}`}>
                {calc.icon}
              </div>
              <div class="font-extrabold text-ink-900 text-sm sm:text-base leading-tight" style="font-family: 'Inter Tight', sans-serif;">
                {calc.name}
              </div>
              <p class="text-xs sm:text-sm text-ink-800 mt-1.5 leading-snug line-clamp-2 font-medium">
                {calc.description}
              </p>
            </>
          );
          return isLive ? (
            <a href={calc.href} class={cardClass}>{inner}</a>
          ) : (
            <div class={cardClass} aria-disabled="true">{inner}</div>
          );
        })
      }
    </div>
  </section>

  <!-- ============================================== -->
  <!--   USE CASES BENTO                               -->
  <!-- ============================================== -->
  <section class="relative bg-ink-50 border-y-2 border-ink-900 overflow-hidden">
    <div class="absolute inset-0 bg-grid opacity-50" aria-hidden="true"></div>

    <div class="container-wide relative py-16 md:py-24">
      <div class="text-center max-w-2xl mx-auto mb-12 md:mb-16">
        <span class="chip-pink mb-4">💡 Use cases</span>
        <h2 class="!text-4xl sm:!text-5xl md:!text-6xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">
          What's the vibe?
        </h2>
        <p class="text-base md:text-lg text-ink-700 mt-4 font-medium">
          Pick what you're trying to do. We'll send you to the right tool.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-5">
        {
          useCases.map((uc) => (
            <a
              href={uc.href}
              class="group relative bg-white border-2 border-ink-900 rounded-3xl p-6 md:p-7 flex flex-col
                     shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)]
                     hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200 no-underline"
            >
              <span class={`${uc.chipColor} self-start mb-4`}>Now</span>
              <div class="text-5xl mb-4 transition-transform group-hover:rotate-12">{uc.icon}</div>
              <h3 class="!text-xl !mt-0 !mb-2 !text-ink-900 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">
                {uc.title}
              </h3>
              <p class="text-sm text-ink-700 flex-1 leading-relaxed font-medium">{uc.desc}</p>
              <div class="mt-5 inline-flex items-center gap-1 text-sm font-extrabold text-ink-900 group-hover:gap-2 transition-all">
                {uc.cta}
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============================================== -->
  <!--   STATS — BIG NUMBERS                           -->
  <!-- ============================================== -->
  <section class="relative bg-white border-b-2 border-ink-900 overflow-hidden">
    <div class="container-wide py-16 md:py-20">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
        <div class="stat-block">
          <CountUp to={totalCount} suffix="+" className="stat-num text-gradient-brand" client:visible />
          <div class="stat-label">Calculators</div>
        </div>
        <div class="stat-block">
          <CountUp to={100} suffix="%" className="stat-num text-gradient-sunset" client:visible />
          <div class="stat-label">Free forever</div>
        </div>
        <div class="stat-block">
          <span class="stat-num text-gradient-electric">0</span>
          <div class="stat-label">Signups required</div>
        </div>
        <div class="stat-block">
          <CountUp to={5} suffix="s" className="stat-num text-gradient-brand" client:visible />
          <div class="stat-label">Avg load time</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================== -->
  <!--   CATEGORIES — bento grid mix                   -->
  <!-- ============================================== -->
  <section id="categories" class="container-wide py-16 md:py-24">
    <div class="text-center max-w-2xl mx-auto mb-12 md:mb-16">
      <span class="chip-cyan mb-4">📂 Categories</span>
      <h2 class="!text-4xl sm:!text-5xl md:!text-6xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">
        Browse the
        <span class="text-gradient-electric">whole library</span>
      </h2>
      <p class="text-base md:text-lg text-ink-600 mt-4 font-medium">
        Everything organized. Nothing buried.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
      {
        categories.map((cat) => {
          const meta = categoryMeta[cat];
          const calcs = calculatorsByCategory(cat).slice(0, 5);
          return (
            <div class={`group relative ${categoryColorBg[meta.color] || 'bg-ink-100'} border-2 border-ink-900 rounded-3xl p-6 md:p-7 flex flex-col shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200`}>
              <div class="flex items-center gap-3 mb-4">
                <div class={`w-14 h-14 rounded-2xl ${categoryColorIcon[meta.color] || 'bg-ink-400'} border-2 border-ink-900 shadow-sticker-sm flex items-center justify-center text-2xl text-white group-hover:rotate-6 transition-transform`}>
                  {meta.icon}
                </div>
                <h3 class="!text-2xl !my-0 !text-ink-900" style="font-family: 'Inter Tight', sans-serif;">{meta.label}</h3>
              </div>
              <p class="text-sm text-ink-800 mb-5 leading-relaxed font-medium">{meta.description}</p>
              <ul class="space-y-1.5 mb-5 flex-1">
                {calcs.map((c) => {
                  const isLive = c.status === 'live';
                  const liInner = (
                    <>
                      <span class="text-base flex-shrink-0">{c.icon}</span>
                      <span class={`truncate ${isLive ? 'group-hover/item:underline' : ''}`}>{c.name}</span>
                      {!isLive && (
                        <span class="ml-auto text-[9px] font-bold px-1.5 py-0.5 rounded-full bg-white border border-ink-300 text-ink-600 uppercase tracking-wider flex-shrink-0">
                          Soon
                        </span>
                      )}
                    </>
                  );
                  return (
                    <li>
                      {isLive ? (
                        <a href={c.href} class="flex items-center gap-2.5 text-sm text-ink-900 hover:text-brand-700 no-underline py-1 font-semibold group/item">{liInner}</a>
                      ) : (
                        <div class="flex items-center gap-2.5 text-sm text-ink-500 py-1 font-semibold" aria-disabled="true">{liInner}</div>
                      )}
                    </li>
                  );
                })}
              </ul>
              <a
                href={meta.href}
                class="inline-flex items-center gap-1 text-sm font-extrabold text-ink-900 hover:text-brand-700 no-underline mt-auto underline decoration-2 underline-offset-4 hover:decoration-brand-500"
              >
                View all {meta.label.toLowerCase()} →
              </a>
            </div>
          );
        })
      }
    </div>
  </section>

  <!-- ============================================== -->
  <!--   WHY — DARK SECTION WITH AURORA                -->
  <!-- ============================================== -->
  <section class="relative overflow-hidden bg-ink-950 text-white">
    <div class="absolute inset-0 -z-0" aria-hidden="true">
      <div class="absolute top-1/4 left-1/4 w-[500px] h-[500px] bg-brand-500/30 rounded-full blur-[120px] float-slow"></div>
      <div class="absolute bottom-1/4 right-1/4 w-[500px] h-[500px] bg-pink-accent/20 rounded-full blur-[120px] float-slow-2"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[700px] bg-lime-accent/10 rounded-full blur-[120px]"></div>
    </div>
    <div class="absolute inset-0 bg-grid-dark opacity-30" aria-hidden="true"></div>

    <div class="container-wide relative z-10 py-20 md:py-28">
      <div class="text-center max-w-3xl mx-auto mb-14 md:mb-20">
        <span class="chip bg-lime-accent text-ink-900 mb-4">⚡ Built different</span>
        <h2 class="!text-4xl sm:!text-5xl md:!text-6xl !mt-4 !text-white !leading-[1.05]" style="font-family: 'Inter Tight', sans-serif;">
          No popups. No signups.
          <br />
          <span class="text-gradient-electric">Just calculations.</span>
        </h2>
        <p class="text-base md:text-lg text-ink-300 mt-5 font-medium">
          Most calculator sites are bloated with ads and signup walls. We built the opposite.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 md:gap-6">
        <!-- Card 1 — speed -->
        <div class="relative bg-white/[0.04] backdrop-blur-xl border border-white/10 rounded-3xl p-7 hover:bg-white/[0.08] hover:border-lime-accent/40 transition-all">
          <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-lime-accent to-emerald-500 flex items-center justify-center mb-5 shadow-glow-lime">
            <svg class="w-7 h-7 text-ink-900" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="!text-2xl !mt-0 !mb-3 !text-white" style="font-family: 'Inter Tight', sans-serif;">⚡ Sub-second.</h3>
          <p class="text-ink-300 leading-relaxed">
            Static pages on a global CDN. Calculators run in your browser. Zero API calls. Zero loading screens.
          </p>
        </div>

        <!-- Card 2 — accuracy -->
        <div class="relative bg-white/[0.04] backdrop-blur-xl border border-white/10 rounded-3xl p-7 hover:bg-white/[0.08] hover:border-pink-accent/40 transition-all">
          <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-pink-accent to-rose-500 flex items-center justify-center mb-5 shadow-glow-pink">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="!text-2xl !mt-0 !mb-3 !text-white" style="font-family: 'Inter Tight', sans-serif;">🎯 Verified math.</h3>
          <p class="text-ink-300 leading-relaxed">
            Every formula cites its authoritative source (IRS, USDA, central banks). Tested against known outputs.
          </p>
        </div>

        <!-- Card 3 — privacy -->
        <div class="relative bg-white/[0.04] backdrop-blur-xl border border-white/10 rounded-3xl p-7 hover:bg-white/[0.08] hover:border-cyan-accent/40 transition-all">
          <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-cyan-accent to-brand-500 flex items-center justify-center mb-5 shadow-glow">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
          </div>
          <h3 class="!text-2xl !mt-0 !mb-3 !text-white" style="font-family: 'Inter Tight', sans-serif;">🔒 Private af.</h3>
          <p class="text-ink-300 leading-relaxed">
            Your numbers never leave your browser. No accounts. No personal-data tracking. Real privacy, not the buzzword.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================== -->
  <!--   FAQ                                           -->
  <!-- ============================================== -->
  <section class="container-prose py-16 md:py-24">
    <div class="text-center max-w-2xl mx-auto mb-10 md:mb-14">
      <span class="chip-yellow mb-4">❓ FAQ</span>
      <h2 class="!text-4xl sm:!text-5xl md:!text-6xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">
        Quick answers.
      </h2>
    </div>

    <div class="space-y-3">
      {
        faqs.map((faq, idx) => (
          <details
            class="group bg-white border-2 border-ink-900 rounded-2xl shadow-sticker-sm hover:shadow-sticker transition-all overflow-hidden"
            open={idx === 0}
          >
            <summary class="cursor-pointer p-5 md:p-6 font-extrabold text-ink-900 flex items-center justify-between gap-4 list-none">
              <span class="text-base md:text-lg" style="font-family: 'Inter Tight', sans-serif;">{faq.q}</span>
              <span class="flex-shrink-0 w-9 h-9 rounded-full bg-ink-900 group-open:bg-lime-accent flex items-center justify-center transition-colors">
                <svg
                  class="w-4 h-4 text-white group-open:text-ink-900 transition-all group-open:rotate-180"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="3"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </span>
            </summary>
            <div class="px-5 md:px-6 pb-5 md:pb-6 text-ink-700 leading-relaxed font-medium">{faq.a}</div>
          </details>
        ))
      }
    </div>

    <div class="text-center mt-10">
      <p class="text-ink-600">
        Still curious?
        <a href="/contact/" class="font-bold underline decoration-2 underline-offset-4 decoration-lime-accent">Hit us up →</a>
      </p>
    </div>
  </section>

  <!-- ============================================== -->
  <!--   CTA — Big sticker block                       -->
  <!-- ============================================== -->
  <section class="px-4 sm:px-6 lg:px-8 pb-20">
    <div class="relative overflow-hidden bg-lime-accent border-2 border-ink-900 rounded-[2rem] md:rounded-[3rem] shadow-sticker max-w-6xl mx-auto">
      <div class="absolute inset-0 bg-grid opacity-30" aria-hidden="true"></div>

      <!-- Floating sparkles -->
      <div class="absolute top-8 right-8 text-3xl float-slow" aria-hidden="true">✨</div>
      <div class="absolute bottom-12 left-12 text-2xl float-slow-2" aria-hidden="true">🚀</div>
      <div class="absolute top-1/3 left-8 text-2xl float-slow" style="animation-delay: -2s;" aria-hidden="true">⚡</div>

      <div class="relative z-10 px-6 md:px-12 py-16 md:py-24 text-center">
        <h2 class="!text-4xl sm:!text-5xl md:!text-6xl !mt-0 !leading-[1.05] !text-ink-900 !font-extrabold max-w-3xl mx-auto" style="font-family: 'Inter Tight', sans-serif;">
          Missing a calc? <span class="text-pink-accent">We'll build it.</span>
        </h2>
        <p class="text-ink-800 mt-5 text-base md:text-lg max-w-xl mx-auto leading-relaxed font-medium">
          New calculators shipping every 3 days based on what real people request.
          Drop a note. We usually ship within 7 days.
        </p>
        <div class="mt-9 md:mt-10 flex flex-col sm:flex-row items-center justify-center gap-4 max-w-md mx-auto sm:max-w-none">
          <a href="/contact/" class="btn-primary w-full sm:w-auto">
            Request a calculator →
          </a>
          <a href="mailto:ideas@calctube.com" class="btn-secondary w-full sm:w-auto !bg-white">
            Email us
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
