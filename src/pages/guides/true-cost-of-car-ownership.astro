---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AuthorBadge from '../../components/ui/AuthorBadge.astro';
import { buildBreadcrumbSchema, buildFAQSchema } from '../../lib/seo';
import { getAuthor } from '../../data/authors';

const path = '/guides/true-cost-of-car-ownership';
const lastUpdated = '2026-07-20';
const reviewer = getAuthor('aisha-rahman')!;
const breadcrumbs = [
  { name: 'Home', url: '/' }, { name: 'Guides', url: '/guides/' }, { name: 'True Cost of Car Ownership', url: path },
];

// Build-time: 5-year total cost of ownership for a sample ₹12L (on-road) car.
const PRICE = 1200000;          // on-road price paid
const YEARS = 5;
const DEP_RATE = 0.15;          // ~15%/yr reducing-balance depreciation
const KM_YEAR = 12000;          // typical annual running
const MILEAGE = 15;             // km per litre (petrol)
const FUEL_PRICE = 100;         // ₹ per litre
const INS_RATE = 0.028;         // comprehensive ≈ 2.8% of that year's value
const MAINT_BASE = 8000;        // first-year servicing
const MAINT_GROWTH = 1.5;       // maintenance climbs sharply after warranty
const LTV = 0.8;                // 80% financed
const LOAN_RATE = 0.095;        // 9.5% annual

// Depreciation: reducing balance, so the residual value is what you'd sell for.
const residual = PRICE * Math.pow(1 - DEP_RATE, YEARS);
const depreciation = PRICE - residual;

// Fuel: fixed by how far you drive.
const litresYear = KM_YEAR / MILEAGE;
const fuelYear = litresYear * FUEL_PRICE;
const fuel = fuelYear * YEARS;

// Insurance: a % of the car's declining value each year.
let insurance = 0;
for (let i = 0; i < YEARS; i++) insurance += PRICE * Math.pow(1 - DEP_RATE, i) * INS_RATE;

// Maintenance: low under warranty, then rises with age.
let maintenance = 0;
for (let i = 0; i < YEARS; i++) maintenance += MAINT_BASE * Math.pow(MAINT_GROWTH, i);

// Loan interest: EMI maths on the financed portion.
const loan = PRICE * LTV;
const r = LOAN_RATE / 12;
const n = YEARS * 12;
const emi = loan * r * Math.pow(1 + r, n) / (Math.pow(1 + r, n) - 1);
const interest = emi * n - loan;

const total = depreciation + fuel + insurance + maintenance + interest;
const perYear = total / YEARS;
const totalKm = KM_YEAR * YEARS;
const perKm = total / totalKm;

const rows = [
  { name: 'Depreciation', note: `${(DEP_RATE * 100).toFixed(0)}%/yr (value lost, not spent)`, cost: depreciation },
  { name: 'Fuel', note: `${KM_YEAR.toLocaleString('en-IN')} km/yr @ ${MILEAGE} kmpl`, cost: fuel },
  { name: 'Loan interest', note: `${(LTV * 100).toFixed(0)}% financed @ ${(LOAN_RATE * 100).toFixed(1)}%`, cost: interest },
  { name: 'Insurance', note: 'Comprehensive, declining IDV', cost: insurance },
  { name: 'Maintenance', note: 'Servicing + wear, rising with age', cost: maintenance },
].sort((a, b) => b.cost - a.cost);

const fmtINR = (v: number) => new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 }).format(v);
const fmtL = (v: number) => `₹${(v / 100000).toFixed(1)}L`;

const faqs = [
  { q: 'What is the single biggest cost of owning a car?', a: `Depreciation, the value your car quietly loses whether you drive it or not. On a ${fmtL(PRICE)} car falling ~${(DEP_RATE*100).toFixed(0)}% a year, that's about ${fmtINR(depreciation)} gone over ${YEARS} years, more than fuel, insurance, maintenance and even loan interest. It doesn't show up as a bill, which is exactly why people ignore it: you only feel it the day you try to sell. The car that's "cheap to run" but crashes in resale value can easily cost more to own than a pricier one that holds its value.` },
  { q: `How much does a ₹12L car really cost over ${YEARS} years?`, a: `In this worked example, about ${fmtINR(total)}, roughly ${fmtL(total)} to own a ${fmtL(PRICE)} car for ${YEARS} years, or around ${fmtINR(perYear)} every year. Break it down and it's depreciation ${fmtINR(depreciation)}, fuel ${fmtINR(fuel)}, loan interest ${fmtINR(interest)}, insurance ${fmtINR(insurance)} and maintenance ${fmtINR(maintenance)}. Spread over the ${totalKm.toLocaleString('en-IN')} km you'd drive, that works out to about ${fmtINR(perKm)} per kilometre, a far more honest number than the showroom sticker.` },
  { q: 'Does paying cash instead of taking a loan avoid the interest cost?', a: `Yes. Buying outright removes the ${fmtINR(interest)} of interest in this example, cutting the ${YEARS}-year cost to about ${fmtINR(total - interest)}. But it isn't free: that ${fmtINR(loan)} would otherwise have earned a return. Parked at even 8%, it could grow by well over a lakh across ${YEARS} years, so the true saving is the loan rate minus what your money could have earned elsewhere. Cash is the clear winner only when the loan rate is higher than your realistic investment return, which, for a ${(LOAN_RATE*100).toFixed(1)}% car loan, it usually is.` },
  { q: 'How do I actually reduce the true cost of ownership?', a: `Three levers move the needle most. First, keep the car longer: depreciation is steepest early, so years 6-10 of ownership are far cheaper per year than years 1-5. Selling every few years is the most expensive habit there is. Second, buy fuel-efficient and hold resale value; a model known to depreciate slowly can save lakhs. Third, finance less or pay cash if your money isn't earning more than the loan rate. Squeezing the insurance or service bill barely matters. The big money is in depreciation and interest.` },
  { q: 'Is a cheaper or used car always better on total cost?', a: `Often, but not automatically. A used car's steepest depreciation has already been absorbed by the first owner, so a 3-year-old car of the same model loses value far more slowly than a new one, a genuine TCO advantage. The offset is higher maintenance and possibly a pricier loan, and no manufacturer warranty. Run the same five-line sum (depreciation, fuel, interest, insurance, maintenance) on both the new and used option before deciding. The winner is whichever has the lower total cost per kilometre, not the lower sticker price.` },
];
const schemas = [buildBreadcrumbSchema(breadcrumbs), buildFAQSchema(faqs)];
---

<BaseLayout title={`True Cost of Car Ownership: A ₹12L Car Costs ${fmtL(total)} Over 5 Years`} description={`The sticker says ${fmtL(PRICE)}, but owning it for ${YEARS} years costs about ${fmtINR(total)}, roughly ${fmtINR(perKm)}/km. Full breakdown: depreciation ${fmtINR(depreciation)}, fuel, insurance, maintenance and loan interest, all computed.`} schemas={schemas} publishedTime={lastUpdated} modifiedTime={lastUpdated}>
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-pink-accent/30 rounded-full blur-[120px] float-slow"></div>
      <div class="absolute top-[5%] right-[-10%] w-[400px] h-[400px] bg-cyan-accent/25 rounded-full blur-[120px] float-slow-2"></div>
    </div>
    <div class="container-wide relative pt-8 pb-10 md:pt-12 md:pb-14">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-1.5 text-xs sm:text-sm">
          {breadcrumbs.map((item, idx) => (
            <li class="flex items-center gap-1.5">
              {idx === breadcrumbs.length - 1 ? (
                <span class="px-3 py-1 rounded-full bg-ink-900 text-white font-bold border-2 border-ink-900">{item.name}</span>
              ) : (
                <>
                  <a href={item.url} class="px-3 py-1 rounded-full bg-white border-2 border-ink-200 text-ink-700 font-semibold hover:border-ink-900 hover:text-ink-900 no-underline transition-colors">{item.name}</a>
                  <svg class="w-3 h-3 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </>
              )}
            </li>
          ))}
        </ol>
      </nav>
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="chip-cyan">📚 Guide</span>
          <span class="chip-yellow">🚗 True cost</span>
          <span class="chip-white"><span class="text-ink-500">Updated</span><span>{lastUpdated}</span></span>
        </div>
        <h1 class="!text-4xl sm:!text-5xl md:!text-6xl !font-extrabold !tracking-tight !leading-[1.05] text-ink-900" style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.035em;">
          The sticker is the <span class="text-gradient-brand">smallest number.</span>
        </h1>
        <div class="mt-7 bg-yellow-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker">
          <div class="flex items-start gap-3">
            <div class="text-2xl">⚡</div>
            <div>
              <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-1">Quick answer</div>
              <p class="text-ink-900 text-base sm:text-lg leading-relaxed font-medium !m-0">
                A <strong>{fmtL(PRICE)}</strong> car costs about <strong>{fmtINR(total)}</strong> to own over {YEARS} years, roughly <strong>{fmtINR(perYear)}/year</strong>, or <strong>{fmtINR(perKm)} per km</strong>. The hidden giant is depreciation ({fmtINR(depreciation)}), which dwarfs fuel, insurance and maintenance. Financing adds {fmtINR(interest)} of interest on top.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wide pb-12 md:pb-16 pt-4">
    <div class="max-w-4xl mx-auto prose prose-lg">
      <h2 style="font-family: 'Inter Tight', sans-serif;">Five costs, ranked by what they actually take</h2>
      <p class="text-ink-700 font-medium leading-relaxed max-w-3xl">
        The price on the windscreen is a down payment on a much larger bill. Owning a car is five costs, not one, and the biggest of them never arrives as an invoice. Here's a {fmtL(PRICE)} car driven {KM_YEAR.toLocaleString('en-IN')} km a year for {YEARS} years, every line computed, ranked from largest to smallest:
      </p>
      <div class="not-prose overflow-x-auto">
        <table class="w-full bg-white border-[2.5px] border-ink-900 rounded-2xl shadow-sticker-sm overflow-hidden border-separate border-spacing-0 text-sm">
          <thead><tr class="bg-ink-900 text-white">
            <th class="text-left p-3 font-extrabold">Cost</th>
            <th class="text-left p-3 font-extrabold hidden sm:table-cell">What it is</th>
            <th class="text-right p-3 font-extrabold">5-year total</th>
            <th class="text-right p-3 font-extrabold">Share</th>
          </tr></thead>
          <tbody>
            {rows.map((row, i) => (
              <tr class={`border-b-2 border-ink-100 ${i === 0 ? 'bg-pink-accent/15' : i % 2 ? 'bg-ink-50' : ''}`}>
                <td class="p-3 font-bold text-ink-900">{row.name}</td>
                <td class="p-3 text-ink-600 font-semibold hidden sm:table-cell">{row.note}</td>
                <td class="p-3 text-right font-mono font-extrabold text-ink-900">{fmtINR(row.cost)}</td>
                <td class="p-3 text-right font-mono text-ink-700">{(row.cost / total * 100).toFixed(0)}%</td>
              </tr>
            ))}
            <tr class="bg-lime-accent/30 border-t-2 border-ink-900">
              <td class="p-3 font-extrabold text-ink-900">Total cost of ownership</td>
              <td class="p-3 text-ink-700 font-semibold hidden sm:table-cell">≈ {fmtINR(perKm)}/km · {fmtINR(perYear)}/yr</td>
              <td class="p-3 text-right font-mono font-extrabold text-ink-900">{fmtINR(total)}</td>
              <td class="p-3 text-right font-mono font-extrabold text-ink-900">100%</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="text-xs text-ink-500 mt-3 font-medium">Illustrative: {(DEP_RATE*100).toFixed(0)}%/yr reducing-balance depreciation, {MILEAGE} kmpl at ₹{FUEL_PRICE}/l petrol, comprehensive insurance at {(INS_RATE*100).toFixed(1)}% of declining value, {(LTV*100).toFixed(0)}% loan at {(LOAN_RATE*100).toFixed(1)}%. Your figures vary with model, fuel type and usage. Not financial advice.</p>

      <h2 style="font-family: 'Inter Tight', sans-serif;">Why depreciation, not fuel, decides the bill</h2>
      <p class="text-ink-700 font-medium leading-relaxed max-w-3xl">
        Everyone budgets for fuel because they pay for it every week, but depreciation, the {(depreciation/total*100).toFixed(0)}% of this bill nobody sees, is the real cost of driving a new car. After {YEARS} years the {fmtL(PRICE)} car is worth about {fmtINR(residual)}; the {fmtINR(depreciation)} difference simply evaporated, fastest in the earliest years. That's the maths behind two rules of thumb worth internalising. <strong>Keep cars longer:</strong> once the steep early depreciation is behind you, each extra year of ownership is dramatically cheaper, which is why serial upgraders spend the most. <strong>And a car is a use it, not an investment:</strong> the entire {fmtINR(total)} is money spent to move around, so the right question isn't "can I afford the EMI?" but "am I happy paying about {fmtINR(perKm)} for every kilometre I drive?"
      </p>
      <p class="text-ink-700 font-medium leading-relaxed max-w-3xl">
        Financing changes the picture too. The {fmtINR(interest)} of interest here is a real, avoidable cost, but only worth avoiding if your cash can't earn more than the {(LOAN_RATE*100).toFixed(1)}% loan rate elsewhere. Run your own numbers on the <a href="/finance/car-loan-calculator/">car loan calculator</a> before you decide how much to put down.
      </p>
      {reviewer && <div class="not-prose mt-8"><AuthorBadge author={reviewer} verb="Reviewed" /></div>}
    </div>
  </section>

  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-3xl mx-auto">
        <span class="chip-yellow mb-4">❓ FAQ</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Common questions.</h2>
        <div class="space-y-3 mt-8">
          {faqs.map((faq, idx) => (
            <details class="group bg-white border-2 border-ink-900 rounded-2xl shadow-sticker-sm hover:shadow-sticker transition-all" open={idx === 0}>
              <summary class="cursor-pointer p-5 md:p-6 font-extrabold text-ink-900 flex items-center justify-between gap-4 list-none">
                <span class="text-base md:text-lg" style="font-family: 'Inter Tight', sans-serif;">{faq.q}</span>
                <span class="flex-shrink-0 w-9 h-9 rounded-full bg-ink-900 group-open:bg-lime-accent flex items-center justify-center transition-colors">
                  <svg class="w-4 h-4 text-white group-open:text-ink-900 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </span>
              </summary>
              <div class="px-5 md:px-6 pb-5 md:pb-6 text-ink-700 leading-relaxed font-medium">{faq.a}</div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="container-wide py-12 md:py-16">
    <div class="max-w-3xl mx-auto">
      <span class="chip bg-violet-300 text-ink-900 mb-4">🔗 Related</span>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mt-6">
        {[
          { name: 'Car Loan Calculator', href: '/finance/car-loan-calculator/', icon: '🚗', color: 'bg-cyan-accent' },
          { name: 'EMI Calculator', href: '/finance/emi-calculator/', icon: '📅', color: 'bg-lime-accent' },
          { name: 'Compound Interest', href: '/finance/compound-interest-calculator/', icon: '💹', color: 'bg-yellow-accent' },
        ].map((c) => (
          <a href={c.href} class={`group ${c.color} border-[2.5px] border-ink-900 rounded-3xl p-5 no-underline shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200`}>
            <div class="text-3xl mb-2 group-hover:rotate-12 transition-transform inline-block">{c.icon}</div>
            <div class="font-extrabold text-ink-900 text-base leading-tight" style="font-family: 'Inter Tight', sans-serif;">{c.name}</div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
