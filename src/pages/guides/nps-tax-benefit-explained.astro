---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildBreadcrumbSchema, buildFAQSchema } from '../../lib/seo';

const path = '/guides/nps-tax-benefit-explained';
const lastUpdated = '2026-07-23';
const breadcrumbs = [
  { name: 'Home', url: '/' }, { name: 'Guides', url: '/guides/' }, { name: 'NPS Tax Benefit Explained', url: path },
];

// Build-time: the extra 80CCD(1B) deduction, tax saved by slab, and the effective cost.
const EXTRA = 50000;        // Section 80CCD(1B) additional deduction ceiling
const SEC_80C = 150000;     // Section 80CCE ceiling covering 80C + 80CCD(1)
const CESS = 4;             // health & education cess on tax

const slabs = [5, 20, 30];
const rows = slabs.map((slab) => {
  const taxSaved = EXTRA * (slab / 100) * (1 + CESS / 100);
  const netCost = EXTRA - taxSaved;
  return { slab, taxSaved, netCost, instantReturn: (taxSaved / netCost) * 100 };
});
const top = rows[rows.length - 1];          // 30% slab
const mid = rows[1];                        // 20% slab

// Combined headroom for someone who uses 80C fully and adds 80CCD(1B).
const combined = SEC_80C + EXTRA;
const combinedSaved = combined * (top.slab / 100) * (1 + CESS / 100);

// Employer route: 80CCD(2), which survives in the new regime.
const EMP_SALARY = 1200000;     // annual basic + DA
const EMP_PCT_NEW = 14;         // employer contribution deductible, new regime (FY 2025-26)
const EMP_PCT_OLD = 10;         // old regime, non-government employer
const empDeductionNew = EMP_SALARY * EMP_PCT_NEW / 100;
const empDeductionOld = EMP_SALARY * EMP_PCT_OLD / 100;
const empSavedNew = empDeductionNew * (top.slab / 100) * (1 + CESS / 100);

// What the ₹50,000 a year actually becomes: 20 years at a mid-range NPS return.
const YEARS = 20, RET = 10;
const corpus20 = EXTRA * ((Math.pow(1 + RET / 100, YEARS) - 1) / (RET / 100));
const contributed20 = EXTRA * YEARS;
const taxSaved20 = top.taxSaved * YEARS;
const lumpSumFree = corpus20 * 0.60;   // up to 60% withdrawable, tax-exempt
const annuityPart = corpus20 * 0.40;   // minimum 40% must buy an annuity

const fmtINR = (v: number) => new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 }).format(v);
const fmtL = (v: number) => `₹${(v / 100000).toFixed(2)} L`;

const faqs = [
  { q: 'What is the extra ₹50,000 NPS deduction under Section 80CCD(1B)?', a: `Section 80CCD(1B) gives you a deduction of up to ₹50,000 a year for your own contribution to an NPS Tier-1 account, and it sits on top of the ₹1.5 lakh Section 80C ceiling rather than inside it. That makes it one of the few genuinely additional deductions left in the old regime: if you have already exhausted 80C with EPF, PPF, ELSS, life insurance premiums or school fees, this ₹50,000 is fresh headroom. At the 30% slab plus ${CESS}% cess it is worth ${fmtINR(top.taxSaved)} of tax saved, at 20% it is ${fmtINR(mid.taxSaved)}, and at 5% it is ${fmtINR(rows[0].taxSaved)}.` },
  { q: 'Is the NPS deduction available in the new tax regime?', a: `The ₹50,000 under 80CCD(1B) is an old-regime benefit only, as is 80C. The new regime, which is now the default, strips out both. But one NPS route does survive: Section 80CCD(2), the deduction for your employer\'s contribution to your NPS account. In the new regime that is allowed up to ${EMP_PCT_NEW}% of salary (basic + DA) for private-sector employees from FY 2025-26, against ${EMP_PCT_OLD}% under the old regime for a non-government employer. On a ${fmtL(EMP_SALARY)} basic + DA, ${EMP_PCT_NEW}% is ${fmtINR(empDeductionNew)} of deductible employer contribution, which is why NPS is often the last big lever a new-regime taxpayer still has.` },
  { q: 'Can I claim ₹1.5 lakh under 80C and ₹50,000 for NPS together?', a: `Yes, that is exactly the design. Section 80CCE caps 80C plus 80CCD(1), your own NPS contribution counted as part of 80C, at ₹1.5 lakh combined. Section 80CCD(1B) then allows a further ₹50,000, taking the total self-funded deduction to ${fmtL(combined)}. At the 30% slab with cess that combined headroom is worth about ${fmtINR(combinedSaved)} of tax. The order matters: claim NPS money under 80CCD(1B) first if your 80C is already full, otherwise the same rupee gets absorbed into a limit you had already hit and saves you nothing extra.` },
  { q: 'Is NPS maturity money tax-free?', a: `Partly. At retirement (age 60) you can withdraw up to 60% of the corpus as a lump sum and that portion is exempt from tax. At least 40% must be used to buy an annuity, and the pension the annuity pays is taxable in the year you receive it, at your slab rate then. So NPS is not fully EEE like PPF: it is closer to exempt on the way in, exempt on growth, and partly taxed on the way out. On a ${fmtL(corpus20)} corpus, roughly ${fmtL(lumpSumFree)} could come out tax-free and about ${fmtL(annuityPart)} would go into an annuity whose payouts are taxed.` },
  { q: 'Is NPS worth it just for the tax break?', a: `The deduction is real, but so is the lock-in. Tier-1 money is locked until you turn 60, partial withdrawals are limited to specified reasons after three years, and the compulsory annuity at the end pays taxable income at rates you cannot predict today. Judge it as a retirement product first and a tax product second. If ${fmtINR(EXTRA)} a year suits your retirement plan anyway, the ${fmtINR(top.taxSaved)} of tax saved at the 30% slab makes an already sensible contribution cheaper, effectively ${fmtINR(top.netCost)} out of pocket. If it does not, a ${YEARS}-year lock-in is a high price for a one-year deduction.` },
];
const schemas = [buildBreadcrumbSchema(breadcrumbs), buildFAQSchema(faqs)];
---

<BaseLayout title={`NPS Tax Benefit Explained: The Extra ₹50,000 Under 80CCD(1B)`} description={`Section 80CCD(1B) adds ₹50,000 of deduction on top of 80C, worth ${fmtINR(top.taxSaved)} at the 30% slab and ${fmtINR(mid.taxSaved)} at 20%. Tax saved by slab, the effective cost, and the 80CCD(2) employer route that survives in the new regime.`} schemas={schemas} publishedTime={lastUpdated} modifiedTime={lastUpdated}>
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-cyan-accent/30 rounded-full blur-[120px] float-slow"></div>
      <div class="absolute top-[5%] right-[-10%] w-[400px] h-[400px] bg-yellow-accent/25 rounded-full blur-[120px] float-slow-2"></div>
    </div>
    <div class="container-wide relative pt-8 pb-10 md:pt-12 md:pb-14">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-1.5 text-xs sm:text-sm">
          {breadcrumbs.map((item, idx) => (
            <li class="flex items-center gap-1.5">
              {idx === breadcrumbs.length - 1 ? (
                <span class="px-3 py-1 rounded-full bg-ink-900 text-white font-bold border-2 border-ink-900">{item.name}</span>
              ) : (
                <>
                  <a href={item.url} class="px-3 py-1 rounded-full bg-white border-2 border-ink-200 text-ink-700 font-semibold hover:border-ink-900 hover:text-ink-900 no-underline transition-colors">{item.name}</a>
                  <svg class="w-3 h-3 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </>
              )}
            </li>
          ))}
        </ol>
      </nav>
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="chip-yellow">📚 Guide</span>
          <span class="chip-cyan">🪙 Tax</span>
          <span class="chip-white"><span class="text-ink-500">Updated</span><span>{lastUpdated}</span></span>
        </div>
        <h1 class="!text-4xl sm:!text-5xl md:!text-6xl !font-extrabold !tracking-tight !leading-[1.05] text-ink-900" style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.035em;">
          The extra <span class="text-gradient-brand">₹50,000</span> deduction
        </h1>
        <div class="mt-7 bg-yellow-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker">
          <div class="flex items-start gap-3">
            <div class="text-2xl">⚡</div>
            <div>
              <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-1">Quick answer</div>
              <p class="text-ink-900 text-base sm:text-lg leading-relaxed font-medium !m-0">
                Section <strong>80CCD(1B)</strong> lets you deduct up to <strong>₹50,000</strong> a year for your own NPS Tier-1 contribution, <strong>on top of</strong> the ₹1.5 lakh 80C limit. That is <strong>{fmtINR(top.taxSaved)}</strong> saved at the 30% slab (with {CESS}% cess), {fmtINR(mid.taxSaved)} at 20%, {fmtINR(rows[0].taxSaved)} at 5%. Old regime only, though the employer route under 80CCD(2) survives in the new regime at up to {EMP_PCT_NEW}% of salary.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wide pb-12 md:pb-16 pt-4">
    <div class="max-w-4xl mx-auto prose prose-lg">
      <h2 style="font-family: 'Inter Tight', sans-serif;">Why this ₹50,000 is different</h2>
      <p class="text-ink-700 font-medium leading-relaxed max-w-3xl">
        Most tax-saving instruments compete for the same ₹1.5 lakh. Your EPF deduction, PPF, ELSS, life insurance premium, children's tuition fees and home-loan principal all pile into Section 80C, and for a salaried person with a decent EPF contribution that limit is usually full before you have made a single deliberate investment. Section 80CCD(1B) is the exception: it is a separate ₹50,000 ceiling that only NPS can fill, stacked <em>above</em> the ₹1.5 lakh. Take both and your self-funded deduction headroom is {fmtL(combined)} rather than {fmtL(SEC_80C)}.
      </p>
      <p class="text-ink-700 font-medium leading-relaxed max-w-3xl">
        The value of a deduction is always your marginal slab rate, plus the {CESS}% cess that rides on the tax. Here is what the full ₹50,000 is worth, and what it really costs you once the refund is netted off:
      </p>
      <div class="not-prose overflow-x-auto">
        <table class="w-full bg-white border-[2.5px] border-ink-900 rounded-2xl shadow-sticker-sm overflow-hidden border-separate border-spacing-0 text-sm">
          <thead><tr class="bg-ink-900 text-white">
            <th class="text-left p-3 font-extrabold">Your slab</th>
            <th class="text-right p-3 font-extrabold">Tax saved</th>
            <th class="text-right p-3 font-extrabold">Net cost of ₹50,000</th>
            <th class="text-right p-3 font-extrabold hidden sm:table-cell">Instant return</th>
          </tr></thead>
          <tbody>
            {rows.map((row, i) => (
              <tr class={`border-b-2 border-ink-100 ${row.slab === top.slab ? 'bg-lime-accent/25' : i % 2 ? 'bg-ink-50' : ''}`}>
                <td class="p-3 font-bold text-ink-900">{row.slab}%</td>
                <td class="p-3 text-right font-mono font-extrabold text-green-700">{fmtINR(row.taxSaved)}</td>
                <td class="p-3 text-right font-mono text-ink-800">{fmtINR(row.netCost)}</td>
                <td class="p-3 text-right font-mono font-bold text-ink-900 hidden sm:table-cell">{row.instantReturn.toFixed(1)}%</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-xs text-ink-500 mt-3 font-medium">Old regime, FY 2025-26, including {CESS}% health and education cess. "Instant return" is the tax saved expressed against the net outlay ({fmtINR(top.taxSaved)} back on {fmtINR(top.netCost)} spent at the 30% slab), a one-off first-year effect, not an annual yield. Surcharge at higher incomes raises the saving further. Not tax advice.</p>

      <h2 style="font-family: 'Inter Tight', sans-serif;">The regime question, and the employer route nobody uses</h2>
      <p class="text-ink-700 font-medium leading-relaxed max-w-3xl">
        The 80CCD(1B) deduction lives only in the old regime. If you have moved to the new regime's lower slabs, which is now the default, your ₹50,000 NPS contribution buys you no deduction at all. That is the first thing to check before you transfer money in March.
      </p>
      <p class="text-ink-700 font-medium leading-relaxed max-w-3xl">
        But there is a second NPS deduction that does survive: Section <strong>80CCD(2)</strong>, for the contribution your <em>employer</em> makes to your NPS account. It is available in both regimes, it sits outside the ₹1.5 lakh cap entirely, and it is not capped at ₹50,000 but at a percentage of your salary (basic + DA): {EMP_PCT_NEW}% under the new regime for private-sector employees from FY 2025-26, against {EMP_PCT_OLD}% under the old regime for a non-government employer. On a {fmtL(EMP_SALARY)} basic + DA that is up to {fmtINR(empDeductionNew)} of deductible employer contribution in the new regime versus {fmtINR(empDeductionOld)} in the old, worth roughly {fmtINR(empSavedNew)} of tax at a 30% marginal rate. It costs nothing extra if your employer restructures part of your existing CTC into an NPS contribution rather than taxable allowance, which is precisely why it is the strongest remaining tax lever for a new-regime salaried employee. Ask your payroll team whether the corporate NPS option exists: many companies offer it and almost nobody opts in.
      </p>
      <p class="text-ink-700 font-medium leading-relaxed max-w-3xl">
        Finally, keep the deduction in proportion. Put {fmtINR(EXTRA)} a year into NPS for {YEARS} years and, at a {RET}% blended return, the corpus is about {fmtL(corpus20)} on {fmtL(contributed20)} contributed, while the tax saved along the way totals roughly {fmtL(taxSaved20)} at the 30% slab. The growth, not the deduction, is doing the heavy lifting. The trade-off is liquidity: Tier-1 money is locked until 60, at least 40% must buy an annuity, and that annuity income is taxable when it arrives. Contribute because the retirement math works, and treat the {fmtINR(top.taxSaved)} as a discount on a decision you had already made.
      </p>
    </div>
  </section>

  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-3xl mx-auto">
        <span class="chip-yellow mb-4">❓ FAQ</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Common questions.</h2>
        <div class="space-y-3 mt-8">
          {faqs.map((faq, idx) => (
            <details class="group bg-white border-2 border-ink-900 rounded-2xl shadow-sticker-sm hover:shadow-sticker transition-all" open={idx === 0}>
              <summary class="cursor-pointer p-5 md:p-6 font-extrabold text-ink-900 flex items-center justify-between gap-4 list-none">
                <span class="text-base md:text-lg" style="font-family: 'Inter Tight', sans-serif;">{faq.q}</span>
                <span class="flex-shrink-0 w-9 h-9 rounded-full bg-ink-900 group-open:bg-lime-accent flex items-center justify-center transition-colors">
                  <svg class="w-4 h-4 text-white group-open:text-ink-900 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </span>
              </summary>
              <div class="px-5 md:px-6 pb-5 md:pb-6 text-ink-700 leading-relaxed font-medium">{faq.a}</div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="container-wide py-12 md:py-16">
    <div class="max-w-3xl mx-auto">
      <span class="chip bg-violet-300 text-ink-900 mb-4">🔗 Related</span>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mt-6">
        {[
          { name: 'NPS Calculator', href: '/finance/nps-calculator/', icon: '🧾', color: 'bg-lime-accent' },
          { name: 'Old vs New Tax Regime', href: '/finance/old-vs-new-tax-regime-india/', icon: '⚖️', color: 'bg-yellow-accent' },
          { name: 'Home Loan Tax Benefits', href: '/guides/home-loan-tax-benefits/', icon: '🪙', color: 'bg-cyan-accent' },
        ].map((c) => (
          <a href={c.href} class={`group ${c.color} border-[2.5px] border-ink-900 rounded-3xl p-5 no-underline shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200`}>
            <div class="text-3xl mb-2 group-hover:rotate-12 transition-transform inline-block">{c.icon}</div>
            <div class="font-extrabold text-ink-900 text-base leading-tight" style="font-family: 'Inter Tight', sans-serif;">{c.name}</div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
