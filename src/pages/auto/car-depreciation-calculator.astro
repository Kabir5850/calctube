---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AuthorBadge from '../../components/ui/AuthorBadge.astro';
import CarDepreciationCalculator from '../../components/calculators/CarDepreciationCalculator.tsx';
import { buildCalculatorSchema, buildBreadcrumbSchema, buildFAQSchema, buildHowToSchema, buildSpeakableSchema } from '../../lib/seo';
import { getAuthor } from '../../data/authors';

const meta = {
  slug: 'car-depreciation-calculator', name: 'Car Depreciation Calculator',
  description: 'Free car depreciation calculator: estimate your car\'s resale value after any number of years at a fixed annual rate, with a year-by-year value table.',
  category: 'auto' as const,
  keywords: ['car depreciation calculator', 'vehicle depreciation', 'car value over time', 'car resale value', 'how much does my car depreciate', 'depreciation rate'],
  lastUpdated: '2026-07-19',
};
const path = '/auto/car-depreciation-calculator';
const reviewer = getAuthor('aisha-rahman')!;
const breadcrumbs = [
  { name: 'Home', url: '/' }, { name: 'Auto', url: '/auto/' }, { name: 'Car Depreciation Calculator', url: path },
];

// Build-time reference: value remaining at a 15% annual rate on a 30,000 starting price.
const refYears = [1, 2, 3, 4, 5, 7, 10];
const refRows = refYears.map((y) => {
  const value = 30000 * Math.pow(0.85, y);
  return { year: y, value, pct: Math.pow(0.85, y) * 100 };
});

const faqs = [
  { q: 'How do I calculate car depreciation?', a: 'Use value = purchase price × (1 − rate/100) raised to the number of years. With a 30,000 car and a 15% annual rate, the retained factor is 0.85 per year: after 1 year the car is worth 30,000 × 0.85 = 25,500, and after 5 years it is 30,000 × 0.85^5 = 13,311. This straight-line-on-the-remaining-value method (declining balance) is a simple, currency-agnostic estimate. Enter your own price, rate and holding period above to model any vehicle.' },
  { q: 'How much value does a car lose in 5 years?', a: 'At a constant 15% annual rate, a 30,000 car is worth about 13,311 after 5 years. That is a total loss of 16,689, or 55.6% of the original price gone in five years. Cars with slower depreciation (10%/yr) keep more value, while luxury models and EVs can lose value faster, especially in the first year.' },
  { q: 'What is a typical car depreciation rate?', a: 'Many mainstream cars lose roughly 15–20% of their value each year, with the first year usually the steepest (often close to 20%). At 15% per year on a 30,000 car, the value falls to 25,500 after year 1 (85% remaining), 18,424 after year 3 (61.4% remaining), and 13,311 after year 5 (44.4% remaining). Your exact rate depends on brand, mileage, condition and demand.' },
  { q: 'Why is the first year of depreciation the steepest?', a: 'A new car loses its "new" premium the moment it is registered and becomes a used car, so the biggest single drop typically happens in year one. After that, the percentage lost each year tends to shrink as the car settles into the used market. This calculator applies a single constant annual rate for simplicity, so treat the early years as an estimate that real-world curves may fall faster than.' },
  { q: 'How can depreciation help me decide when to sell?', a: 'Depreciation slows in later years, so holding longer spreads the loss across more time. At 15% per year, a 30,000 car retains 44.4% of its value (13,311) after 5 years but still 19.7% (5,906) after 10 years. The drop from year 5 to year 10 is much smaller than the drop in the first five years. If you want to minimise loss per year of ownership, keeping a car well past the steep early period usually helps.' },
];
const schemas = [
  buildCalculatorSchema(meta, path),
  buildBreadcrumbSchema(breadcrumbs),
  buildFAQSchema(faqs),
  buildSpeakableSchema(path),
  buildHowToSchema({
    name: 'How to calculate car depreciation',
    description: 'Estimate a vehicle\'s value over time using a constant annual depreciation rate.',
    totalTime: 'PT1M',
    estimatedCost: { value: '0', currency: 'USD' },
    steps: [
      { name: 'Enter the purchase price', text: 'Type in what you paid (or expect to pay) for the car.' },
      { name: 'Set the depreciation rate and years', text: 'Enter an annual depreciation rate (~15% is typical) and how many years you plan to hold the car.' },
      { name: 'Read the value and loss', text: 'The calculator shows the value after N years, the total amount lost, and a year-by-year value table.' },
    ],
  }),
];
const relatedCalcs = [
  { name: 'Car Loan Calculator', href: '/finance/car-loan-calculator/', desc: 'Monthly payment & interest.', icon: '💳', color: 'bg-rose-300' },
  { name: 'Lease vs Buy Calculator', href: '/auto/lease-vs-buy-calculator/', desc: 'Compare the true cost.', icon: '🚗', color: 'bg-violet-300' },
  { name: 'Fuel Cost Calculator', href: '/auto/fuel-cost-calculator/', desc: 'Cost per trip or year.', icon: '⛽', color: 'bg-cyan-accent' },
  { name: 'Fuel Economy Calculator', href: '/auto/fuel-economy-calculator/', desc: 'MPG & L/100km.', icon: '⛽', color: 'bg-lime-accent' },
];
---

<BaseLayout title="Car Depreciation Calculator: Resale Value & Loss by Year" description={meta.description} schemas={schemas} publishedTime={meta.lastUpdated} modifiedTime={meta.lastUpdated}>
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-yellow-accent/40 rounded-full blur-[120px] float-slow"></div>
      <div class="absolute top-[5%] right-[-10%] w-[400px] h-[400px] bg-lime-accent/25 rounded-full blur-[120px] float-slow-2"></div>
    </div>
    <div class="container-wide relative pt-8 pb-10 md:pt-12 md:pb-14">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-1.5 text-xs sm:text-sm">
          {breadcrumbs.map((item, idx) => (
            <li class="flex items-center gap-1.5">
              {idx === breadcrumbs.length - 1 ? (
                <span class="px-3 py-1 rounded-full bg-ink-900 text-white font-bold border-2 border-ink-900">{item.name}</span>
              ) : (
                <>
                  <a href={item.url} class="px-3 py-1 rounded-full bg-white border-2 border-ink-200 text-ink-700 font-semibold hover:border-ink-900 hover:text-ink-900 no-underline transition-colors">{item.name}</a>
                  <svg class="w-3 h-3 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </>
              )}
            </li>
          ))}
        </ol>
      </nav>
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="chip bg-yellow-accent text-ink-900">🚗 Auto</span>
          <span class="chip-white"><span class="text-ink-500">Updated</span><span>{meta.lastUpdated}</span></span>
        </div>
        <h1 class="!text-4xl sm:!text-5xl md:!text-6xl !font-extrabold !tracking-tight !leading-[1.05] text-ink-900" style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.035em;">
          Car Depreciation <span class="text-gradient-brand">Calculator.</span>
        </h1>
        <div class="mt-7 bg-yellow-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker">
          <div class="flex items-start gap-3">
            <div class="text-2xl">⚡</div>
            <div>
              <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-1">Quick answer</div>
              <p class="speakable-answer text-ink-900 text-base sm:text-lg leading-relaxed font-medium !m-0">
                Car value = <strong>price × (1 − rate/100)<sup>years</sup></strong>. A <strong>30,000</strong> car depreciating <strong>15% a year</strong> is worth <strong>13,311</strong> after 5 years, a loss of <strong>16,689</strong>, or <strong>55.6%</strong> of its original value. Enter your own price, rate and years below.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wide pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto">
      <CarDepreciationCalculator client:load />
      {reviewer && <div class="mt-4"><AuthorBadge author={reviewer} verb="Reviewed" /></div>}
    </div>
  </section>

  <!-- REFERENCE TABLE -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-3xl mx-auto">
        <span class="chip bg-yellow-accent text-ink-900 mb-4">📊 Quick reference</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Value remaining at 15% a year.</h2>
        <p class="mt-3 text-ink-700 font-medium">On a 30,000 starting price, using a constant 15% annual depreciation rate (× 0.85 per year).</p>
        <div class="mt-8 overflow-x-auto">
          <table class="w-full bg-white border-[2.5px] border-ink-900 rounded-2xl shadow-sticker-sm overflow-hidden border-separate border-spacing-0 text-sm">
            <thead><tr class="bg-ink-900 text-white">
              <th class="text-left p-3 font-extrabold">Years owned</th>
              <th class="text-center p-3 font-extrabold">Value</th>
              <th class="text-right p-3 font-extrabold">% remaining</th>
            </tr></thead>
            <tbody>
              {refRows.map((row, i) => (
                <tr class={`border-b-2 border-ink-100 ${i % 2 ? 'bg-ink-50' : ''}`}>
                  <td class="p-3 font-extrabold text-ink-900">{row.year} {row.year === 1 ? 'year' : 'years'}</td>
                  <td class="p-3 text-center font-mono font-bold text-ink-900">{Math.round(row.value).toLocaleString()}</td>
                  <td class="p-3 text-right font-mono font-bold text-ink-900">{row.pct.toFixed(1)}%</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-3xl mx-auto">
      <span class="chip-yellow mb-4">❓ FAQ</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Common questions.</h2>
      <div class="space-y-3 mt-8">
        {faqs.map((faq, idx) => (
          <details class="group bg-white border-2 border-ink-900 rounded-2xl shadow-sticker-sm hover:shadow-sticker transition-all" open={idx === 0}>
            <summary class="cursor-pointer p-5 md:p-6 font-extrabold text-ink-900 flex items-center justify-between gap-4 list-none">
              <span class="text-base md:text-lg" style="font-family: 'Inter Tight', sans-serif;">{faq.q}</span>
              <span class="flex-shrink-0 w-9 h-9 rounded-full bg-ink-900 group-open:bg-lime-accent flex items-center justify-center transition-colors">
                <svg class="w-4 h-4 text-white group-open:text-ink-900 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </span>
            </summary>
            <div class="px-5 md:px-6 pb-5 md:pb-6 text-ink-700 leading-relaxed font-medium">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <span class="chip bg-yellow-accent text-ink-900 mb-4">🔗 Related</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">More auto & finance tools.</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-8">
          {relatedCalcs.map((c) => (
            <a href={c.href} class={`group ${c.color} border-[2.5px] border-ink-900 rounded-3xl p-5 no-underline shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200`}>
              <div class="text-3xl mb-3 group-hover:rotate-12 transition-transform inline-block">{c.icon}</div>
              <div class="font-extrabold text-ink-900 text-base leading-tight" style="font-family: 'Inter Tight', sans-serif;">{c.name}</div>
              <p class="text-xs text-ink-800 mt-1.5 leading-snug font-medium">{c.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
