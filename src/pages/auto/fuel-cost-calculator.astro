---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AuthorBadge from '../../components/ui/AuthorBadge.astro';
import FuelCostCalculator from '../../components/calculators/FuelCostCalculator.tsx';
import { buildCalculatorSchema, buildBreadcrumbSchema, buildFAQSchema, buildHowToSchema, buildSpeakableSchema } from '../../lib/seo';
import { getAuthor } from '../../data/authors';

const meta = {
  slug: 'fuel-cost-calculator', name: 'Fuel Cost Calculator',
  description: 'Free fuel cost calculator: enter distance, MPG or km/L and fuel price to get total trip cost, fuel used, cost per mile, and round-trip totals in seconds.',
  category: 'auto' as const,
  keywords: ['fuel cost calculator', 'trip cost calculator', 'gas cost calculator', 'fuel calculator', 'cost of gas for a trip', 'fuel price calculator'],
  lastUpdated: '2026-07-19',
};
const path = '/auto/fuel-cost-calculator';
const reviewer = getAuthor('calctube-editorial')!;
const breadcrumbs = [
  { name: 'Home', url: '/' }, { name: 'Auto', url: '/auto/' }, { name: 'Fuel Cost Calculator', url: path },
];

// Build-time reference: trip cost at 30 MPG and $3.50 / US gallon.
const MPG = 30, PRICE = 3.5;
const trips = [50, 100, 200, 300, 500].map((mi) => {
  const gal = mi / MPG;
  return { mi, gal, cost: gal * PRICE };
});

const faqs = [
  { q: 'How do I calculate fuel cost for a trip?', a: 'Divide the trip distance by your vehicle\'s fuel efficiency to get the fuel used, then multiply by the fuel price. For example, a 300-mile trip in a car that does 30 MPG uses 300 ÷ 30 = 10 gallons; at $3.50 per gallon that is 10 × $3.50 = $35.00. In metric the same idea applies: distance in km ÷ efficiency in km/L gives litres, multiplied by the price per litre. Real-world mileage is usually 5–15% worse than the sticker figure, so budget a little extra for hills, headwinds, and city stop-and-go.' },
  { q: 'How much does a 500-mile road trip cost in gas?', a: 'At 30 MPG and $3.50 per gallon, a 500-mile trip uses 500 ÷ 30 = 16.67 gallons, which costs 16.67 × $3.50 = $58.33 one way. If it is a round trip you cover 1,000 miles and burn 33.33 gallons, so the fuel bill roughly doubles to $116.67. A more efficient 40 MPG car would use only 12.5 gallons one way ($43.75), while a 20 MPG SUV would need 25 gallons ($87.50). Efficiency is the single biggest lever on trip cost.' },
  { q: 'How do I work out the cost per mile of driving?', a: 'Cost per mile is simply the fuel price divided by the miles per gallon: $3.50 ÷ 30 MPG = $0.117 per mile. Over a 100-mile trip that is about $11.67 in fuel. This "cents per mile" figure is handy for comparing vehicles, estimating commuting costs, or working out mileage reimbursement. Note it only covers fuel. Total running cost per mile also includes depreciation, insurance, tyres, and maintenance, which often add more than the fuel itself.' },
  { q: 'How do I calculate fuel cost in litres and kilometres?', a: 'Switch the calculator to Metric and enter distance in kilometres, efficiency in km per litre, and price per litre. Fuel used = distance ÷ efficiency, and cost = fuel used × price. For example, a 480 km drive in a car doing 12 km/L uses 480 ÷ 12 = 40 litres; at $1.50 per litre that is 40 × $1.50 = $60.00. If your economy is quoted as L/100km instead, divide 100 by that number to get km/L (e.g. 8 L/100km = 12.5 km/L).' },
  { q: 'Does a round trip just double the fuel cost?', a: 'Yes. A round trip covers the distance twice, so both the fuel used and the cost double, while the cost per mile stays the same. A 100-mile one-way trip at 30 MPG and $3.50/gallon costs $11.67; the 200-mile round trip costs $23.33. Toggle the round-trip switch and the calculator shows both figures side by side, so you can see the one-way and there-and-back totals at once when planning a commute or weekend drive.' },
];

const schemas = [
  buildCalculatorSchema(meta, path),
  buildBreadcrumbSchema(breadcrumbs),
  buildFAQSchema(faqs),
  buildSpeakableSchema(path),
  buildHowToSchema({
    name: 'How to calculate fuel cost for a trip',
    description: 'Work out the total fuel cost, fuel used, and cost per mile for any trip.',
    totalTime: 'PT1M',
    estimatedCost: { value: '0', currency: 'USD' },
    steps: [
      { name: 'Enter the distance', text: 'Type the trip distance in miles (US) or kilometres (metric).' },
      { name: 'Add efficiency and price', text: 'Enter your vehicle\'s fuel efficiency (MPG or km/L) and the fuel price per gallon or litre.' },
      { name: 'Choose one-way or round trip', text: 'Toggle round trip to double the distance, then read the total cost, fuel used, and cost per mile.' },
    ],
  }),
];

const relatedCalcs = [
  { name: 'Fuel Economy', href: '/auto/fuel-economy-calculator/', desc: 'MPG, km/L & L/100km.', icon: '⛽', color: 'bg-lime-accent' },
  { name: 'Car Depreciation', href: '/auto/car-depreciation-calculator/', desc: 'Value lost over time.', icon: '📉', color: 'bg-yellow-accent' },
  { name: 'Lease vs Buy', href: '/auto/lease-vs-buy-calculator/', desc: 'Compare car costs.', icon: '🚗', color: 'bg-violet-300' },
  { name: 'Car Loan', href: '/finance/car-loan-calculator/', desc: 'Monthly payment & interest.', icon: '💳', color: 'bg-rose-300' },
];
---

<BaseLayout title="Fuel Cost Calculator: Trip Cost by Distance & MPG" description={meta.description} schemas={schemas} publishedTime={meta.lastUpdated} modifiedTime={meta.lastUpdated}>
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-cyan-accent/40 rounded-full blur-[120px] float-slow"></div>
      <div class="absolute top-[5%] right-[-10%] w-[400px] h-[400px] bg-yellow-accent/25 rounded-full blur-[120px] float-slow-2"></div>
    </div>
    <div class="container-wide relative pt-8 pb-10 md:pt-12 md:pb-14">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-1.5 text-xs sm:text-sm">
          {breadcrumbs.map((item, idx) => (
            <li class="flex items-center gap-1.5">
              {idx === breadcrumbs.length - 1 ? (
                <span class="px-3 py-1 rounded-full bg-ink-900 text-white font-bold border-2 border-ink-900">{item.name}</span>
              ) : (
                <>
                  <a href={item.url} class="px-3 py-1 rounded-full bg-white border-2 border-ink-200 text-ink-700 font-semibold hover:border-ink-900 hover:text-ink-900 no-underline transition-colors">{item.name}</a>
                  <svg class="w-3 h-3 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </>
              )}
            </li>
          ))}
        </ol>
      </nav>
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="chip bg-cyan-accent text-ink-900">🚗 Auto</span>
          <span class="chip-white"><span class="text-ink-500">Updated</span><span>{meta.lastUpdated}</span></span>
        </div>
        <h1 class="!text-4xl sm:!text-5xl md:!text-6xl !font-extrabold !tracking-tight !leading-[1.05] text-ink-900" style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.035em;">
          Fuel Cost <span class="text-gradient-brand">Calculator.</span>
        </h1>
        <div class="mt-7 bg-yellow-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker">
          <div class="flex items-start gap-3">
            <div class="text-2xl">⚡</div>
            <div>
              <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-1">Quick answer</div>
              <p class="speakable-answer text-ink-900 text-base sm:text-lg leading-relaxed font-medium !m-0">
                Trip cost = <strong>(distance ÷ efficiency) × fuel price</strong>. A 100-mile trip at 30 MPG and $3.50/gal uses 3.33 gallons = <strong>$11.67</strong> one way ($23.33 round trip), about <strong>$0.117 per mile</strong>. Enter your numbers below.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wide pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto">
      <FuelCostCalculator client:load />
      {reviewer && <div class="mt-4"><AuthorBadge author={reviewer} verb="Reviewed" /></div>}
    </div>
  </section>

  <!-- TRIP TABLE -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-3xl mx-auto">
        <span class="chip bg-cyan-accent text-ink-900 mb-4">📊 Quick reference</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Fuel cost by trip distance.</h2>
        <p class="mt-3 text-ink-700 font-medium">At 30 MPG and $3.50 per US gallon, one way.</p>
        <div class="mt-8 overflow-x-auto">
          <table class="w-full bg-white border-[2.5px] border-ink-900 rounded-2xl shadow-sticker-sm overflow-hidden border-separate border-spacing-0 text-sm">
            <thead><tr class="bg-ink-900 text-white">
              <th class="text-left p-3 font-extrabold">Distance</th>
              <th class="text-center p-3 font-extrabold">Fuel used (gal)</th>
              <th class="text-right p-3 font-extrabold">Trip cost</th>
            </tr></thead>
            <tbody>
              {trips.map((t, i) => (
                <tr class={`border-b-2 border-ink-100 ${i % 2 ? 'bg-ink-50' : ''}`}>
                  <td class="p-3 font-extrabold text-ink-900">{t.mi} miles</td>
                  <td class="p-3 text-center font-mono font-bold text-ink-900">{t.gal.toFixed(2)}</td>
                  <td class="p-3 text-right font-mono font-bold text-ink-900">${t.cost.toFixed(2)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-3xl mx-auto">
      <span class="chip-yellow mb-4">❓ FAQ</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Common questions.</h2>
      <div class="space-y-3 mt-8">
        {faqs.map((faq, idx) => (
          <details class="group bg-white border-2 border-ink-900 rounded-2xl shadow-sticker-sm hover:shadow-sticker transition-all" open={idx === 0}>
            <summary class="cursor-pointer p-5 md:p-6 font-extrabold text-ink-900 flex items-center justify-between gap-4 list-none">
              <span class="text-base md:text-lg" style="font-family: 'Inter Tight', sans-serif;">{faq.q}</span>
              <span class="flex-shrink-0 w-9 h-9 rounded-full bg-ink-900 group-open:bg-lime-accent flex items-center justify-center transition-colors">
                <svg class="w-4 h-4 text-white group-open:text-ink-900 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </span>
            </summary>
            <div class="px-5 md:px-6 pb-5 md:pb-6 text-ink-700 leading-relaxed font-medium">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <span class="chip bg-cyan-accent text-ink-900 mb-4">🔗 Related</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">More auto tools.</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-8">
          {relatedCalcs.map((c) => (
            <a href={c.href} class={`group ${c.color} border-[2.5px] border-ink-900 rounded-3xl p-5 no-underline shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200`}>
              <div class="text-3xl mb-3 group-hover:rotate-12 transition-transform inline-block">{c.icon}</div>
              <div class="font-extrabold text-ink-900 text-base leading-tight" style="font-family: 'Inter Tight', sans-serif;">{c.name}</div>
              <p class="text-xs text-ink-800 mt-1.5 leading-snug font-medium">{c.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
