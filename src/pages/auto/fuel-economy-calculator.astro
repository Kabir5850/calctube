---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FuelEconomyCalculator from '../../components/calculators/FuelEconomyCalculator.tsx';
import { buildCalculatorSchema, buildBreadcrumbSchema, buildFAQSchema, buildHowToSchema, buildSpeakableSchema } from '../../lib/seo';

const meta = {
  slug: 'fuel-economy-calculator', name: 'Fuel Economy Calculator',
  description: 'Free fuel economy calculator: enter distance and fuel to get MPG, km/L and L/100km at once, and convert between all three units with a reference table.',
  category: 'auto' as const,
  keywords: ['fuel economy calculator', 'mpg calculator', 'km/l calculator', 'l/100km calculator', 'mpg to l/100km', 'fuel efficiency calculator'],
  lastUpdated: '2026-07-19',
};
const path = '/auto/fuel-economy-calculator';
const breadcrumbs = [
  { name: 'Home', url: '/' }, { name: 'Auto', url: '/auto/' }, { name: 'Fuel Economy Calculator', url: path },
];

// Build-time reference: common US MPG values converted to km/L (× 0.425144) and L/100km (235.215 ÷ mpg).
const mpgRows = [20, 25, 30, 35, 40, 50].map((mpg) => ({
  mpg,
  kmPerL: mpg * 0.425144,
  l100: 235.215 / mpg,
}));

const faqs = [
  { q: 'How do I calculate fuel economy?', a: 'Divide the distance travelled by the fuel used, keeping units consistent. In US units, a car that covers 300 miles on 12 gallons returns 300 ÷ 12 = 25.0 MPG. In metric units you divide kilometres by litres to get km/L. The same trip works out to about 10.63 km/L, or 9.41 L/100km. This calculator does the division and shows all three figures at once, so you never have to convert by hand.' },
  { q: 'How do I convert MPG to L/100km?', a: 'Use L/100km = 235.215 ÷ MPG. For example, 30 MPG becomes 235.215 ÷ 30 = 7.84 L/100km, and 25 MPG becomes 9.41 L/100km. The two units run in opposite directions: MPG counts distance per unit of fuel (higher is better) while L/100km counts fuel per fixed distance (lower is better). The constant 235.215 assumes the US gallon of 3.785 litres.' },
  { q: 'How do I convert MPG to km/L (and back)?', a: 'Multiply MPG by 0.425144 to get km/L, so 40 MPG is 40 × 0.425144 = 17.01 km/L. To go the other way, multiply km/L by 2.35215 to get MPG, since 2.35215 is 1 ÷ 0.425144. Both km/L and MPG measure distance per unit of fuel, so a higher number always means better economy in either unit.' },
  { q: 'Is a higher or a lower number better?', a: 'For MPG and km/L, higher is better. You are travelling further on the same fuel. For L/100km, lower is better. You are burning less fuel to cover the same distance. As an example, a thrifty 50 MPG car uses just 4.70 L/100km, while a thirsty 20 MPG vehicle uses 11.76 L/100km, more than double the fuel for the same journey.' },
  { q: 'Does this use US or imperial gallons?', a: 'The MPG figures and the 0.425144 and 235.215 constants are all based on the US gallon (3.785 litres). The imperial gallon used in the UK is larger (about 1.20095 US gallons), so imperial MPG numbers look higher for the same real economy. For instance, 30 US MPG is roughly 30 × 1.20095 = 36.03 imperial MPG. If your figure is in imperial MPG, divide by 1.20095 before comparing here.' },
];
const schemas = [
  buildCalculatorSchema(meta, path),
  buildBreadcrumbSchema(breadcrumbs),
  buildFAQSchema(faqs),
  buildSpeakableSchema(path),
  buildHowToSchema({
    name: 'How to calculate and convert fuel economy',
    description: 'Work out MPG, km/L and L/100km from a distance and a fuel amount.',
    totalTime: 'PT1M',
    estimatedCost: { value: '0', currency: 'USD' },
    steps: [
      { name: 'Choose your units', text: 'Pick US (miles and gallons) or Metric (kilometres and litres).' },
      { name: 'Enter distance and fuel', text: 'Type the distance travelled and the fuel used for that trip.' },
      { name: 'Read all three figures', text: 'The calculator shows MPG, km/L and L/100km, converted instantly between units.' },
    ],
  }),
];
const relatedCalcs = [
  { name: 'Fuel Cost', href: '/auto/fuel-cost-calculator/', desc: 'Trip cost by mileage.', icon: '⛽', color: 'bg-cyan-accent' },
  { name: 'Car Depreciation', href: '/auto/car-depreciation-calculator/', desc: 'Value lost over time.', icon: '📉', color: 'bg-yellow-accent' },
  { name: 'Lease vs Buy', href: '/auto/lease-vs-buy-calculator/', desc: 'Compare the two.', icon: '🚗', color: 'bg-violet-300' },
  { name: 'Unit Converter', href: '/conversions/unit-converter/', desc: 'Convert any units.', icon: '🔄', color: 'bg-rose-300' },
];
---

<BaseLayout title="Fuel Economy Calculator: MPG, km/L & L/100km Converter" description={meta.description} schemas={schemas} publishedTime={meta.lastUpdated} modifiedTime={meta.lastUpdated}>
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-lime-accent/40 rounded-full blur-[120px] float-slow"></div>
      <div class="absolute top-[5%] right-[-10%] w-[400px] h-[400px] bg-yellow-accent/25 rounded-full blur-[120px] float-slow-2"></div>
    </div>
    <div class="container-wide relative pt-8 pb-10 md:pt-12 md:pb-14">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-1.5 text-xs sm:text-sm">
          {breadcrumbs.map((item, idx) => (
            <li class="flex items-center gap-1.5">
              {idx === breadcrumbs.length - 1 ? (
                <span class="px-3 py-1 rounded-full bg-ink-900 text-white font-bold border-2 border-ink-900">{item.name}</span>
              ) : (
                <>
                  <a href={item.url} class="px-3 py-1 rounded-full bg-white border-2 border-ink-200 text-ink-700 font-semibold hover:border-ink-900 hover:text-ink-900 no-underline transition-colors">{item.name}</a>
                  <svg class="w-3 h-3 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </>
              )}
            </li>
          ))}
        </ol>
      </nav>
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="chip bg-lime-accent text-ink-900">⛽ Auto</span>
          <span class="chip-white"><span class="text-ink-500">Updated</span><span>{meta.lastUpdated}</span></span>
        </div>
        <h1 class="!text-4xl sm:!text-5xl md:!text-6xl !font-extrabold !tracking-tight !leading-[1.05] text-ink-900" style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.035em;">
          Fuel Economy <span class="text-gradient-brand">Calculator.</span>
        </h1>
        <div class="mt-7 bg-yellow-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker">
          <div class="flex items-start gap-3">
            <div class="text-2xl">⚡</div>
            <div>
              <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-1">Quick answer</div>
              <p class="speakable-answer text-ink-900 text-base sm:text-lg leading-relaxed font-medium !m-0">
                Fuel economy = <strong>distance ÷ fuel</strong>. A car that goes 300 miles on 12 gallons returns <strong>25.0 MPG</strong>, the same as <strong>10.63 km/L</strong> or <strong>9.41 L/100km</strong>. Higher MPG and km/L are better; lower L/100km is better.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wide pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto">
      <FuelEconomyCalculator client:load />
    </div>
  </section>

  <!-- MPG CONVERSION TABLE -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-3xl mx-auto">
        <span class="chip bg-lime-accent text-ink-900 mb-4">📊 Quick reference</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">MPG to km/L and L/100km.</h2>
        <p class="mt-3 text-ink-700 font-medium">Common US MPG figures converted with × 0.425144 (km/L) and 235.215 ÷ MPG (L/100km).</p>
        <div class="mt-8 overflow-x-auto">
          <table class="w-full bg-white border-[2.5px] border-ink-900 rounded-2xl shadow-sticker-sm overflow-hidden border-separate border-spacing-0 text-sm">
            <thead><tr class="bg-ink-900 text-white">
              <th class="text-left p-3 font-extrabold">MPG (US)</th>
              <th class="text-center p-3 font-extrabold">km/L</th>
              <th class="text-right p-3 font-extrabold">L/100km</th>
            </tr></thead>
            <tbody>
              {mpgRows.map((row, i) => (
                <tr class={`border-b-2 border-ink-100 ${i % 2 ? 'bg-ink-50' : ''}`}>
                  <td class="p-3 font-extrabold text-ink-900">{row.mpg}</td>
                  <td class="p-3 text-center font-mono font-bold text-ink-900">{row.kmPerL.toFixed(2)}</td>
                  <td class="p-3 text-right font-mono font-bold text-ink-900">{row.l100.toFixed(2)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-3xl mx-auto">
      <span class="chip-yellow mb-4">❓ FAQ</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Common questions.</h2>
      <div class="space-y-3 mt-8">
        {faqs.map((faq, idx) => (
          <details class="group bg-white border-2 border-ink-900 rounded-2xl shadow-sticker-sm hover:shadow-sticker transition-all" open={idx === 0}>
            <summary class="cursor-pointer p-5 md:p-6 font-extrabold text-ink-900 flex items-center justify-between gap-4 list-none">
              <span class="text-base md:text-lg" style="font-family: 'Inter Tight', sans-serif;">{faq.q}</span>
              <span class="flex-shrink-0 w-9 h-9 rounded-full bg-ink-900 group-open:bg-lime-accent flex items-center justify-center transition-colors">
                <svg class="w-4 h-4 text-white group-open:text-ink-900 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </span>
            </summary>
            <div class="px-5 md:px-6 pb-5 md:pb-6 text-ink-700 leading-relaxed font-medium">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <span class="chip bg-lime-accent text-ink-900 mb-4">🔗 Related</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">More auto tools.</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-8">
          {relatedCalcs.map((c) => (
            <a href={c.href} class={`group ${c.color} border-[2.5px] border-ink-900 rounded-3xl p-5 no-underline shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200`}>
              <div class="text-3xl mb-3 group-hover:rotate-12 transition-transform inline-block">{c.icon}</div>
              <div class="font-extrabold text-ink-900 text-base leading-tight" style="font-family: 'Inter Tight', sans-serif;">{c.name}</div>
              <p class="text-xs text-ink-800 mt-1.5 leading-snug font-medium">{c.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
