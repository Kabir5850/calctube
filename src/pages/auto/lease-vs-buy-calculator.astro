---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeaseVsBuyCalculator from '../../components/calculators/LeaseVsBuyCalculator.tsx';
import { buildCalculatorSchema, buildBreadcrumbSchema, buildFAQSchema, buildHowToSchema, buildSpeakableSchema } from '../../lib/seo';

const meta = {
  slug: 'lease-vs-buy-calculator', name: 'Lease vs Buy Car Calculator',
  description: 'Free lease vs buy car calculator. Compare the total cost of leasing versus financing a car over the lease term, including down payments and resale value.',
  category: 'auto' as const,
  keywords: ['lease vs buy calculator', 'lease or buy a car', 'car lease vs finance', 'should i lease or buy', 'total cost of leasing', 'lease vs buy comparison'],
  lastUpdated: '2026-07-19',
};
const path = '/auto/lease-vs-buy-calculator';
const breadcrumbs = [
  { name: 'Home', url: '/' }, { name: 'Auto', url: '/auto/' }, { name: 'Lease vs Buy Calculator', url: path },
];

// Build-time reference: worked example on the calculator defaults.
// BUY: price 30000, down 3000, APR 7%, term 60 mo, resale 12000.
// LEASE: 350/mo, 2000 drive-off, 36-month term. Horizon = lease term = 36 months.
const ex = (() => {
  const price = 30000, buyDown = 3000, apr = 7, loanTerm = 60, resale = 12000;
  const leaseMonthly = 350, leaseDown = 2000, leaseTerm = 36;
  const horizon = leaseTerm;
  const P = price - buyDown;
  const rate = apr / 1200;
  const monthly = rate === 0 ? P / loanTerm : (P * rate) / (1 - Math.pow(1 + rate, -loanTerm));
  const buyPayMonths = Math.min(horizon, loanTerm);
  const buyPayments = monthly * buyPayMonths;
  const buyTotal = buyDown + buyPayments - resale;
  const leaseTotal = leaseDown + leaseMonthly * leaseTerm;
  const buyCheaper = buyTotal <= leaseTotal;
  const savings = Math.abs(buyTotal - leaseTotal);
  return {
    price, buyDown, apr, loanTerm, resale, leaseMonthly, leaseDown, leaseTerm, horizon,
    monthly, buyPayMonths, buyPayments, buyTotal, leaseTotal, buyCheaper, savings,
  };
})();
const money = (n: number) => Math.round(n).toLocaleString();

// Build-time reference table: side-by-side breakdown on the defaults.
const rows = [
  { item: 'Up-front (down / drive-off)', buy: ex.buyDown, lease: ex.leaseDown },
  { item: `Payments over ${ex.horizon} mo`, buy: ex.buyPayments, lease: ex.leaseMonthly * ex.leaseTerm },
  { item: 'Resale value returned', buy: -ex.resale, lease: 0 },
  { item: 'Net total cost', buy: ex.buyTotal, lease: ex.leaseTotal },
];

const faqs = [
  { q: 'Is it cheaper to lease or buy a car?', a: `It depends on how long you keep the car and its resale value. Using the calculator defaults (a ${money(ex.price)} car financed with ${money(ex.buyDown)} down at ${ex.apr}% over ${ex.loanTerm} months versus a lease of ${money(ex.leaseMonthly)}/month with ${money(ex.leaseDown)} drive-off), over the ${ex.horizon}-month lease term buying costs about ${money(ex.buyTotal)} while leasing costs ${money(ex.leaseTotal)}. Buying is cheaper by roughly ${money(ex.savings)}, mainly because you still own an asset worth ${money(ex.resale)} at the end. Change the resale value or lease payment and the answer can flip.` },
  { q: 'How is the total cost of buying calculated?', a: `First the monthly payment is found by amortizing the amount financed (price minus down payment). For the defaults that is ${money(ex.price - ex.buyDown)} financed at ${ex.apr}% over ${ex.loanTerm} months, giving a payment of about ${money(ex.monthly)} per month. Over the ${ex.horizon}-month comparison horizon you pay ${money(ex.monthly)} × ${ex.buyPayMonths} = ${money(ex.buyPayments)}, add the ${money(ex.buyDown)} down payment, then subtract the ${money(ex.resale)} resale value because you own the car at the end. That nets to ${money(ex.buyTotal)}.` },
  { q: 'How is the total cost of leasing calculated?', a: `Leasing is simpler: you pay the drive-off amount up front plus the monthly payment for every month of the lease, and you own nothing at the end. For the defaults that is ${money(ex.leaseDown)} drive-off + ${money(ex.leaseMonthly)} × ${ex.leaseTerm} months = ${money(ex.leaseTotal)}. There is no resale value to subtract because the car goes back to the dealer, which is why leases often look cheap month-to-month but cost more over a full ownership cycle.` },
  { q: 'Why does resale value matter so much?', a: `Resale (residual) value is the single biggest lever in a lease-versus-buy decision. When you buy, the resale value is money you get back, so it is subtracted from your total cost. In the default example the ${money(ex.resale)} resale is what makes buying win. Without it, buying would cost ${money(ex.buyTotal + ex.resale)} instead of ${money(ex.buyTotal)}. Cars that hold value reward buyers; cars that depreciate fast make leasing relatively more attractive.` },
  { q: 'What does this calculator leave out?', a: 'This is a simplified total-cost comparison. It ignores sales tax and registration, dealer and acquisition fees, maintenance and repairs, insurance differences, mileage overage charges on leases, and the time value of money (a payment made today costs more than the same payment made in three years). Leasing generally suits drivers who upgrade every few years and want lower monthly outlay and warranty coverage; buying suits people who keep cars long after the loan is paid off.' },
];
const schemas = [
  buildCalculatorSchema(meta, path),
  buildBreadcrumbSchema(breadcrumbs),
  buildFAQSchema(faqs),
  buildSpeakableSchema(path),
  buildHowToSchema({
    name: 'How to compare leasing vs buying a car',
    description: 'Compare the total cost of leasing versus financing a car over the lease term.',
    totalTime: 'PT2M',
    estimatedCost: { value: '0', currency: 'USD' },
    steps: [
      { name: 'Enter the buy details', text: 'Add the car price, down payment, loan APR, loan term and the resale value you expect at the end of the comparison period.' },
      { name: 'Enter the lease details', text: 'Add the monthly lease payment, drive-off amount and the lease term in months, which sets the comparison horizon.' },
      { name: 'Compare the totals', text: 'The calculator shows the total cost of each option over the lease term and highlights the cheaper one along with your savings.' },
    ],
  }),
];
const relatedCalcs = [
  { name: 'Car Loan', href: '/finance/car-loan-calculator/', desc: 'Monthly payment & interest.', icon: '💳', color: 'bg-rose-300' },
  { name: 'Car Depreciation', href: '/auto/car-depreciation-calculator/', desc: 'Value lost over time.', icon: '📉', color: 'bg-yellow-accent' },
  { name: 'Fuel Cost', href: '/auto/fuel-cost-calculator/', desc: 'Cost of a trip.', icon: '⛽', color: 'bg-lime-accent' },
  { name: 'Fuel Economy', href: '/auto/fuel-economy-calculator/', desc: 'MPG & L/100km.', icon: '⛽', color: 'bg-violet-300' },
];
---

<BaseLayout title="Lease vs Buy Car Calculator: Compare Total Cost & Savings" description={meta.description} schemas={schemas} publishedTime={meta.lastUpdated} modifiedTime={meta.lastUpdated}>
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-cyan-accent/40 rounded-full blur-[120px] float-slow"></div>
      <div class="absolute top-[5%] right-[-10%] w-[400px] h-[400px] bg-yellow-accent/25 rounded-full blur-[120px] float-slow-2"></div>
    </div>
    <div class="container-wide relative pt-8 pb-10 md:pt-12 md:pb-14">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-1.5 text-xs sm:text-sm">
          {breadcrumbs.map((item, idx) => (
            <li class="flex items-center gap-1.5">
              {idx === breadcrumbs.length - 1 ? (
                <span class="px-3 py-1 rounded-full bg-ink-900 text-white font-bold border-2 border-ink-900">{item.name}</span>
              ) : (
                <>
                  <a href={item.url} class="px-3 py-1 rounded-full bg-white border-2 border-ink-200 text-ink-700 font-semibold hover:border-ink-900 hover:text-ink-900 no-underline transition-colors">{item.name}</a>
                  <svg class="w-3 h-3 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </>
              )}
            </li>
          ))}
        </ol>
      </nav>
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="chip bg-cyan-accent text-ink-900">🚗 Auto</span>
          <span class="chip-white"><span class="text-ink-500">Updated</span><span>{meta.lastUpdated}</span></span>
        </div>
        <h1 class="!text-4xl sm:!text-5xl md:!text-6xl !font-extrabold !tracking-tight !leading-[1.05] text-ink-900" style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.035em;">
          Lease vs Buy <span class="text-gradient-brand">Calculator.</span>
        </h1>
        <div class="mt-7 bg-yellow-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker">
          <div class="flex items-start gap-3">
            <div class="text-2xl">⚡</div>
            <div>
              <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-1">Quick answer</div>
              <p class="speakable-answer text-ink-900 text-base sm:text-lg leading-relaxed font-medium !m-0">
                Compare <strong>total cost over the lease term</strong>. A {money(ex.price)} car financed with {money(ex.buyDown)} down at {ex.apr}% over {ex.loanTerm} months costs about <strong>{money(ex.buyTotal)}</strong> over {ex.horizon} months (after a {money(ex.resale)} resale) versus <strong>{money(ex.leaseTotal)}</strong> to lease at {money(ex.leaseMonthly)}/mo, so <strong>buying saves {money(ex.savings)}</strong>. Enter your own numbers below.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wide pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto">
      <LeaseVsBuyCalculator client:load />
    </div>
  </section>

  <!-- COMPARISON TABLE -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-3xl mx-auto">
        <span class="chip bg-cyan-accent text-ink-900 mb-4">📊 Quick reference</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Worked example on the defaults.</h2>
        <p class="mt-3 text-ink-700 font-medium">Buy: {money(ex.price)} car, {money(ex.buyDown)} down, {ex.apr}% APR, {ex.loanTerm}-month loan (payment ≈ {money(ex.monthly)}/mo), {money(ex.resale)} resale. Lease: {money(ex.leaseMonthly)}/mo, {money(ex.leaseDown)} drive-off. Compared over the {ex.horizon}-month lease term.</p>
        <div class="mt-8 overflow-x-auto">
          <table class="w-full bg-white border-[2.5px] border-ink-900 rounded-2xl shadow-sticker-sm overflow-hidden border-separate border-spacing-0 text-sm">
            <thead><tr class="bg-ink-900 text-white">
              <th class="text-left p-3 font-extrabold">Over {ex.horizon} months</th>
              <th class="text-right p-3 font-extrabold">Buy (finance)</th>
              <th class="text-right p-3 font-extrabold">Lease</th>
            </tr></thead>
            <tbody>
              {rows.map((row, i) => (
                <tr class={`border-b-2 border-ink-100 ${row.item === 'Net total cost' ? 'bg-cyan-accent/40 font-extrabold' : i % 2 ? 'bg-ink-50' : ''}`}>
                  <td class="p-3 font-extrabold text-ink-900">{row.item}</td>
                  <td class="p-3 text-right font-mono font-bold text-ink-900">{row.buy < 0 ? `−${money(-row.buy)}` : money(row.buy)}</td>
                  <td class="p-3 text-right font-mono font-bold text-ink-900">{money(row.lease)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="mt-4 text-ink-900 font-bold">On these defaults, <span class="bg-lime-accent px-1.5 py-0.5 border-2 border-ink-900 rounded">{ex.buyCheaper ? 'buying' : 'leasing'} is cheaper by {money(ex.savings)}</span> over {ex.horizon} months, because you keep a car worth {money(ex.resale)} at the end.</p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-3xl mx-auto">
      <span class="chip-yellow mb-4">❓ FAQ</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Common questions.</h2>
      <div class="space-y-3 mt-8">
        {faqs.map((faq, idx) => (
          <details class="group bg-white border-2 border-ink-900 rounded-2xl shadow-sticker-sm hover:shadow-sticker transition-all" open={idx === 0}>
            <summary class="cursor-pointer p-5 md:p-6 font-extrabold text-ink-900 flex items-center justify-between gap-4 list-none">
              <span class="text-base md:text-lg" style="font-family: 'Inter Tight', sans-serif;">{faq.q}</span>
              <span class="flex-shrink-0 w-9 h-9 rounded-full bg-ink-900 group-open:bg-lime-accent flex items-center justify-center transition-colors">
                <svg class="w-4 h-4 text-white group-open:text-ink-900 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </span>
            </summary>
            <div class="px-5 md:px-6 pb-5 md:pb-6 text-ink-700 leading-relaxed font-medium">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <span class="chip bg-cyan-accent text-ink-900 mb-4">🔗 Related</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">More auto & finance tools.</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-8">
          {relatedCalcs.map((c) => (
            <a href={c.href} class={`group ${c.color} border-[2.5px] border-ink-900 rounded-3xl p-5 no-underline shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200`}>
              <div class="text-3xl mb-3 group-hover:rotate-12 transition-transform inline-block">{c.icon}</div>
              <div class="font-extrabold text-ink-900 text-base leading-tight" style="font-family: 'Inter Tight', sans-serif;">{c.name}</div>
              <p class="text-xs text-ink-800 mt-1.5 leading-snug font-medium">{c.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
