---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AgeCalculator from '../../components/calculators/AgeCalculator.tsx';
import { buildCalculatorSchema, buildBreadcrumbSchema, buildFAQSchema } from '../../lib/seo';
import AuthorBadge from '../../components/ui/AuthorBadge.astro';
import { getAuthor } from '../../data/authors';

const meta = {
  slug: 'age-calculator',
  name: 'Age Calculator',
  description: 'Free age calculator. Enter your date of birth to instantly find your exact age in years, months, and days, plus your next birthday countdown and fun life stats.',
  category: 'date-time' as const,
  keywords: ['age calculator', 'how old am i', 'date of birth calculator', 'age in years months days', 'birthday calculator', 'next birthday'],
  lastUpdated: '2026-05-25',
  ratingValue: '4.9',
  ratingCount: '312',
};
const path = '/date-time/age-calculator';
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Date & Time', url: '/date-time/' },
  { name: 'Age Calculator', url: path },
];
const faqs = [
  {
    q: 'How is age calculated in years, months, and days?',
    a: 'Start with the full difference in calendar years. Then count remaining months. Then count remaining days, adjusting for varying month lengths. For example, if you were born on March 15 and today is May 25, you\'re 2 months and 10 days past your birthday this year.',
  },
  {
    q: 'Why does the day count sometimes feel off?',
    a: 'Different months have different lengths (28–31 days). The calculator always uses the actual number of days in each preceding month when computing the "days" remainder, so the result is exact.',
  },
  {
    q: 'Can I calculate age for a future date?',
    a: 'Yes. Change the "Calculate As Of" date to any future date and the calculator will show your projected age on that day. Useful for finding your age at a milestone event.',
  },
  {
    q: 'How is the next birthday countdown calculated?',
    a: "We find the next occurrence of your birth month and day. If your birthday has already passed this calendar year, we advance to next year. The countdown shows exact days remaining.",
  },
  {
    q: 'What if I was born on February 29 (leap day)?',
    a: "The calculator handles leap-day birthdays correctly. In non-leap years, your birthday is treated as March 1 for the purpose of the next-birthday countdown, which matches common practice.",
  },
];
const schemas = [buildCalculatorSchema(meta, path), buildBreadcrumbSchema(breadcrumbs), buildFAQSchema(faqs)];
const relatedCalcs = [
  { name: 'Date Difference', href: '/date-time/date-difference-calculator/', desc: 'Days between any two dates.', icon: '📅', color: 'bg-cyan-accent' },
  { name: 'BMI Calculator', href: '/health/bmi-calculator/', desc: 'Your Body Mass Index.', icon: '⚖️', color: 'bg-lime-accent' },
  { name: 'Tip Calculator', href: '/math/tip-calculator/', desc: 'Split bills & tips easily.', icon: '🍽️', color: 'bg-yellow-accent' },
  { name: 'Percentage Calculator', href: '/math/percentage-calculator/', desc: 'Percents made easy.', icon: '🧮', color: 'bg-pink-accent' },
];
const reviewer = getAuthor('calctube-editorial');
---

<BaseLayout
  title="Age Calculator: Exact Age in Years, Months & Days"
  description={meta.description}
  schemas={schemas}
  publishedTime={meta.lastUpdated}
  modifiedTime={meta.lastUpdated}
>
  <!-- HERO -->
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-lime-accent/40 rounded-full blur-[120px] float-slow"></div>
      <div class="absolute top-[5%] right-[-10%] w-[400px] h-[400px] bg-cyan-accent/25 rounded-full blur-[120px] float-slow-2"></div>
    </div>
    <div class="container-wide relative pt-8 pb-10 md:pt-12 md:pb-14">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-1.5 text-xs sm:text-sm">
          {breadcrumbs.map((item, idx) => (
            <li class="flex items-center gap-1.5">
              {idx === breadcrumbs.length - 1 ? (
                <span class="px-3 py-1 rounded-full bg-ink-900 text-white font-bold border-2 border-ink-900">{item.name}</span>
              ) : (
                <>
                  <a href={item.url} class="px-3 py-1 rounded-full bg-white border-2 border-ink-200 text-ink-700 font-semibold hover:border-ink-900 hover:text-ink-900 no-underline transition-colors">{item.name}</a>
                  <svg class="w-3 h-3 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </>
              )}
            </li>
          ))}
        </ol>
      </nav>
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="chip bg-lime-accent text-ink-900">🎂 Date & Time</span>
          <span class="chip-cyan">Birthday countdown</span>
          <span class="chip-white"><span class="text-ink-500">Last tested</span><span>{meta.lastUpdated}</span></span>
        </div>
        <h1
          class="!text-4xl sm:!text-5xl md:!text-6xl !font-extrabold !tracking-tight !leading-[1.05] text-ink-900"
          style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.035em;"
        >
          Age Calculator <span class="text-gradient-brand">in seconds.</span>
        </h1>
        <div class="mt-7 bg-lime-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker speakable-answer">
          <div class="flex items-start gap-3">
            <div class="text-2xl">⚡</div>
            <div>
              <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-1">Quick answer</div>
              <p class="text-ink-900 text-base sm:text-lg leading-relaxed font-medium !m-0">
                Someone born on <strong>March 15, 1990</strong> is <strong>36 years, 2 months, and 10 days old</strong> as of May 25, 2026, with their next birthday in 294 days (March 15, 2027).
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CALCULATOR -->
  <section class="container-wide pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto">
      <AgeCalculator client:visible />
    </div>
  </section>

  <!-- Reviewer attribution — E-E-A-T signal -->
  <section class="container-wide pt-2 pb-8">
    <div class="max-w-4xl mx-auto">
      {reviewer && <AuthorBadge author={reviewer} verb="Reviewed" />}
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <span class="chip-cyan mb-4">📖 How it works</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Three numbers. Exact age.</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 md:gap-5 mt-8">
          {[
            { num: '1', text: 'Enter your date of birth using the date picker.', color: 'bg-lime-accent' },
            { num: '2', text: '"Calculate As Of" defaults to today. Change it to any past or future date.', color: 'bg-cyan-accent' },
            { num: '3', text: 'See exact years, months, days, plus birthday countdown and fun life stats.', color: 'bg-yellow-accent' },
          ].map((step) => (
            <div class={`${step.color} border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker-sm`}>
              <div class="text-3xl font-extrabold mb-3 leading-none" style="font-family: 'Inter Tight', sans-serif;">{step.num}</div>
              <p class="text-sm font-semibold leading-snug !m-0 !text-current">{step.text}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- THE MATH -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-4xl mx-auto">
      <span class="chip-pink mb-4">🧮 The math</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">How age is computed.</h2>
      <div class="mt-8 bg-ink-900 text-white border-[2.5px] border-ink-900 rounded-3xl p-6 md:p-8 shadow-sticker">
        <div class="text-xs font-extrabold uppercase tracking-wider text-lime-accent mb-3">Step-by-step</div>
        <ol class="space-y-3 text-sm text-ink-300">
          <li class="flex gap-3"><span class="text-lime-accent font-extrabold">1.</span><span>Compute full calendar <strong class="text-white">years</strong> elapsed between DOB and target date.</span></li>
          <li class="flex gap-3"><span class="text-cyan-accent font-extrabold">2.</span><span>From the remaining partial year, count full <strong class="text-white">months</strong>, adjusting for months with different day counts.</span></li>
          <li class="flex gap-3"><span class="text-pink-accent font-extrabold">3.</span><span>The leftover is the <strong class="text-white">day</strong> count, always exact because we account for 28/29/30/31-day months.</span></li>
          <li class="flex gap-3"><span class="text-yellow-accent font-extrabold">4.</span><span>Total days = (target − DOB) in ms ÷ 86,400,000. Weeks = ⌊totalDays ÷ 7⌋.</span></li>
        </ol>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-3xl mx-auto speakable-summary">
        <span class="chip-yellow mb-4">❓ FAQ</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Common questions.</h2>
        <div class="space-y-3 mt-8">
          {faqs.map((faq, idx) => (
            <details class="group bg-white border-2 border-ink-900 rounded-2xl shadow-sticker-sm hover:shadow-sticker transition-all" open={idx === 0}>
              <summary class="cursor-pointer p-5 md:p-6 font-extrabold text-ink-900 flex items-center justify-between gap-4 list-none">
                <span class="text-base md:text-lg" style="font-family: 'Inter Tight', sans-serif;">{faq.q}</span>
                <span class="flex-shrink-0 w-9 h-9 rounded-full bg-ink-900 group-open:bg-lime-accent flex items-center justify-center transition-colors">
                  <svg class="w-4 h-4 text-white group-open:text-ink-900 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </span>
              </summary>
              <div class="px-5 md:px-6 pb-5 md:pb-6 text-ink-700 leading-relaxed font-medium">{faq.a}</div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- RELATED -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-4xl mx-auto">
      <span class="chip bg-violet-300 text-ink-900 mb-4">🔗 Related</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Try these next.</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-8">
        {relatedCalcs.map((c) => (
          <a href={c.href} class={`group ${c.color} border-[2.5px] border-ink-900 rounded-3xl p-5 no-underline shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200`}>
            <div class="text-3xl mb-3 group-hover:rotate-12 transition-transform inline-block">{c.icon}</div>
            <div class="font-extrabold text-ink-900 text-base leading-tight" style="font-family: 'Inter Tight', sans-serif;">{c.name}</div>
            <p class="text-xs text-ink-800 mt-1.5 leading-snug font-medium">{c.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
