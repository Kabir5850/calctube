---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CountdownCalculator from '../../components/calculators/CountdownCalculator.tsx';
import { buildCalculatorSchema, buildBreadcrumbSchema, buildFAQSchema, buildHowToSchema, buildSpeakableSchema } from '../../lib/seo';

const meta = {
  slug: 'countdown-timer', name: 'Countdown Timer & Days Until Calculator',
  description: 'Free countdown timer and days-until calculator. Count down to any date (a birthday, exam, holiday or event) in days, hours, minutes and seconds, updating live.',
  category: 'date-time' as const,
  keywords: ['countdown timer', 'days until calculator', 'how many days until', 'countdown to date', 'days until', 'event countdown'],
  lastUpdated: '2026-07-18',
};
const path = '/date-time/countdown-timer';
const breadcrumbs = [
  { name: 'Home', url: '/' }, { name: 'Date & Time', url: '/date-time/' }, { name: 'Countdown Timer', url: path },
];

// Build-time reference of durations (unique, extractable).
const durations = [
  { span: '1 week', days: '7 days', hrs: '168 hours' },
  { span: '1 month (avg)', days: '30.44 days', hrs: '730 hours' },
  { span: '90 days', days: '≈ 3 months', hrs: '2,160 hours' },
  { span: '100 days', days: '14.3 weeks', hrs: '2,400 hours' },
  { span: '6 months', days: '182.6 days', hrs: '4,383 hours' },
  { span: '1 year', days: '365 days', hrs: '8,760 hours' },
];

const faqs = [
  { q: 'How do I count how many days until a date?', a: 'Subtract today\'s date from the target date. The tricky part is month lengths and leap years, which is why a calculator helps: just pick the target date above and it shows the exact number of days remaining, plus a live hours-minutes-seconds countdown. For counting to a past date, it shows the days elapsed instead.' },
  { q: 'Does the countdown update in real time?', a: 'Yes. Once you choose a date, the seconds tick down live in your device\'s local time zone, refreshing every second. The day count is calculated to midnight of the target date, so "days to go" drops by one each midnight. Leaving the tab open keeps the timer running.' },
  { q: 'Should the countdown include the start and end day?', a: 'It depends what you\'re measuring. This tool counts full days remaining until the target, so if something is "3 days away", there are three midnights between now and then. If you need to include both the start and end date (inclusive counting, common for trip lengths or notice periods), add one to the number of days shown.' },
  { q: 'How do time zones affect the countdown?', a: 'The countdown runs in your local time zone and counts to midnight of the target date as your device sees it. If you\'re counting to an event in another country (a product launch or a match kick-off), remember the event\'s local midnight may differ from yours by several hours. For cross-time-zone events, factor in the offset.' },
  { q: 'What can I use a countdown for?', a: 'Anything with a deadline: exams and assignment due dates, a wedding or birthday, a holiday or festival, a product launch, a project milestone, or a fitness goal. Seeing the days tick down is a simple motivator and a quick way to sanity-check "do I really have enough time?" The quick-pick buttons jump to common targets like New Year.' },
];
const schemas = [
  buildCalculatorSchema(meta, path),
  buildBreadcrumbSchema(breadcrumbs),
  buildFAQSchema(faqs),
  buildSpeakableSchema(path),
  buildHowToSchema({
    name: 'How to count down to a date',
    description: 'Count the days, hours, minutes and seconds until any future date.',
    totalTime: 'PT1M',
    estimatedCost: { value: '0', currency: 'USD' },
    steps: [
      { name: 'Pick a target date', text: 'Choose the date you want to count down to, or use a quick-pick button.' },
      { name: 'Watch it tick', text: 'The countdown shows days, hours, minutes and seconds, updating live.' },
    ],
  }),
];
const relatedCalcs = [
  { name: 'Date Difference', href: '/date-time/date-difference-calculator/', desc: 'Days between two dates.', icon: '📆', color: 'bg-cyan-accent' },
  { name: 'Age Calculator', href: '/date-time/age-calculator/', desc: 'Exact age in y/m/d.', icon: '🎂', color: 'bg-lime-accent' },
  { name: 'Pregnancy Due Date', href: '/health/pregnancy-calculator/', desc: 'Countdown to your EDD.', icon: '🤰', color: 'bg-rose-300' },
  { name: 'Unit Converter', href: '/conversions/unit-converter/', desc: 'Length, weight, time…', icon: '🔄', color: 'bg-yellow-accent' },
];
---

<BaseLayout title="Countdown Timer: Days, Hours & Minutes Until Any Date" description={meta.description} schemas={schemas} publishedTime={meta.lastUpdated} modifiedTime={meta.lastUpdated}>
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-sky-300/40 rounded-full blur-[120px] float-slow"></div>
      <div class="absolute top-[5%] right-[-10%] w-[400px] h-[400px] bg-cyan-accent/25 rounded-full blur-[120px] float-slow-2"></div>
    </div>
    <div class="container-wide relative pt-8 pb-10 md:pt-12 md:pb-14">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-1.5 text-xs sm:text-sm">
          {breadcrumbs.map((item, idx) => (
            <li class="flex items-center gap-1.5">
              {idx === breadcrumbs.length - 1 ? (
                <span class="px-3 py-1 rounded-full bg-ink-900 text-white font-bold border-2 border-ink-900">{item.name}</span>
              ) : (
                <>
                  <a href={item.url} class="px-3 py-1 rounded-full bg-white border-2 border-ink-200 text-ink-700 font-semibold hover:border-ink-900 hover:text-ink-900 no-underline transition-colors">{item.name}</a>
                  <svg class="w-3 h-3 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </>
              )}
            </li>
          ))}
        </ol>
      </nav>
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="chip bg-sky-300 text-ink-900">⏳ Date & Time</span>
          <span class="chip-white"><span class="text-ink-500">Updated</span><span>{meta.lastUpdated}</span></span>
        </div>
        <h1 class="!text-4xl sm:!text-5xl md:!text-6xl !font-extrabold !tracking-tight !leading-[1.05] text-ink-900" style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.035em;">
          Countdown <span class="text-gradient-brand">Timer.</span>
        </h1>
        <div class="mt-7 bg-yellow-accent border-[2.5px] border-ink-900 rounded-2xl p-5 shadow-sticker">
          <div class="flex items-start gap-3">
            <div class="text-2xl">⚡</div>
            <div>
              <div class="text-xs font-extrabold uppercase tracking-wider text-ink-900 mb-1">Quick answer</div>
              <p class="speakable-answer text-ink-900 text-base sm:text-lg leading-relaxed font-medium !m-0">
                Pick any date and this <strong>counts down live</strong> in days, hours, minutes and seconds, perfect for a birthday, exam, holiday or launch. The <strong>days-until</strong> figure updates each midnight in your local time zone. Choose a date or a quick-pick below.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wide pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto">
      <CountdownCalculator client:load />
    </div>
  </section>

  <!-- DURATIONS TABLE -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-3xl mx-auto">
        <span class="chip bg-sky-300 text-ink-900 mb-4">📊 Quick reference</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">How long is that, exactly?</h2>
        <div class="mt-8 overflow-x-auto">
          <table class="w-full bg-white border-[2.5px] border-ink-900 rounded-2xl shadow-sticker-sm overflow-hidden border-separate border-spacing-0 text-sm">
            <thead><tr class="bg-ink-900 text-white">
              <th class="text-left p-3 font-extrabold">Span</th>
              <th class="text-center p-3 font-extrabold">In days</th>
              <th class="text-right p-3 font-extrabold">In hours</th>
            </tr></thead>
            <tbody>
              {durations.map((r, i) => (
                <tr class={`border-b-2 border-ink-100 ${i % 2 ? 'bg-ink-50' : ''}`}>
                  <td class="p-3 font-extrabold text-ink-900">{r.span}</td>
                  <td class="p-3 text-center font-mono font-bold text-ink-900">{r.days}</td>
                  <td class="p-3 text-right font-mono font-bold text-ink-900">{r.hrs}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="container-wide py-12 md:py-16">
    <div class="max-w-3xl mx-auto">
      <span class="chip-yellow mb-4">❓ FAQ</span>
      <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Common questions.</h2>
      <div class="space-y-3 mt-8">
        {faqs.map((faq, idx) => (
          <details class="group bg-white border-2 border-ink-900 rounded-2xl shadow-sticker-sm hover:shadow-sticker transition-all" open={idx === 0}>
            <summary class="cursor-pointer p-5 md:p-6 font-extrabold text-ink-900 flex items-center justify-between gap-4 list-none">
              <span class="text-base md:text-lg" style="font-family: 'Inter Tight', sans-serif;">{faq.q}</span>
              <span class="flex-shrink-0 w-9 h-9 rounded-full bg-ink-900 group-open:bg-lime-accent flex items-center justify-center transition-colors">
                <svg class="w-4 h-4 text-white group-open:text-ink-900 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </span>
            </summary>
            <div class="px-5 md:px-6 pb-5 md:pb-6 text-ink-700 leading-relaxed font-medium">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED -->
  <section class="bg-ink-50 border-y-2 border-ink-900">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-4xl mx-auto">
        <span class="chip bg-sky-300 text-ink-900 mb-4">🔗 Related</span>
        <h2 class="!text-3xl sm:!text-4xl !mt-4 !leading-tight" style="font-family: 'Inter Tight', sans-serif;">Try these next.</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-8">
          {relatedCalcs.map((c) => (
            <a href={c.href} class={`group ${c.color} border-[2.5px] border-ink-900 rounded-3xl p-5 no-underline shadow-sticker hover:shadow-[8px_8px_0_0_rgba(15,23,42,0.9)] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200`}>
              <div class="text-3xl mb-3 group-hover:rotate-12 transition-transform inline-block">{c.icon}</div>
              <div class="font-extrabold text-ink-900 text-base leading-tight" style="font-family: 'Inter Tight', sans-serif;">{c.name}</div>
              <p class="text-xs text-ink-800 mt-1.5 leading-snug font-medium">{c.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
