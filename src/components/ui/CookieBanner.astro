---
// Cookie consent banner — vanilla, GDPR-compliant, zero dependencies.
// Sets `calctube-consent` cookie to 'all' | 'essential-only' for 365 days.
//
// Google Consent Mode v2 defaults are set in BaseLayout BEFORE any tracker
// loads. This component only handles the UI + on-click consent updates.
---

<!-- Banner UI — hidden if consent cookie already set -->
<div
  id="cookie-banner"
  role="dialog"
  aria-live="polite"
  data-print-hide
  aria-label="Cookie consent"
  class="fixed bottom-0 inset-x-0 z-[100] hidden"
>
  <div class="mx-auto max-w-4xl m-3 sm:m-5 bg-white border-2 border-ink-900 rounded-2xl shadow-sticker p-4 sm:p-5">
    <div class="flex flex-col md:flex-row md:items-center gap-4">
      <div class="flex-1 min-w-0">
        <h2 class="!text-base sm:!text-lg !mt-0 !mb-1.5 !font-extrabold !text-ink-900" style="font-family: 'Inter Tight', sans-serif;">
          We use cookies 🍪
        </h2>
        <p class="text-xs sm:text-sm text-ink-700 !leading-snug !mb-0">
          Essential cookies keep the site working. Analytics &amp; ad cookies help us learn what people use and pay the bills.
          See our <a href="/legal/cookies/" class="font-bold underline decoration-2 underline-offset-2 decoration-lime-accent text-ink-900">cookie policy</a>.
        </p>
      </div>
      <div class="flex flex-col-reverse sm:flex-row gap-2 shrink-0">
        <button
          id="cookie-reject"
          type="button"
          class="text-xs sm:text-sm font-bold px-4 py-2.5 rounded-xl bg-white border-2 border-ink-900 text-ink-900 hover:bg-ink-100 transition-colors"
        >
          Essential only
        </button>
        <button
          id="cookie-accept"
          type="button"
          class="text-xs sm:text-sm font-bold px-4 py-2.5 rounded-xl bg-lime-accent border-2 border-ink-900 text-ink-900 hover:shadow-sticker-sm hover:-translate-x-0.5 hover:-translate-y-0.5 transition-all"
        >
          Accept all
        </button>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    var KEY = 'calctube-consent';
    var hasConsent = /(?:^|; )calctube-consent=/.test(document.cookie);
    var banner = document.getElementById('cookie-banner');
    if (!banner) return;

    if (!hasConsent) {
      // Show after 600ms so it doesn't compete with hero render
      setTimeout(function () { banner.classList.remove('hidden'); }, 600);
    }

    function setCookie(value) {
      var maxAge = 60 * 60 * 24 * 365; // 365 days
      document.cookie = KEY + '=' + encodeURIComponent(value) + '; path=/; max-age=' + maxAge + '; SameSite=Lax; Secure';
    }

    function gtag() { window.dataLayer = window.dataLayer || []; window.dataLayer.push(arguments); }

    var accept = document.getElementById('cookie-accept');
    var reject = document.getElementById('cookie-reject');

    if (accept) accept.addEventListener('click', function () {
      setCookie('all');
      gtag('consent', 'update', {
        ad_storage: 'granted',
        ad_user_data: 'granted',
        ad_personalization: 'granted',
        analytics_storage: 'granted',
      });
      banner.classList.add('hidden');
    });

    if (reject) reject.addEventListener('click', function () {
      setCookie('essential-only');
      // Defaults remain (all denied)
      banner.classList.add('hidden');
    });
  })();
</script>
