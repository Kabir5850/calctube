---
/**
 * Renders a country flag from public/flags/{slug}.svg (circle-flags, MIT-licensed).
 * Solves the Windows-emoji-flag rendering problem (Windows shows '🇺🇸' as 'US' text).
 *
 * Props:
 *   slug:   Country slug matching the mortgage-locales data (e.g., 'usa', 'uk', 'india')
 *   size:   Rendered px size — defaults to 32. Square. Flag is always circular.
 *   alt:    Accessible alt text. Defaults to humanized slug.
 *   class:  Extra classes (applied to the <img>)
 */
export interface Props {
  slug: string;
  size?: number;
  alt?: string;
  class?: string;
}
const { slug, size = 32, alt, class: className = '' } = Astro.props;
const altText = alt || `${slug.replace(/-/g, ' ')} flag`;
---

<img
  src={`/flags/${slug}.svg`}
  alt={altText}
  width={size}
  height={size}
  loading="lazy"
  decoding="async"
  class={`inline-block rounded-full ${className}`}
  style={`width: ${size}px; height: ${size}px;`}
/>
