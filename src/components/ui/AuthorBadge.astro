---
import type { Author } from '../../data/authors';

interface Props {
  author: Author;
  verb?: 'Reviewed' | 'Written' | 'Verified';
  compact?: boolean;
}

const { author, verb = 'Reviewed', compact = false } = Astro.props;
const displayName = author.credentials
  ? `${author.name}, ${author.credentials}`
  : author.name;
---

{compact ? (
  <div class="flex items-center gap-2 text-xs text-ink-600 font-semibold not-prose">
    {/* Avatar placeholder */}
    <div class="w-6 h-6 rounded-full bg-gradient-to-br from-brand-400 to-violet-500 flex items-center justify-center text-white font-extrabold text-[10px] flex-shrink-0 border border-ink-200">
      {author.name.split(' ').map(n => n[0]).join('').slice(0, 2)}
    </div>
    <span>
      {verb} by{' '}
      <a href={`/authors/${author.slug}/`} class="font-extrabold text-ink-800 hover:text-brand-600 no-underline hover:underline underline-offset-2">
        {displayName}
      </a>
    </span>
  </div>
) : (
  <div class="flex items-start gap-3 p-3 sm:p-4 bg-ink-50 border border-ink-200 rounded-2xl not-prose">
    {/* Avatar */}
    {author.avatar ? (
      <img
        src={author.avatar}
        alt={`${author.name} headshot`}
        class="w-12 h-12 rounded-full object-cover flex-shrink-0 border-2 border-ink-200"
        loading="lazy"
        width="48"
        height="48"
      />
    ) : (
      <div class="w-12 h-12 rounded-full bg-gradient-to-br from-brand-400 to-violet-500 flex items-center justify-center text-white font-extrabold text-lg flex-shrink-0 border-2 border-ink-200">
        {author.name.split(' ').map((n: string) => n[0]).join('').slice(0, 2)}
      </div>
    )}

    <div class="min-w-0 flex-1">
      <div class="text-[10px] font-extrabold uppercase tracking-wider text-ink-500 mb-0.5">
        {verb} by
      </div>
      <div class="flex flex-wrap items-center gap-x-2 gap-y-0.5">
        <a
          href={`/authors/${author.slug}/`}
          class="font-extrabold text-sm text-ink-900 hover:text-brand-600 no-underline hover:underline underline-offset-2"
        >
          {displayName}
        </a>
        {author.linkedin && (
          <a
            href={author.linkedin}
            target="_blank"
            rel="noopener noreferrer nofollow"
            class="text-[10px] font-bold text-brand-600 hover:text-brand-700 no-underline hover:underline"
            aria-label={`${author.name} on LinkedIn`}
          >
            LinkedIn ↗
          </a>
        )}
      </div>
      <p class="text-xs text-ink-600 mt-0.5 font-semibold">{author.shortBio}</p>
    </div>
  </div>
)}
